---
import Layout from '../../layouts/Layout.astro';
import { getDailyTheme, getAllThemes } from '../../utils/daily-theme';
import { getDailyCommunityTheme } from '../../utils/omni-bridge';

const communityDaily = await getDailyCommunityTheme();
const today = communityDaily || getDailyTheme();
const allThemes = getAllThemes();
const totalAvailable = allThemes.length;

const directory = allThemes.map((t) => ({
  preset: t.preset,
  name: t.presetName,
  primary: t.cssVars['--color-primary'],
  accent: t.cssVars['--color-accent'],
  logoText: t.logoText || null,
}));

const minimalResponse = JSON.stringify({
  date: new Date().toISOString().slice(0, 10),
  preset: today.preset,
  presetName: today.presetName,
  generatedAt: new Date().toISOString(),
  cssVars: Object.fromEntries(
    Object.entries(today.cssVars).slice(0, 8)
  ),
  customCss: today.customCss ? "(theme-specific CSS animations)" : null,
  extensions: today.extensions ? [{ type: "html", content: "..." }] : null,
  logoText: today.logoText || null,
  logoColors: today.logoColors || null,
  available: totalAvailable,
  directory: directory.slice(0, 4),
}, null, 2);

const fullResponse = JSON.stringify({
  date: new Date().toISOString().slice(0, 10),
  preset: today.preset,
  presetName: today.presetName,
  generatedAt: new Date().toISOString(),
  cssVars: today.cssVars,
  customCss: today.customCss || null,
  extensions: today.extensions || null,
  logoText: today.logoText || null,
  logoColors: today.logoColors || null,
  available: totalAvailable,
  directory,
}, null, 2);

const siteUrl = Astro.url.origin;

const curlCmd = `curl ${siteUrl}/api/today.json`;
const curlJqCmd = `curl -s ${siteUrl}/api/today.json | jq .`;
const fetchCmd = `fetch('${siteUrl}/api/today.json').then(r => r.json()).then(console.log)`;
const wgetCmd = `wget -qO- ${siteUrl}/api/today.json | jq .`;

const vanillaJS = String.raw`// 完整集成示例 — 含缓存、降级、特效注入
(async () => {
  const today = new Date().toISOString().slice(0, 10);
  const cached = JSON.parse(localStorage.getItem('td') || 'null');

  if (cached?.date === today) return applyTheme(cached);

  const res = await fetch('{siteUrl}/api/today.json');
  const t = await res.json();

  const data = { date: t.date, cssVars: t.cssVars, customCss: t.customCss, exts: t.extensions };
  localStorage.setItem('td', JSON.stringify(data));
  applyTheme(data);
})().catch(() => {
  const fallback = JSON.parse(localStorage.getItem('td') || 'null');
  if (fallback) applyTheme(fallback);
});

function applyTheme(d) {
  Object.entries(d.cssVars).forEach(([k,v]) => document.documentElement.style.setProperty(k,v));
  if (d.customCss) { let s = document.createElement('style'); s.textContent = d.customCss; document.head.appendChild(s); }
  if (d.exts) { let e = document.createElement('div'); e.innerHTML = d.exts.map(x => x.content).join(''); document.body.prepend(e); }
}`;
---

<Layout>
  <section class="section-sm">
    <div style="max-width:760px;margin:0 auto">
      <div class="docs-header">
        <p class="t-label" style="margin:0">Documentation</p>
        <h1 style="margin:2px 0 0;font-size:1.5rem;font-weight:700;letter-spacing:-0.02em">API 文档</h1>
        <p class="t-subhead" style="margin:2px 0 0;font-size:0.85rem">一个 GET 请求获取每日主题的完整 CSS 变量与特效数据</p>
      </div>

      <div style="max-width:760px;margin:0 auto">

      <!-- ====== OVERVIEW ====== -->
      <h2 id="overview" style="font-size:20px;font-weight:700;letter-spacing:-0.03em;margin-bottom:14px">概述</h2>
      <div class="card" style="margin-bottom:36px;padding:24px 28px">
        <p class="text-muted" style="font-size:14px;line-height:1.75;margin:0">
          ThemeDist 是<strong>每日自动轮换的主题分发 API</strong>。主题由 CDN 边缘函数实时计算，无需定时构建。
          客户端 GET <code>/api/today.json</code>，将返回的 34 个 CSS 自定义属性注入 <code>:root</code>，即可获得当日主题。
          同时提供<strong>社区主题</strong>（用户投稿 / 点赞 / 分享）和 <strong>AI 生成</strong> 等完整 API。
          无认证、无速率限制、支持 CORS 跨域。
        </p>
        <div style="margin-top:16px;display:flex;flex-wrap:wrap;gap:10px">
          <span class="tag">{totalAvailable}+ 预设</span>
          <span class="tag">农历 + 公历节日</span>
          <span class="tag">CORS 跨域</span>
          <span class="tag">CDN 友好</span>
          <span class="tag">特效动画</span>
        </div>
      </div>

      <!-- ====== QUICKSTART ====== -->
      <h2 id="quickstart" style="font-size:20px;font-weight:700;letter-spacing:-0.03em;margin-bottom:14px;margin-top:40px">快速开始</h2>
      <div class="card" style="margin-bottom:36px;padding:24px 28px">
        <p class="text-muted" style="font-size:13px;line-height:1.6;margin:0 0 18px 0">点击右侧按钮即可复制命令，粘贴到终端或浏览器控制台即可获取今日主题数据。</p>

        <div class="cmd-group">
          <div class="cmd-header">
            <span class="cmd-label">curl</span>
            
          </div>
          <pre class="cmd-block"><code>{curlCmd}</code></pre>
        </div>

        <div class="cmd-group">
          <div class="cmd-header">
            <span class="cmd-label">curl + jq (格式化输出)</span>
            
          </div>
          <pre class="cmd-block"><code>{curlJqCmd}</code></pre>
        </div>

        <div class="cmd-group">
          <div class="cmd-header">
            <span class="cmd-label">fetch (浏览器控制台)</span>
            
          </div>
          <pre class="cmd-block"><code>{fetchCmd}</code></pre>
        </div>

        <div class="cmd-group" style="margin-bottom:0">
          <div class="cmd-header">
            <span class="cmd-label">wget</span>
            
          </div>
          <pre class="cmd-block"><code>{wgetCmd}</code></pre>
        </div>
      </div>

      <!-- ====== ENDPOINTS ====== -->
      <h2 id="endpoints" style="font-size:20px;font-weight:700;letter-spacing:-0.03em;margin-bottom:14px;margin-top:40px">端点</h2>
      <div class="card card-glass" style="padding:0;overflow:hidden;margin-bottom:36px">
        <table style="width:100%;border-collapse:collapse;font-size:14px">
          <thead><tr style="border-bottom:1px solid var(--color-border)">
            <th style="text-align:left;padding:12px 18px;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase;width:60px">方法</th>
            <th style="text-align:left;padding:12px 18px;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase;width:200px">路径</th>
            <th style="text-align:left;padding:12px 18px;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase">说明</th>
          </tr></thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:12px 18px"><span class="ep-tag get">GET</span></td>
              <td style="padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600">/api/today.json</td>
              <td style="padding:12px 18px;font-size:13px">今日主题的完整数据（CSS 变量 + 特效 + 目录）</td>
            </tr>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:12px 18px"><span class="ep-tag get">GET</span></td>
              <td style="padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600">/api/today-safe</td>
              <td style="padding:12px 18px;font-size:13px">安全主题代理 — Vercel 优先，Netlify 备用，XSS 清洗后输出</td>
            </tr>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:12px 18px"><span class="ep-tag get">GET</span></td>
              <td style="padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600">/api/theme/{'{preset}'}.json</td>
              <td style="padding:12px 18px;font-size:13px">指定预设的完整数据（{totalAvailable} 个端点，永久缓存）</td>
            </tr>
            <tr><td colspan="3" style="padding:8px 18px;font-size:10px;font-weight:700;letter-spacing:0.05em;color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 4%, transparent)">COMMUNITY 社区主题</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:12px 18px"><span class="ep-tag get">GET</span></td>
              <td style="padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600">/api/diy/themes.json</td>
              <td style="padding:12px 18px;font-size:13px">社区主题列表（分页 + 排序 + 标签筛选）</td>
            </tr>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:12px 18px"><span class="ep-tag get">GET</span></td>
              <td style="padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600">/api/diy/theme.json?id=</td>
              <td style="padding:12px 18px;font-size:13px">单个社区主题详情（含点赞数）</td>
            </tr>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:12px 18px"><span class="ep-tag post">POST</span></td>
              <td style="padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600">/api/diy/submit.json</td>
              <td style="padding:12px 18px;font-size:13px">提交社区主题（自动发布）</td>
            </tr>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:12px 18px"><span class="ep-tag post">POST</span></td>
              <td style="padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600">/api/diy/like.json</td>
              <td style="padding:12px 18px;font-size:13px">点赞社区主题（IP+UA 去重）</td>
            </tr>
            <tr><td colspan="3" style="padding:8px 18px;font-size:10px;font-weight:700;letter-spacing:0.05em;color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 4%, transparent)">AI 生成</td></tr>
            <tr>
              <td style="padding:12px 18px"><span class="ep-tag post">POST</span></td>
              <td style="padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600">/api/ai/generate.json</td>
              <td style="padding:12px 18px;font-size:13px">AI 主题生成（规则引擎，或客户端 DeepSeek 直调）</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- ====== RESPONSE SCHEMA ====== -->
      <h2 id="schema" style="font-size:20px;font-weight:700;letter-spacing:-0.03em;margin-bottom:14px;margin-top:40px">响应结构 /api/today.json</h2>
      <div class="card card-glass" style="padding:0;overflow:hidden;margin-bottom:20px">
        <table style="width:100%;border-collapse:collapse;font-size:13px">
          <thead><tr style="border-bottom:1px solid var(--color-border)">
            <th style="text-align:left;padding:10px 16px;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase;width:110px">字段</th>
            <th style="text-align:left;padding:10px 16px;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase;width:80px">类型</th>
            <th style="text-align:left;padding:10px 16px;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase">说明</th>
          </tr></thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">date</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">string</td><td style="padding:9px 16px">ISO 日期 YYYY-MM-DD（UTC 时区）</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">generatedAt</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">string</td><td style="padding:9px 16px">ISO 8601 生成时间戳</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">preset</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">string</td><td style="padding:9px 16px">预设标识符 (kebab-case)</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">presetName</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">string</td><td style="padding:9px 16px">人类可读名称</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">cssVars</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">object</td><td style="padding:9px 16px">28 个 CSS 自定义属性键值对（5 组：Colors / Typography / Spacing / Effects / Ambient）</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">customCss</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">string|null</td><td style="padding:9px 16px">主题专属 CSS（动画 keyframes、特效样式），注入为 <code>&lt;style&gt;</code></td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">extensions</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">array|null</td><td style="padding:9px 16px">HTML 片段数组 <code>{'{ type:"html", content:"..." }'}</code>，注入为 DOM 元素</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">logoText</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">string|null</td><td style="padding:9px 16px">Logo 文字</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">logoColors</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">array|null</td><td style="padding:9px 16px">Logo 渐变色 hex 数组</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">available</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">number</td><td style="padding:9px 16px">可用主题总数</td></tr>
            <tr><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600">directory</td><td style="padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">array</td><td style="padding:9px 16px">轻量索引 <code>[{'\{'}preset, name, primary, accent, logoText{'}\}'}]</code></td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-muted" style="font-size:12px;margin-bottom:14px"><code>/api/theme/{'{preset}'}.json</code> 结构一致，但不含 <code>date</code>、<code>generatedAt</code>、<code>available</code>、<code>directory</code>。</p>

      <h3 style="font-size:15px;font-weight:700;letter-spacing:-0.02em;margin-bottom:10px">示例响应</h3>
      <pre style="max-height:400px;overflow-y:auto;margin-bottom:40px"><code>{minimalResponse}</code></pre>

      <!-- ====== CSS VARS ====== -->
      <h2 id="css-vars" style="font-size:20px;font-weight:700;letter-spacing:-0.03em;margin-bottom:14px;margin-top:40px">CSS 变量参考</h2>
      <p class="text-muted" style="font-size:13px;line-height:1.6;margin-bottom:16px">所有变量均通过 <code>cssVars</code> 对象返回，直接在 CSS 中 <code>var(--xxx)</code> 引用。</p>

      <div class="card card-glass" style="padding:0;overflow:hidden;margin-bottom:36px">
        <table style="width:100%;border-collapse:collapse;font-size:13px">
          <thead><tr style="border-bottom:1px solid var(--color-border)">
            <th style="text-align:left;padding:10px 14px;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase;width:150px">变量</th>
            <th style="text-align:left;padding:10px 14px;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase">用途</th>
          </tr></thead>
          <tbody>
            <tr><td colspan="2" style="padding:8px 14px;font-size:10px;font-weight:700;letter-spacing:0.05em;color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 4%, transparent)">COLORS 色板</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--color-primary / --color-secondary / --color-accent</td><td style="padding:8px 14px;font-size:12px">主色 / 辅色 / 强调色</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--color-bg / --color-surface</td><td style="padding:8px 14px;font-size:12px">页面背景 / 卡片面板背景</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--color-text / --color-text-muted / --color-border</td><td style="padding:8px 14px;font-size:12px">正文 / 弱化文字 / 边框（带 alpha）</td></tr>

            <tr><td colspan="2" style="padding:8px 14px;font-size:10px;font-weight:700;letter-spacing:0.05em;color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 4%, transparent)">TYPOGRAPHY 排版</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--font-heading / --font-body / --font-mono</td><td style="padding:8px 14px;font-size:12px">标题 / 正文 / 等宽字体栈</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--text-base / --text-lg / --text-xl / --text-2xl / --text-sm</td><td style="padding:8px 14px;font-size:12px">Modular Scale 字号（base 使用 clamp 流式）</td></tr>

            <tr><td colspan="2" style="padding:8px 14px;font-size:10px;font-weight:700;letter-spacing:0.05em;color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 4%, transparent)">SPACING 间距</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--space-unit / --space-1~12</td><td style="padding:8px 14px;font-size:12px">4px 基准间距，7 级阶梯 (4~48px)</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--radii / --content-max</td><td style="padding:8px 14px;font-size:12px">统一圆角 (0.75rem) / 内容最大宽度 (72rem)</td></tr>

            <tr><td colspan="2" style="padding:8px 14px;font-size:10px;font-weight:700;letter-spacing:0.05em;color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 4%, transparent)">EFFECTS 效果</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--shadow-sm / --shadow-md / --shadow-lg</td><td style="padding:8px 14px;font-size:12px">三级阴影</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--glass-bg / --glass-blur / --noise-opacity</td><td style="padding:8px 14px;font-size:12px">毛玻璃背景 / 模糊量 / 噪点纹理</td></tr>

            <tr><td colspan="2" style="padding:8px 14px;font-size:10px;font-weight:700;letter-spacing:0.05em;color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 4%, transparent)">AMBIENT 氛围</td></tr>
            <tr><td style="padding:8px 14px;font-family:'JetBrains Mono',monospace;font-size:11px">--ambient-1 / --ambient-2</td><td style="padding:8px 14px;font-size:12px">氛围光球 rgba 颜色</td></tr>
          </tbody>
        </table>
      </div>

      <!-- ====== ROTATION ====== -->
      <h2 id="rotation" style="font-size:20px;font-weight:700;letter-spacing:-0.03em;margin-bottom:14px;margin-top:40px">轮换策略</h2>
      <div class="card card-glass" style="padding:0;overflow:hidden;margin-bottom:36px">

---
import Layout from '../../layouts/Layout.astro';
import { getDailyTheme } from '../../utils/daily-theme';

const today = getDailyTheme();
const primary = today.cssVars['--color-primary'];
const secondary = today.cssVars['--color-secondary'];

const minimalResponse = JSON.stringify({
  date: today.date || new Date().toISOString().slice(0, 10),
  preset: today.preset,
  presetName: today.presetName,
  generatedAt: new Date().toISOString(),
  cssVars: Object.fromEntries(
    Object.entries(today.cssVars).slice(0, 8)
  ),
  customCss: today.customCss ? "(theme-specific CSS animations)" : null,
  extensions: today.extensions ? [{ type: "html", content: "..." }] : null,
  logoText: today.logoText || null,
  logoColors: today.logoColors || null,
  available: 232,
  directory: [
    { preset: "crimson-abyss", name: "Crimson Abyss", primary: "#ff2a4b", accent: "#ff2a4b", logoText: "CRIMSON" },
    { preset: "yozakura-reverie", name: "Yozakura Reverie", primary: "#ff8fa3", accent: "#f472b6", logoText: "YOZAKURA" },
    "..."
  ]
}, null, 2);

const fullResponse = JSON.stringify({
  date: new Date().toISOString().slice(0, 10),
  preset: today.preset,
  presetName: today.presetName,
  generatedAt: new Date().toISOString(),
  cssVars: today.cssVars,
  customCss: today.customCss || null,
  extensions: today.extensions || null,
  logoText: today.logoText || null,
  logoColors: today.logoColors || null,
  available: 232,
  directory: [
    { preset: "crimson-abyss", name: "Crimson Abyss", primary: "#ff2a4b", accent: "#ff2a4b", logoText: "CRIMSON" },
    { preset: "yozakura-reverie", name: "Yozakura Reverie", primary: "#ff8fa3", accent: "#f472b6", logoText: "YOZAKURA" },
    "..."
  ]
}, null, 2);

const presetExample = JSON.stringify({
  preset: "crimson-abyss",
  presetName: "Crimson Abyss",
  cssVars: Object.fromEntries(
    Object.entries(today.cssVars).slice(0, 8)
  ),
  customCss: null,
  extensions: null,
  logoText: "CRIMSON",
  logoColors: ["#ff2a4b", "#ff6b7f"]
}, null, 2);

const quickStartCurl = `# 获取今日主题
curl https://YOUR.netlify.app/api/today.json

# 获取指定预设
curl https://YOUR.netlify.app/api/theme/crimson-abyss.json`;

const vanillaJS = String.raw`// 完整集成 — 含缓存、降级、特效注入
(async () => {
  const today = new Date().toISOString().slice(0, 10);
  const cached = JSON.parse(localStorage.getItem('td') || 'null');
  if (cached?.date === today) return applyTheme(cached);

  const res = await fetch('https://YOUR.netlify.app/api/today.json');
  if (!res.ok) throw new Error('API unavailable');
  const t = await res.json();

  const data = { date: t.date, cssVars: t.cssVars, customCss: t.customCss, exts: t.extensions };
  localStorage.setItem('td', JSON.stringify(data));
  applyTheme(data);
})().catch(() => {
  const fallback = JSON.parse(localStorage.getItem('td') || 'null');
  if (fallback) applyTheme(fallback);
});

function applyTheme(d) {
  Object.entries(d.cssVars).forEach(([k, v]) =>
    document.documentElement.style.setProperty(k, v));
  if (d.customCss) {
    const s = document.createElement('style');
    s.textContent = d.customCss;
    document.head.appendChild(s);
  }
  if (d.exts) {
    const div = document.createElement('div');
    div.innerHTML = d.exts.map(x => x.content).join('');
    document.body.prepend(div);
  }
}`;

const reactHook = String.raw`// React Hook — useDailyTheme.ts
import { useState, useEffect } from 'react';

interface ThemeData {
  date: string;
  preset: string;
  presetName: string;
  cssVars: Record<string, string>;
  customCss: string | null;
  extensions: { type: string; content: string }[] | null;
  logoText: string | null;
  logoColors: string[] | null;
}

export function useDailyTheme(apiBase: string) {
  const [theme, setTheme] = useState<ThemeData | null>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const today = new Date().toISOString().slice(0, 10);
    const cached = JSON.parse(localStorage.getItem('td') || 'null');

    if (cached?.date === today) {
      setTheme(cached);
      setLoading(false);
      return;
    }

    fetch(\`\${apiBase}/api/today.json\`)
      .then(r => r.json())
      .then(t => {
        const data = { date: t.date, ...t };
        localStorage.setItem('td', JSON.stringify(data));
        setTheme(data);
      })
      .catch(() => {
        const fallback = JSON.parse(localStorage.getItem('td') || 'null');
        if (fallback) setTheme(fallback);
      })
      .finally(() => setLoading(false));
  }, [apiBase]);

  // Inject CSS variables into :root
  useEffect(() => {
    if (!theme?.cssVars) return;
    const root = document.documentElement;
    Object.entries(theme.cssVars).forEach(([k, v]) =>
      root.style.setProperty(k, v));
  }, [theme]);

  return { theme, loading };
}`;

const vueComposable = String.raw`// Vue 3 Composable — useDailyTheme.ts
import { ref, watch, onMounted } from 'vue';

interface ThemeData {
  date: string;
  preset: string;
  presetName: string;
  cssVars: Record<string, string>;
  customCss: string | null;
  extensions: { type: string; content: string }[] | null;
  logoText: string | null;
  logoColors: string[] | null;
}

export function useDailyTheme(apiBase: string) {
  const theme = ref<ThemeData | null>(null);
  const loading = ref(true);

  async function fetchTheme() {
    const today = new Date().toISOString().slice(0, 10);
    const cached = JSON.parse(localStorage.getItem('td') || 'null');

    if (cached?.date === today) {
      theme.value = cached;
      loading.value = false;
      return;
    }

    try {
      const res = await fetch(\`\${apiBase}/api/today.json\`);
      const t = await res.json();
      const data = { date: t.date, ...t };
      localStorage.setItem('td', JSON.stringify(data));
      theme.value = data;
    } catch {
      const fallback = JSON.parse(localStorage.getItem('td') || 'null');
      if (fallback) theme.value = fallback;
    } finally {
      loading.value = false;
    }
  }

  // Inject CSS variables whenever theme changes
  watch(theme, (t) => {
    if (!t?.cssVars) return;
    const root = document.documentElement;
    Object.entries(t.cssVars).forEach(([k, v]) =>
      root.style.setProperty(k, v));
  });

  onMounted(fetchTheme);

  return { theme, loading };
}`;

const availableCount = 232;

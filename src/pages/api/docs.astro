          <tbody>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:6px 0;font-family:'JetBrains Mono',monospace;font-weight:700;color:var(--color-primary)">200</td><td style="padding:6px 0;font-size:12px">正常</td><td style="padding:6px 0;font-size:12px">解析 JSON，注入变量</td></tr>
            <tr style="border-bottom:1px solid var(--color-border)"><td style="padding:6px 0;font-family:'JetBrains Mono',monospace;font-weight:700;color:var(--color-primary)">404</td><td style="padding:6px 0;font-size:12px">文件不存在</td><td style="padding:6px 0;font-size:12px">提示检查 API 地址</td></tr>
            <tr><td style="padding:6px 0;font-family:'JetBrains Mono',monospace;font-weight:700;color:var(--color-primary)">—</td><td style="padding:6px 0;font-size:12px">网络中断</td><td style="padding:6px 0;font-size:12px"><code>catch</code> → localStorage 降级</td></tr>

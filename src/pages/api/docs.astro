<script>
  // ── Sidebar toggle (mobile) ──
  const sidebarToggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const overlay = document.getElementById('sidebar-overlay')!;

  function openSidebar() {
    sidebar.classList.add('open');
    overlay.classList.add('open');
    sidebarToggle.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
    sidebarToggle.classList.remove('open');
    document.body.style.overflow = '';
  }

  sidebarToggle.addEventListener('click', () => {
    sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
  });

  overlay.addEventListener('click', closeSidebar);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sidebar.classList.contains('open')) closeSidebar();
  });

  // Close sidebar on link click (mobile)
  sidebar.querySelectorAll('.sidebar-link').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 960) closeSidebar();
    });
  });

  // ── Scroll spy ──
  const sidebarLinks = document.querySelectorAll('.sidebar-link');
  const mainHeadings = document.querySelectorAll('.docs-main h2[id]');

  let spyTimer: number;
  function updateActiveLink() {
    let current = '';
    mainHeadings.forEach(h => {
      if (h.getBoundingClientRect().top < 140) current = h.id;
    });
    sidebarLinks.forEach(link => {
      const target = link.getAttribute('href')?.replace('#', '');
      link.classList.toggle('active', target === current);
    });
  }

  window.addEventListener('scroll', () => {
    clearTimeout(spyTimer);
    spyTimer = setTimeout(updateActiveLink, 60);
  }, { passive: true });

  // Initial active state
  updateActiveLink();

  // ── Try It Live ──
  const tryBtn = document.getElementById('try-it-btn')!;
  const tryOutput = document.getElementById('try-it-output')!;
  const tryMeta = document.getElementById('try-it-meta')!;
  const tryStatus = document.getElementById('try-it-status')!;
  const trySize = document.getElementById('try-it-size')!;
  const tryTime = document.getElementById('try-it-time')!;

  tryBtn.addEventListener('click', async () => {
    tryBtn.disabled = true;
    tryBtn.style.opacity = '0.6';
    tryOutput.querySelector('code')!.textContent = '// 加载中...';
    tryOutput.querySelector('code')!.style.color = 'var(--color-text-muted)';
    tryMeta.style.display = 'none';

    const start = performance.now();
    try {
      const res = await fetch('/api/today.json');
      const text = await res.text();
      const elapsed = (performance.now() - start).toFixed(0);
      const bytes = new TextEncoder().encode(text).length;
      const kb = bytes > 1024 ? (bytes / 1024).toFixed(1) + ' KB' : bytes + ' B';

      try {
        const json = JSON.parse(text);
        tryOutput.querySelector('code')!.textContent = JSON.stringify(json, null, 2);
      } catch {
        tryOutput.querySelector('code')!.textContent = text;
      }

      tryOutput.querySelector('code')!.style.color = 'var(--color-text)';
      tryStatus.textContent = String(res.status);
      tryStatus.style.color = res.ok ? 'var(--color-primary)' : '#ef4444';
      trySize.textContent = kb;
      tryTime.textContent = elapsed + ' ms';
      tryMeta.style.display = 'flex';
    } catch (err: any) {
      tryOutput.querySelector('code')!.textContent = '// 请求失败: ' + (err.message || '网络错误');
      tryOutput.querySelector('code')!.style.color = '#ef4444';
      tryStatus.textContent = 'ERR';
      tryStatus.style.color = '#ef4444';
      trySize.textContent = '—';
      tryTime.textContent = '—';
      tryMeta.style.display = 'flex';
    } finally {
      tryBtn.disabled = false;
      tryBtn.style.opacity = '1';
    }
  });
</script>

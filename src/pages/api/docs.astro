  <!-- Copy all button -->
  <button class="copy-all-fab" id="copy-all" title="复制全部文档">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 6v8a2 2 0 002 2h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  </button>

  <style>
    .tag {
      font-size:11px;padding:3px 10px;border-radius:99px;
      background:color-mix(in srgb, var(--color-primary) 10%, transparent);
      color:var(--color-primary);font-weight:600;
    }
    .toc-fab {
      position:fixed;bottom:88px;right:32px;z-index:250;
      display:flex;flex-direction:column;align-items:center;gap:10px;
    }
    .toc-trigger {
      width:48px;height:48px;border-radius:50%;
      border:1.5px solid var(--color-border);
      background:color-mix(in srgb, var(--color-surface) 90%, transparent);
      backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
      color:var(--color-text);cursor:pointer;
      display:flex;align-items:center;justify-content:center;
      transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1);
      box-shadow:0 8px 32px rgba(0,0,0,0.18);
      position:relative;z-index:1;
    }
    .toc-trigger:hover {border-color:var(--color-primary);transform:scale(1.05);}
    .toc-trigger:active {transform:scale(0.94);}
    .toc-icon-close {display:none;}
    .toc-fab.open .toc-icon-list {display:none;}
    .toc-fab.open .toc-icon-close {display:block;}
    .toc-menu {
      display:flex;flex-direction:column;align-items:center;gap:14px;
      opacity:0;pointer-events:none;
      transform:translateY(20px) scale(0.5);
      transition:all 0.4s cubic-bezier(0.34,1.56,0.64,1);
      padding:24px 0 8px;margin-top:-68px;
      background:color-mix(in srgb, var(--color-surface) 85%, transparent);
      backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
      border-radius:28px;border:1px solid var(--color-border);
      min-width:56px;
    }
    .toc-fab.open .toc-menu {opacity:1;pointer-events:auto;transform:translateY(0) scale(1);}
    .toc-dot {
      display:block;width:11px;height:11px;border-radius:50%;
      background:var(--color-text-muted);border:2px solid transparent;
      transition:all 0.25s cubic-bezier(0.34,1.56,0.64,1);
      position:relative;flex-shrink:0;
    }
    .toc-dot::after {
      content:attr(title);position:absolute;right:24px;top:50%;transform:translateY(-50%);
      font-size:11px;font-weight:600;color:var(--color-text);white-space:nowrap;
      background:color-mix(in srgb, var(--color-surface) 95%, transparent);
      padding:4px 12px;border-radius:7px;opacity:0;pointer-events:none;
      transition:opacity 0.2s;border:1px solid var(--color-border);
    }
    .toc-dot:hover {background:var(--color-primary);border-color:var(--color-primary);transform:scale(1.5);box-shadow:0 4px 14px color-mix(in srgb, var(--color-primary) 40%, transparent);}
    .toc-dot:hover::after {opacity:1;}
    .toc-dot.active {background:var(--color-primary);border-color:var(--color-primary);width:13px;height:13px;box-shadow:0 0 10px color-mix(in srgb, var(--color-primary) 50%, transparent);}

    .copy-all-fab {
      position:fixed;bottom:32px;right:32px;z-index:240;
      width:44px;height:44px;border-radius:50%;
      border:1.5px solid var(--color-border);
      background:color-mix(in srgb, var(--color-surface) 90%, transparent);
      backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
      color:var(--color-text-muted);cursor:pointer;
      display:flex;align-items:center;justify-content:center;
      transition:all 0.25s;
      box-shadow:0 6px 24px rgba(0,0,0,0.15);
      font-family:inherit;
    }
    .copy-all-fab:hover {border-color:var(--color-primary);color:var(--color-primary);transform:scale(1.06);}
    .copy-all-fab.copied {border-color:var(--color-primary);color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 12%, transparent);}

    @media (max-width:768px) {
      .toc-fab {bottom:80px;right:16px;}
      .toc-dot::after {display:none;}
      .toc-fab.open .toc-dot {width:15px;height:15px;}
      .copy-all-fab {bottom:24px;right:16px;}
    }
  </style>

  <script>
    // TOC logic
    const tocFab = document.getElementById('toc-fab')!;
    document.getElementById('toc-trigger')!.addEventListener('click', () => tocFab.classList.toggle('open'));
    document.addEventListener('click', (e) => { if (!tocFab.contains(e.target as Node)) tocFab.classList.remove('open'); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') tocFab.classList.remove('open'); });

    document.querySelectorAll('.toc-dot').forEach(dot => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        const id = (dot as HTMLElement).dataset.target || '';
        const el = document.getElementById(id);
        if (el) { el.scrollIntoView({ behavior:'smooth', block:'start' }); tocFab.classList.remove('open'); }
      });
    });

    // Scroll spy
    const dots = document.querySelectorAll('.toc-dot');
    const headings = document.querySelectorAll('h2[id]');
    let scrollTimer: number;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => {
        let current = '';
        headings.forEach(h => { if (h.getBoundingClientRect().top < 180) current = h.id; });
        dots.forEach(d => d.classList.toggle('active', d.getAttribute('data-target') === current));
      }, 80);
    }, { passive:true });

    // Copy all docs as structured reference
    const copyAll = document.getElementById('copy-all')!;
    copyAll.addEventListener('click', async () => {
      const sections = document.querySelectorAll('h2[id]');
      const lines: string[] = ['# ThemeDist API Reference', '', `> Base: ${location.origin}/api/today.json`, ''];
      sections.forEach(h => {
        const text = h.textContent?.trim() || '';
        lines.push(`## ${text}`, '');
        let el = h.nextElementSibling;
        while (el && el.tagName !== 'H2') {
          const txt = (el as HTMLElement).textContent?.trim();
          if (txt) lines.push(txt, '');
          el = el.nextElementSibling;
        }
        lines.push('');
      });
      try {
        await navigator.clipboard.writeText(lines.join('\n'));
        copyAll.classList.add('copied');
        copyAll.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        setTimeout(() => {
          copyAll.classList.remove('copied');
          copyAll.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 6v8a2 2 0 002 2h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>';
        }, 1800);
      } catch { (window as any).__toast?.('复制失败'); }
    });
  </script>
</Layout>

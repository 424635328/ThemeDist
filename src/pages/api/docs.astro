  <style>
    .docs-header { margin-bottom: 28px; }
    h2[id] { scroll-margin-top: 80px; }
    h3[id] { scroll-margin-top: 80px; }
    .ep-tag { font-weight:800; font-size:10px; padding:3px 10px; border-radius:5px; color:#fff; white-space:nowrap; }
    .ep-tag.get  { background:#16a34a; }
    .ep-tag.post { background:#2563eb; }
    .ep-tag.page { background:#9333ea; }
    .tag {
      font-size:11px;padding:3px 10px;border-radius:99px;
      background:color-mix(in srgb, var(--color-primary) 10%, transparent);
      color:var(--color-primary);font-weight:600;
    }
    /* command blocks */
    .cmd-group { margin-bottom:18px; }
    .cmd-header {
      display:flex;align-items:center;justify-content:space-between;
      margin-bottom:6px;gap:12px;
    }
    .cmd-label {
      font-size:11px;font-weight:600;
      color:var(--color-text-muted);
      text-transform:uppercase;letter-spacing:0.04em;
    }
    .cmd-copy-btn {
      display:inline-flex;align-items:center;gap:5px;
      padding:4px 12px;font-size:11px;font-weight:600;
      border-radius:7px;border:1px solid var(--color-border);
      background:var(--color-surface);color:var(--color-text-muted);
      cursor:pointer;transition:all 0.2s;
      font-family:inherit;line-height:1.5;
      white-space:nowrap;flex-shrink:0;
    }
    .cmd-copy-btn:hover {
      border-color:var(--color-primary);color:var(--color-primary);
    }
    .cmd-copy-btn:active {transform:scale(0.95);}
    .cmd-copy-btn.copied {
      border-color:var(--color-primary);color:var(--color-primary);
      background:color-mix(in srgb, var(--color-primary) 10%, transparent);
    }
    .cmd-block {
      background:#1e1e2e;color:#cdd6f4;
      padding:14px 18px;border-radius:10px;
      font-size:13px;overflow-x:auto;
      margin:0;line-height:1.7;
    }
    .cmd-block code {background:none;padding:0;color:inherit;}
    .toc-fab {
      position:fixed;bottom:200px;right:32px;z-index:250;
    }
    .toc-trigger {
      width:48px;height:48px;border-radius:50%;
      border:1.5px solid var(--color-border);
      background:color-mix(in srgb, var(--color-surface) 90%, transparent);
      backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
      color:var(--color-text);cursor:pointer;
      display:flex;align-items:center;justify-content:center;
      transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1);
      box-shadow:0 8px 32px rgba(0,0,0,0.18);
      position:relative;z-index:2;
    }
    .toc-trigger:hover {border-color:var(--color-primary);transform:scale(1.05);}
    .toc-trigger:active {transform:scale(0.94);}
    .toc-icon-close {display:none;}
    .toc-fab.open .toc-icon-list {display:none;}
    .toc-fab.open .toc-icon-close {display:block;}
    .toc-menu {
      position:absolute;bottom:56px;right:0;
      display:flex;flex-direction:column;gap:0;
      background:color-mix(in srgb, var(--color-surface) 92%, transparent);
      backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
      border-radius:16px;border:1px solid var(--color-border);
      box-shadow:0 12px 40px rgba(0,0,0,0.22);
      padding:6px;min-width:170px;max-height:70vh;overflow-y:auto;
      opacity:0;pointer-events:none;
      transform:translateY(8px) scale(0.92);
      transform-origin:bottom right;
      transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }
    .toc-fab.open .toc-menu {
      opacity:1;pointer-events:auto;transform:translateY(0) scale(1);
    }
    .toc-group {
      display:flex;flex-direction:column;gap:1px;
      padding:3px 0;
    }
    .toc-group + .toc-group {
      border-top:1px solid color-mix(in srgb, var(--color-border) 40%, transparent);
    }
    .toc-link {
      display:flex;align-items:center;justify-content:space-between;gap:10px;
      padding:7px 12px;font-size:13px;font-weight:500;
      color:var(--color-text-muted);text-decoration:none;
      border-radius:8px;transition:all 0.2s;white-space:nowrap;
    }
    .toc-link:hover {
      background:color-mix(in srgb, var(--color-primary) 8%, transparent);
      color:var(--color-text);
    }
    .toc-link:focus-visible {
      outline:2px solid var(--color-primary);outline-offset:-2px;
    }
    .toc-link.active {
      color:var(--color-primary);font-weight:600;
      background:color-mix(in srgb, var(--color-primary) 8%, transparent);
    }
    .toc-link.active::after {
      content:'';width:5px;height:5px;border-radius:50%;
      background:var(--color-primary);flex-shrink:0;
    }
    .toc-sub {
      font-size:12px;padding:5px 12px 5px 24px;
      font-weight:400;opacity:0.85;
    }
    .toc-sub.active {
      opacity:1;font-weight:600;
    }
    .toc-sub.active::after {
      width:4px;height:4px;
    }
    .toc-parent {
      font-weight:600;font-size:13px;
    }

    .copy-all-fab {
      position:fixed;bottom:88px;right:32px;z-index:240;
      height:44px;padding:0 20px;border-radius:22px;
      border:1.5px solid var(--color-border);
      background:color-mix(in srgb, var(--color-surface) 90%, transparent);
      backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
      color:var(--color-text-muted);cursor:pointer;
      display:flex;align-items:center;gap:8px;
      font-size:13px;font-weight:600;font-family:inherit;
      white-space:nowrap;
      transition:all 0.25s;
      box-shadow:0 6px 24px rgba(0,0,0,0.15);
    }
    .copy-all-fab:hover {border-color:var(--color-primary);color:var(--color-primary);transform:scale(1.06);}
    .copy-all-fab.copied {border-color:var(--color-primary);color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 12%, transparent);}

    @media (max-width:768px) {
      .toc-fab {bottom:180px;right:16px;}
      .toc-menu {min-width:160px;max-height:60vh;}
      .toc-link {font-size:12px;padding:6px 10px;}
      .toc-sub {font-size:11px;padding:4px 10px 4px 22px;}
      .copy-all-fab {bottom:80px;right:16px;padding:0 16px;height:40px;font-size:12px;}
    }
  </style>

  <script>
    // Copy button handler — all elements with .cmd-copy-btn
    document.querySelectorAll('.cmd-copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const cmd = btn.dataset.cmd || '';
        try {
          await navigator.clipboard.writeText(cmd);
          btn.classList.add('copied');
          const origHTML = btn.innerHTML;
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 18 18" fill="none"><path d="M4 9l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> 已复制';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = origHTML;
          }, 1800);
        } catch { window.__toast?.('复制失败'); }
      });
    });

    const tocFab = document.getElementById('toc-fab');
    const tocTrigger = document.getElementById('toc-trigger');
    const tocMenu = document.getElementById('toc-menu');
    const dots = Array.from(document.querySelectorAll('.toc-link'));
    const headings = Array.from(document.querySelectorAll('h2[id], h3[id]'));

    function openToc() { tocFab.classList.add('open'); tocTrigger.setAttribute('aria-expanded', 'true'); dots[0]?.focus(); }
    function closeToc() { tocFab.classList.remove('open'); tocTrigger.setAttribute('aria-expanded', 'false'); tocTrigger.focus(); }

    tocTrigger.addEventListener('click', () => tocFab.classList.contains('open') ? closeToc() : openToc());
    document.addEventListener('click', (e) => { if (!tocFab.contains(e.target)) closeToc(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeToc(); });

    // Dot click → scroll to section
    dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        const id = dot.dataset.target || '';
        const el = document.getElementById(id);
        if (el) { el.scrollIntoView({ behavior:'smooth', block:'start' }); closeToc(); }
      });
    });

    // Keyboard nav: arrow keys between dots, Home/End
    tocMenu.addEventListener('keydown', (e) => {
      const idx = dots.indexOf(document.activeElement);
      if (idx === -1) return;
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') { e.preventDefault(); dots[(idx + 1) % dots.length].focus(); }
      if (e.key === 'ArrowUp'   || e.key === 'ArrowLeft')  { e.preventDefault(); dots[(idx - 1 + dots.length) % dots.length].focus(); }
      if (e.key === 'Home') { e.preventDefault(); dots[0].focus(); }
      if (e.key === 'End')  { e.preventDefault(); dots[dots.length - 1].focus(); }
    });

    // IntersectionObserver scroll spy
    let activeId = '';
    let hashTimer;
    const observer = new IntersectionObserver((entries) => {
      // Find the topmost heading that's crossed the top threshold
      let bestId = '';
      let bestTop = Infinity;
      headings.forEach(h => {
        const top = h.getBoundingClientRect().top;
        if (top < 120 && top > -200 && top < bestTop) { bestTop = top; bestId = h.id; }
      });
      // Fallback: if scrolled past all, pick the last one
      if (!bestId) {
        const last = headings[headings.length - 1];
        if (last && last.getBoundingClientRect().top < 0) bestId = last.id;
      }
      if (bestId && bestId !== activeId) {
        activeId = bestId;
        dots.forEach(d => d.classList.toggle('active', d.dataset.target === bestId));
        clearTimeout(hashTimer);
        hashTimer = setTimeout(() => history.replaceState(null, '', '#' + bestId), 250);
      }
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
    headings.forEach(h => observer.observe(h));

    // On load: check if URL has a hash → scroll to it and set active
    if (location.hash) {
      const id = location.hash.slice(1);
      const targetHeading = document.getElementById(id);
      if (targetHeading) {
        setTimeout(() => targetHeading.scrollIntoView({ behavior:'smooth', block:'start' }), 100);
        dots.forEach(d => d.classList.toggle('active', d.dataset.target === id));
        activeId = id;
      }
    }

    // Copy all docs
    const copyAll = document.getElementById('copy-all');
    copyAll.addEventListener('click', async () => {
      const sections = document.querySelectorAll('h2[id]');
      const lines = ['# ThemeDist API Reference', '', `> Base: ${location.origin}/api/v1/today.json`, ''];
      sections.forEach(h => {
        const text = h.textContent?.trim() || '';
        lines.push(`## ${text}`, '');
        let el = h.nextElementSibling;
        while (el && el.tagName !== 'H2') {
          const txt = el.textContent?.trim();
          if (txt) lines.push(txt, '');
          el = el.nextElementSibling;
        }
        lines.push('');
      });
      try {
        await navigator.clipboard.writeText(lines.join('\n'));
        copyAll.classList.add('copied');
        const icon = copyAll.querySelector('.copy-all-icon');
        if (icon) icon.innerHTML = '<path d="M4 9l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
        setTimeout(() => {
          copyAll.classList.remove('copied');
          if (icon) icon.innerHTML = '<rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 6v8a2 2 0 002 2h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
        }, 1800);
      } catch { window.__toast?.('复制失败'); }
    });
  </script>
</Layout>

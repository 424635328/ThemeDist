  <script>
    // Copy button handler — all elements with .cmd-copy-btn
    document.querySelectorAll('.cmd-copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const cmd = btn.dataset.cmd || '';
        try {
          await navigator.clipboard.writeText(cmd);
          btn.classList.add('copied');
          const origHTML = btn.innerHTML;
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 18 18" fill="none"><path d="M4 9l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> 已复制';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = origHTML;
          }, 1800);
        } catch { window.__toast?.('复制失败'); }
      });
    });

    const tocFab = document.getElementById('toc-fab');
    const tocTrigger = document.getElementById('toc-trigger');
    const tocMenu = document.getElementById('toc-menu');
    const dots = Array.from(document.querySelectorAll('.toc-link'));
    const headings = Array.from(document.querySelectorAll('h2[id]'));

    function openToc() { tocFab.classList.add('open'); tocTrigger.setAttribute('aria-expanded', 'true'); dots[0]?.focus(); }
    function closeToc() { tocFab.classList.remove('open'); tocTrigger.setAttribute('aria-expanded', 'false'); tocTrigger.focus(); }

    tocTrigger.addEventListener('click', () => tocFab.classList.contains('open') ? closeToc() : openToc());
    document.addEventListener('click', (e) => { if (!tocFab.contains(e.target)) closeToc(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeToc(); });

    // Dot click → scroll to section
    dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        const id = dot.dataset.target || '';
        const el = document.getElementById(id);
        if (el) { el.scrollIntoView({ behavior:'smooth', block:'start' }); closeToc(); }
      });
    });

    // Keyboard nav: arrow keys between dots, Home/End
    tocMenu.addEventListener('keydown', (e) => {
      const idx = dots.indexOf(document.activeElement);
      if (idx === -1) return;
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') { e.preventDefault(); dots[(idx + 1) % dots.length].focus(); }
      if (e.key === 'ArrowUp'   || e.key === 'ArrowLeft')  { e.preventDefault(); dots[(idx - 1 + dots.length) % dots.length].focus(); }
      if (e.key === 'Home') { e.preventDefault(); dots[0].focus(); }
      if (e.key === 'End')  { e.preventDefault(); dots[dots.length - 1].focus(); }
    });

    // IntersectionObserver scroll spy
    let activeId = '';
    let hashTimer;
    const observer = new IntersectionObserver((entries) => {
      // Find the topmost heading that's crossed the top threshold
      let bestId = '';
      let bestTop = Infinity;
      headings.forEach(h => {
        const top = h.getBoundingClientRect().top;
        if (top < 120 && top > -200 && top < bestTop) { bestTop = top; bestId = h.id; }
      });
      // Fallback: if scrolled past all, pick the last one
      if (!bestId) {
        const last = headings[headings.length - 1];
        if (last && last.getBoundingClientRect().top < 0) bestId = last.id;
      }
      if (bestId && bestId !== activeId) {
        activeId = bestId;
        dots.forEach(d => d.classList.toggle('active', d.dataset.target === bestId));
        clearTimeout(hashTimer);
        hashTimer = setTimeout(() => history.replaceState(null, '', '#' + bestId), 250);
      }
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
    headings.forEach(h => observer.observe(h));

    // On load: check if URL has a hash → scroll to it and set active
    if (location.hash) {
      const id = location.hash.slice(1);
      const targetHeading = document.getElementById(id);
      if (targetHeading) {
        setTimeout(() => targetHeading.scrollIntoView({ behavior:'smooth', block:'start' }), 100);
        dots.forEach(d => d.classList.toggle('active', d.dataset.target === id));
        activeId = id;
      }
    }

    // Copy all docs
    const copyAll = document.getElementById('copy-all');
    copyAll.addEventListener('click', async () => {
      const sections = document.querySelectorAll('h2[id]');
      const lines = ['# ThemeDist API Reference', '', `> Base: ${location.origin}/api/today.json`, ''];
      sections.forEach(h => {
        const text = h.textContent?.trim() || '';
        lines.push(`## ${text}`, '');
        let el = h.nextElementSibling;
        while (el && el.tagName !== 'H2') {
          const txt = el.textContent?.trim();
          if (txt) lines.push(txt, '');
          el = el.nextElementSibling;
        }
        lines.push('');
      });
      try {
        await navigator.clipboard.writeText(lines.join('\n'));
        copyAll.classList.add('copied');
        const icon = copyAll.querySelector('.copy-all-icon');
        if (icon) icon.innerHTML = '<path d="M4 9l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
        setTimeout(() => {
          copyAll.classList.remove('copied');
          if (icon) icon.innerHTML = '<rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 6v8a2 2 0 002 2h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
        }, 1800);
      } catch { window.__toast?.('复制失败'); }
    });
  </script>

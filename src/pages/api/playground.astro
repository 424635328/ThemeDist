  .pg-amb-orb:nth-child(2) { width: 450px; height: 450px; bottom: -20%; right: -8%; background: var(--ambient-2); animation-delay: -7s; }
  .pg-amb-grain {
    position: absolute; inset: 0; opacity: 0.03;

<Layout>
  <section style="padding:28px 20px;max-width:1520px;margin:0 auto">
    <div class="pg-topbar">
      <div>
        <p class="t-label" style="margin:0">Developer Tools</p>
        <h1 style="margin:2px 0 0;font-size:1.35rem;font-weight:700;letter-spacing:-0.02em">API Playground</h1>
      </div>
      <div class="pg-topbar__actions">
        <button class="pg-mobile-toggle" id="mobile-sidebar-toggle" type="button" aria-label="Toggle sidebar">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect y="2" width="18" height="2" rx="1" fill="currentColor"/><rect y="8" width="18" height="2" rx="1" fill="currentColor"/><rect y="14" width="18" height="2" rx="1" fill="currentColor"/></svg>
        </button>
        <div class="pg-topbar__hint">
          <kbd>Ctrl</kbd> + <kbd>Enter</kbd> to send
        </div>
      </div>
    </div>

    <div class="pg-shell" id="pg-shell">
      <!-- ====== SIDEBAR ====== -->
      <nav class="pg-sidebar" id="pg-sidebar">
        <div class="pg-sidebar__section">
          <div class="pg-sidebar__label">Endpoints</div>
          <div class="pg-search">
            <svg class="pg-search__icon" width="14" height="14" viewBox="0 0 18 18" fill="none"><circle cx="7.5" cy="7.5" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M11.5 11.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <input class="pg-search__input" id="ep-search" type="text" placeholder="Filter endpoints..." autocomplete="off" />
          </div>
          <div class="pg-ep-list" id="ep-list">
            {groups.map((g) => (
              <div class="pg-ep-group" data-group={g.name}>
                <div class="pg-ep-group__name">{g.name}</div>
                {g.items.map((ep: any) => (
                  <button class="pg-ep-item" data-idx={String(ep._idx)} data-method={ep.method} data-path={ep.path} data-label={ep.label} type="button"
                    onclick="window.__selectEndpoint && window.__selectEndpoint({ep._idx})">
                    <span class={`pg-ep-item__method pg-ep-method--${ep.method.toLowerCase()}`}>{ep.method}</span>
                    <span class="pg-ep-item__label">{ep.label}</span>
                  </button>
                ))}
              </div>
            ))}
          </div>
        </div>

        <button class="pg-custom-trigger" id="custom-url-toggle" type="button">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none"><path d="M7 3H4a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1v-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 2L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M11 2h5v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Custom URL
        </button>

        <div class="pg-sidebar__section" id="history-section" style="display:none">
          <div class="pg-sidebar__label">History <button class="pg-history-clear" id="history-clear" type="button">Clear</button></div>
          <div class="pg-history-list" id="history-list"></div>
        </div>
      </nav>

      <!-- ====== MAIN: Request + Docs ====== -->
      <div class="pg-main">
        <div class="pg-panel" style="height:100%;overflow-y:auto">
          <!-- URL bar -->
          <div class="pg-url-section">
            <div class="pg-url-row">
              <select class="pg-method-select" id="method-select">
                <option value="GET">GET</option>
                <option value="POST">POST</option>
              </select>
              <div class="pg-url-input-wrap">
                <span class="pg-url-prefix">{siteUrl}</span>
                <input class="pg-url-input" id="url-input" type="text" value="/api/v1/today.json" autocomplete="off" spellcheck="false" />
              </div>
              <button class="pg-send-btn" id="pg-send" type="button" onclick="window.__doSend && window.__doSend()">
                <svg width="15" height="15" viewBox="0 0 18 18" fill="none"><path d="M2 9l14-7-7 14-2-5-5-2z" fill="currentColor"/></svg>
                <span id="pg-send-label">Send</span>
              </button>
            </div>
          </div>

          <!-- API Description -->
          <div class="pg-docs" id="pg-docs">
            <div class="pg-docs__empty" id="pg-docs-empty">
              <p>Select an endpoint from the sidebar to view details and send requests.</p>
            </div>
            <div class="pg-docs__content" id="pg-docs-content" style="display:none">
              <h2 class="pg-docs__title" id="docs-title"></h2>
              <p class="pg-docs__desc" id="docs-desc"></p>

              <div class="pg-docs__section">
                <h3>Usage</h3>
                <p class="pg-docs__usage" id="docs-usage"></p>
              </div>

              <div class="pg-docs__section" id="docs-notes-block" style="display:none">
                <h3>Notes</h3>
                <div class="pg-docs__notes" id="docs-notes"></div>
              </div>

              <div class="pg-docs__section" id="docs-response-block" style="display:none">
                <h3>Response Fields</h3>
                <div class="pg-table-wrap">
                  <table class="pg-docs-table" id="docs-response-table"></table>
                </div>
              </div>

              <div class="pg-docs__section">
                <h3>cURL Example</h3>
                <pre class="pg-docs__curl" id="docs-curl"></pre>
              </div>
            </div>
          </div>

          <!-- Query params -->
          <div class="pg-params" id="params-container">
            <div class="pg-params__head">
              <span class="pg-params__title">Query Parameters</span>
              <button class="pg-params__add" id="param-add" type="button">+ Add</button>
            </div>
            <div id="params-list"></div>
            <div class="pg-no-params" id="no-params">No parameters for this endpoint</div>
          </div>

          <!-- Body (POST) -->
          <div class="pg-body-section" id="body-section" style="display:none">
            <div class="pg-body__head">
              <span class="pg-params__title">Request Body</span>
              <div class="pg-body__actions">
                <button class="pg-body__btn" id="body-format" type="button">Prettify</button>
                <button class="pg-body__btn" id="body-validate" type="button">Validate</button>
              </div>
            </div>
            <textarea class="pg-body-editor" id="body-editor" rows="10" placeholder='{"key": "value"}' spellcheck="false"></textarea>
            <span class="pg-body-feedback" id="body-feedback"></span>
          </div>

          <!-- Rate limit bar -->
          <div class="pg-rate" id="pg-rate" style="display:none">
            <div class="pg-rate__bar"><div class="pg-rate__fill" id="rate-fill"></div></div>
            <span class="pg-rate__text" id="rate-text"></span>
          </div>

          <span class="pg-send-hint" id="pg-send-hint"></span>
        </div>
      </div>

      <!-- ====== RIGHT: Response ====== -->
      <div class="pg-response" id="res-panel">
        <div class="pg-panel" style="height:100%;display:flex;flex-direction:column">
          <div class="pg-panel__head">
            <span class="pg-panel__title">Response</span>
            <div class="pg-res__meta" id="res-meta" style="display:none">
              <span class="pg-res-status" id="res-status"></span>
              <span class="pg-res-time" id="res-time"></span>
              <button class="pg-res-copy" id="res-copy" type="button">Copy</button>
            </div>
          </div>

          <div class="pg-res-empty" id="pg-empty">
            <svg width="40" height="40" viewBox="0 0 48 48" fill="none" opacity="0.25">
              <rect x="10" y="10" width="28" height="28" rx="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M18 21l4 4 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p>Select an endpoint and click <strong>Send</strong> to inspect the response</p>
          </div>

          <div class="pg-res-loading" id="pg-loading" style="display:none">
            <div class="pg-spinner"></div>
            <span>Sending request...</span>
          </div>

          <div class="pg-res-error" id="pg-error" style="display:none">
            <span class="pg-res-error__icon">!</span>
            <div><strong id="pg-error-title">Request Failed</strong><p id="pg-error-msg"></p></div>
          </div>

          <div class="pg-res-content" id="res-content" style="display:none">
            <details class="pg-res-headers" id="res-headers-block" open>
              <summary class="pg-res-headers__toggle">Response Headers <span class="pg-res-count" id="hdr-count"></span></summary>
              <div class="pg-res-headers__table-wrap">
                <table class="pg-res-headers__table" id="res-headers"></table>
              </div>
            </details>
            <div class="pg-res-body" id="res-body-block">
              <div class="pg-res-body__head">
                <span class="pg-res-body__label">Response Body</span>
                <button class="pg-res-body__maximize" id="res-maximize" type="button" title="Toggle full-width">⤢</button>
              </div>
              <pre class="pg-res-body__code" id="res-body"></pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script type="application/json" id="flat-data" is:inline>
{JSON.stringify(flat.map((ep: any) => ({id: ep.id, method: ep.method, path: ep.path, label: ep.label, desc: ep.desc, usage: ep.usage, params: ep.params, curlExample: ep.curlExample, notes: ep.notes, responseFields: ep.responseFields, _idx: ep._idx, _gid: ep._gid, _eid: ep._eid})))}
</script>

<script>
  var siteUrl = '{siteUrl}';
  var RATE_WINDOW = 60000;
  var RATE_LIMITS = { GET: 30, POST: 5 };
  var STORAGE_KEY = 'td-pg-rate';
  var HIST_KEY = 'td-pg-history';
  var FLAT = JSON.parse(document.getElementById('flat-data').textContent);

  var activeEP = FLAT[0];
  var isCustom = false;
  var lastResBody = '';
  var lastResCT = '';
  var maxed = false;

  // ── Rate helpers ──
  function getHits() {
    try { return JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { return []; }
  }
  function recordHit(method) {
    var now = Date.now();
    var hist = getHits().filter(function(h) { return h.method === method && now - h.ts < RATE_WINDOW; });
    hist.push({ method: method, ts: now });
    sessionStorage.setItem(STORAGE_KEY, JSON.stringify(hist));
    return hist;
  }
  function checkRate(method) {
    var hist = getHits().filter(function(h) { return h.method === method && Date.now() - h.ts < RATE_WINDOW; });
    var limit = RATE_LIMITS[method] || 30;
    var remaining = Math.max(0, limit - hist.length);
    var blocked = remaining === 0;
    var waitSec = 0;
    if (blocked) {
      var oldest = hist.reduce(function(min, h) { return h.ts < min ? h.ts : min; }, Infinity);
      waitSec = Math.ceil((RATE_WINDOW - (Date.now() - oldest)) / 1000);
    }
    return { count: hist.length, limit: limit, remaining: remaining, blocked: blocked, waitSec: waitSec };
  }

  // ── History ──
  function getHistory() {
    try { return JSON.parse(sessionStorage.getItem(HIST_KEY) || '[]'); } catch(e) { return []; }
  }
  function saveHistory(entry) {
    var hist = getHistory();
    hist.unshift(entry);
    if (hist.length > 20) hist.length = 20;
    sessionStorage.setItem(HIST_KEY, JSON.stringify(hist));
    renderHistory();
  }

  // ── DOM refs ──
  function $(s) { return document.querySelector(s); }
  function $i(s) { return document.getElementById(s); }

  var epSearchEl   = $i('ep-search');
  var epListEl     = $i('ep-list');
  var methodSel    = $i('method-select');
  var urlInput     = $i('url-input');
  var pgSend       = $i('pg-send');
  var pgSendLabel  = $i('pg-send-label');
  var pgSendHint   = $i('pg-send-hint');
  var rateShort    = $i('rate-short');
  var paramsList   = $i('params-list');
  var noParams     = $i('no-params');
  var bodySection  = $i('body-section');
  var bodyEditor   = $i('body-editor');
  var bodyFeedback = $i('body-feedback');
  var pgRate       = $i('pg-rate');
  var rateFill     = $i('rate-fill');
  var rateText     = $i('rate-text');
  var resMeta      = $i('res-meta');
  var resStatus    = $i('res-status');
  var resTime      = $i('res-time');
  var resHeaders   = $i('res-headers');
  var resBody      = $i('res-body');
  var hdrCount     = $i('hdr-count');
  var pgEmptyEl    = $i('pg-empty');
  var pgLoading    = $i('pg-loading');
  var pgError      = $i('pg-error');
  var pgErrorTitle = $i('pg-error-title');
  var pgErrorMsg   = $i('pg-error-msg');
  var resContent   = $i('res-content');
  var resHeadersBlock = $i('res-headers-block');
  var resBodyBlock = $i('res-body-block');
  var resCopy      = $i('res-copy');
  var historyList  = $i('history-list');
  var historySection = $i('history-section');
  var docsEmpty    = $i('pg-docs-empty');
  var docsContent  = $i('pg-docs-content');
  var docsTitle    = $i('docs-title');
  var docsDesc     = $i('docs-desc');
  var docsUsage    = $i('docs-usage');
  var docsCurl     = $i('docs-curl');
  var docsNotesBlock = $i('docs-notes-block');
  var docsNotes    = $i('docs-notes');
  var docsResponseBlock = $i('docs-response-block');
  var docsResponseTable = $i('docs-response-table');
  var sidebarEl    = $i('pg-sidebar');
  var mobileToggle = $i('mobile-sidebar-toggle');
  var resPanel     = $i('res-panel');

  // ── Show endpoint docs ──
  function showDocs(ep) {
    docsEmpty.style.display = 'none';
    docsContent.style.display = 'block';
    docsTitle.textContent = ep.method + ' ' + (ep.label || '');
    docsDesc.textContent = ep.desc || '';
    docsUsage.textContent = ep.usage || '';
    docsCurl.textContent = ep.curlExample || buildURL();

    if (ep.notes) {
      docsNotesBlock.style.display = 'block';
      docsNotes.textContent = ep.notes;
    } else {
      docsNotesBlock.style.display = 'none';
    }

    if (ep.responseFields && ep.responseFields.length) {
      docsResponseBlock.style.display = 'block';
      docsResponseTable.innerHTML = '<thead><tr><th>Field</th><th>Type</th><th>Description</th></tr></thead><tbody>' +
        ep.responseFields.map(function(f) {
          return '<tr><td class="pg-docs-field">' + esc(f.name) + '</td><td class="pg-docs-type">' + esc(f.type) + '</td><td>' + esc(f.desc) + '</td></tr>';
        }).join('') + '</tbody>';
    } else {
      docsResponseBlock.style.display = 'none';
    }
  }

  // ── Select endpoint ──
  function selectEndpoint(idx) {
    isCustom = false;
    $('#custom-url-toggle').classList.remove('active');
    activeEP = FLAT[idx];
    methodSel.value = activeEP.method;
    methodSel.disabled = false;
    urlInput.value = activeEP.path;
    urlInput.readOnly = false;
    renderParams();
    highlightSidebar();
    updateRateUI();
    showDocs(activeEP);
    bodySection.style.display = activeEP.method === 'POST' ? 'block' : 'none';
    if (activeEP.method === 'POST') {
      var bodyParam = (activeEP.params || []).find(function(p) { return p.name === 'body'; });
      if (bodyParam && !bodyEditor.value) bodyEditor.value = bodyParam.placeholder || '';
    }
    // Close mobile sidebar after selection
    if (window.innerWidth < 1150) sidebarEl.classList.remove('open');
  }

  window.__selectEndpoint = selectEndpoint;

  function highlightSidebar() {
    document.querySelectorAll('.pg-ep-item').forEach(function(el) {
      el.classList.toggle('active', el.dataset.idx === String(activeEP._idx));
    });
  }

  // ── Filter endpoints ──
  epSearchEl.addEventListener('input', function() {
    var q = epSearchEl.value.toLowerCase();
    document.querySelectorAll('.pg-ep-group').forEach(function(g) {
      var vis = false;
      g.querySelectorAll('.pg-ep-item').forEach(function(item) {
        var ok = !q || (item.dataset.label || '').toLowerCase().indexOf(q) !== -1 || (item.dataset.path || '').toLowerCase().indexOf(q) !== -1;
        item.style.display = ok ? '' : 'none';
        if (ok) vis = true;
      });
      g.style.display = vis ? '' : 'none';
    });
  });

  // ── Render params ──
  function renderParams() {
    paramsList.innerHTML = '';
    var params = isCustom ? [] : (activeEP.params || []);
    if (params.length === 0) {
      noParams.style.display = 'block';
      bodySection.style.display = activeEP.method === 'POST' ? 'block' : 'none';
      return;
    }
    noParams.style.display = 'none';
    params.forEach(function(p) {
      if (p.name === 'body') return;
      var row = document.createElement('div');
      row.className = 'pg-param-row';
      var optTag = p.optional ? '<span class="pg-opt">optional</span>' : '<span class="pg-req">required</span>';
      var valHTML;
      if (p.type === 'select') {
        valHTML = '<select class="pg-param-val pg-input" data-param="' + p.name + '">' +
          (p.options || []).map(function(o) { return '<option value="' + o + '">' + (o || '—') + '</option>'; }).join('') +
          '</select>';
      } else {
        valHTML = '<input class="pg-param-val pg-input" type="text" data-param="' + p.name + '" placeholder="' + (p.placeholder || '') + '" />';
      }
      row.innerHTML =
        '<input class="pg-param-key" type="text" value="' + p.name + '" ' + (p.optional ? '' : 'data-required="true"') + ' readonly />' +
        '<span class="pg-param-eq">=</span>' +
        valHTML +
        '<button class="pg-param-del" type="button">&times;</button>';
      var delBtn = row.querySelector('.pg-param-del');
      if (delBtn) delBtn.addEventListener('click', function() { row.remove(); updateParamState(); });
      paramsList.appendChild(row);
    });
  }

  function updateParamState() {
    noParams.style.display = paramsList.querySelectorAll('.pg-param-row').length === 0 ? 'block' : 'none';
  }

  // ── Add param ──
  $i('param-add').addEventListener('click', function() {
    noParams.style.display = 'none';
    var row = document.createElement('div');
    row.className = 'pg-param-row pg-param-row--custom';
    row.innerHTML =
      '<input class="pg-param-key pg-input" type="text" placeholder="key" />' +
      '<span class="pg-param-eq">=</span>' +
      '<input class="pg-param-val pg-input" type="text" placeholder="value" />' +
      '<button class="pg-param-del" type="button">&times;</button>';
    var firstKey = row.querySelector('.pg-param-key');
    if (firstKey) { firstKey.readOnly = false; firstKey.classList.add('pg-input'); }
    row.querySelector('.pg-param-del').addEventListener('click', function() { row.remove(); updateParamState(); });
    paramsList.appendChild(row);
  });

  // ── Custom URL ──
  $i('custom-url-toggle').addEventListener('click', function() {
    isCustom = !isCustom;
    this.classList.toggle('active', isCustom);
    document.querySelectorAll('.pg-ep-item').forEach(function(el) { el.classList.remove('active'); });
    if (isCustom) {
      methodSel.disabled = false;
      urlInput.value = '/api/v1/';
      urlInput.readOnly = false;
      paramsList.innerHTML = '';
      noParams.style.display = 'block';
      bodySection.style.display = 'none';
      pgRate.style.display = 'none';
      docsEmpty.style.display = 'block';
      docsContent.style.display = 'none';
    } else {
      selectEndpoint(activeEP._idx);
    }
    updateRateUI();
  });

  // ── Build URL ──
  function buildURL() {
    var path = urlInput.value.trim();
    if (path.indexOf('/') !== 0) path = '/' + path;
    var rows = paramsList.querySelectorAll('.pg-param-row');
    var qp = [];
    rows.forEach(function(row) {
      var key = (row.querySelector('.pg-param-key') || {}).value || '';
      var val = (row.querySelector('.pg-param-val') || {}).value || '';
      if (!key) return;
      if (path.indexOf('{' + key + '}') !== -1) {
        path = path.replace('{' + key + '}', encodeURIComponent(val));
      } else if (val) {
        qp.push(encodeURIComponent(key) + '=' + encodeURIComponent(val));
      }
    });
    if (qp.length) path += '?' + qp.join('&');
    return siteUrl + path;
  }

  // ── Rate UI ──
  function updateRateUI() {
    var method = methodSel.value;
    var r = checkRate(method);
    if (rateShort) {
      rateShort.textContent = r.remaining + ' left';
      rateShort.style.color = r.blocked ? '#ef4444' : (r.count / r.limit > 0.7 ? '#f59e0b' : '');
    }
    if (r.count > 0) {
      pgRate.style.display = 'flex';
      var pct = Math.min(100, (r.count / r.limit) * 100);
      rateFill.style.width = pct + '%';
      rateFill.style.background = pct >= 90 ? '#ef4444' : pct >= 60 ? '#f59e0b' : 'var(--color-primary)';
      rateText.textContent = r.count + '/' + r.limit + ' · ' + (r.blocked ? 'blocked ' + r.waitSec + 's' : r.remaining + ' remaining');
      rateText.style.color = r.blocked ? '#ef4444' : '';
    } else {
      pgRate.style.display = 'none';
    }
    if (r.blocked) {
      pgSend.disabled = true;
      pgSendHint.textContent = 'Rate limited — retry in ' + r.waitSec + 's';
      pgSendHint.style.color = '#ef4444';
      scheduleRetry(r.waitSec);
    } else {
      pgSend.disabled = false;
      pgSendHint.textContent = '';
    }
  }

  var retryTimer = 0;
  function scheduleRetry(sec) {
    clearInterval(retryTimer);
    retryTimer = setInterval(function() {
      var r = checkRate(methodSel.value);
      if (r.blocked) {
        pgSendHint.textContent = 'Rate limited — retry in ' + r.waitSec + 's';
      } else {
        clearInterval(retryTimer);
        updateRateUI();
      }
    }, 1000);
  }

  methodSel.addEventListener('change', updateRateUI);

  // ── JSON utils ──
  function tryFormatJSON(text) {
    try { return JSON.stringify(JSON.parse(text), null, 2); } catch(e) { return null; }
  }
  function isValidJSON(text) {
    try { JSON.parse(text); return true; } catch(e) { return false; }
  }

  // ── Body buttons ──
  $i('body-format').addEventListener('click', function() {
    var f = tryFormatJSON(bodyEditor.value);
    if (f) { bodyEditor.value = f; bodyFeedback.textContent = 'Formatted'; bodyFeedback.className = 'pg-body-feedback ok'; }
    else   { bodyFeedback.textContent = 'Invalid JSON'; bodyFeedback.className = 'pg-body-feedback err'; }
    setTimeout(function() { bodyFeedback.textContent = ''; }, 2000);
  });
  $i('body-validate').addEventListener('click', function() {
    if (isValidJSON(bodyEditor.value)) { bodyFeedback.textContent = 'Valid JSON'; bodyFeedback.className = 'pg-body-feedback ok'; }
    else {
      var msg = 'Invalid JSON';
      try { JSON.parse(bodyEditor.value); } catch(e) { msg += ' — ' + e.message; }
      bodyFeedback.textContent = msg; bodyFeedback.className = 'pg-body-feedback err';
    }
    setTimeout(function() { bodyFeedback.textContent = ''; }, 3000);
  });

  // ── Highlight & escape ──
  function highlightJSON(text) {
    return text
      .replace(/("(?:[^"\\]|\\.)*")\s*:/g, '<span class="hl-key">$1</span>:')
      .replace(/"((?:[^"\\]|\\.)*)"/g, '<span class="hl-str">"$1"</span>')
      .replace(/\b(true|false|null)\b/g, '<span class="hl-bool">$1</span>')
      .replace(/:\s*(-?\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)/g, ': <span class="hl-num">$1</span>');
  }
  function highlightCSS(text) {
    return text
      .replace(/(\/\*[\s\S]*?\*\/)/g, '<span class="hl-comment">$1</span>')
      .replace(/(@[a-z-]+)/g, '<span class="hl-atrule">$1</span>')
      .replace(/([a-z-]+)\s*:/g, '<span class="hl-prop">$1</span>:')
      .replace(/:\s*([^;{]+)/g, ': <span class="hl-val">$1</span>')
      .replace(/(--[\w-]+)/g, '<span class="hl-var">$1</span>');
  }
  function formatBody(text, ct) {
    if (ct.indexOf('application/json') !== -1 || ct.indexOf('+json') !== -1) {
      try { return highlightJSON(JSON.stringify(JSON.parse(text), null, 2)); } catch(e) { return esc(text); }
    }
    if (ct.indexOf('text/css') !== -1) return highlightCSS(text);
    if (ct.indexOf('text/html') !== -1) return esc(text);
    try { return highlightJSON(JSON.stringify(JSON.parse(text), null, 2)); } catch(e) { return esc(text); }
  }
  function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // ── Send ──
  function doSend() {
    var method = methodSel.value;
    var r = checkRate(method);
    if (r.blocked) {
      pgSendHint.textContent = 'Rate limited — retry in ' + r.waitSec + 's';
      pgSendHint.style.color = '#ef4444';
      return;
    }
    var url = buildURL();
    hideAllRes();
    pgLoading.style.display = 'flex';
    pgSend.disabled = true;
    pgSendLabel.textContent = 'Sending...';
    pgSendHint.textContent = '';
    var t0 = performance.now();
    fetch(url, {
      method: method,
      headers: method === 'POST' && bodyEditor.value.trim() ? { 'Content-Type': 'application/json' } : {},
      body: method === 'POST' && bodyEditor.value.trim() ? bodyEditor.value.trim() : undefined
    }).then(function(res) {
      var elapsed = Math.round(performance.now() - t0);
      recordHit(method);
      var hdrRows = [];
      var hdrNum = 0;
      res.headers.forEach(function(v, k) { hdrRows.push('<tr><td class="pg-hdr-key">' + esc(k) + '</td><td class="pg-hdr-val">' + esc(v) + '</td></tr>'); hdrNum++; });
      resHeaders.innerHTML = hdrRows.join('');
      hdrCount.textContent = '(' + hdrNum + ')';
      return res.text().then(function(text) {
        lastResCT = res.headers.get('content-type') || '';
        lastResBody = text;
        resBody.innerHTML = formatBody(text, lastResCT);
        var cls = res.ok ? 'pg-res-status--ok' : 'pg-res-status--err';
        resStatus.className = 'pg-res-status ' + cls;
        resStatus.textContent = res.status + ' ' + res.statusText;
        resTime.textContent = elapsed + 'ms';
        hideAllRes();
        resMeta.style.display = 'flex';
        resContent.style.display = 'flex';
        resHeadersBlock.setAttribute('open', '');
        saveHistory({ method: method, url: url.replace(siteUrl, ''), status: res.status, elapsed: elapsed, ts: Date.now(), endpoint: isCustom ? null : activeEP.label });
        if (window.innerWidth < 1150) resPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }).catch(function(err) {
      hideAllRes();
      pgError.style.display = 'flex';
      pgErrorTitle.textContent = 'Network Error';
      pgErrorMsg.textContent = err.message || 'Failed to connect.';
    }).then(function() {
      pgSend.disabled = false;
      pgSendLabel.textContent = 'Send';
      updateRateUI();
    });
  }

  window.__doSend = doSend;

  function hideAllRes() {
    pgEmptyEl.style.display = 'none';
    pgLoading.style.display = 'none';
    pgError.style.display = 'none';
    resContent.style.display = 'none';
    resMeta.style.display = 'none';
  }

  // Keyboard
  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); doSend(); }
  });

  // ── Copy ──
  resCopy.addEventListener('click', function() {
    try { navigator.clipboard.writeText(lastResBody); } catch(e) {}
    try { var ta = document.createElement('textarea'); ta.value = lastResBody; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); } catch(e) {}
    resCopy.textContent = 'Copied!';
    resCopy.classList.add('copied');
    setTimeout(function() { resCopy.textContent = 'Copy'; resCopy.classList.remove('copied'); }, 1500);
  });

  // ── Maximize ──
  $i('res-maximize').addEventListener('click', function() {
    maxed = !maxed;
    var shell = $('.pg-shell');
    if (maxed) {
      sidebarEl.style.display = 'none';
      $('.pg-main').style.display = 'none';
      resPanel.style.gridColumn = 'span 3';
    } else {
      sidebarEl.style.display = '';
      $('.pg-main').style.display = '';
      resPanel.style.gridColumn = '';
    }
  });

  // ── Mobile sidebar toggle ──
  mobileToggle.addEventListener('click', function() {
    sidebarEl.classList.toggle('open');
  });

  // Close sidebar when clicking outside on mobile
  document.addEventListener('click', function(e) {
    if (window.innerWidth >= 1150) return;
    if (!sidebarEl.contains(e.target) && e.target !== mobileToggle && !mobileToggle.contains(e.target)) {
      sidebarEl.classList.remove('open');
    }
  });

  // ── History render ──
  function renderHistory() {
    var h = getHistory();
    if (h.length === 0) { historySection.style.display = 'none'; return; }
    historySection.style.display = 'block';
    historyList.innerHTML = h.map(function(entry, i) {
      return '<button class="pg-history-item" data-idx="' + i + '" type="button">' +
        '<span class="pg-history-method pg-ep-method--' + entry.method.toLowerCase() + '">' + entry.method + '</span>' +
        '<span class="pg-history-status' + (entry.status >= 400 ? ' pg-history-status--err' : '') + '">' + entry.status + '</span>' +
        '<span class="pg-history-url" title="' + esc(entry.url) + '">' + esc(entry.endpoint || entry.url.slice(0, 35)) + '</span>' +
        '<span class="pg-history-time">' + entry.elapsed + 'ms</span>' +
      '</button>';
    }).join('');
    historyList.querySelectorAll('.pg-history-item').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var entry = h[parseInt(this.dataset.idx)];
        if (!entry) return;
        if (entry.endpoint && !isCustom) {
          var ep = FLAT.find(function(e) { return e.label === entry.endpoint; });
          if (ep) selectEndpoint(ep._idx);
        }
        urlInput.value = entry.url;
        methodSel.value = entry.method;
        updateRateUI();
        pgSend.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    });
  }

  $i('history-clear').addEventListener('click', function() {
    sessionStorage.removeItem(HIST_KEY);
    renderHistory();
  });

  // ── Init ──
  highlightSidebar();
  updateRateUI();
  renderHistory();
  showDocs(activeEP);
</script>

<style>
  /* ============================================
     API PLAYGROUND — ENTERPRISE CONSOLE v3
     ============================================ */
  .pg-topbar {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 16px; gap: 16px; flex-wrap: wrap;
  }
  .pg-topbar__actions { display: flex; align-items: center; gap: 10px; margin-top: 6px; }
  .pg-topbar__hint {
    display: flex; align-items: center; gap: 5px;
    font-size: 10px; color: var(--color-text-muted);
  }
  .pg-topbar__hint kbd {
    display: inline-block;
    padding: 2px 6px; border-radius: 4px;
    font-size: 9px; font-weight: 600; font-family: "JetBrains Mono", monospace;
    background: color-mix(in srgb, var(--color-text-muted) 10%, transparent);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .pg-mobile-toggle {
    display: none;
    width: 36px; height: 36px; border-radius: 8px;
    border: 1.5px solid var(--color-border);
    background: transparent; color: var(--color-text);
    cursor: pointer; align-items: center; justify-content: center;
  }
  @media (max-width: 1150px) {
    .pg-mobile-toggle { display: flex; }
  }

  /* ── Shell ── */
  .pg-shell {
    display: grid;
    grid-template-columns: 260px 1fr 1fr;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-surface) 40%, transparent);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    min-height: calc(100vh - 160px);
  }
  @media (max-width: 1150px) {
    .pg-shell { grid-template-columns: 1fr; }
    .pg-sidebar {
      display: none;
      position: fixed; top: 0; left: 0; bottom: 0;
      width: 280px; z-index: 500;
      border-right: 1px solid var(--color-border);
      box-shadow: 8px 0 32px rgba(0,0,0,0.3);
      overflow-y: auto;
    }
    .pg-sidebar.open { display: flex; }
    .pg-response { min-height: 55vh; }
    .pg-topbar__hint { display: none; }
  }

  /* ── Sidebar ── */
  .pg-sidebar {
    border-right: 1px solid var(--color-border);
    display: flex; flex-direction: column;
    background: color-mix(in srgb, var(--color-bg) 35%, transparent);
    overflow: hidden;
  }
  .pg-sidebar__section {
    padding: 12px;
    display: flex; flex-direction: column;
    overflow: hidden;
  }
  .pg-sidebar__section:first-child { flex: 1; min-height: 0; }
  .pg-sidebar__label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--color-text-muted);
    margin-bottom: 6px;
    display: flex; align-items: center; justify-content: space-between;
  }

  .pg-search { position: relative; margin-bottom: 6px; }
  .pg-search__icon {
    position: absolute; left: 9px; top: 50%; transform: translateY(-50%);
    color: var(--color-text-muted); pointer-events: none;
  }
  .pg-search__input {
    width: 100%; height: 32px; padding: 0 8px 0 28px;
    border-radius: 7px; border: 1.5px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 50%, transparent);
    color: var(--color-text); font-size: 11px;
    font-family: "Inter", sans-serif;
    outline: none; transition: border-color 0.2s;
  }
  .pg-search__input:focus { border-color: var(--color-primary); }
  .pg-search__input::placeholder { color: var(--color-text-muted); opacity: 0.5; }

  .pg-ep-list { overflow-y: auto; flex: 1; min-height: 0; }
  .pg-ep-group { margin-bottom: 1px; }
  .pg-ep-group__name {
    font-size: 9px; font-weight: 700; letter-spacing: 0.07em;
    text-transform: uppercase; color: var(--color-primary);
    padding: 8px 8px 3px;
  }
  .pg-ep-item {
    display: flex; align-items: center; gap: 7px;
    width: 100%; padding: 6px 8px;
    border: none; border-radius: 6px;
    background: transparent; color: var(--color-text-muted);
    font-size: 11px; font-family: "Inter", sans-serif;
    cursor: pointer; transition: all 0.12s;
    text-align: left;
  }
  .pg-ep-item:hover { background: color-mix(in srgb, var(--color-primary) 8%, transparent); color: var(--color-text); }
  .pg-ep-item.active {

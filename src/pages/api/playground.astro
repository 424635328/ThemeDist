  /* ====== RESPONSE COLUMN ====== */
  .response-col { display: flex; flex-direction: column; overflow: hidden; min-height: 0; background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radii-lg); box-shadow: 0 8px 32px rgba(0,0,0,0.05); }

  /* Response Tabs */
  .res-tabs { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border-subtle); padding: 0 16px; background: var(--bg-surface); flex-shrink: 0; }
  .res-tabs-nav { display: flex; position: relative; }
  .res-tab { padding: 14px 20px; background: transparent; border: none; color: var(--text-muted); font-size: 13px; font-weight: 500; cursor: pointer; transition: color 0.2s; position: relative; z-index: 1; }
  .res-tab:hover { color: var(--text-primary); }
  .res-tab.active { color: var(--accent); }
  .tab-indicator { position: absolute; bottom: 0; left: 0; height: 2px; width: 0; background: var(--accent); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 2px 2px 0 0; }
  
  .res-tab-btn { padding: 6px; background: transparent; border: none; color: var(--text-muted); cursor: pointer; border-radius: 4px; transition: all 0.2s; display: flex; align-items: center; }
  .res-tab-btn:hover { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 10%, transparent); }

  /* ====== RESPONSE BOX ====== */
  .response-box { flex: 1; min-height: 0; display: flex; flex-direction: column; overflow: hidden; }
  .res-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-bottom: 1px solid var(--border-subtle); background: var(--bg-surface); flex-shrink: 0; }
  .res-status-wrap { display: flex; align-items: center; gap: 16px; }
  .status-code { font-family: var(--font-mono); font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 6px; }
  .status-code.ok { color: var(--accent-green); background: color-mix(in srgb, var(--accent-green) 12%, transparent); }
  .status-code.err { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 12%, transparent); }
  .res-time, .res-size { font-family: var(--font-mono); font-size: 12px; font-weight: 500; }
  .res-time.fast { color: var(--accent-green); }
  .res-time.medium { color: var(--accent-orange); }
  .res-time.slow { color: var(--accent-red); }
  .res-size { color: var(--text-muted); }

  .btn-icon { width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; color: var(--text-muted); border-radius: 6px; cursor: pointer; transition: all 0.2s; flex-shrink: 0; }
  .btn-icon:hover { background: var(--bg-elevated); color: var(--text-primary); }

  .res-content-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0; position: relative; }

  .loader-pulse { width: 40px; height: 40px; border-radius: 50%; background: color-mix(in srgb, var(--accent) 20%, transparent); animation: pulse 1.5s infinite cubic-bezier(0.4, 0, 0.2, 1); margin-bottom: 16px; border: 2px solid var(--accent); }
  @keyframes pulse { 0% { transform: scale(0.8); opacity: 1; } 100% { transform: scale(1.5); opacity: 0; } }
  .loading-text { color: var(--text-primary); font-size: 14px; font-weight: 500; }
  .loading-url { color: var(--text-muted); font-size: 11px; margin-top: 6px; font-family: var(--font-mono); max-width: 80%; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .error-state { padding: 24px; background: color-mix(in srgb, var(--accent-red) 5%, transparent); border-bottom: 1px solid color-mix(in srgb, var(--accent-red) 15%, transparent); }
  .error-header { display: flex; align-items: center; gap: 8px; color: var(--accent-red); margin-bottom: 8px; }
  .error-desc { font-size: 13px; color: var(--text-secondary); font-family: var(--font-mono); }

  .res-headers { background: var(--bg-surface); border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; }
  .res-headers summary { padding: 10px 16px; font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); cursor: pointer; list-style: none; user-select: none; display: flex; align-items: center; }
  .res-headers summary::-webkit-details-marker { display: none; }
  .res-headers summary::before { content: "вЦЄ"; display: inline-block; width: 16px; transition: transform 0.2s; }
  .res-headers[open] summary::before { transform: rotate(90deg); }
  
  .res-headers-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 11.5px; }
  .res-headers-table td { padding: 6px 16px; border-top: 1px solid var(--border-subtle); color: var(--text-secondary); }
  .res-headers-table td:first-child { color: var(--text-primary); font-weight: 500; width: 30%; }

  .fill-block { flex: 1; margin: 0; padding: 16px; background: transparent; border: none; overflow-y: auto; color: var(--text-secondary); font-family: var(--font-mono); font-size: 13px; line-height: 1.6; white-space: pre-wrap; word-break: break-all; min-height: 0; }
  .fill-block::-webkit-scrollbar { width: 6px; height: 6px; }
  .fill-block::-webkit-scrollbar-track { background: transparent; }
  .fill-block::-webkit-scrollbar-thumb { background: var(--border-subtle); border-radius: 6px; }

  .res-preview { padding: 32px; display: flex; justify-content: center; align-items: center; background: repeating-conic-gradient(var(--bg-surface) 0% 25%, transparent 0% 50%) 50% / 20px 20px; border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; min-height: 200px; }
  .res-preview img { max-width: 100%; max-height: 400px; border-radius: var(--radii); box-shadow: 0 8px 32px rgba(0,0,0,0.4); border: 1px solid var(--border-subtle); }

  /* Syntax Highlighting - Dark Mode Optimized */
  .hl-key { color: color-mix(in srgb, var(--accent) 70%, #a5b4fc); font-weight: 500; }
  .hl-str { color: var(--accent-green, #34d399); }
  .hl-num { color: var(--accent-orange, #fbbf24); }
  .hl-bool { color: var(--accent-blue, #60a5fa); font-weight: 500; }
  .hl-null { color: var(--text-muted); font-style: italic; }

  /* ====== HISTORY PANEL ====== */
  .history-panel { flex: 1; min-height: 0; overflow-y: auto; display: flex; flex-direction: column; background: var(--bg-elevated); }
  .history-panel::-webkit-scrollbar { width: 4px; }
  .history-panel::-webkit-scrollbar-thumb { background: var(--border-subtle); border-radius: 4px; }

  .history-list { display: flex; flex-direction: column; }
  .history-item { display: flex; align-items: center; gap: 14px; padding: 14px 16px; border-bottom: 1px solid var(--border-subtle); cursor: pointer; transition: all 0.2s; border-left: 3px solid transparent; }
  .history-item:hover { background: var(--bg-surface); border-left-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  .history-item:last-child { border-bottom: none; }

  .history-item-status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; background: var(--accent-green); box-shadow: 0 0 8px var(--accent-green); }
  .history-item-status-dot.err { background: var(--accent-red); box-shadow: 0 0 8px var(--accent-red); }

  .history-item-method { font-family: var(--font-mono); font-size: 10px; font-weight: 700; padding: 4px 8px; border-radius: 4px; min-width: 44px; text-align: center; flex-shrink: 0; letter-spacing: 0.02em; }
  .history-item-method.GET { color: var(--accent-green); background: color-mix(in srgb, var(--accent-green) 15%, transparent); }
  .history-item-method.POST { color: var(--accent-blue); background: color-mix(in srgb, var(--accent-blue) 15%, transparent); }

  .history-item-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
  .history-item-path { font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .history-item-meta { display: flex; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }
  .history-item-status-code { font-weight: 600; }
  .history-item-status-code.ok { color: var(--accent-green); }
  .history-item-status-code.err { color: var(--accent-red); }

  .history-item-actions { display: flex; gap: 6px; flex-shrink: 0; opacity: 0; transition: opacity 0.2s; }
  .history-item:hover .history-item-actions { opacity: 1; }
  
  .history-item-action { display: flex; align-items: center; gap: 4px; padding: 6px 10px; background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 6px; color: var(--text-secondary); font-size: 11px; font-weight: 500; cursor: pointer; transition: all 0.2s; }
  .history-item-action:hover { background: var(--bg-surface); color: var(--text-primary); border-color: var(--text-muted); }
  .history-item-action.delete:hover { color: var(--accent-red); border-color: color-mix(in srgb, var(--accent-red) 30%, transparent); background: color-mix(in srgb, var(--accent-red) 10%, transparent); }
</style>

<script define:vars={{ siteUrl, flatJSON }}>
  window.__SITE_URL__ = siteUrl;
  window.__FLAT_JSON__ = flatJSON;
</script>

<script>
  (function() {
    var siteUrl = window.__SITE_URL__;
    var FLAT = JSON.parse(window.__FLAT_JSON__);
    var activeEP = FLAT[0];
    var isCustom = false;
    var lastResBody = '';

    // вФАвФА Debounce & Quota вФАвФА
    var lastRequestTime = 0;
    var DEBOUNCE_MS = 500;
    var DAILY_LIMIT = 100;
    var dailyCount = 0;

    function loadDailyCount() {
      try {
        var data = JSON.parse(localStorage.getItem('pg-daily') || '{}');
        var today = new Date().toISOString().slice(0, 10);
        dailyCount = (data.date === today) ? (data.count || 0) : 0;
      } catch(e) { dailyCount = 0; }
    }

    function incrementDailyCount() {
      dailyCount++;
      var today = new Date().toISOString().slice(0, 10);
      try { localStorage.setItem('pg-daily', JSON.stringify({ date: today, count: dailyCount })); } catch(e) {}
      updateQuotaHint();
      return dailyCount;
    }

    function updateQuotaHint() {
      var hint = getEl('pg-send-hint');
      var remaining = DAILY_LIMIT - dailyCount;
      if (remaining <= 15) {
        hint.style.color = remaining <= 5 ? 'var(--accent-red)' : 'var(--accent-orange)';
        hint.textContent = 'Daily quota: ' + dailyCount + '/' + DAILY_LIMIT + ' (' + remaining + ' left)';
      } else {
        hint.textContent = '';
      }
    }

    // вФАвФА Cache вФАвФА
    var responseCache = new Map();
    var CACHE_TTL = 5 * 60 * 1000;

    function getCached(method, url) {
      var key = method + '::' + url;
      var entry = responseCache.get(key);
      if (!entry) return null;
      if (Date.now() - entry.time > CACHE_TTL) { responseCache.delete(key); return null; }
      return entry.data;
    }

    function setCached(method, url, data) {
      var key = method + '::' + url;
      if (responseCache.size >= 50) responseCache.delete(responseCache.keys().next().value);
      responseCache.set(key, { time: Date.now(), data: data });
    }

    // вФАвФА History вФАвФА
    var HISTORY_KEY = 'pg-history';
    var HISTORY_MAX = 30;
    var historyEntries = [];

    function loadHistory() {
      try { var raw = localStorage.getItem(HISTORY_KEY); historyEntries = raw ? JSON.parse(raw) : []; } catch(e) { historyEntries = []; }
    }
    function persistHistory() {
      try { localStorage.setItem(HISTORY_KEY, JSON.stringify(historyEntries)); } catch(e) {}
    }
    function addHistoryEntry(entry) {
      historyEntries.unshift(entry);
      if (historyEntries.length > HISTORY_MAX) historyEntries = historyEntries.slice(0, HISTORY_MAX);
      persistHistory();
    }
    window.__deleteHistoryEntry = function(id) {
      historyEntries = historyEntries.filter(function(e) { return e.id !== id; });
      persistHistory(); renderHistoryPanel();
    }
    window.__rerunHistoryEntry = function(id) {
      var entry = historyEntries.find(function(e) { return e.id === id; });
      if (!entry) return;
      switchTab('response');
      getEl('method-select').value = entry.method;
      getEl('url-input').value = entry.path;
      syncURLPrefix();
      doSend();
    }
    window.__viewHistoryResponse = function(id) {
      var entry = historyEntries.find(function(e) { return e.id === id; });
      if (!entry) return;
      switchTab('response');
      
      getEl('pg-empty').style.display = 'none';
      getEl('pg-loading').style.display = 'none';
      getEl('pg-error').style.display = 'none';
      getEl('res-content').style.display = 'flex';
      getEl('res-toolbar').style.display = 'flex';

      getEl('res-status').className = 'status-code ' + (entry.status < 400 ? 'ok' : 'err');
      getEl('res-status').textContent = entry.status + ' ' + entry.statusText;
      getEl('res-time').textContent = formatDuration(entry.duration);
      getEl('res-time').className = 'res-time ' + durationClass(entry.duration);
      getEl('res-size').textContent = formatBytes(entry.size);

      lastResBody = entry.responseBody;
      var isImg = entry.contentType && entry.contentType.includes('image/');
      
      if (isImg) {
        getEl('res-preview').style.display = 'flex';
        getEl('res-preview').innerHTML = '<span style="color:var(--text-muted);font-size:12px;">Image preview not available in history</span>';
        getEl('res-body').innerHTML = esc(entry.responseBody);
      } else {
        getEl('res-preview').style.display = 'none';
        var formatted = esc(entry.responseBody);
        if (entry.contentType && entry.contentType.includes('json')) {
          try { formatted = hlJSON(JSON.stringify(JSON.parse(entry.responseBody), null, 2)); } catch(e) {}
        }
        getEl('res-body').innerHTML = formatted;
      }
      
      getEl('res-headers').innerHTML = '<tr><td colspan="2" style="text-align:center;font-style:italic;">Headers not stored in history</td></tr>';
      getEl('hdr-count').textContent = '0';
    }

    // вФАвФА Helpers вФАвФА
    function formatBytes(b) { if(b<1024)return b+' B'; if(b<1048576)return(b/1024).toFixed(1)+' KB'; return(b/1048576).toFixed(2)+' MB'; }
    function formatDuration(ms) { if(ms<1000)return ms+'ms'; return (ms/1000).toFixed(2)+'s'; }
    function durationClass(ms) { if(ms<200)return 'fast'; if(ms<800)return 'medium'; return 'slow'; }
    function formatTimestamp(ts) {
      var d = Date.now() - ts;
      if (d < 60000) return 'just now';
      if (d < 3600000) return Math.floor(d/60000) + 'm ago';
      if (d < 86400000) return Math.floor(d/3600000) + 'h ago';
      return Math.floor(d/86400000) + 'd ago';
    }
    function getEl(s) { return document.getElementById(s); }
    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    // Enhanced JSON syntax highlighter
    function hlJSON(json) {
      json = esc(json);
      return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
        var cls = 'hl-num';
        if (/^"/.test(match)) {
          if (/:$/.test(match)) cls = 'hl-key';
          else cls = 'hl-str';
        } else if (/true|false/.test(match)) {
          cls = 'hl-bool';
        } else if (/null/.test(match)) {
          cls = 'hl-null';
        }
        return '<span class="' + cls + '">' + match + '</span>';
      });
    }

    // вФАвФА URL Sync вФАвФА
    function syncURLPrefix() {
      var path = getEl('url-input').value.trim();
      var isAbs = path.startsWith('http://') || path.startsWith('https://');
      getEl('url-prefix').style.display = isAbs ? 'none' : 'inline-block';
    }
    getEl('url-input').addEventListener('input', syncURLPrefix);

    // вФАвФА UI Rendering вФАвФА
    function showDocs(ep) {
      getEl('docs-title').textContent = ep.label || 'Custom Request';
      getEl('docs-desc').textContent = ep.desc || 'Send a custom API request and explore the response.';
      getEl('docs-desc-card').textContent = ep.desc || 'No specific description provided.';
      getEl('docs-usage').textContent = ep.usage || 'N/A';
      getEl('docs-cache').textContent = ep.cache || 'No Cache';
      getEl('docs-curl').textContent = ep.curlExample || ('curl ' + siteUrl + (ep.path || '/'));

      var notesEl = getEl('docs-notes');
      if (ep.notes) { notesEl.innerHTML = '<strong>Notes:</strong> ' + ep.notes; notesEl.style.display = 'block'; } 
      else { notesEl.style.display = 'none'; }

      var fieldsEl = getEl('docs-fields');
      var fieldsTable = getEl('docs-fields-table');
      if (ep.responseFields && ep.responseFields.length) {
        fieldsTable.innerHTML = ep.responseFields.map(f =>
          '<tr><td>' + esc(f.name) + '<br><span style="color:var(--text-muted);font-size:10px;font-weight:400;">' + esc(f.type) + '</span></td><td>' + esc(f.desc) + '</td></tr>'
        ).join('');
        fieldsEl.style.display = 'block';
      } else {
        fieldsEl.style.display = 'none';
      }
    }

    getEl('copy-curl-btn').addEventListener('click', function() {
      var curlCode = getEl('docs-curl').textContent;
      navigator.clipboard.writeText(curlCode).then(function() {
        var btn = getEl('copy-curl-btn');
        btn.classList.add('copied');
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
        setTimeout(function() { 
          btn.classList.remove('copied'); 
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
        }, 1500);
      });
    });

    window.__selectEndpoint = function(idx) {
      isCustom = false;
      getEl('custom-url-toggle').classList.remove('active');
      activeEP = FLAT[idx];

      getEl('method-select').value = activeEP.method;
      getEl('url-input').value = activeEP.path;
      syncURLPrefix();

      renderParams();
      highlightSidebar();
      showDocs(activeEP);

      getEl('body-section').style.display = ['POST','PUT','PATCH'].includes(activeEP.method) ? 'block' : 'none';
      if (activeEP.method === 'POST') {
        var bp = (activeEP.params || []).find(p => p.name === 'body');
        if (bp) getEl('body-editor').value = bp.placeholder || '';
        else getEl('body-editor').value = '';
      }

      resetResponseView();
    }

    function resetResponseView() {
      getEl('pg-empty').style.display = 'flex';
      getEl('pg-loading').style.display = 'none';
      getEl('pg-error').style.display = 'none';
      getEl('res-content').style.display = 'none';
      getEl('res-toolbar').style.display = 'none';
      switchTab('response');
    }

    function highlightSidebar() {
      document.querySelectorAll('.nav-item').forEach(el => {
        el.classList.toggle('active', el.getAttribute('data-idx') === String(activeEP._idx));
      });
    }

    function renderParams() {
      var list = getEl('params-list');
      list.innerHTML = '';
      var params = isCustom ? [] : (activeEP.params || []);

      if (params.length === 0 || (params.length === 1 && params[0].name === 'body')) {
        getEl('no-params').style.display = 'flex';
        list.style.display = 'none';
        return;
      }

      getEl('no-params').style.display = 'none';
      list.style.display = 'flex';

      params.forEach(p => {
        if (p.name === 'body') return;
        var row = document.createElement('div');
        row.className = 'param-row';
        var valHTML = p.type === 'select'
          ? '<select class="param-val-sel" data-param="' + p.name + '">' + (p.options||[]).map(o => '<option value="' + o + '">' + (o||'вАФ') + '</option>').join('') + '</select>'
          : '<input class="param-val" type="text" data-param="' + p.name + '" placeholder="' + (p.placeholder||'') + '" />';

        row.innerHTML =
          '<input class="param-key" type="text" value="' + p.name + '" placeholder="Key" readonly />' +
          '<span class="param-eq">=</span>' +
          valHTML +
          '<button class="param-del" title="Clear">' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
          '</button>';
        row.querySelector('.param-del').addEventListener('click', function() {
          var input = row.querySelector('.param-val, .param-val-sel');
          if (input) { if (input.tagName === 'SELECT') input.selectedIndex = 0; else input.value = ''; }
        });
        list.appendChild(row);
      });
    }

    getEl('param-add').addEventListener('click', function() {
      getEl('no-params').style.display = 'none';
      getEl('params-list').style.display = 'flex';
      var row = document.createElement('div');
      row.className = 'param-row';
      row.innerHTML =
        '<input class="param-key" type="text" placeholder="Key" />' +
        '<span class="param-eq">=</span>' +
        '<input class="param-val" type="text" placeholder="Value" />' +
        '<button class="param-del" title="Remove">' +
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
        '</button>';
      row.querySelector('.param-del').addEventListener('click', function() {
        row.remove();
        if(getEl('params-list').children.length===0) {
          getEl('no-params').style.display = 'flex';
          getEl('params-list').style.display = 'none';
        }
      });
      getEl('params-list').appendChild(row);
    });

    getEl('custom-url-toggle').addEventListener('click', function() {
      isCustom = true;
      document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
      this.classList.add('active');

      getEl('url-input').value = '/api/v1/';
      syncURLPrefix();
      getEl('params-list').innerHTML = '';
      getEl('no-params').style.display = 'flex';
      getEl('params-list').style.display = 'none';
      getEl('body-section').style.display = ['POST','PUT','PATCH'].includes(getEl('method-select').value) ? 'block' : 'none';
      showDocs({ label: 'Custom Request', method: 'GET', path: '/api/v1/' });
      resetResponseView();
    });

    getEl('method-select').addEventListener('change', function() {
      getEl('body-section').style.display = ['POST','PUT','PATCH'].includes(this.value) ? 'block' : 'none';
    });

    function buildURL() {
      var path = getEl('url-input').value.trim();
      var isAbs = path.startsWith('http://') || path.startsWith('https://');
      if (!isAbs && path.charAt(0) !== '/') path = '/' + path;

      var rows = getEl('params-list').querySelectorAll('.param-row');
      var qp = [];
      rows.forEach(row => {
        var keyInput = row.querySelector('.param-key');
        var valInput = row.querySelector('.param-val, .param-val-sel');
        var key = keyInput ? keyInput.value.trim() : '';
        var val = valInput ? valInput.value.trim() : '';

        if (!key) return;
        if (path.includes('{' + key + '}')) {
          path = path.replace('{' + key + '}', encodeURIComponent(val));
        } else if (val) {
          qp.push(encodeURIComponent(key) + '=' + encodeURIComponent(val));
        }
      });

      path = path.replace(/\{[^}]+\}/g, '');
      if (qp.length) path += (path.includes('?') ? '&' : '?') + qp.join('&');
      return isAbs ? path : siteUrl + path;
    }

    getEl('body-format').addEventListener('click', function() {
      var fb = getEl('body-feedback');
      try {
        var val = getEl('body-editor').value;
        if (!val.trim()) return;
        getEl('body-editor').value = JSON.stringify(JSON.parse(val), null, 2);
        fb.textContent = 'JSON Formatted successfully';
        fb.className = 'feedback ok';
      } catch(e) {
        fb.textContent = 'Invalid JSON structure';
        fb.className = 'feedback err';
      }
      setTimeout(() => fb.textContent = '', 2500);
    });

    // вФАвФА Tabs вФАвФА
    function updateTabIndicator(tabEl) {
      var indicator = document.querySelector('.tab-indicator');
      if (indicator && tabEl) {
        indicator.style.width = tabEl.offsetWidth + 'px';
        indicator.style.transform = 'translateX(' + tabEl.offsetLeft + 'px)';
      }
    }
    function switchTab(tabName) {
      document.querySelectorAll('.res-tab').forEach(t => {
        if (t.getAttribute('data-tab') === tabName) { t.classList.add('active'); updateTabIndicator(t); }
        else t.classList.remove('active');
      });
      getEl('response-box').style.display = tabName === 'response' ? 'flex' : 'none';
      getEl('history-panel').style.display = tabName === 'history' ? 'flex' : 'none';
    }
    document.querySelectorAll('.res-tab').forEach(tab => {
      tab.addEventListener('click', function() { switchTab(this.getAttribute('data-tab')); });
    });
    
    // Initialize indicator position
    setTimeout(() => updateTabIndicator(document.querySelector('.res-tab.active')), 100);
    window.addEventListener('resize', () => updateTabIndicator(document.querySelector('.res-tab.active')));

    getEl('history-clear').addEventListener('click', function() {
      if (confirm('Clear all request history?')) {
        historyEntries = [];
        persistHistory();
        renderHistoryPanel();
      }
    });

    function renderHistoryPanel() {
      var list = getEl('history-list');
      var empty = getEl('history-empty');
      var clearBtn = getEl('history-clear');

      if (historyEntries.length === 0) {
        list.innerHTML = '';
        empty.style.display = 'flex';
        clearBtn.style.display = 'none';
        return;
      }
      empty.style.display = 'none';
      clearBtn.style.display = 'block';

      list.innerHTML = historyEntries.map(e => {
        var ok = e.status < 400;
        return '<div class="history-item" onclick="window.__viewHistoryResponse(\'' + e.id + '\')">' +
          '<span class="history-item-status-dot' + (ok ? '' : ' err') + '"></span>' +
          '<span class="history-item-method ' + e.method + '">' + e.method + '</span>' +
          '<div class="history-item-body">' +
            '<span class="history-item-path" title="' + esc(e.path) + '">' + esc(e.path) + '</span>' +
            '<div class="history-item-meta">' +
              '<span class="history-item-status-code ' + (ok ? 'ok' : 'err') + '">' + e.status + '</span>' +
              '<span>' + formatDuration(e.duration) + '</span>' +
              '<span>' + formatBytes(e.size) + '</span>' +
              '<span>&middot; ' + formatTimestamp(e.timestamp) + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="history-item-actions" onclick="event.stopPropagation()">' +
            '<button class="history-item-action" onclick="window.__rerunHistoryEntry(\'' + e.id + '\')">Re-run</button>' +
            '<button class="history-item-action delete" title="Delete" onclick="window.__deleteHistoryEntry(\'' + e.id + '\')"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg></button>' +
          '</div>' +
        '</div>';
      }).join('');
    }

    // вФАвФА Execute Logic вФАвФА
    window.__doSend = function() {
      var now = Date.now();
      if (now - lastRequestTime < DEBOUNCE_MS) return;
      lastRequestTime = now;

      if (dailyCount >= DAILY_LIMIT) {
        showError('Daily request limit reached (' + DAILY_LIMIT + '/' + DAILY_LIMIT + '). Try again tomorrow.');
        return;
      }

      var m = getEl('method-select').value;
      var url = buildURL();

      // Check cache
      if (m === 'GET') {
        var cached = getCached(m, url);
        if (cached) { displayResponse(cached, true); return; }
      }

      getEl('pg-empty').style.display = 'none';
      getEl('res-content').style.display = 'none';
      getEl('res-toolbar').style.display = 'none';
      getEl('pg-error').style.display = 'none';
      getEl('pg-loading').style.display = 'flex';
      getEl('pg-loading-url').textContent = m + ' ' + url;
      getEl('pg-send').disabled = true;

      var t0 = performance.now();
      var bodyVal = getEl('body-editor').value.trim();
      var headers = {};
      if (['POST','PUT','PATCH'].includes(m) && bodyVal) headers['Content-Type'] = 'application/json';

      fetch(url, { method: m, headers: headers, body: ['POST','PUT','PATCH'].includes(m) && bodyVal ? bodyVal : undefined })
      .then(res => {
        var elapsed = Math.round(performance.now() - t0);
        var ct = res.headers.get('content-type') || '';
        
        // Render headers
        var hdrRows = '', hdrNum = 0;
        res.headers.forEach((v, k) => { hdrRows += '<tr><td>' + esc(k) + '</td><td>' + esc(v) + '</td></tr>'; hdrNum++; });
        getEl('res-headers').innerHTML = hdrRows;
        getEl('hdr-count').textContent = hdrNum;

        return res.blob().then(blob => ({ res, ct, blob, elapsed }));
      })
      .then(data => {
        var isImg = data.ct.includes('image/');
        var payload = {
          status: data.res.status,
          statusText: data.res.statusText,
          elapsed: data.elapsed,
          bodySize: data.blob.size,
          contentType: data.ct,
          ok: data.res.ok,
          isImage: isImg
        };

        if (isImg) {
          payload.objectUrl = URL.createObjectURL(data.blob);
          payload.text = 'Binary Blob (' + data.blob.size + ' bytes)';
          finalize(payload, m, url);
        } else {
          data.blob.text().then(txt => {
            payload.text = txt;
            finalize(payload, m, url);
          });
        }
      })
      .catch(err => {
        showError(err.message || 'Failed to connect. The server might be down or blocked by CORS.');
      })
      .finally(() => { getEl('pg-send').disabled = false; });
    };

    function finalize(data, m, url) {
      if (m === 'GET' && data.ok && !data.isImage) {
        setCached(m, url, data);
      }
      displayResponse(data, false);
      incrementDailyCount();

      addHistoryEntry({
        id: Date.now().toString(36) + Math.random().toString(36).slice(2, 7),
        timestamp: Date.now(),
        method: m,
        path: getEl('url-input').value.trim(),
        fullUrl: url,
        status: data.status,
        statusText: data.statusText,
        duration: data.elapsed,
        size: data.bodySize,
        contentType: data.contentType,
        responseBody: data.isImage ? 'Binary Image Data' : (data.text.length > 10240 ? data.text.slice(0, 10240) + '\n... (truncated)' : data.text)
      });
      renderHistoryPanel();
    }

    function showError(msg) {
      getEl('pg-loading').style.display = 'none';
      getEl('pg-empty').style.display = 'none';
      getEl('res-content').style.display = 'none';
      getEl('res-toolbar').style.display = 'none';
      getEl('pg-error').style.display = 'block';
      getEl('pg-error-msg').textContent = msg;
    }

    function displayResponse(data, fromCache) {
      lastResBody = data.text;
      var preview = getEl('res-preview');
      
      if (data.isImage && data.objectUrl) {
        preview.innerHTML = '<img src="' + data.objectUrl + '" alt="Response Image Preview" />';
        preview.style.display = 'flex';
      } else {
        preview.style.display = 'none';
      }

      var formattedText = esc(data.text);
      if (data.contentType && data.contentType.includes('json') && !data.isImage) {
        try { formattedText = hlJSON(JSON.stringify(JSON.parse(data.text), null, 2)); } catch(e) {}
      }
      getEl('res-body').innerHTML = formattedText;

      getEl('res-status').className = 'status-code ' + (data.ok ? 'ok' : 'err');
      getEl('res-status').textContent = data.status + ' ' + data.statusText + (fromCache ? ' (cached)' : '');
      getEl('res-time').textContent = fromCache ? '(cache)' : formatDuration(data.elapsed);
      getEl('res-time').className = 'res-time' + (fromCache ? '' : ' ' + durationClass(data.elapsed));
      getEl('res-size').textContent = formatBytes(data.bodySize);

      getEl('pg-loading').style.display = 'none';
      getEl('pg-empty').style.display = 'none';
      getEl('res-toolbar').style.display = 'flex';
      getEl('res-content').style.display = 'flex';
    }

    document.addEventListener('keydown', e => { 
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { 
        e.preventDefault(); 
        window.__doSend(); 
      } 
    });

    getEl('res-copy').addEventListener('click', function() {
      navigator.clipboard.writeText(lastResBody).then(() => {
        var btn = this;
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent-green)" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
        setTimeout(() => {
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
        }, 1500);
      });
    });

    // Init
    loadDailyCount();
    updateQuotaHint();
    loadHistory();
    renderHistoryPanel();
    window.__selectEndpoint(0);
  })();
</script>
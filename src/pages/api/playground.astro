    function renderParams() {
      var list = getEl('params-list');
      list.innerHTML = '';
      var params = isCustom ? [] : (activeEP.params || []);

      if (params.length === 0 || (params.length === 1 && params[0].name === 'body')) {
        getEl('no-params').style.display = 'flex';
        list.style.display = 'none';
        return;
      }

      getEl('no-params').style.display = 'none';
      list.style.display = 'flex';

      params.forEach(p => {
        if (p.name === 'body') return;
        var row = document.createElement('div');
        row.className = 'param-row';
        var valHTML = p.type === 'select'
          ? '<select class="param-val-sel" data-param="' + p.name + '">' + (p.options||[]).map(o => '<option value="' + o + '">' + (o||'—') + '</option>').join('') + '</select>'
          : '<input class="param-val" type="text" data-param="' + p.name + '" placeholder="' + (p.placeholder||'') + '" />';

        row.innerHTML =
          '<input class="param-key" type="text" value="' + p.name + '" placeholder="Key" readonly />' +
          '<span class="param-eq">=</span>' +
          valHTML +
          '<button class="param-del" title="Clear">' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
          '</button>';
        row.querySelector('.param-del').addEventListener('click', function() {
          var input = row.querySelector('.param-val, .param-val-sel');
          if (input) { if (input.tagName === 'SELECT') input.selectedIndex = 0; else input.value = ''; }
        });
        list.appendChild(row);
      });
    }

    getEl('param-add').addEventListener('click', function() {
      getEl('no-params').style.display = 'none';
      getEl('params-list').style.display = 'flex';
      var row = document.createElement('div');
      row.className = 'param-row';
      row.innerHTML =
        '<input class="param-key" type="text" placeholder="Key" />' +
        '<span class="param-eq">=</span>' +
        '<input class="param-val" type="text" placeholder="Value" />' +
        '<button class="param-del" title="Remove">' +
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
        '</button>';
      row.querySelector('.param-del').addEventListener('click', function() {
        row.remove();
        if(getEl('params-list').children.length===0) {
          getEl('no-params').style.display = 'flex';
          getEl('params-list').style.display = 'none';
        }
      });
      getEl('params-list').appendChild(row);
    });

    getEl('custom-url-toggle').addEventListener('click', function() {
      isCustom = true;
      document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
      this.classList.add('active');

      getEl('url-input').value = '/api/v1/';
      syncURLPrefix();
      getEl('params-list').innerHTML = '';
      getEl('no-params').style.display = 'flex';
      getEl('params-list').style.display = 'none';
      getEl('body-section').style.display = ['POST','PUT','PATCH'].includes(getEl('method-select').value) ? 'block' : 'none';
      showDocs({ label: 'Custom Request', method: 'GET', path: '/api/v1/' });
      resetResponseView();
    });

    getEl('method-select').addEventListener('change', function() {
      getEl('body-section').style.display = ['POST','PUT','PATCH'].includes(this.value) ? 'block' : 'none';
    });

    function buildURL() {
      var path = getEl('url-input').value.trim();
      var isAbs = path.startsWith('http://') || path.startsWith('https://');
      if (!isAbs && path.charAt(0) !== '/') path = '/' + path;

      var rows = getEl('params-list').querySelectorAll('.param-row');
      var qp = [];
      rows.forEach(row => {
        var keyInput = row.querySelector('.param-key');
        var valInput = row.querySelector('.param-val, .param-val-sel');
        var key = keyInput ? keyInput.value.trim() : '';
        var val = valInput ? valInput.value.trim() : '';

        if (!key) return;
        if (path.includes('{' + key + '}')) {
          path = path.replace('{' + key + '}', encodeURIComponent(val));
        } else if (val) {
          qp.push(encodeURIComponent(key) + '=' + encodeURIComponent(val));
        }
      });

      path = path.replace(/\{[^}]+\}/g, '');
      if (qp.length) path += (path.includes('?') ? '&' : '?') + qp.join('&');
      return isAbs ? path : siteUrl + path;
    }

    getEl('body-format').addEventListener('click', function() {
      var fb = getEl('body-feedback');
      try {
        var val = getEl('body-editor').value;
        if (!val.trim()) return;
        getEl('body-editor').value = JSON.stringify(JSON.parse(val), null, 2);
        fb.textContent = 'JSON Formatted successfully';
        fb.className = 'feedback ok';
      } catch(e) {
        fb.textContent = 'Invalid JSON structure';
        fb.className = 'feedback err';
      }
      setTimeout(() => fb.textContent = '', 2500);
    });

    // ── Tabs ──
    function updateTabIndicator(tabEl) {
      var indicator = document.querySelector('.tab-indicator');
      if (indicator && tabEl) {
        indicator.style.width = tabEl.offsetWidth + 'px';
        indicator.style.transform = 'translateX(' + tabEl.offsetLeft + 'px)';
      }
    }
    function switchTab(tabName) {
      document.querySelectorAll('.res-tab').forEach(t => {
        if (t.getAttribute('data-tab') === tabName) { t.classList.add('active'); updateTabIndicator(t); }
        else t.classList.remove('active');
      });
      getEl('response-box').style.display = tabName === 'response' ? 'flex' : 'none';
      getEl('history-panel').style.display = tabName === 'history' ? 'flex' : 'none';
    }
    document.querySelectorAll('.res-tab').forEach(tab => {
      tab.addEventListener('click', function() { switchTab(this.getAttribute('data-tab')); });
    });
    
    // Initialize indicator position
    setTimeout(() => updateTabIndicator(document.querySelector('.res-tab.active')), 100);
    window.addEventListener('resize', () => updateTabIndicator(document.querySelector('.res-tab.active')));

    getEl('history-clear').addEventListener('click', function() {
      if (confirm('Clear all request history?')) {
        historyEntries = [];
        persistHistory();
        renderHistoryPanel();
      }
    });

    // ✨ FIX 2: 生成高保真卡片化历史面板渲染函数
    function renderHistoryPanel() {
      var list = getEl('history-list');
      var empty = getEl('history-empty');
      var clearBtn = getEl('history-clear');

      if (historyEntries.length === 0) {
        list.innerHTML = '';
        empty.style.display = 'flex';
        clearBtn.style.display = 'none';
        return;
      }
      empty.style.display = 'none';
      clearBtn.style.display = 'block';

      list.innerHTML = historyEntries.map(e => {
        var ok = e.status < 400;
        return `
          <div class="history-item" onclick="window.__viewHistoryResponse('${e.id}')">
            <div class="history-item-left">
              <span class="history-item-method ${e.method}">${e.method}</span>
              <span class="history-item-status-code ${ok ? 'ok' : 'err'}">${e.status}</span>
            </div>
            <div class="history-item-main">
              <div class="history-item-url" title="${esc(e.path)}">${esc(e.path)}</div>
              <div class="history-item-meta">
                <span title="Duration"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> ${formatDuration(e.duration)}</span>
                <span title="Size"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> ${formatBytes(e.size)}</span>
                <span title="Timestamp"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> ${formatTimestamp(e.timestamp)}</span>
              </div>
            </div>
            <div class="history-item-actions" onclick="event.stopPropagation()">
              <button class="history-btn rerun" title="Re-run" onclick="window.__rerunHistoryEntry('${e.id}')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
              </button>
              <button class="history-btn delete" title="Delete" onclick="window.__deleteHistoryEntry('${e.id}')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
              </button>
            </div>
          </div>
        `;
      }).join('');
    }

    // ── Execute Logic ──
    window.__doSend = function() {
      var now = Date.now();
      if (now - lastRequestTime < DEBOUNCE_MS) return;
      lastRequestTime = now;

      if (dailyCount >= DAILY_LIMIT) {
        showError('Daily request limit reached (' + DAILY_LIMIT + '/' + DAILY_LIMIT + '). Try again tomorrow.');
        return;
      }

      var m = getEl('method-select').value;
      var url = buildURL();

      // Check cache
      if (m === 'GET') {
        var cached = getCached(m, url);
        if (cached) { displayResponse(cached, true); return; }
      }

      getEl('pg-empty').style.display = 'none';
      getEl('res-content').style.display = 'none';
      getEl('res-toolbar').style.display = 'none';
      getEl('pg-error').style.display = 'none';
      getEl('pg-loading').style.display = 'flex';
      getEl('pg-loading-url').textContent = m + ' ' + url;
      getEl('pg-send').disabled = true;

      var t0 = performance.now();
      var bodyVal = getEl('body-editor').value.trim();
      var headers = {};
      if (['POST','PUT','PATCH'].includes(m) && bodyVal) headers['Content-Type'] = 'application/json';

      fetch(url, { method: m, headers: headers, body: ['POST','PUT','PATCH'].includes(m) && bodyVal ? bodyVal : undefined })
      .then(res => {
        var elapsed = Math.round(performance.now() - t0);
        var ct = res.headers.get('content-type') || '';
        
        // Render headers
        var hdrRows = '', hdrNum = 0;
        res.headers.forEach((v, k) => { hdrRows += '<tr><td>' + esc(k) + '</td><td>' + esc(v) + '</td></tr>'; hdrNum++; });
        getEl('res-headers').innerHTML = hdrRows;
        getEl('hdr-count').textContent = hdrNum;

        return res.blob().then(blob => ({ res, ct, blob, elapsed }));
      })
      .then(data => {
        var isImg = data.ct.includes('image/');
        var payload = {
          status: data.res.status,
          statusText: data.res.statusText,
          elapsed: data.elapsed,
          bodySize: data.blob.size,
          contentType: data.ct,
          ok: data.res.ok,
          isImage: isImg
        };

        if (isImg) {
          payload.objectUrl = URL.createObjectURL(data.blob);
          payload.text = 'Binary Blob (' + data.blob.size + ' bytes)';
          finalize(payload, m, url);
        } else {
          data.blob.text().then(txt => {
            payload.text = txt;
            finalize(payload, m, url);
          });
        }
      })
      .catch(err => {
        showError(err.message || 'Failed to connect. The server might be down or blocked by CORS.');
      })
      .finally(() => { getEl('pg-send').disabled = false; });
    };

    function finalize(data, m, url) {
      if (m === 'GET' && data.ok && !data.isImage) {
        setCached(m, url, data);
      }
      displayResponse(data, false);
      incrementDailyCount();

      addHistoryEntry({
        id: Date.now().toString(36) + Math.random().toString(36).slice(2, 7),
        timestamp: Date.now(),
        method: m,
        path: getEl('url-input').value.trim(),
        fullUrl: url,
        status: data.status,
        statusText: data.statusText,
        duration: data.elapsed,
        size: data.bodySize,
        contentType: data.contentType,
        responseBody: data.isImage ? 'Binary Image Data' : (data.text.length > 10240 ? data.text.slice(0, 10240) + '\n... (truncated)' : data.text)
      });
      renderHistoryPanel();
    }

    function showError(msg) {
      getEl('pg-loading').style.display = 'none';
      getEl('pg-empty').style.display = 'none';
      getEl('res-content').style.display = 'none';
      getEl('res-toolbar').style.display = 'none';
      getEl('pg-error').style.display = 'block';
      getEl('pg-error-msg').textContent = msg;
    }

    function displayResponse(data, fromCache) {
      lastResBody = data.text;
      var preview = getEl('res-preview');
      
      if (data.isImage && data.objectUrl) {
        preview.innerHTML = '<img src="' + data.objectUrl + '" alt="Response Image Preview" />';
        preview.style.display = 'flex';
      } else {
        preview.style.display = 'none';
      }

      var formattedText = esc(data.text);
      if (data.contentType && data.contentType.includes('json') && !data.isImage) {
        try { formattedText = hlJSON(JSON.stringify(JSON.parse(data.text), null, 2)); } catch(e) {}
      }
      getEl('res-body').innerHTML = formattedText;

      getEl('res-status').className = 'status-code ' + (data.ok ? 'ok' : 'err');
      getEl('res-status').textContent = data.status + ' ' + data.statusText + (fromCache ? ' (cached)' : '');
      getEl('res-time').textContent = fromCache ? '(cache)' : formatDuration(data.elapsed);
      getEl('res-time').className = 'res-time' + (fromCache ? '' : ' ' + durationClass(data.elapsed));
      getEl('res-size').textContent = formatBytes(data.bodySize);

      getEl('pg-loading').style.display = 'none';
      getEl('pg-empty').style.display = 'none';
      getEl('res-toolbar').style.display = 'flex';
      getEl('res-content').style.display = 'flex';
    }

    document.addEventListener('keydown', e => { 
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { 
        e.preventDefault(); 
        window.__doSend(); 
      } 
    });

    getEl('res-copy').addEventListener('click', function() {
      navigator.clipboard.writeText(lastResBody).then(() => {
        var btn = this;

---
import Layout from '../../layouts/Layout.astro';

const siteUrl = Astro.url.origin;

interface EP {
  id: string; method: string; path: string; label: string; desc: string;
  usage: string;
  responseFields?: { name: string; type: string; desc: string }[];
  params?: { name: string; type: string; label: string; placeholder: string; optional: boolean; options?: string[] }[];
  curlExample?: string;
  notes?: string;
}

const groups: { name: string; items: EP[] }[] = [
  {
    name: 'Core',
    items: [
      {
        id: 'today', method: 'GET', path: '/api/v1/today.json', label: 'Today Theme',
        desc: '获取每日主题的完整数据，包含 34 个 CSS 自定义属性、自定义 CSS 动画、声明式装饰元素数组、Logo 信息、主题目录索引。',
        usage: '客户端 GET 此端点，将返回的 cssVars 注入 :root，customCss 创建 <style>，extensions 安全渲染为 DOM 元素。',
        curlExample: `curl ${siteUrl}/api/v1/today.json | jq .`,
        responseFields: [
          { name: 'date', type: 'string', desc: 'ISO 日期 YYYY-MM-DD（UTC 时区）' },
          { name: 'preset', type: 'string', desc: '预设标识符 (kebab-case)' },
          { name: 'presetName', type: 'string', desc: '人类可读名称' },
          { name: 'cssVars', type: 'object', desc: '34 个 CSS 自定义属性键值对（5 组：Colors / Typography / Spacing / Effects / Ambient）' },
          { name: 'customCss', type: 'string|null', desc: '主题专属 CSS（动画 keyframes、特效样式）' },
          { name: 'extensions', type: 'array|null', desc: '声明式装饰元素数组（floating / decorative）' },
          { name: 'logoText', type: 'string|null', desc: '主题 Logo 文字标识' },
          { name: 'logoColors', type: 'array|null', desc: 'Logo 渐变色 hex 字符串数组' },
          { name: 'available', type: 'number', desc: '可用主题总数' },
          { name: 'directory', type: 'array', desc: '轻量索引 [{preset, name, primary, accent, logoText}]' },
        ],
        params: [
          { name: 'tz', type: 'text', label: '时区', placeholder: 'Asia/Shanghai', optional: true },
          { name: 'overrides', type: 'text', label: 'CSS 覆盖', placeholder: '--radii:0px;--font-body:monospace', optional: true },
        ],
        notes: 'GET 端点无速率限制，CDN 缓存 24h (stale-while-revalidate)。颜色变量自动附带 -rgb 通道变体。',
      },
      {
        id: 'today-css', method: 'GET', path: '/api/v1/today.css', label: 'Today CSS',
        desc: '返回今日主题的纯 CSS (:root 变量块)，可直接通过 <link> 标签引入，阻塞渲染消除 FOUC。',
        usage: '在 <head> 中添加 <link rel="stylesheet" href="/api/v1/today.css"> 即可，浏览器会阻塞等待 CSS 加载完成后再渲染。',
        curlExample: `curl ${siteUrl}/api/v1/today.css`,
        notes: '返回 text/css MIME 类型。支持 ?tz= 参数。CDN 缓存 24h。推荐对 FOUC 敏感的场景使用。',
        params: [
          { name: 'tz', type: 'text', label: '时区', placeholder: 'Asia/Shanghai', optional: true },
        ],
      },
      {
        id: 'preset', method: 'GET', path: '/api/v1/theme/{preset}.json', label: 'Preset Theme',
        desc: '获取指定预设主题的完整数据。与 today.json 结构一致，但不含 date、generatedAt、available、directory 字段。',
        usage: '从 /api/v1/today.json 的 directory 中选择 preset，调用此端点获取该主题的完整数据。可用于主题预览、主题商店详情页。',
        curlExample: `curl ${siteUrl}/api/v1/theme/yozakura-reverie.json | jq .`,
        params: [
          { name: 'preset', type: 'text', label: '预设名', placeholder: 'yozakura-reverie', optional: false },
        ],
        notes: '365 天 CDN 缓存 (immutable)。227+ 个端点，覆盖所有预设主题。',
      },
      {
        id: 'random', method: 'GET', path: '/api/v1/theme/random.json', label: 'Random Theme',
        desc: '随机获取一个主题。支持 ?pool=static|community|all 筛选池子和 ?seed=N 确定性随机。',
        usage: '用于"随机换肤"按钮或主题发现场景。传入 seed 可保证相同种子返回相同结果。',
        curlExample: `curl "${siteUrl}/api/v1/theme/random.json?pool=all&seed=42" | jq .`,
        params: [
          { name: 'pool', type: 'select', label: '池子', options: ['', 'static', 'community', 'all'], optional: true },
          { name: 'seed', type: 'text', label: '种子', placeholder: '42', optional: true },
        ],
      },
      {
        id: 'today-safe', method: 'GET', path: '/api/v1/today-safe', label: 'Safe Proxy',
        desc: '安全主题代理 — Vercel 优先，Netlify 备用。从 ThemeDist 代理获取最新 today.json 数据并应用 XSS 清洗。',
        usage: '下游主题渲染器可直接安全消费，无需自行处理输入净化。返回 _meta.sanitized 和 _meta.schemaValid 字段。',
        curlExample: `curl https://themedist-monitor.vercel.app/api/v1/today-safe | jq .`,
        notes: '此端点部署在独立监控服务上。502 表示两个上游平台均不可达。',
      },
      {
        id: 'date-lookup', method: 'GET', path: '/api/v1/date=MM-DD', label: 'Date Lookup',
        desc: '按日期查询主题，格式 MM-DD。可用于查询特定节日的主题（如 /api/v1/date=02-14 查询情人节主题）。',
        usage: '用于日历组件、节日预览等场景。',
        curlExample: `curl ${siteUrl}/api/v1/date=02-14 | jq .`,
        params: [
          { name: 'date', type: 'text', label: '日期 (MM-DD)', placeholder: '02-14', optional: false },
        ],
      },
    ]
  },
  {
    name: 'Community',
    items: [
      {
        id: 'diy-list', method: 'GET', path: '/api/v1/diy/themes.json', label: 'Community List',
        desc: '获取社区投稿主题列表，支持分页、排序（new/hot）、标签筛选。返回包含 id、author、likes、status、tags 等社区特有字段。',
        usage: 'GET 端点无速率限制。sort=new 按提交时间降序，sort=hot 按点赞数降序。tag 支持 dark/light/warm/cool/vibrant/minimal/nature/tech。',
        curlExample: `curl "${siteUrl}/api/v1/diy/themes.json?sort=hot&page=1&size=20" | jq .`,
        params: [
          { name: 'sort', type: 'select', label: '排序', options: ['new', 'hot'], optional: true },
          { name: 'page', type: 'text', label: '页码', placeholder: '1', optional: true },
          { name: 'size', type: 'text', label: '每页数量', placeholder: '20', optional: true },
          { name: 'tag', type: 'select', label: '标签', options: ['', 'dark', 'light', 'warm', 'cool', 'vibrant', 'minimal', 'nature', 'tech'], optional: true },
        ],
        notes: '浏览器缓存 1 分钟。max size=50。',
      },
      {
        id: 'diy-single', method: 'GET', path: '/api/v1/diy/theme.json', label: 'Single Theme',
        desc: '获取单个社区主题详情（含点赞数、作者信息、审核状态）。',
        usage: '通过 ?id= 参数指定主题 ID。返回此主题的完整 CSS 变量、作者、标签、点赞数等。',
        curlExample: `curl "${siteUrl}/api/v1/diy/theme.json?id=abc12345" | jq .`,
        params: [
          { name: 'id', type: 'text', label: '主题 ID', placeholder: 'abc12345', optional: false },
        ],
      },
      {
        id: 'diy-submit', method: 'POST', path: '/api/v1/diy/submit.json', label: 'Submit Theme',
        desc: '提交社区主题到审核队列。必填 name、author、cssVars（必须含 --color-primary 和 --color-bg）。可选 customCss、extensions、tags（最多 5 个）。',
        usage: 'POST JSON body。成功返回 201 + { success: true, theme: { id, name, ... }, warnings?: [...] }。warnings 数组表示部分字段被自动调整。',
        curlExample: `curl -X POST ${siteUrl}/api/v1/diy/submit.json \\
  -H 'Content-Type: application/json' \\
  -d '{"name":"My Theme","author":"You","cssVars":{"--color-primary":"#ff6b6b","--color-bg":"#1a1a2e"},"tags":["dark","vibrant"]}'`,
        params: [
          { name: 'body', type: 'textarea', label: '请求体 (JSON)', placeholder: '{\n  "name": "My Theme",\n  "author": "You",\n  "cssVars": {\n    "--color-primary": "#ff6b6b",\n    "--color-bg": "#1a1a2e"\n  },\n  "tags": ["dark", "vibrant"]\n}', optional: false },
        ],
        notes: '限流：3 次/分钟。cssVars 键自动补齐 -- 前缀。不支持 JavaScript 类型的 extension。超限返回 429。',
      },
      {
        id: 'diy-like', method: 'POST', path: '/api/v1/diy/like.json', label: 'Like Theme',
        desc: '点赞社区主题。服务器基于 IP + User-Agent 指纹去重，同一用户对同一主题仅计一次。',
        usage: 'POST JSON body: { "id": "abc12345" }。返回 { likes: number, voted: boolean }。',
        curlExample: `curl -X POST ${siteUrl}/api/v1/diy/like.json \\
  -H 'Content-Type: application/json' \\
  -d '{"id":"abc12345"}'`,
        params: [
          { name: 'body', type: 'textarea', label: '请求体 (JSON)', placeholder: '{\n  "id": "abc12345"\n}', optional: false },
        ],
        notes: '限流：10 次/分钟。',
      },
    ]
  },
  {
    name: 'AI',
    items: [
      {
        id: 'ai-generate', method: 'POST', path: '/api/v1/ai/generate.json', label: 'AI Generate',
        desc: 'AI 主题生成（规则引擎，或客户端 DeepSeek 直调）。根据文本描述生成完整主题的 CSS 变量。',
        usage: 'POST JSON body 含 prompt 字段，服务端根据 prompt 通过规则引擎或 AI 生成匹配的主题变量。',
        curlExample: `curl -X POST ${siteUrl}/api/v1/ai/generate.json \\
  -H 'Content-Type: application/json' \\
  -d '{"prompt":"a dark cyberpunk theme with neon green accents"}'`,
        params: [
          { name: 'body', type: 'textarea', label: '请求体 (JSON)', placeholder: '{\n  "prompt": "a dark cyberpunk theme with neon green accents"\n}', optional: false },
        ],
      },
      {
        id: 'ai-describe', method: 'POST', path: '/api/v1/ai/describe.json', label: 'AI Describe',
        desc: 'AI 逆向描述 — 分析 CSS 变量集合，输出中文风格描述。可用于"这个主题是什么风格"的查询。',
        usage: 'POST JSON body 含 cssVars 对象。返回包含风格描述的中文文本。',
        curlExample: `curl -X POST ${siteUrl}/api/v1/ai/describe.json \\
  -H 'Content-Type: application/json' \\
  -d '{"cssVars":{"--color-primary":"#3b82f6","--color-bg":"#0f172a","--color-accent":"#f59e0b"}}'`,
        params: [
          { name: 'body', type: 'textarea', label: '请求体 (JSON)', placeholder: '{\n  "cssVars": {\n    "--color-primary": "#3b82f6",\n    "--color-bg": "#0f172a",\n    "--color-accent": "#f59e0b"\n  }\n}', optional: false },
        ],
      },
    ]
  },
  {
    name: 'Advanced',
    items: [
      {
        id: 'tokens', method: 'GET', path: '/api/v1/tokens.json', label: 'Design Tokens (DTCG)',
        desc: 'W3C DTCG 设计令牌导出。将主题的 CSS 变量转换为标准化设计令牌层级结构（color / typography / space / effects）。',
        usage: '用于与 Figma、Style Dictionary 等设计工具集成。返回符合 DTCG 规范的 JSON。',
        curlExample: `curl ${siteUrl}/api/v1/tokens.json | jq .`,
      },
      {
        id: 'search-color', method: 'GET', path: '/api/v1/search/color.json', label: 'Color Search',
        desc: '按颜色相似度搜索主题。RGB 欧几里得距离排序，找出与目标颜色最接近的主题。',
        usage: '传入 hex 颜色值和可选 limit 参数。返回按相似度排序的主题列表。',
        curlExample: `curl "${siteUrl}/api/v1/search/color.json?hex=ff6b6b&limit=10" | jq .`,
        params: [
          { name: 'hex', type: 'text', label: '颜色值', placeholder: '#ff6b6b', optional: false },
          { name: 'limit', type: 'text', label: '结果数量', placeholder: '10', optional: true },
        ],
      },
      {
        id: 'recommend', method: 'GET', path: '/api/v1/recommend/{preset}.json', label: 'Smart Recommend',
        desc: '智能推荐引擎。基于 Jaccard 标签相似度 + 颜色距离加权计算，推荐与指定主题风格相近的其他主题。',
        usage: '传入一个 preset 名，返回与之风格最相似的主题列表。用于"相似主题"推荐栏目。',
        curlExample: `curl ${siteUrl}/api/v1/recommend/yozakura-reverie.json | jq .`,
        params: [
          { name: 'preset', type: 'text', label: '预设名', placeholder: 'yozakura-reverie', optional: false },
        ],
      },
      {
        id: 'trending', method: 'GET', path: '/api/v1/trending.json', label: 'Trending',
        desc: '趋势排行榜。热度 = 点赞数 × 10 + 使用量 × 1。发现社区中最受欢迎的主题。',
        usage: '无需参数。返回按热度降序排列的主题列表。',
        curlExample: `curl ${siteUrl}/api/v1/trending.json | jq .`,
      },
      {
        id: 'badge', method: 'GET', path: '/api/v1/badge/{username}.svg', label: 'GitHub Badge',
        desc: 'GitHub 动态徽章。shields.io 风格作者统计 SVG，可嵌入 README 展示主题贡献者信息。',
        usage: '将 {username} 替换为 GitHub 用户名。返回 SVG 图片可直接在 <img> 或 Markdown 中使用。',
        curlExample: `curl ${siteUrl}/api/v1/badge/424635328.svg`,
        params: [
          { name: 'username', type: 'text', label: 'GitHub 用户名', placeholder: '424635328', optional: false },
        ],
      },
      {
        id: 'telemetry', method: 'POST', path: '/api/v1/telemetry/hit', label: 'Telemetry Hit',
        desc: '匿名遥测上报。使用 HyperLogLog 算法统计独立域名和主题使用计数，不存储个人信息。',
        usage: 'POST 上报使用数据。用于统计主题流行度和使用量。客户端应仅在首次加载时上报。',
        curlExample: `curl -X POST ${siteUrl}/api/v1/telemetry/hit \\
  -H 'Content-Type: application/json' \\
  -d '{"preset":"yozakura-reverie"}'`,
        params: [
          { name: 'body', type: 'textarea', label: '请求体 (JSON)', placeholder: '{\n  "preset": "yozakura-reverie"\n}', optional: false },
        ],
      },
      {
        id: 'pool-create', method: 'POST', path: '/api/v1/pool/create.json', label: 'Create Pool',
        desc: '创建自定义主题轮换池。指定一组主题 preset，系统每日从中轮换选择。',
        usage: 'POST JSON body 含 presets 数组和可选的 name。返回创建的 pool ID。',
        curlExample: `curl -X POST ${siteUrl}/api/v1/pool/create.json \\
  -H 'Content-Type: application/json' \\
  -d '{"name":"my-pool","presets":["minimal-blue","yozakura-reverie","sunset-boulevard"]}'`,
        params: [
          { name: 'body', type: 'textarea', label: '请求体 (JSON)', placeholder: '{\n  "name": "my-pool",\n  "presets": ["minimal-blue", "yozakura-reverie"]\n}', optional: false },
        ],
      },
      {
        id: 'pool-get', method: 'GET', path: '/api/v1/pool/{poolId}.json', label: 'Pool Rotation',
        desc: '查询自定义轮换池的每日主题。类似 today.json 但限于指定池子内轮换。',
        usage: '创建池子后，通过池子 ID 获取当日从该池子中选中的主题。',
        curlExample: `curl ${siteUrl}/api/v1/pool/abc123.json | jq .`,
        params: [
          { name: 'poolId', type: 'text', label: '池子 ID', placeholder: 'abc123', optional: false },
        ],
      },
      {
        id: 'tailwind-config', method: 'GET', path: '/api/v1/tailwind-config.json', label: 'Tailwind Config',
        desc: '一键生成 Tailwind CSS 配置片段。含 RGB 通道变量和 <alpha-value> 支持，可直接用于 Tailwind v3/v4 项目。',
        usage: '返回完整的 tailwind.config.js 配置对象或 CSS @theme 块。所有颜色使用 RGB 通道以支持不透明度修饰符。',
        curlExample: `curl ${siteUrl}/api/v1/tailwind-config.json | jq .`,
      },
      {
        id: 'today-favicon', method: 'GET', path: '/api/v1/today/favicon.svg', label: 'Dynamic Favicon',
        desc: '动态 Favicon SVG。根据今日主题主色生成圆角矩形 + Logo 首字母的动态图标。',
        usage: '<link rel="icon" type="image/svg+xml" href="/api/v1/today/favicon.svg">。每日自动变色。',
        curlExample: `curl ${siteUrl}/api/v1/today/favicon.svg`,
      },
      {
        id: 'today-fonts', method: 'GET', path: '/api/v1/today/fonts.css', label: 'Auto Fonts CSS',
        desc: '自动字体注入。提取今日主题的字体设置，生成 Google Fonts @import 和 font-family 声明。',
        usage: '<link rel="stylesheet" href="/api/v1/today/fonts.css">。自动处理 Google Fonts CDN 引用。',
        curlExample: `curl ${siteUrl}/api/v1/today/fonts.css`,
      },
      {
        id: 'today-palette', method: 'GET', path: '/api/v1/today/palette.svg', label: 'Palette Badge',
        desc: '今日主题调色盘 SVG 徽章。可嵌入 README / 博客 Footer 展示当日主题配色。',
        usage: '<img src="/api/v1/today/palette.svg" alt="Today Palette">。',
        curlExample: `curl ${siteUrl}/api/v1/today/palette.svg`,
      },
    ]
  },
  {
    name: 'Diagnostics & Export',
    items: [
      {
        id: 'wcag', method: 'GET', path: '/api/v1/theme/{id}/wcag.json', label: 'WCAG Audit',
        desc: 'WCAG 2.1 无障碍诊断。评估主题的颜色对比度，检查正文、主色、辅色在背景上的可读性。',
        usage: '返回每条颜色组合的对比度数值及 AA/AAA 级别通过情况，含 compliant 总览标记和 warnings 修复建议。',
        curlExample: `curl ${siteUrl}/api/v1/theme/yozakura-reverie/wcag.json | jq .`,
        params: [
          { name: 'id', type: 'text', label: '主题 ID', placeholder: 'yozakura-reverie', optional: false },
        ],
      },
      {
        id: 'scale', method: 'GET', path: '/api/v1/theme/{id}/scale.json', label: 'Color Scale',
        desc: 'Tailwind 风格色阶生成。基于黑白色插值法，从主题主色/辅色/强调色/背景色生成 50~950 共 11 级色阶。',
        usage: '返回 scales.primary、scales.secondary、scales.accent、scales.background 四组色阶。365 天 CDN 缓存。',
        curlExample: `curl ${siteUrl}/api/v1/theme/yozakura-reverie/scale.json | jq .`,
        params: [
          { name: 'id', type: 'text', label: '主题 ID', placeholder: 'yozakura-reverie', optional: false },
        ],
      },
      {
        id: 'shadcn', method: 'GET', path: '/api/v1/theme/{id}/export/shadcn.css', label: 'Shadcn UI Export',
        desc: 'Shadcn UI 适配器。将主题 CSS 变量转换为 Shadcn UI 所需的 HSL 通道变量体系，前景色自动根据背景亮度推断。',
        usage: '返回完整 CSS（@layer base { :root {} }），可直接复制到 Shadcn UI 项目的 globals.css 中使用。',
        curlExample: `curl ${siteUrl}/api/v1/theme/yozakura-reverie/export/shadcn.css`,
        params: [
          { name: 'id', type: 'text', label: '主题 ID', placeholder: 'yozakura-reverie', optional: false },
        ],
      },
      {
        id: 'shiki', method: 'GET', path: '/api/v1/theme/{id}/shiki.json', label: 'Shiki Highlight',
        desc: 'Shiki / VS Code 代码高亮主题。将主题的 CSS 变量映射为 TextMate Token 颜色，可直接作为代码高亮主题使用。',
        usage: '返回包含 tokenColors 和 semanticTokenColors 的 JSON，可直接导入 Shiki 配置。',
        curlExample: `curl ${siteUrl}/api/v1/theme/yozakura-reverie/shiki.json | jq .`,
        params: [
          { name: 'id', type: 'text', label: '主题 ID', placeholder: 'yozakura-reverie', optional: false },
        ],
      },
      {
        id: 'extract-theme', method: 'POST', path: '/api/v1/extract-theme.json', label: 'Image Extract',
        desc: '图片取色 API。传入图片 URL，服务端下载后用纯 JavaScript 解码（jpeg-js / pngjs），K-means 聚类提取 Top 5 主色调，通过色彩语义引擎映射为标准 UI 变量。',
        usage: 'POST JSON body: { "imageUrl": "https://example.com/poster.jpg" }。仅支持 JPEG/PNG，最大 5MB，抓取超时 5s。返回 sourcePalette、isDark、cssVars、customCss。',
        curlExample: `curl -X POST ${siteUrl}/api/v1/extract-theme.json \\
  -H 'Content-Type: application/json' \\
  -d '{"imageUrl":"https://example.com/poster.jpg"}'`,
        params: [
          { name: 'body', type: 'textarea', label: '请求体 (JSON)', placeholder: '{\n  "imageUrl": "https://example.com/poster.jpg"\n}', optional: false },
        ],
      },
      {
        id: 'og-svg', method: 'GET', path: '/api/v1/theme/{id}/og.svg', label: 'OG Image',
        desc: 'OG 社交分享卡片。1200×630 SVG，含主题色板与名称，适合用于 Open Graph 预览图。',
        usage: '<meta property="og:image" content="/api/v1/theme/yozakura-reverie/og.svg">。',
        curlExample: `curl ${siteUrl}/api/v1/theme/yozakura-reverie/og.svg`,
        params: [
          { name: 'id', type: 'text', label: '主题 ID', placeholder: 'yozakura-reverie', optional: false },
        ],
      },
      {
        id: 'index-data', method: 'GET', path: '/api/v1/index-data.json', label: 'Index Data',
        desc: '首页所需的聚合数据。包含当日主题、推荐列表、社区统计等一站式数据。',
        usage: '用于构建首页仪表盘，减少多次 API 调用。',
        curlExample: `curl ${siteUrl}/api/v1/index-data.json | jq .`,
      },
    ]
  },
  {
    name: 'Environment',
    items: [
      {
        id: 'weather', method: 'GET', path: '/api/v1/weather-theme.json', label: 'Weather-Adaptive',
        desc: '天气自适应主题。嗅探式跨平台地理位置检测（Vercel x-vercel-ip-latitude / Netlify x-nf-geo），调用免费 Open-Meteo API 获取实时天气，自动匹配对应氛围的主题。',
        usage: '支持 ?lat= 和 ?lon= 查询参数覆盖 IP 检测。天气映射：晴天→sunny-day / 阴天→cloudy-grey / 雨→rainy-mood / 雪→snow-white / 雷暴→thunderstorm。API 超时 3s，失败降级为 Clear Sky + 今日主题。',
        curlExample: `curl "${siteUrl}/api/v1/weather-theme.json?lat=35.68&lon=139.76" | jq .`,
        params: [
          { name: 'lat', type: 'text', label: '纬度', placeholder: '35.68', optional: true },
          { name: 'lon', type: 'text', label: '经度', placeholder: '139.76', optional: true },
        ],
        notes: '缓存 30 分钟。返回城市名（OpenStreetMap Nominatim 逆地理编码）。',
      },
      {
        id: 'status-override', method: 'GET', path: '/api/v1/status-override.json', label: 'Status Override',
        desc: '系统状态覆盖主题。根据系统运行状态返回覆盖主题，用于维护页、哀悼日、故障降级等场景。',
        usage: '?status=maintenance（纯灰）、?status=mourning（暗黑灰调 + grayscale 滤镜）、?status=incident（红色警示）。',
        curlExample: `curl "${siteUrl}/api/v1/status-override.json?status=maintenance" | jq .`,
        params: [
          { name: 'status', type: 'select', label: '状态', options: ['maintenance', 'mourning', 'incident'], optional: false },
        ],
        notes: '缓存 5 分钟。',
      },
      {
        id: 'today-pattern', method: 'GET', path: '/api/v1/today/pattern.css', label: 'SVG Pattern',
        desc: '动态 SVG 背景纹理。根据今日主题色实时生成几何图案 SVG，转为 data URI 嵌入 CSS，可作 background-image 使用。',
        usage: '<link rel="stylesheet" href="/api/v1/today/pattern.css"> 或在 CSS 中 @import。',
        curlExample: `curl ${siteUrl}/api/v1/today/pattern.css`,
      },
      {
        id: 'today-weather-js', method: 'GET', path: '/api/v1/today/weather.js', label: 'Weather Particles',
        desc: '天气粒子渲染脚本。云/雨/雪/太阳/闪电粒子动画，<script src> 引入即自动渲染 canvas 粒子层。',
        usage: '<script src="/api/v1/today/weather.js" defer></script>。自动在页面创建 canvas 天气粒子效果。',
        curlExample: `curl ${siteUrl}/api/v1/today/weather.js`,
        notes: 'CDN 缓存 24h。浏览器缓存 1h。',
      },
    ]
  },
];

// Flatten and assign indices
let epIndex = 0;
const flat: any[] = [];
groups.forEach((g, gi) => {
  g.items.forEach((ep: any, ei: number) => {
    ep._idx = epIndex++;
    ep._gid = gi;
    ep._eid = ei;
    flat.push(ep);
  });
});

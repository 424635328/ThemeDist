  .pg-custom-trigger:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .pg-custom-trigger.active {
    border-style: solid; border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    color: var(--color-primary);
  }

  /* ── History ── */
  .pg-history-clear {
    font-size: 9px; font-weight: 600; letter-spacing: 0.03em;

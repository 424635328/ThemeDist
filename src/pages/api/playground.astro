  .feedback { font-size: 12px; margin-top: 6px; min-height: 18px; font-weight: 500; } .feedback.ok { color: var(--accent-green); } .feedback.err { color: var(--accent-red); }

  /* Light Docs */
  .docs-card { background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radii); padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.02); }
  .docs-meta { display: flex; gap: 32px; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border-subtle); }
  .meta-label { display: block; font-size: 10px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 4px; font-weight: 600; letter-spacing: 0.05em; }
  .meta-value { font-size: 12.5px; color: var(--text-primary); }
  .meta-value.highlight { color: var(--accent); font-family: var(--font-mono); font-size: 12px; }
  .docs-notes { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }
  .docs-notes code, #docs-params code { font-family: var(--font-mono); font-size: 11px; background: var(--bg-base); padding: 1px 6px; border-radius: 3px; border: 1px solid var(--border-subtle); }
  
  .styled-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 8px; }
  .styled-table td { padding: 8px 12px; border-bottom: 1px solid var(--border-subtle); color: var(--text-secondary); }
  .styled-table tr:last-child td { border-bottom: none; }

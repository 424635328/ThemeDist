  .param-eq { color: var(--text-muted); font-family: var(--font-mono); font-size: 12px; user-select: none; text-align: center; }

  .param-val { width: 100%; background: transparent; border: none; color: var(--text-primary); font-family: var(--font-mono); font-size: 12.5px; outline: none; padding: 6px 8px; border-radius: 4px; }

  }
  .pg-history-clear:hover { color: #ef4444; background: rgba(239,68,68,0.1); }
  .pg-history-list { display: flex; flex-direction: column; gap: 1px; overflow-y: auto; max-height: 200px; }
  .pg-history-item {
    display: flex; align-items: center; gap: 4px;
    width: 100%; padding: 4px 6px;
    border: none; border-radius: 5px;
    background: transparent; font-family: "JetBrains Mono", monospace;
    cursor: pointer; font-size: 9px;
    color: var(--color-text-muted); text-align: left;
    transition: background 0.15s;
  }
  .pg-history-item:hover { background: color-mix(in srgb, var(--color-primary) 6%, transparent); }
  .pg-history-method { font-size: 7px; font-weight: 800; padding: 1px 4px; border-radius: 3px; color: #fff; min-width: 26px; text-align: center; }
  .pg-history-status { font-weight: 700; color: #16a34a; min-width: 22px; }
  .pg-history-status--err { color: #ef4444; }
  .pg-history-url { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .pg-history-time { font-size: 8px; opacity: 0.5; }

  /* ── Main ── */
  .pg-main { border-right: 1px solid var(--color-border); display: flex; flex-direction: column; }

  .pg-panel { display: flex; flex-direction: column; }
  .pg-panel__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
    gap: 8px; flex-shrink: 0;
  }
  .pg-panel__title {
    font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--color-text-muted);
  }
  .pg-panel__hint { font-size: 9px; color: var(--color-text-muted); font-family: "JetBrains Mono", monospace; }

  /* ── URL bar ── */
  .pg-url-section { padding: 14px 16px 10px; }
  .pg-url-row { display: flex; gap: 0; }
  .pg-method-select {
    width: 72px; height: 38px; padding: 0 6px;
    border: 1.5px solid var(--color-border); border-right: none;
    border-radius: 9px 0 0 9px;
    background: color-mix(in srgb, var(--color-bg) 60%, transparent);
    color: var(--color-text); font-size: 10px; font-weight: 700;
    font-family: "JetBrains Mono", monospace;
    cursor: pointer; outline: none;
    -webkit-appearance: none; appearance: none;
  }
  .pg-method-select:focus { border-color: var(--color-primary); }
  .pg-url-input-wrap {
    flex: 1; display: flex; align-items: center;
    border: 1.5px solid var(--color-border); border-right: none;
    background: color-mix(in srgb, var(--color-bg) 40%, transparent);
    overflow: hidden;
  }
  .pg-url-prefix {
    font-size: 11px; font-family: "JetBrains Mono", monospace;
    color: var(--color-text-muted); opacity: 0.5;
    padding: 0 0 0 10px; white-space: nowrap; user-select: none;
  }
  .pg-url-input {
    flex: 1; height: 38px; padding: 0 10px;
    border: none; background: transparent;
    color: var(--color-text); font-size: 12px;
    font-family: "JetBrains Mono", monospace;
    outline: none;
  }
  .pg-send-btn {
    display: flex; align-items: center; justify-content: center; gap: 5px;
    height: 38px; padding: 0 18px;
    border-radius: 0 9px 9px 0;
    border: none;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 0.01em;
    cursor: pointer; font-family: "Inter", sans-serif;
    transition: all 0.2s; white-space: nowrap; flex-shrink: 0;
    box-shadow: 0 2px 10px color-mix(in srgb, var(--color-primary) 25%, transparent);
  }
  .pg-send-btn:hover:not(:disabled) {
    box-shadow: 0 4px 18px color-mix(in srgb, var(--color-primary) 40%, transparent);
    transform: translateY(-1px);
  }
  .pg-send-btn:active:not(:disabled) { transform: scale(0.97); }
  .pg-send-btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .pg-send-hint { display: block; text-align: center; font-size: 10px; color: var(--color-text-muted); min-height: 16px; padding: 0 16px 6px; }

  /* ── Docs panel ── */
  .pg-docs { padding: 0 16px 8px; }
  .pg-docs__empty { padding: 16px 0; font-size: 11px; color: var(--color-text-muted); font-style: italic; }
  .pg-docs__content { font-size: 12px; line-height: 1.6; }
  .pg-docs__title {
    font-size: 14px; font-weight: 700; letter-spacing: -0.02em;
    margin: 0 0 6px; color: var(--color-text);
  }
  .pg-docs__desc { color: var(--color-text-muted); margin: 0 0 12px; }
  .pg-docs__section { margin-bottom: 12px; }
  .pg-docs__section h3 {
    font-size: 10px; font-weight: 700; letter-spacing: 0.05em;
    text-transform: uppercase; color: var(--color-text-muted);
    margin: 0 0 4px;
  }
  .pg-docs__usage { color: var(--color-text-muted); margin: 0; font-size: 11px; }
  .pg-docs__notes {
    padding: 8px 12px; border-radius: 8px;
    background: color-mix(in srgb, var(--color-primary) 6%, transparent);
    border-left: 3px solid var(--color-primary);
    font-size: 11px; color: var(--color-text-muted);
  }
  .pg-docs__curl {
    padding: 10px 12px; border-radius: 8px;
    background: color-mix(in srgb, var(--color-text) 5%, var(--color-bg));
    border: 1px solid var(--color-border);
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px; line-height: 1.55; margin: 0;
    white-space: pre-wrap; word-break: break-all;
    overflow-x: auto; max-height: 120px; overflow-y: auto;
  }
  .pg-table-wrap { overflow-x: auto; }
  .pg-docs-table {
    width: 100%; border-collapse: collapse;
    font-size: 10.5px;

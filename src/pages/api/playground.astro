  /* ====== PARAMETERS ====== */
  .params-box { background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radii); padding: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.02); }

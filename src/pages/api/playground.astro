  .curl-wrapper { position: relative; margin-top: 16px; }
  .curl-block { white-space: pre-wrap; word-break: break-all; margin: 0; padding: 16px 48px 16px 16px; background: var(--bg-base); border: 1px solid var(--border-subtle); border-radius: var(--radii); color: var(--text-secondary); font-family: var(--font-mono); font-size: 12px; line-height: 1.5; }
  .copy-btn { position: absolute; top: 12px; right: 12px; width: 28px; height: 28px; border-radius: 6px; background: var(--bg-elevated); border: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: center; color: var(--text-muted); cursor: pointer; transition: all 0.2s; }
  .copy-btn:hover { background: var(--bg-surface); color: var(--text-primary); }
  .copy-btn.copied { color: var(--accent-green); border-color: var(--accent-green); }

  /* ====== RESPONSE COLUMN ====== */
  .response-col { display: flex; flex-direction: column; overflow: hidden; min-height: 0; background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radii-lg); box-shadow: 0 8px 32px rgba(0,0,0,0.05); }

  /* Response Tabs */
  .res-tabs { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border-subtle); padding: 0 16px; background: var(--bg-surface); flex-shrink: 0; }
  .res-tabs-nav { display: flex; position: relative; }
  .res-tab { padding: 14px 20px; background: transparent; border: none; color: var(--text-muted); font-size: 13px; font-weight: 500; cursor: pointer; transition: color 0.2s; position: relative; z-index: 1; }
  .res-tab:hover { color: var(--text-primary); }
  .res-tab.active { color: var(--accent); }
  .tab-indicator { position: absolute; bottom: 0; left: 0; height: 2px; width: 0; background: var(--accent); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 2px 2px 0 0; }
  
  .res-tab-btn { padding: 6px; background: transparent; border: none; color: var(--text-muted); cursor: pointer; border-radius: 4px; transition: all 0.2s; display: flex; align-items: center; }
  .res-tab-btn:hover { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 10%, transparent); }

  /* ====== RESPONSE BOX ====== */
  .response-box { flex: 1; min-height: 0; display: flex; flex-direction: column; overflow: hidden; }
  .res-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-bottom: 1px solid var(--border-subtle); background: var(--bg-surface); flex-shrink: 0; }
  .res-status-wrap { display: flex; align-items: center; gap: 16px; }
  .status-code { font-family: var(--font-mono); font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 6px; }
  .status-code.ok { color: var(--accent-green); background: color-mix(in srgb, var(--accent-green) 12%, transparent); }
  .status-code.err { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 12%, transparent); }
  .res-time, .res-size { font-family: var(--font-mono); font-size: 12px; font-weight: 500; }
  .res-time.fast { color: var(--accent-green); }
  .res-time.medium { color: var(--accent-orange); }
  .res-time.slow { color: var(--accent-red); }
  .res-size { color: var(--text-muted); }

  .btn-icon { width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; color: var(--text-muted); border-radius: 6px; cursor: pointer; transition: all 0.2s; flex-shrink: 0; }
  .btn-icon:hover { background: var(--bg-elevated); color: var(--text-primary); }

  .res-content-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0; position: relative; }

  .loader-pulse { width: 40px; height: 40px; border-radius: 50%; background: color-mix(in srgb, var(--accent) 20%, transparent); animation: pulse 1.5s infinite cubic-bezier(0.4, 0, 0.2, 1); margin-bottom: 16px; border: 2px solid var(--accent); }
  @keyframes pulse { 0% { transform: scale(0.8); opacity: 1; } 100% { transform: scale(1.5); opacity: 0; } }
  .loading-text { color: var(--text-primary); font-size: 14px; font-weight: 500; }
  .loading-url { color: var(--text-muted); font-size: 11px; margin-top: 6px; font-family: var(--font-mono); max-width: 80%; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .error-state { padding: 24px; background: color-mix(in srgb, var(--accent-red) 5%, transparent); border-bottom: 1px solid color-mix(in srgb, var(--accent-red) 15%, transparent); }
  .error-header { display: flex; align-items: center; gap: 8px; color: var(--accent-red); margin-bottom: 8px; }
  .error-desc { font-size: 13px; color: var(--text-secondary); font-family: var(--font-mono); }

  /* ✨ FIX 1: 让外部容器 `#res-content` 承接完整的纵向滚动，释放子级的包裹约束 */
  #res-content {
    overflow-y: auto;
    overflow-x: hidden;
    scroll-behavior: smooth;
  }
  #res-content::-webkit-scrollbar { width: 6px; }
  #res-content::-webkit-scrollbar-track { background: transparent; }
  #res-content::-webkit-scrollbar-thumb { background: var(--border-subtle); border-radius: 6px; }

  .res-headers { background: var(--bg-surface); border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; }
  .res-headers summary { padding: 10px 16px; font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); cursor: pointer; list-style: none; user-select: none; display: flex; align-items: center; }
  .res-headers summary::-webkit-details-marker { display: none; }
  .res-headers summary::before { content: "▸"; display: inline-block; width: 16px; transition: transform 0.2s; }
  .res-headers[open] summary::before { transform: rotate(90deg); }
  
  .res-headers-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 11.5px; }
  .res-headers-table td { padding: 6px 16px; border-top: 1px solid var(--border-subtle); color: var(--text-secondary); }
  .res-headers-table td:first-child { color: var(--text-primary); font-weight: 500; width: 30%; }

  /* ✨ FIX 1: 代码块 `fill-block` 去除局部滚动，转为 `flex: none` 自然撑开其高度 */
  .fill-block {
    flex: none;
    margin: 0;
    padding: 16px;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .res-preview { padding: 32px; display: flex; justify-content: center; align-items: center; background: repeating-conic-gradient(var(--bg-surface) 0% 25%, transparent 0% 50%) 50% / 20px 20px; border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; min-height: 200px; }
  .res-preview img { max-width: 100%; max-height: 400px; border-radius: var(--radii); box-shadow: 0 8px 32px rgba(0,0,0,0.4); border: 1px solid var(--border-subtle); }

  /* Syntax Highlighting */
  .hl-key { color: color-mix(in srgb, var(--accent) 70%, #a5b4fc); font-weight: 500; }
  .hl-str { color: var(--accent-green, #34d399); }
  .hl-num { color: var(--accent-orange, #fbbf24); }
  .hl-bool { color: var(--accent-blue, #60a5fa); font-weight: 500; }
  .hl-null { color: var(--text-muted); font-style: italic; }

  /* ====== HISTORY PANEL ====== */
  /* ✨ FIX 2: 重新绘制精美的高保真卡片化历史面板 UI */
  .history-panel { flex: 1; min-height: 0; overflow-y: auto; display: flex; flex-direction: column; background: var(--bg-elevated); padding: 20px; }
  .history-panel::-webkit-scrollbar { width: 6px; }
  .history-panel::-webkit-scrollbar-thumb { background: var(--border-subtle); border-radius: 6px; }

  .history-list { display: flex; flex-direction: column; gap: 12px; }
  .history-item {
    display: flex; align-items: center; gap: 16px; padding: 16px;
    border-radius: var(--radii); background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    cursor: pointer; transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
    position: relative; overflow: hidden;
  }
  .history-item::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: transparent; transition: background 0.25s;
  }
  .history-item:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border-subtle));
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .history-item:hover::before { background: var(--accent); }

  .history-item-left { display: flex; flex-direction: column; gap: 8px; align-items: center; width: 56px; flex-shrink: 0; }
  .history-item-method { font-family: var(--font-mono); font-size: 11px; font-weight: 700; padding: 4px 0; border-radius: 6px; text-align: center; letter-spacing: 0.05em; width: 100%; box-sizing: border-box; }
  .history-item-method.GET { color: var(--accent-green); background: color-mix(in srgb, var(--accent-green) 12%, transparent); }
  .history-item-method.POST { color: var(--accent-blue); background: color-mix(in srgb, var(--accent-blue) 12%, transparent); }
  .history-item-method.PUT { color: var(--accent-orange); background: color-mix(in srgb, var(--accent-orange) 12%, transparent); }
  .history-item-method.DELETE { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 12%, transparent); }

  .history-item-status-code { font-family: var(--font-mono); font-size: 11px; font-weight: 600; padding: 2px 6px; border-radius: 4px; }
  .history-item-status-code.ok { color: var(--accent-green); background: color-mix(in srgb, var(--accent-green) 10%, transparent); }
  .history-item-status-code.err { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 10%, transparent); }

  .history-item-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8px; padding: 2px 0; }
  .history-item-url { font-family: var(--font-mono); font-size: 13.5px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .history-item-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; font-size: 11.5px; color: var(--text-muted); font-family: var(--font-mono); }
  .history-item-meta span { display: flex; align-items: center; gap: 5px; }
  .history-item-meta svg { opacity: 0.6; }

  .history-item-actions { display: flex; gap: 8px; opacity: 0; transform: translateX(10px); transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1); }
  .history-item:hover .history-item-actions { opacity: 1; transform: translateX(0); }

  .history-btn { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 8px; color: var(--text-secondary); cursor: pointer; transition: all 0.2s; }
  .history-btn:hover { background: var(--bg-surface); color: var(--text-primary); border-color: var(--text-muted); transform: scale(1.05); }
  .history-btn.delete:hover { color: var(--accent-red); border-color: color-mix(in srgb, var(--accent-red) 30%, transparent); background: color-mix(in srgb, var(--accent-red) 10%, transparent); }
</style>

<script define:vars={{ siteUrl, flatJSON }}>
  window.__SITE_URL__ = siteUrl;
  window.__FLAT_JSON__ = flatJSON;
</script>

<script>
  (function() {
    var siteUrl = window.__SITE_URL__;
    var FLAT = JSON.parse(window.__FLAT_JSON__);
    var activeEP = FLAT[0];
    var isCustom = false;
    var lastResBody = '';

    // ── Debounce & Quota ──
    var lastRequestTime = 0;
    var DEBOUNCE_MS = 500;
    var DAILY_LIMIT = 100;
    var dailyCount = 0;

    function loadDailyCount() {
      try {
        var data = JSON.parse(localStorage.getItem('pg-daily') || '{}');
        var today = new Date().toISOString().slice(0, 10);
        dailyCount = (data.date === today) ? (data.count || 0) : 0;
      } catch(e) { dailyCount = 0; }
    }

    function incrementDailyCount() {
      dailyCount++;
      var today = new Date().toISOString().slice(0, 10);
      try { localStorage.setItem('pg-daily', JSON.stringify({ date: today, count: dailyCount })); } catch(e) {}
      updateQuotaHint();
      return dailyCount;
    }

    function updateQuotaHint() {
      var hint = getEl('pg-send-hint');
      var remaining = DAILY_LIMIT - dailyCount;
      if (remaining <= 15) {
        hint.style.color = remaining <= 5 ? 'var(--accent-red)' : 'var(--accent-orange)';
        hint.textContent = 'Daily quota: ' + dailyCount + '/' + DAILY_LIMIT + ' (' + remaining + ' left)';
      } else {
        hint.textContent = '';
      }
    }

    // ── Cache ──
    var responseCache = new Map();
    var CACHE_TTL = 5 * 60 * 1000;

    function getCached(method, url) {
      var key = method + '::' + url;
      var entry = responseCache.get(key);
      if (!entry) return null;
      if (Date.now() - entry.time > CACHE_TTL) { responseCache.delete(key); return null; }
      return entry.data;
    }

    function setCached(method, url, data) {
      var key = method + '::' + url;
      if (responseCache.size >= 50) responseCache.delete(responseCache.keys().next().value);
      responseCache.set(key, { time: Date.now(), data: data });
    }

    // ── History ──
    var HISTORY_KEY = 'pg-history';
    var HISTORY_MAX = 30;
    var historyEntries = [];

    function loadHistory() {
      try { var raw = localStorage.getItem(HISTORY_KEY); historyEntries = raw ? JSON.parse(raw) : []; } catch(e) { historyEntries = []; }
    }
    function persistHistory() {
      try { localStorage.setItem(HISTORY_KEY, JSON.stringify(historyEntries)); } catch(e) {}
    }
    function addHistoryEntry(entry) {
      historyEntries.unshift(entry);
      if (historyEntries.length > HISTORY_MAX) historyEntries = historyEntries.slice(0, HISTORY_MAX);
      persistHistory();
    }
    window.__deleteHistoryEntry = function(id) {
      historyEntries = historyEntries.filter(function(e) { return e.id !== id; });
      persistHistory(); renderHistoryPanel();
    }
    window.__rerunHistoryEntry = function(id) {
      var entry = historyEntries.find(function(e) { return e.id === id; });
      if (!entry) return;
      switchTab('response');
      getEl('method-select').value = entry.method;
      getEl('url-input').value = entry.path;
      syncURLPrefix();
      doSend();
    }
    window.__viewHistoryResponse = function(id) {
      var entry = historyEntries.find(function(e) { return e.id === id; });
      if (!entry) return;
      switchTab('response');
      
      getEl('pg-empty').style.display = 'none';
      getEl('pg-loading').style.display = 'none';
      getEl('pg-error').style.display = 'none';
      getEl('res-content').style.display = 'flex';
      getEl('res-toolbar').style.display = 'flex';

      getEl('res-status').className = 'status-code ' + (entry.status < 400 ? 'ok' : 'err');
      getEl('res-status').textContent = entry.status + ' ' + entry.statusText;
      getEl('res-time').textContent = formatDuration(entry.duration);
      getEl('res-time').className = 'res-time ' + durationClass(entry.duration);
      getEl('res-size').textContent = formatBytes(entry.size);

      lastResBody = entry.responseBody;
      var isImg = entry.contentType && entry.contentType.includes('image/');
      
      if (isImg) {
        getEl('res-preview').style.display = 'flex';
        getEl('res-preview').innerHTML = '<span style="color:var(--text-muted);font-size:12px;">Image preview not available in history</span>';
        getEl('res-body').innerHTML = esc(entry.responseBody);
      } else {
        getEl('res-preview').style.display = 'none';
        var formatted = esc(entry.responseBody);
        if (entry.contentType && entry.contentType.includes('json')) {
          try { formatted = hlJSON(JSON.stringify(JSON.parse(entry.responseBody), null, 2)); } catch(e) {}
        }
        getEl('res-body').innerHTML = formatted;
      }
      
      getEl('res-headers').innerHTML = '<tr><td colspan="2" style="text-align:center;font-style:italic;">Headers not stored in history</td></tr>';
      getEl('hdr-count').textContent = '0';
    }

    // ── Helpers ──
    function formatBytes(b) { if(b<1024)return b+' B'; if(b<1048576)return(b/1024).toFixed(1)+' KB'; return(b/1048576).toFixed(2)+' MB'; }
    function formatDuration(ms) { if(ms<1000)return ms+'ms'; return (ms/1000).toFixed(2)+'s'; }
    function durationClass(ms) { if(ms<200)return 'fast'; if(ms<800)return 'medium'; return 'slow'; }
    function formatTimestamp(ts) {
      var d = Date.now() - ts;
      if (d < 60000) return 'just now';
      if (d < 3600000) return Math.floor(d/60000) + 'm ago';
      if (d < 86400000) return Math.floor(d/3600000) + 'h ago';
      return Math.floor(d/86400000) + 'd ago';
    }
    function getEl(s) { return document.getElementById(s); }
    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    // Enhanced JSON syntax highlighter
    function hlJSON(json) {
      json = esc(json);
      return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
        var cls = 'hl-num';
        if (/^"/.test(match)) {
          if (/:$/.test(match)) cls = 'hl-key';
          else cls = 'hl-str';
        } else if (/true|false/.test(match)) {
          cls = 'hl-bool';
        } else if (/null/.test(match)) {
          cls = 'hl-null';
        }
        return '<span class="' + cls + '">' + match + '</span>';
      });
    }

    // ── URL Sync ──
    function syncURLPrefix() {
      var path = getEl('url-input').value.trim();
      var isAbs = path.startsWith('http://') || path.startsWith('https://');
      getEl('url-prefix').style.display = isAbs ? 'none' : 'inline-block';
    }
    getEl('url-input').addEventListener('input', syncURLPrefix);

    // ── UI Rendering ──
    function showDocs(ep) {
      getEl('docs-title').textContent = ep.label || 'Custom Request';
      getEl('docs-desc').textContent = ep.desc || 'Send a custom API request and explore the response.';
      getEl('docs-desc-card').textContent = ep.desc || 'No specific description provided.';
      getEl('docs-usage').textContent = ep.usage || 'N/A';
      getEl('docs-cache').textContent = ep.cache || 'No Cache';
      getEl('docs-curl').textContent = ep.curlExample || ('curl ' + siteUrl + (ep.path || '/'));

      var notesEl = getEl('docs-notes');
      if (ep.notes) { notesEl.innerHTML = '<strong>Notes:</strong> ' + ep.notes; notesEl.style.display = 'block'; }
      else { notesEl.style.display = 'none'; }

      var paramsEl = getEl('docs-params');
      var paramsTable = getEl('docs-params-table');
      var displayParams = (ep.params || []).filter(function(p) { return p.name !== 'body'; });
      if (displayParams.length > 0) {
        paramsTable.innerHTML = displayParams.map(function(p) {
          var badge = p.optional
            ? '<span style="color:var(--text-muted);font-size:10px;">optional</span>'
            : '<span style="color:var(--accent-red);font-size:10px;font-weight:500;">required</span>';
          var usage;
          if (p.isPath) {
            usage = 'Path: <code>' + esc(ep.path) + '</code>';
          } else if (p.type === 'select') {
            var opts = (p.options || []).filter(function(o) { return o; });
            usage = 'Query: <code>?' + esc(p.name) + '=&lt;' + esc(opts.join('|')) + '&gt;</code>';
          } else {
            usage = 'Query: <code>?' + esc(p.name) + '=' + esc(p.placeholder || '...') + '</code>';
          }
          var example = p.placeholder || (p.type === 'select' && p.options ? p.options.filter(function(o){return o;})[0] || '—' : '—');
          return '<tr>' +
            '<td>' + esc(p.name) + ' ' + badge + '<br><span style="color:var(--text-muted);font-size:10px;">type: ' + esc(p.type) + '</span></td>' +
            '<td>' + esc(p.label) + '<br><span style="font-size:11px;color:var(--accent);">' + usage + '</span><br><span style="color:var(--text-muted);font-size:10px;">e.g. ' + esc(example) + '</span></td>' +
            '</tr>';
        }).join('');
        paramsEl.style.display = 'block';
      } else {
        paramsEl.style.display = 'none';
      }

      var fieldsEl = getEl('docs-fields');
      var fieldsTable = getEl('docs-fields-table');
      if (ep.responseFields && ep.responseFields.length) {
        fieldsTable.innerHTML = ep.responseFields.map(f =>
          '<tr><td>' + esc(f.name) + '<br><span style="color:var(--text-muted);font-size:10px;font-weight:400;">' + esc(f.type) + '</span></td><td>' + esc(f.desc) + '</td></tr>'
        ).join('');
        fieldsEl.style.display = 'block';
      } else {
        fieldsEl.style.display = 'none';
      }
    }

    getEl('copy-curl-btn').addEventListener('click', function() {
      var curlCode = getEl('docs-curl').textContent;
      navigator.clipboard.writeText(curlCode).then(function() {
        var btn = getEl('copy-curl-btn');
        btn.classList.add('copied');
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
        setTimeout(function() { 
          btn.classList.remove('copied'); 
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
        }, 1500);
      });
    });

    window.__selectEndpoint = function(idx) {
      isCustom = false;
      getEl('custom-url-toggle').classList.remove('active');
      activeEP = FLAT[idx];

      getEl('method-select').value = activeEP.method;
      getEl('url-input').value = activeEP.path;
      syncURLPrefix();

      renderParams();
      highlightSidebar();
      showDocs(activeEP);

      getEl('body-section').style.display = ['POST','PUT','PATCH'].includes(activeEP.method) ? 'block' : 'none';
      if (activeEP.method === 'POST') {
        var bp = (activeEP.params || []).find(p => p.name === 'body');
        if (bp) getEl('body-editor').value = bp.placeholder || '';
        else getEl('body-editor').value = '';
      }

      resetResponseView();
    }

    function resetResponseView() {
      getEl('pg-empty').style.display = 'flex';
      getEl('pg-loading').style.display = 'none';
      getEl('pg-error').style.display = 'none';
      getEl('res-content').style.display = 'none';
      getEl('res-toolbar').style.display = 'none';
      switchTab('response');
    }

    function highlightSidebar() {
      document.querySelectorAll('.nav-item').forEach(el => {
        el.classList.toggle('active', el.getAttribute('data-idx') === String(activeEP._idx));
      });

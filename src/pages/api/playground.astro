---
import Layout from '../../layouts/Layout.astro';

// ==========================================
// Types & Interfaces (Server-Side)
// ==========================================

interface Param {
  name: string;
  type: 'text' | 'select' | 'textarea';
  label: string;
  placeholder?: string;
  optional: boolean;
  options?: string[];
  isPath?: boolean;
}

interface EndpointField {
  name: string;
  type: string;
  desc: string;
}

interface EndpointRaw {
  id: string;
  method: 'GET' | 'POST' | 'PUT' | 'DELETE';
  path: string;
  label: string;
  desc: string;
  usage: string;
  cache: string;
  responseFields?: EndpointField[];
  params?: Param[];
  curlExample?: string;
  notes?: string;
}

interface GroupRaw {
  name: string;
  items: EndpointRaw[];
}

interface EndpointParsed extends EndpointRaw {
  _idx: number;
  _gid: number;
  displayPath: string;
}

// ==========================================
// Data Processing
// ==========================================

const siteUrl = Astro.url.origin;

const rawGroups: GroupRaw[] = [
  {
    name: 'Core API',
    items: [
      { id:'today', method:'GET', path:'/api/v1/today.json', label:'Today Theme', desc:'获取每日主题的完整数据。包含 34 个 CSS 自定义属性、自定义 CSS 动画、声明式装饰元素数组。', usage:'将 cssVars 注入 :root，推荐配合 localStorage 缓存。', cache:'浏览器 1h / CDN 24h',
        notes:'返回的 cssVars 对象包含 --color-primary、--color-bg、--color-surface、--color-text、--radii、--shadow 等 34 个标准 CSS 自定义属性。同时返回 decorations 数组、animations 对象、以及 meta 元数据。支持 ?tz= 参数按目标时区计算日期。',
        responseFields:[
          {name:'cssVars',type:'object',desc:'34 个 CSS 自定义属性键值对'},
          {name:'decorations',type:'array',desc:'声明式装饰元素（位置、形状、颜色）'},
          {name:'animations',type:'object',desc:'CSS @keyframes 动画定义'},
          {name:'meta',type:'object',desc:'主题名、日期、节日、调色板等元数据'},
        ],
        params:[
          {name:'tz',type:'text',label:'时区',placeholder:'Asia/Shanghai',optional:true},
          {name:'overrides',type:'text',label:'CSS覆盖',placeholder:'--radii:0px',optional:true},
        ]
      },
      { id:'today-css', method:'GET', path:'/api/v1/today.css', label:'Today CSS', desc:'返回今日主题的纯 CSS。通过 link 标签阻塞引入可消除 FOUC。', usage:'在 head 中添加 <link rel="stylesheet" href="/api/v1/today.css">', cache:'浏览器 1h / CDN 24h',
        notes:'与 today.json 不同，此端点直接返回可用的 CSS 文本。因为是阻塞样式表，浏览器会在渲染前等待其加载完成，彻底消除无样式内容闪烁（FOUC）。',
        params:[{name:'tz',type:'text',label:'时区',placeholder:'Asia/Shanghai',optional:true}]
      },
      { id:'today-safe', method:'GET', path:'https://themedist-monitor.vercel.app/api/v1/today-safe', label:'Safe Proxy', desc:'安全主题代理。从 ThemeDist 获取最新数据并进行严格的 XSS 清洗与验证。', usage:'适用于直接注入外部站点的场景，返回 _meta 安全元数据。', cache:'无缓存',
        notes:'此端点运行在独立域名上作为安全隔离层。所有 CSS 属性值经过 DOMPurify 级清洗，移除 potential XSS 向量。'
      },
      { id:'date-lookup', method:'GET', path:'/api/v1/date={date}', label:'Date Lookup', desc:'按日期查询主题，格式 MM-DD。', usage:'用于日历组件、节日预览等场景。', cache:'浏览器 1h',
        notes:'路径参数 {date} 必须为 MM-DD 格式。查询逻辑按优先级：精确日期匹配 → 同月同日 → 最近节日回退。',
        params:[{name:'date',type:'text',label:'日期',placeholder:'02-14',optional:false,isPath:true}]
      },
      { id:'preset', method:'GET', path:'/api/v1/theme/{id}.json', label:'Theme Detail', desc:'获取指定预设或社区主题的完整数据。', usage:'用于固定主题或主题商店详情页。', cache:'预设 365d / 社区 1h',
        notes:'预设主题 ID 从静态 CDN 提供缓存 365 天。社区主题 ID 从数据库查询缓存 1 小时。不存在的 ID 返回 404。',
        params:[{name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false,isPath:true}]
      },
      { id:'random', method:'GET', path:'/api/v1/theme/random.json', label:'Random Theme', desc:'随机获取一个主题。支持池子过滤和确定性随机种子。', usage:'用于换肤按钮。相同 seed 始终返回相同结果。', cache:'不缓存',
        notes:'?pool=static/community/all 过滤池子。?seed= 接受字符串，基于 deterministic hash 返回确定性随机结果。',
        params:[
          {name:'pool',type:'select',label:'来源池',options:['','static','community','all'],optional:true}, 
          {name:'seed',type:'text',label:'随机种子',placeholder:'42',optional:true}
        ]
      },
      { id:'index-data', method:'GET', path:'/api/v1/index-data.json', label:'Index Data', desc:'首页聚合数据。包含当日主题、推荐列表、节假日映射等。', usage:'用于构建首页仪表盘。', cache:'浏览器 1h / CDN 24h',
        notes:'一次性返回首页所需的全部数据：today、featured、upcoming、popular。可减少多次 HTTP 请求。'
      },
    ]
  },
  {
    name: 'Diagnostics & Export',
    items: [
      { id:'wcag', method:'GET', path:'/api/v1/theme/{id}/wcag.json', label:'WCAG Audit', desc:'WCAG 2.1 无障碍诊断。评估颜色对比度及合规性。', usage:'包含 compliant 总览标记和 warnings 修复建议。', cache:'浏览器 1h',
        notes:'自动检测主题中所有前景/背景颜色组合的对比度。提供具体修复建议。'
      },
      { id:'scale', method:'GET', path:'/api/v1/theme/{id}/scale.json', label:'Tailwind Scale', desc:'基于黑白插值法生成完整的 Tailwind 风格 50~950 色阶。', usage:'返回 11 级色阶。', cache:'365d immutable',
        notes:'将主题主色与黑白分别在 OKLCH 色彩空间中做线性插值，生成 Tailwind 风格变量。'
      },
      { id:'shadcn', method:'GET', path:'/api/v1/theme/{id}/export/shadcn.css', label:'Shadcn UI', desc:'Shadcn UI 适配器，转换为 HSL 变量体系。', usage:'直接复制输出到 globals.css 中。', cache:'365d immutable',
        notes:'自动完成 HEX → HSL 转换，并基于 WCAG 自动推断 foreground 色，覆盖全套 Shadcn 语义变量。'
      },
      { id:'shiki', method:'GET', path:'/api/v1/theme/{id}/shiki.json', label:'Shiki Theme', desc:'映射为 Shiki / VS Code 的 TextMate Token 颜色。', usage:'直接导入 VS Code。', cache:'365d immutable',
        notes:'将主题映射为 keyword, string, comment 等 20+ 种语义标记。'
      },
      { id:'extract', method:'POST', path:'/api/v1/extract-theme.json', label:'Image Extra', desc:'图片取色 API。纯 JS 进行 K-means 聚类并映射为 UI 标准变量。', usage:'POST 图片 URL。', cache:'不缓存',
        notes:'支持 jpg/png/webp/avif 格式。图片 URL 必须可公开访问。返回标准 34 个 CSS 变量。',
        params:[{name:'body',type:'textarea',label:'JSON Body',placeholder:'{\n  "imageUrl": "https://example.com/poster.jpg"\n}',optional:false}]
      }
    ]
  },
  {
    name: 'Tools & Assets',
    items: [
      { id:'tailwind-config', method:'GET', path:'/api/v1/tailwind-config.json', label:'Tailwind Conf', desc:'生成 Tailwind CSS v3/v4 配置片段。', usage:'处理 RGB 通道不透明度支持。', cache:'浏览器 1h',
        notes:'兼容 v3 tailwind.config.js 和 v4 CSS-first 配置。'
      },
      { id:'tokens', method:'GET', path:'/api/v1/tokens.json', label:'Design Tokens', desc:'导出符合 W3C DTCG 规范的 JSON 设计令牌。', usage:'用于导入 Figma 或 Style Dictionary。', cache:'浏览器 1h',
        notes:'包含所有 CSS 变量及其语义分组。'
      },
      { id:'svg-pattern', method:'GET', path:'/api/v1/today/pattern.css', label:'SVG Pattern', desc:'根据今日主题色生成几何图案背景纹理。', usage:'作为 background-image 使用。', cache:'浏览器 1h',
        notes:'生成 data-uri 内联的 SVG 几何图案，图案类型每日轮换。'
      },
      { id:'weather-js', method:'GET', path:'/api/v1/today/weather.js', label:'Weather Particles', desc:'天气粒子动画脚本。云/雨/雪/雷暴特效。', usage:'引入脚本自动渲染。', cache:'浏览器 1h / CDN 24h',
        notes:'自动创建 Canvas 层，根据天气代码选择动画。60fps。'
      },
      { id:'favicon', method:'GET', path:'/api/v1/today/favicon.svg', label:'Dynamic Favicon', desc:'根据今日主题色实时生成 SVG Favicon。', usage:'作为 <link rel="icon"> 引入。', cache:'浏览器 1h',
        notes:'支持通过 ?text= 自定义文字、?bg= 自定义背景色。'
      },
      { id:'search-color', method:'GET', path:'/api/v1/search/color.json', label:'Color Search', desc:'RGB 欧几里得距离计算相似颜色主题。', usage:'传入 hex 寻找匹配。', cache:'浏览器 1h',
        notes:'返回最匹配的主题及 distance 数值。',
        params:[{name:'hex',type:'text',label:'Hex颜色',placeholder:'ff6b6b',optional:false}, {name:'limit',type:'text',label:'数量限制',placeholder:'10',optional:true}]
      }
    ]
  },
  {
    name: 'Environment Context',
    items: [
      { id:'weather-theme', method:'GET', path:'/api/v1/weather-theme.json', label:'Weather Adaptive', desc:'跨平台嗅探地理位置并匹配对应的天气主题。', usage:'支持通过 ?lat= & ?lon= 覆盖检测。', cache:'30min',
        notes:'自动嗅探 IP 并调用 Open-Meteo 获取当前天气进行匹配。',
        params:[{name:'lat',type:'text',label:'纬度',placeholder:'35.68',optional:true}, {name:'lon',type:'text',label:'经度',placeholder:'139.76',optional:true}]
      },
      { id:'status-override', method:'GET', path:'/api/v1/status-override.json', label:'Status Override', desc:'系统状态主题。维护/哀悼/故障。', usage:'用于兜底页及重大状态提示。', cache:'5min',
        notes:'维护(纯灰)/哀悼(暗黑+滤镜)/故障(红色警示)，全局接管客户端视觉。'
      }
    ]
  },
  {
    name: 'Community & AI',
    items: [
      { id:'diy-list', method:'GET', path:'/api/v1/diy/themes.json', label:'Themes List', desc:'获取社区已审核的主题。', usage:'支持多种维度的 tag 查询。', cache:'1min',
        notes:'审核状态为 "approved" 的主题才会出现在列表中。',
        params:[{name:'sort',type:'select',label:'排序',options:['new','hot'],optional:true}, {name:'tag',type:'select',label:'标签',options:['','dark','light','warm','cool','tech'],optional:true}]
      },
      { id:'ai-generate', method:'POST', path:'/api/v1/ai/generate.json', label:'AI Generate', desc:'根据描述生成 CSS 配色。', usage:'支持规则引擎或 DeepSeek。', cache:'不缓存',
        notes:'双引擎策略：简单描述使用规则引擎，复杂描述自动路由到大模型分析。',
        params:[{name:'body',type:'textarea',label:'Body',placeholder:'{"prompt": "neon cyberpunk matrix"}',optional:false}]
      }
    ]
  }
];

function parseEndpoint(ep: EndpointRaw, _idx: number, _gid: number): EndpointParsed {
  const pathParamsMatch = ep.path.match(/\{([^}]+)\}/g);
  const pathParams = pathParamsMatch ? pathParamsMatch.map(m => m.slice(1, -1)) : [];
  const params: Param[] = ep.params ? [...ep.params] : [];

  if (pathParams.length > 0) {
    pathParams.forEach(pp => {
      const existing = params.find(p => p.name === pp);
      if (!existing) {
        params.unshift({ name: pp, type: 'text', label: `Path Param ${pp}`, placeholder: '...', optional: false, isPath: true });
      } else {
        existing.isPath = true;
      }
    });
  }

  let curlPath = ep.path;
  params.filter(p => p.isPath).forEach(p => { 
    curlPath = curlPath.replace(`{${p.name}}`, p.placeholder || 'xxx'); 
  });
  
  const isAbs = curlPath.startsWith('http');
  const curlExample = ep.curlExample || `curl ${isAbs ? '' : siteUrl}${curlPath}`;
  
  let displayPath = ep.path.startsWith('http') ? ep.path : ep.path.replace(/^\/api\/v1/, '');
  if (displayPath === '') displayPath = '/';

  return { ...ep, params, curlExample, displayPath, _idx, _gid };
}

let epIndex = 0;
const flatEndpoints = rawGroups.flatMap((g, gi) => g.items.map(ep => parseEndpoint(ep, epIndex++, gi)));
const flatJSON = JSON.stringify(flatEndpoints);
---

<Layout title="API Playground | Enterprise">
  <div id="pg-app-root" class="dashboard-layout" data-site-url={siteUrl} data-endpoints={flatJSON}>

    <!-- Ambient background (A11y respected via CSS prefers-reduced-motion) -->
    <div class="pg-amb" aria-hidden="true">
      <div class="pg-amb-orb"></div>
      <div class="pg-amb-orb"></div>
      <div class="pg-amb-grain"></div>
    </div>

    <!-- ====== LEFT SIDEBAR ====== -->
    <nav class="sidebar" aria-label="API Endpoint Navigation">
      <div class="sidebar-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2"/></svg>
        <span class="sidebar-title">ThemeDist API</span>
      </div>

      <div class="sidebar-scroll" id="pg-sidebar" role="tablist" aria-orientation="vertical">
        {rawGroups.map((g) => (
          <div class="nav-group" role="group" aria-label={g.name}>
            <div class="nav-group-title">{g.name}</div>
            {g.items.map((ep) => {
              const flatItem = flatEndpoints.find(f => f.id === ep.id);
              return (
                <button type="button" class="nav-item" role="tab" aria-selected="false" data-idx={flatItem?._idx}>
                  <span class={`method ${ep.method}`} aria-label={`Method ${ep.method}`}>{ep.method}</span>
                  <span class="path" title={flatItem?.displayPath}>{flatItem?.displayPath}</span>
                </button>
              )
            })}
          </div>
        ))}
        <div class="nav-group border-separator">
           <button type="button" class="nav-item custom" id="custom-url-toggle" role="tab" aria-selected="false">
             <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 3H4a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1v-3"/><path d="M16 2L9 9"/><path d="M11 2h5v5"/></svg>
             <span class="path margin-left">Custom Request</span>
           </button>
        </div>
      </div>
    </nav>

    <!-- ====== RIGHT MAIN ====== -->
    <main class="main-content" aria-label="Playground Workspace">

      <!-- Header & URL Form -->
      <div class="main-header">
        <header class="page-header">
          <h1 class="page-title" id="docs-title">API Playground</h1>
          <p class="page-desc" id="docs-desc">Select an endpoint to explore.</p>
        </header>

        <form id="request-form" class="url-bar-container" aria-label="Request Builder">
          <select class="url-method" id="method-select" aria-label="HTTP Method">
            <option value="GET">GET</option>
            <option value="POST">POST</option>
            <option value="PUT">PUT</option>
            <option value="DELETE">DELETE</option>
          </select>
          <div class="url-input-wrap">
            <span class="url-prefix" id="url-prefix">{siteUrl}</span>
            <input type="text" class="url-input" id="url-input" spellcheck="false" autocomplete="off" aria-label="Request URL path" />
          </div>
          <button type="submit" class="btn-send" id="pg-send">Send Request</button>
          <span class="kbd-hint" aria-hidden="true">Ctrl+Enter</span>
        </form>

        <div class="rate-limit-hint" id="pg-send-hint" aria-live="polite"></div>
      </div>

      <!-- 2-Column Content Grid -->
      <div class="content-grid">

        <!-- LEFT COL: Request Config -->
        <section class="request-col" aria-label="Request Configuration">
          
          <header class="panel-title">
            <h2>Parameters</h2>
            <button type="button" class="btn-add" id="param-add" aria-label="Add custom parameter">+ Add</button>
          </header>
          
          <div class="params-box">
            <div class="params-list" id="params-list"></div>
            <div id="no-params" class="empty-state">No parameters required.</div>
          </div>

          <div id="body-section" class="hidden">
            <header class="panel-title">
              <h2>Body <span class="badge">JSON</span></h2>
              <button type="button" class="btn-add" id="body-format" aria-label="Format JSON Body">Format</button>
            </header>
            <textarea class="body-editor" id="body-editor" spellcheck="false" aria-label="Request JSON Body"></textarea>
            <div class="feedback" id="body-feedback" aria-live="polite"></div>
          </div>

          <!-- Documentation Area -->
          <article class="docs-mini">
            <h2 class="panel-title margin-top-lg">Documentation</h2>
            <div class="docs-card">
              <div class="docs-meta">
                <div class="meta-item">
                  <span class="meta-label">Cache</span>
                  <span id="docs-cache" class="meta-value color-highlight">—</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Usage</span>
                  <span id="docs-usage" class="meta-value">—</span>
                </div>
              </div>
              <div id="docs-notes" class="docs-notes"></div>
              <div id="docs-fields" class="hidden docs-fields">
                <span class="meta-label">Response Fields</span>
                <table class="res-headers-table margin-top-sm" id="docs-fields-table"></table>
              </div>
            </div>
            <pre id="docs-curl" class="code-block curl-block" aria-label="cURL Command"></pre>
            <button type="button" class="btn-add margin-top-sm" id="copy-curl-btn">Copy cURL</button>
          </article>

        </section>

        <!-- RIGHT COL: Response View -->
        <section class="response-col" aria-label="Response Workspace">
          <header class="panel-title sr-only"><h2>Response & History</h2></header>

          <!-- Tabs -->
          <nav class="res-tabs" id="res-tabs" aria-label="Workspace Tabs">
            <button type="button" class="res-tab" aria-selected="true" data-tab="response">Response</button>
            <button type="button" class="res-tab" aria-selected="false" data-tab="history">History</button>
            <button type="button" class="res-tab-btn hidden" id="history-clear" title="Clear all history">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
              <span class="sr-only">Clear History</span>
            </button>
          </nav>

          <!-- Response Box -->
          <div class="response-box" id="response-box">
            
            <header class="res-toolbar hidden" id="res-toolbar">
              <div class="res-status-wrap" aria-live="polite">
                <span id="res-status" class="status-code"></span>
                <span id="res-time" class="res-time"></span>
                <span id="res-size" class="res-size"></span>
              </div>
              <button type="button" class="btn-icon" id="res-copy" title="Copy response" aria-label="Copy Response">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              </button>
            </header>

            <div class="res-content-area">
              
              <div id="pg-empty" class="empty-state padded">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="icon-faded"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                <p class="margin-bottom-sm">Hit <strong class="color-accent">Send Request</strong> to execute.</p>
                <p class="text-xs color-muted">Or press <kbd class="kbd">Ctrl+Enter</kbd></p>
              </div>

              <div id="pg-loading" class="empty-state padded hidden" aria-live="assertive">
                <div class="spinner" aria-hidden="true"></div>
                <span class="text-sm color-muted">Sending request...</span>
                <span class="text-xs color-muted margin-top-xs block" id="pg-loading-url"></span>
              </div>

              <div id="pg-error" class="error-state hidden" aria-live="assertive">
                <div class="error-header">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                  <strong>Request Failed</strong>
                </div>
                <span id="pg-error-msg" class="text-sm color-secondary"></span>
              </div>

              <div id="res-content" class="res-flex-content hidden">
                <details class="res-headers">
                  <summary>Headers (<span id="hdr-count"></span>)</summary>
                  <table class="res-headers-table" id="res-headers"></table>
                </details>

                <div id="res-preview" class="res-preview hidden"></div>
                <pre id="res-body" class="code-block fill-block" aria-label="Response Body"></pre>
              </div>

            </div>
          </div>

          <!-- History Panel -->
          <div class="history-panel hidden" id="history-panel">
            <div class="history-list" id="history-list" role="list"></div>
            <div class="empty-state padded" id="history-empty">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon-faded margin-bottom-sm"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <p class="text-sm color-muted">No request history yet.</p>
            </div>
          </div>

        </section>
      </div>
    </main>
  </div>
</Layout>

<!-- ==========================================
     Client-Side Script (TypeScript Native in Astro)
=========================================== -->
<script>
  // ------------------------------------------
  // Core Types
  // ------------------------------------------
  interface Param { name: string; type: string; placeholder?: string; options?: string[]; }
  interface EndpointParsed { 
    id: string; method: string; path: string; label: string; desc: string; usage: string; cache: string; 
    notes?: string; curlExample?: string; params?: Param[]; responseFields?: any[]; displayPath: string; _idx: number; 
  }
  
  interface HistoryEntry {
    id: string; timestamp: number; method: string; path: string; fullUrl: string;
    status: number; statusText: string; duration: number; size: number;
    contentType: string; responseBody: string;
  }

  // ------------------------------------------
  // Utility & Storage Services
  // ------------------------------------------
  const DOMUtils = {
    esc: (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'),
    formatBytes: (b: number) => b < 1024 ? `${b} B` : b < 1048576 ? `${(b/1024).toFixed(1)} KB` : `${(b/1048576).toFixed(2)} MB`,
    formatDuration: (ms: number) => ms < 1000 ? `${ms}ms` : ms < 10000 ? `${(ms/1000).toFixed(1)}s` : `${(ms/1000).toFixed(0)}s`,
    durationClass: (ms: number) => ms < 100 ? 'fast' : ms < 500 ? 'medium' : 'slow',
    timeAgo: (ts: number) => {
      const diff = Date.now() - ts;
      if (diff < 60000) return 'just now';
      if (diff < 3600000) return `${Math.floor(diff/60000)}m ago`;
      if (diff < 86400000) return `${Math.floor(diff/3600000)}h ago`;
      return `${Math.floor(diff/86400000)}d ago`;
    },
    hlJSON: (jsonStr: string) => {
      return DOMUtils.esc(jsonStr)
        .replace(/("(?:[^"\\]|\\.)*")\s*:/g, '<span class="hl-key">$1</span>:')
        .replace(/"((?:[^"\\]|\\.)*)"/g, '<span class="hl-str">"$1"</span>')
        .replace(/\b(true|false|null)\b/g, '<span class="hl-bool">$1</span>')
        .replace(/:\s*(-?\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)/g, ': <span class="hl-num">$1</span>');
    }
  };

  class StorageService {
    static get<T>(key: string, fallback: T): T {
      try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : fallback; } catch { return fallback; }
    }
    static set(key: string, val: any): void {
      try { localStorage.setItem(key, JSON.stringify(val)); } catch(e) { console.warn('Storage unavailable', e); }
    }
  }

  class QuotaService {
    static LIMIT = 100;
    static KEY = 'pg_daily_quota_v2';
    
    static getUsage(): number {
      const today = new Date().toISOString().slice(0,10);
      const data = StorageService.get(this.KEY, { date: today, count: 0 });
      return data.date === today ? data.count : 0;
    }
    static increment(): number {
      const today = new Date().toISOString().slice(0,10);
      const next = this.getUsage() + 1;
      StorageService.set(this.KEY, { date: today, count: next });
      return next;
    }
  }

  class HistoryService {
    static KEY = 'pg_history_v2';
    static MAX = 50;
    
    static load(): HistoryEntry[] { return StorageService.get(this.KEY, []); }
    static clear(): void { StorageService.set(this.KEY, []); }
    static remove(id: string): void {
      const items = this.load().filter(e => e.id !== id);
      StorageService.set(this.KEY, items);
    }
    static add(entry: HistoryEntry): void {
      const items = this.load();
      items.unshift(entry);
      if (items.length > this.MAX) items.length = this.MAX;
      StorageService.set(this.KEY, items);
    }
  }

  class CacheService {
    static cache = new Map<string, { time: number, data: any }>();
    static TTL = 5 * 60 * 1000;
    
    static get(key: string) {
      const e = this.cache.get(key);
      if (!e) return null;
      if (Date.now() - e.time > this.TTL) { this.cache.delete(key); return null; }
      return e.data;
    }
    static set(key: string, data: any) {
      if (this.cache.size >= 50) this.cache.delete(this.cache.keys().next().value!);
      this.cache.set(key, { time: Date.now(), data });
    }
  }

  // ------------------------------------------
  // Main Controller
  // ------------------------------------------
  class ApiPlaygroundApp {
    private siteUrl: string;
    private endpoints: EndpointParsed[];
    private activeEp!: EndpointParsed;
    private isCustom = false;
    
    private lastRequestTime = 0;
    private lastResBody = '';

    private els: Record<string, HTMLElement> = {};

    constructor(root: HTMLElement) {
      this.siteUrl = root.dataset.siteUrl || window.location.origin;
      this.endpoints = JSON.parse(root.dataset.endpoints || '[]');
      
      this.cacheDOM();
      this.bindEvents();
      this.updateQuotaUI();
      this.renderHistory();
      
      if (this.endpoints.length) this.selectEndpoint(0);
    }

    private cacheDOM() {
      const ids = [
        'pg-sidebar', 'custom-url-toggle', 'request-form', 'method-select', 'url-input', 'url-prefix', 'pg-send', 'pg-send-hint',
        'params-list', 'no-params', 'param-add', 'body-section', 'body-editor', 'body-feedback', 'body-format',
        'docs-title', 'docs-desc', 'docs-usage', 'docs-cache', 'docs-notes', 'docs-fields', 'docs-fields-table', 'docs-curl', 'copy-curl-btn',
        'res-tabs', 'response-box', 'history-panel', 'history-list', 'history-empty', 'history-clear',
        'pg-empty', 'pg-loading', 'pg-loading-url', 'pg-error', 'pg-error-msg',
        'res-content', 'res-toolbar', 'res-status', 'res-time', 'res-size', 'res-copy',
        'res-headers', 'hdr-count', 'res-preview', 'res-body'
      ];
      ids.forEach(id => {
        const el = document.getElementById(id);
        if (el) this.els[id] = el;
      });
    }

    private bindEvents() {
      // Sidebar Navigation
      this.els['pg-sidebar'].addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.nav-item');
        if (!btn) return;
        if (btn.id === 'custom-url-toggle') this.enableCustomMode();
        else if (btn.hasAttribute('data-idx')) this.selectEndpoint(Number(btn.getAttribute('data-idx')));
      });

      // URL prefix sync
      this.els['url-input'].addEventListener('input', () => this.syncUrlPrefix());
      this.els['method-select'].addEventListener('change', (e) => {
        this.toggleBodySection((e.target as HTMLSelectElement).value !== 'GET');
      });

      // Submit form
      this.els['request-form'].addEventListener('submit', (e) => {
        e.preventDefault();
        this.executeRequest();
      });

      // Global shortcut
      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
          e.preventDefault();
          this.executeRequest();
        }
      });

      // Params Delegation
      this.els['param-add'].addEventListener('click', () => this.addParamRow());
      this.els['params-list'].addEventListener('click', (e) => {
        const delBtn = (e.target as HTMLElement).closest('.param-del');
        if (!delBtn) return;
        const row = delBtn.closest('.param-row') as HTMLElement;
        if (row.dataset.fixed === 'true') {
          const input = row.querySelector('.param-val, .param-val-sel') as HTMLInputElement;
          if (input) input.tagName === 'SELECT' ? (input as HTMLSelectElement).selectedIndex = 0 : input.value = '';
        } else {
          row.remove();
          if (this.els['params-list'].children.length === 0) {
             this.els['no-params'].classList.remove('hidden');
             this.els['params-list'].classList.add('hidden');
          }
        }
      });

      // Utilities
      this.els['body-format'].addEventListener('click', () => this.formatBody());
      this.els['copy-curl-btn'].addEventListener('click', () => this.copyToClipboard(this.els['docs-curl'].textContent || '', this.els['copy-curl-btn'], 'Copy cURL'));
      this.els['res-copy'].addEventListener('click', () => this.copyToClipboard(this.lastResBody, this.els['res-copy'], ''));

      // Tabs
      this.els['res-tabs'].addEventListener('click', (e) => {
        const tab = (e.target as HTMLElement).closest('.res-tab');
        if (tab) this.switchTab(tab.getAttribute('data-tab')!);
      });

      // History
      this.els['history-clear'].addEventListener('click', () => {
        if (confirm('Clear all request history?')) { HistoryService.clear(); this.renderHistory(); }
      });
      this.els['history-list'].addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const item = target.closest('.history-item');
        if (!item) return;
        const id = item.getAttribute('data-id')!;
        
        if (target.closest('[data-action="rerun"]')) this.rerunHistoryEntry(id);
        else if (target.closest('[data-action="delete"]')) { HistoryService.remove(id); this.renderHistory(); }
        else this.viewHistoryResponse(id);
      });
    }

    // --- Core UI State ---
    private selectEndpoint(idx: number) {
      this.isCustom = false;
      this.activeEp = this.endpoints[idx];
      
      // Update UI Highlights
      this.els['pg-sidebar'].querySelectorAll('.nav-item').forEach(el => el.setAttribute('aria-selected', 'false'));
      this.els['pg-sidebar'].querySelector(`[data-idx="${idx}"]`)?.setAttribute('aria-selected', 'true');

      // Form State
      (this.els['method-select'] as HTMLSelectElement).value = this.activeEp.method;
      (this.els['url-input'] as HTMLInputElement).value = this.activeEp.path;
      this.syncUrlPrefix();
      
      this.renderParams(this.activeEp.params || []);
      this.toggleBodySection(this.activeEp.method !== 'GET');
      this.renderDocs(this.activeEp);
      this.resetResponseView();
    }

    private enableCustomMode() {
      this.isCustom = true;
      this.els['pg-sidebar'].querySelectorAll('.nav-item').forEach(el => el.setAttribute('aria-selected', 'false'));
      this.els['custom-url-toggle'].setAttribute('aria-selected', 'true');

      (this.els['url-input'] as HTMLInputElement).value = '/api/v1/';
      this.syncUrlPrefix();
      
      this.els['params-list'].innerHTML = '';
      this.els['no-params'].classList.remove('hidden');
      this.els['params-list'].classList.add('hidden');
      
      this.toggleBodySection((this.els['method-select'] as HTMLSelectElement).value !== 'GET');
      
      this.renderDocs({ label: 'Custom Request', method: 'GET', path: '/api/v1/', desc: 'Execute a custom HTTP request.', usage: '—', cache: '—', displayPath: '/', _idx: -1, _gid: -1 });
      this.resetResponseView();
    }

    // --- Renderer Helpers ---
    private renderParams(params: Param[]) {
      const list = this.els['params-list'];
      const empty = this.els['no-params'];
      list.innerHTML = '';
      
      const visible = params.filter(p => p.name !== 'body');
      if (visible.length === 0) {
        empty.classList.remove('hidden');
        list.classList.add('hidden');
        return;
      }
      
      empty.classList.add('hidden');
      list.classList.remove('hidden');

      visible.forEach(p => {
        const row = document.createElement('div');
        row.className = 'param-row';
        row.dataset.fixed = 'true';
        
        let valHTML = p.type === 'select' 
          ? `<select class="param-val-sel" aria-label="${p.name} value">${(p.options||[]).map(o => `<option value="${DOMUtils.esc(o)}">${DOMUtils.esc(o||'—')}</option>`).join('')}</select>`
          : `<input class="param-val" type="text" placeholder="${DOMUtils.esc(p.placeholder||'')}" aria-label="${p.name} value" />`;

        row.innerHTML = `
          <input class="param-key" type="text" value="${DOMUtils.esc(p.name)}" readonly aria-label="Key" />
          <span class="param-eq" aria-hidden="true">=</span>
          ${valHTML}
          <button type="button" class="param-del" title="Clear value" aria-label="Clear value">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
          </button>`;
        list.appendChild(row);
      });
    }

    private addParamRow() {
      this.els['no-params'].classList.add('hidden');
      this.els['params-list'].classList.remove('hidden');
      
      const row = document.createElement('div');
      row.className = 'param-row';
      row.innerHTML = `
        <input class="param-key" type="text" placeholder="Key" aria-label="Key" />
        <span class="param-eq" aria-hidden="true">=</span>
        <input class="param-val" type="text" placeholder="Value" aria-label="Value" />
        <button type="button" class="param-del" title="Remove parameter" aria-label="Remove parameter">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
        </button>`;
      this.els['params-list'].appendChild(row);
    }

    private toggleBodySection(show: boolean) {
      if (show) {
        this.els['body-section'].classList.remove('hidden');
        if (!this.isCustom && this.activeEp?.params) {
          const bp = this.activeEp.params.find(p => p.name === 'body');
          const editor = this.els['body-editor'] as HTMLTextAreaElement;
          if (bp && !editor.value) editor.value = bp.placeholder || '';
        }
      } else {
        this.els['body-section'].classList.add('hidden');
      }
    }

    private renderDocs(ep: EndpointParsed | any) {
      this.els['docs-title'].textContent = ep.label;
      this.els['docs-desc'].textContent = ep.desc;
      this.els['docs-usage'].textContent = ep.usage;
      this.els['docs-cache'].textContent = ep.cache;
      this.els['docs-curl'].textContent = ep.curlExample || `curl ${this.siteUrl}${ep.path}`;

      const notesEl = this.els['docs-notes'];
      notesEl.textContent = ep.notes || '';
      ep.notes ? notesEl.classList.remove('hidden') : notesEl.classList.add('hidden');

      const fieldsEl = this.els['docs-fields'];
      const ft = this.els['docs-fields-table'];
      if (ep.responseFields?.length) {
        ft.innerHTML = ep.responseFields.map((f:any) => `<tr><td><code>${DOMUtils.esc(f.name)}</code> <span class="text-xs color-muted">${DOMUtils.esc(f.type)}</span></td><td>${DOMUtils.esc(f.desc)}</td></tr>`).join('');
        fieldsEl.classList.remove('hidden');
      } else {
        fieldsEl.classList.add('hidden');
      }
    }

    // --- Actions & Network ---
    private buildUrl(): string {
      let path = (this.els['url-input'] as HTMLInputElement).value.trim();
      const isAbs = path.startsWith('http://') || path.startsWith('https://');
      if (!isAbs && !path.startsWith('/')) path = '/' + path;

      const qp = new URLSearchParams();
      this.els['params-list'].querySelectorAll('.param-row').forEach(row => {
        const key = (row.querySelector('.param-key') as HTMLInputElement)?.value.trim();
        const val = (row.querySelector('.param-val, .param-val-sel') as HTMLInputElement)?.value.trim();
        if (!key) return;

        if (path.includes(`{${key}}`)) path = path.replace(`{${key}}`, encodeURIComponent(val));
        else if (val) qp.append(key, val);
      });

      path = path.replace(/\{[^}]+\}/g, '');
      const query = qp.toString();
      if (query) path += (path.includes('?') ? '&' : '?') + query;
      
      return isAbs ? path : this.siteUrl + path;
    }

    private async executeRequest() {
      const now = Date.now();
      if (now - this.lastRequestTime < 500) return;
      this.lastRequestTime = now;

      if (QuotaService.getUsage() >= QuotaService.LIMIT) {
        this.showNetworkError(`Daily quota reached (${QuotaService.LIMIT}/${QuotaService.LIMIT}).`);
        return;
      }

      const method = (this.els['method-select'] as HTMLSelectElement).value;
      const url = this.buildUrl();

      if (method === 'GET') {
        const cached = CacheService.get(`${method}:${url}`);
        if (cached) return this.displayResponse(cached, true);
      }

      this.setLoadingState(method, url);
      const t0 = performance.now();
      
      try {
        const bodyStr = (this.els['body-editor'] as HTMLTextAreaElement).value.trim();
        const headers: HeadersInit = {};
        if (method !== 'GET' && method !== 'HEAD' && bodyStr) {
          headers['Content-Type'] = 'application/json';
        }

        const res = await fetch(url, { method, headers, body: (method !== 'GET' && bodyStr) ? bodyStr : undefined });
        const elapsed = Math.round(performance.now() - t0);
        
        let hdrRows = '', hdrNum = 0;
        res.headers.forEach((v, k) => { hdrRows += `<tr><td>${DOMUtils.esc(k)}</td><td>${DOMUtils.esc(v)}</td></tr>`; hdrNum++; });
        this.els['res-headers'].innerHTML = hdrRows;
        this.els['hdr-count'].textContent = String(hdrNum);

        const contentType = res.headers.get('content-type') || '';
        const text = await res.text();
        const size = new Blob([text]).size;

        const resData = { ok: res.ok, status: res.status, statusText: res.statusText, elapsed, size, contentType, text };

        if (method === 'GET' && res.ok) CacheService.set(`${method}:${url}`, resData);
        
        this.displayResponse(resData, false);
        QuotaService.increment();
        this.updateQuotaUI();

        HistoryService.add({
          id: Math.random().toString(36).slice(2),
          timestamp: Date.now(),
          method, path: (this.els['url-input'] as HTMLInputElement).value, fullUrl: url,
          status: res.status, statusText: res.statusText, duration: elapsed, size, contentType,
          responseBody: text.length > 10240 ? text.slice(0, 10240) + '\n... (truncated)' : text
        });
        this.renderHistory();

      } catch (err) {
        this.showNetworkError(err instanceof Error ? err.message : 'Network connection failed.');
      } finally {
        (this.els['pg-send'] as HTMLButtonElement).disabled = false;
      }
    }

    private displayResponse(data: any, fromCache: boolean) {
      this.lastResBody = data.text;
      const preview = this.els['res-preview'];
      
      if (data.contentType.includes('image/')) {
        const blobUrl = URL.createObjectURL(new Blob([data.text], { type: data.contentType }));
        preview.innerHTML = `<img src="${blobUrl}" alt="Preview" />`;
        preview.classList.remove('hidden');
      } else {
        preview.classList.add('hidden');
      }

      let formatted = DOMUtils.esc(data.text);
      if (data.contentType.includes('json')) {
        try { formatted = DOMUtils.hlJSON(JSON.stringify(JSON.parse(data.text), null, 2)); } catch(e) {}
      }
      this.els['res-body'].innerHTML = formatted;

      const okClass = data.ok ? 'ok' : 'err';
      this.els['res-status'].className = `status-code ${okClass}`;
      this.els['res-status'].textContent = `${data.status} ${data.statusText}${fromCache ? ' (cached)' : ''}`;
      
      this.els['res-time'].className = `res-time ${fromCache ? '' : DOMUtils.durationClass(data.elapsed)}`;
      this.els['res-time'].textContent = fromCache ? '(cache)' : DOMUtils.formatDuration(data.elapsed);
      this.els['res-size'].textContent = DOMUtils.formatBytes(data.size);

      this.els['pg-loading'].classList.add('hidden');
      this.els['res-toolbar'].classList.remove('hidden');
      this.els['res-content'].classList.remove('hidden');
    }

    // --- State Handlers ---
    private resetResponseView() {
      this.els['pg-empty'].classList.remove('hidden');
      ['pg-loading', 'pg-error', 'res-toolbar', 'res-content'].forEach(id => this.els[id].classList.add('hidden'));
    }

    private setLoadingState(method: string, url: string) {
      this.resetResponseView();
      this.els['pg-empty'].classList.add('hidden');
      this.els['pg-loading'].classList.remove('hidden');
      this.els['pg-loading-url'].textContent = `${method} ${url}`;
      (this.els['pg-send'] as HTMLButtonElement).disabled = true;
    }

    private showNetworkError(msg: string) {
      this.els['pg-loading'].classList.add('hidden');
      this.els['pg-error'].classList.remove('hidden');
      this.els['pg-error-msg'].textContent = msg;
    }

    private syncUrlPrefix() {
      const path = (this.els['url-input'] as HTMLInputElement).value.trim();
      const isAbs = path.startsWith('http');
      this.els['url-prefix'].style.display = isAbs ? 'none' : 'inline-block';
    }

    private switchTab(tab: string) {
      this.els['res-tabs'].querySelectorAll('.res-tab').forEach(el => {
        el.setAttribute('aria-selected', el.getAttribute('data-tab') === tab ? 'true' : 'false');
      });
      this.els['response-box'].classList.toggle('hidden', tab !== 'response');
      this.els['history-panel'].classList.toggle('hidden', tab !== 'history');
    }

    // --- History View ---
    private renderHistory() {
      const history = HistoryService.load();
      if (!history.length) {
        this.els['history-list'].innerHTML = '';
        this.els['history-empty'].classList.remove('hidden');
        this.els['history-clear'].classList.add('hidden');
        return;
      }
      this.els['history-empty'].classList.add('hidden');
      this.els['history-clear'].classList.remove('hidden');

      this.els['history-list'].innerHTML = history.map(e => {
        const ok = e.status < 400;
        return `
          <div class="history-item" data-id="${e.id}" role="listitem" tabindex="0">
            <span class="history-item-status-dot ${ok ? '' : 'err'}"></span>
            <span class="history-item-method ${e.method}">${e.method}</span>
            <span class="history-item-body">
              <span class="history-item-path" title="${DOMUtils.esc(e.path)}">${DOMUtils.esc(e.path)}</span>
              <span class="history-item-meta">
                <span class="history-item-status-code ${ok ? 'ok' : 'err'}">${e.status} ${DOMUtils.esc(e.statusText)}</span>
                <span class="history-item-duration ${DOMUtils.durationClass(e.duration)}">${DOMUtils.formatDuration(e.duration)}</span>
                <span>${DOMUtils.formatBytes(e.size)}</span>
                <span class="history-item-time">${DOMUtils.timeAgo(e.timestamp)}</span>
              </span>
            </span>
            <span class="history-item-actions">
              <button type="button" class="history-item-action" data-action="rerun">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> Re-run
              </button>
              <button type="button" class="history-item-action delete" data-action="delete" title="Delete">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
              </button>
            </span>
          </div>`;
      }).join('');
    }

    private rerunHistoryEntry(id: string) {
      const e = HistoryService.load().find(x => x.id === id);
      if (!e) return;
      this.switchTab('response');
      (this.els['method-select'] as HTMLSelectElement).value = e.method;
      (this.els['url-input'] as HTMLInputElement).value = e.path;
      this.syncUrlPrefix();
      this.executeRequest();
    }

    private viewHistoryResponse(id: string) {
      const e = HistoryService.load().find(x => x.id === id);
      if (!e) return;
      this.switchTab('response');
      this.resetResponseView();
      
      this.els['pg-empty'].classList.add('hidden');
      this.els['res-toolbar'].classList.remove('hidden');
      this.els['res-content'].classList.remove('hidden');

      const ok = e.status < 400;
      this.els['res-status'].className = `status-code ${ok ? 'ok' : 'err'}`;
      this.els['res-status'].textContent = `${e.status} ${e.statusText}`;
      this.els['res-time'].textContent = DOMUtils.formatDuration(e.duration);
      this.els['res-time'].className = `res-time ${DOMUtils.durationClass(e.duration)}`;
      this.els['res-size'].textContent = DOMUtils.formatBytes(e.size);

      let formatted = DOMUtils.esc(e.responseBody);
      if (e.contentType.includes('json')) {
        try { formatted = DOMUtils.hlJSON(JSON.stringify(JSON.parse(e.responseBody), null, 2)); } catch{}
      }
      this.els['res-body'].innerHTML = formatted;
      this.els['res-headers'].innerHTML = '';
      this.els['hdr-count'].textContent = '0';
    }

    // --- Misc ---
    private formatBody() {
      const editor = this.els['body-editor'] as HTMLTextAreaElement;
      const fb = this.els['body-feedback'];
      try {
        editor.value = JSON.stringify(JSON.parse(editor.value), null, 2);
        fb.textContent = 'Format OK'; fb.className = 'feedback ok';
      } catch {
        fb.textContent = 'Invalid JSON'; fb.className = 'feedback err';
      }
      setTimeout(() => fb.textContent = '', 2000);
    }

    private updateQuotaUI() {
      const remaining = QuotaService.LIMIT - QuotaService.getUsage();
      const hint = this.els['pg-send-hint'];
      if (remaining <= 15) {
        hint.style.color = remaining <= 5 ? 'var(--accent-red)' : '#f59e0b';
        hint.textContent = `Daily quota: ${QuotaService.getUsage()}/${QuotaService.LIMIT} (${remaining} remaining)`;
      } else {
        hint.textContent = '';
      }
    }

    private async copyToClipboard(text: string, btn: HTMLElement, resetText: string) {
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        btn.classList.add('copied');
        if (resetText) btn.textContent = 'Copied!';
        setTimeout(() => {
          btn.classList.remove('copied');
          if (resetText) btn.textContent = resetText;
        }, 1500);
      } catch (err) { console.error('Copy failed', err); }
    }
  }

  // --- Bootstrapper ---
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.getElementById('pg-app-root');
    if (root) new ApiPlaygroundApp(root);
  });
</script>


  }
  .pg-ep-method--get  { background: #16a34a; }
  .pg-ep-method--post { background: #2563eb; }
  .pg-ep-item__label { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .pg-custom-trigger {
    display: flex; align-items: center; gap: 6px;
    width: calc(100% - 12px); margin: 0 6px 6px; padding: 7px 10px;
    border: 1.5px dashed var(--color-border); border-radius: 8px;

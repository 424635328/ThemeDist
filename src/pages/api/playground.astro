  .param-val:focus { background: color-mix(in srgb, var(--text-secondary) 8%, transparent); }

  .param-val-sel {
    width: 100%; background: transparent; border: none; color: var(--text-secondary);
    font-family: var(--font-mono); font-size: 12.5px; outline: none; cursor: pointer;
    padding: 6px 28px 6px 8px; border-radius: 4px;
    appearance: none; -webkit-appearance: none;
    background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%23666666%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E");
    background-repeat: no-repeat; background-position: right 6px center; background-size: 12px;
  }
  .param-val-sel:focus { color: var(--text-primary); background-color: color-mix(in srgb, var(--text-secondary) 8%, transparent); }
  .param-val-sel option {
    background-color: var(--bg-surface, #18181b);
    color: var(--text-primary, #fafafa);
    font-weight: 500;
  }

  .param-del {
    width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
    background: transparent; border: none; color: var(--text-muted); border-radius: 4px; cursor: pointer;
    opacity: 0; transition: all 0.2s; margin-left: auto;
  }
  .param-row:hover .param-del, .param-row:focus-within .param-del { opacity: 1; }
  .param-del:hover { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 15%, transparent); }

  .btn-add { background: transparent; border: 1px dashed var(--border-subtle); color: var(--text-secondary); font-size: 11px; font-weight: 500; padding: 4px 12px; border-radius: 4px; cursor: pointer; transition: all 0.2s; font-family: inherit; }
  .btn-add:hover { background: var(--bg-elevated); color: var(--text-primary); border-color: var(--text-muted); }

  .empty-state { text-align: center; color: var(--text-muted); font-size: 13px; padding: 24px; }
  .fill-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px 24px; }
  .empty-icon-wrap { width: 56px; height: 56px; border-radius: 50%; background: var(--bg-elevated); display: flex; align-items: center; justify-content: center; color: var(--text-muted); margin-bottom: 16px; border: 1px solid var(--border-subtle); }
  .empty-title { font-weight: 600; color: var(--text-primary); margin: 0 0 6px 0; font-size: 14px; }
  .empty-subtitle { margin: 0; font-size: 12px; }

  /* Body Editor */
  .body-editor-wrap { border: 1px solid var(--border-subtle); border-radius: var(--radii); background: var(--bg-elevated); transition: border-color 0.2s; padding: 2px; }

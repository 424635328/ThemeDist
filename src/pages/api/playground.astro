      { id:'diy-like', method:'POST', path:'/api/v1/diy/like.json', label:'Like Theme', desc:'дЄЇз§ЊеМЇдЄїйҐШзВєиµЮгАВеЯЇдЇО IP + UA + UUID йШ≤еИЈдњЭжК§гАВ', usage:'иѓЈж±ВйЩРжµБ 10жђ°/еИЖйТЯгАВ', cache:'дЄНзЉУе≠Ш',
        notes:'йШ≤еИЈжЬЇеИґпЉЪеРМдЄА IP+UA зїДеРИеѓєеРМдЄАдЄїйҐШеП™иГљзВєиµЮдЄАжђ°пЉИеЖНжђ°иѓЈж±ВдЄЇеПЦжґИзВєиµЮпЉЙгАВеРМжЧґзїіжК§жµПиІИеЩ®зЂѓ UUIDпЉИlocalStorageпЉЙпЉМеН≥дљњ IP еПШжЫідєЯиГљиѓЖеИЂйЗНе§НжУНдљЬгАВжѓПеИЖйТЯеЕ®е±АйЩРжµБ 10 жђ°пЉМиґЕеЗЇињФеЫЮ 429гАВзВєиµЮжХ∞еПШжЫіеЃЮжЧґзФЯжХИпЉМдљЖжОТи°Мж¶ЬзЉУе≠Ш 1 еИЖйТЯгАВ'
      }
    ]
  },
  {
    name: 'AI & Telemetry',
    items: [
      { id:'ai-generate', method:'POST', path:'/api/v1/ai/generate.json', label:'AI Generate', desc:'ж†єжНЃжППињ∞зФЯжИР CSS йЕНиЙ≤гАВжФѓжМБиІДеИЩеЉХжУОжИЦ DeepSeekгАВ', usage:'POST жППињ∞жЦЗжЬђгАВ', cache:'дЄНзЉУе≠Ш',
        notes:'еПМеЉХжУОз≠ЦзХ•пЉЪзЃАеНХжППињ∞пЉИе¶В "dark blue theme"пЉЙдљњзФ®жЬђеЬ∞иІДеИЩеЉХжУОпЉМжѓЂзІТзЇІеУНеЇФдЄФеЕНиієпЉЫе§НжЭВжППињ∞пЉИе¶В "neon cyberpunk matrix with purple accents"пЉЙиЗ™еК®иЈѓзФ±еИ∞ DeepSeek API ињЫи°Миѓ≠дєЙзРЖиІ£гАВDeepSeek и∞ГзФ®жЬЙжѓПжЧ•йЕНйҐЭйЩРеИґпЉИ100 жђ°/IP/е§©пЉЙпЉМиґЕеЗЇеРОеЫЮйААеИ∞иІДеИЩеЉХжУОгАВињФеЫЮж†ЗеЗЖ 34 дЄ™ cssVars зїУжЮДпЉМдЄО today.json ж†ЉеЉПдЄАиЗіпЉМеПѓзЫіжО•ж≥®еЕ•й°µйЭҐгАВ',
        params:[{name:'body',type:'textarea',label:'Body',placeholder:'{"prompt": "neon cyberpunk matrix"}',optional:false}]
      },
      { id:'ai-describe', method:'POST', path:'/api/v1/ai/describe.json', label:'AI Describe', desc:'иЊУеЕ• CSS еПШйЗПпЉМAI еИЖжЮРеєґињФеЫЮдЄ≠жЦЗй£Ож†ЉжППињ∞гАВ', usage:'йАЖеРСжО®зРЖдЄїйҐШй£Ож†ЉгАВ', cache:'дЄНзЉУе≠Ш',
        notes:'AI Generate зЪДйАЖеРСжУНдљЬпЉЪиЊУеЕ•дЄАзїД cssVarsпЉМAI еИЖжЮРиЙ≤зЫЄеИЖеЄГгАБй•±еТМеЇ¶гАБдЇЃеЇ¶гАБеѓєжѓФеЇ¶з≠ЙзЙєеЊБпЉМиЊУеЗЇй£Ож†ЉжППињ∞пЉИдЄ≠жЦЗдЄЇдЄїпЉМеПѓйЩДеЄ¶ en иЛ±жЦЗзњїиѓСпЉЙеТМй£Ож†Љж†Зз≠ЊпЉИе¶В ["dark","tech","cool"]пЉЙгАВйАВзФ®еЬЇжЩѓпЉЪзФ®жИЈдЄКдЉ†жИ™еЫЊеПЦиЙ≤еРОзРЖиІ£йЕНиЙ≤й£Ож†ЉгАБдЄЇеЈ≤жЬЙдЄїйҐШи°•еЕ®еЕГжХ∞жНЃгАВеУНеЇФеМЕеРЂ styleNameпЉИй£Ож†ЉеРНзІ∞пЉЙгАБdescriptionпЉИйХњжППињ∞пЉЙгАБtagsпЉИж†Зз≠ЊжХ∞зїДпЉЙгАБmoodпЉИжГЕжДЯеАЊеРСеИЖжЮРпЉЙгАВ'
      }

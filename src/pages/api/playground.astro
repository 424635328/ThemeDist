  .res-preview { padding: 24px; display: flex; justify-content: center; background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10"><rect width="10" height="10" fill="%23111"/><rect width="5" height="5" fill="%231a1a1a"/><rect x="5" y="5" width="5" height="5" fill="%231a1a1a"/></svg>'); border-bottom: 1px solid var(--border-subtle); }

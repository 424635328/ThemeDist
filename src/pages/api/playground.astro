---
import Layout from '../../layouts/Layout.astro';

const siteUrl = Astro.url.origin;

interface Param {
  name: string; type: string; label: string; placeholder?: string; optional: boolean; options?: string[]; isPath?: boolean;
}
interface EP {
  id: string; method: string; path: string; label: string; desc: string;
  usage: string; cache: string;
  responseFields?: { name: string; type: string; desc: string }[];
  params?: Param[];
  curlExample?: string; notes?: string;
  _idx?: number; _gid?: number; displayPath?: string;
}

function parseEndpoint(ep: EP): EP {
  const pathParamsMatch = ep.path.match(/\{([^}]+)\}/g);
  const pathParams = pathParamsMatch ? pathParamsMatch.map(m => m.slice(1, -1)) : [];

  if (pathParams.length > 0) {
    if (!ep.params) ep.params = [];
    pathParams.forEach(pp => {
      if (!ep.params!.find(p => p.name === pp)) {
        ep.params!.unshift({ name: pp, type: 'text', label: `路径参数 ${pp}`, placeholder: '...', optional: false, isPath: true });
      } else {
        const existing = ep.params!.find(p => p.name === pp);
        if (existing) existing.isPath = true;
      }
    });
  }

  // Generate robust cURL example
  if (!ep.curlExample) {
    let curlPath = ep.path;
    ep.params?.filter(p => p.isPath).forEach(p => { 
      curlPath = curlPath.replace(`{${p.name}}`, p.placeholder || 'xxx'); 
    });
    
    const isAbs = curlPath.startsWith('http');
    let fullUrl = `${isAbs ? '' : siteUrl}${curlPath}`;

    const queryParams = ep.params?.filter(p => !p.isPath && p.name !== 'body' && !p.optional) || [];
    if (queryParams.length > 0 && ep.method === 'GET') {
      const qs = queryParams.map(p => `${p.name}=${encodeURIComponent(p.placeholder || 'xxx')}`).join('&');
      fullUrl += fullUrl.includes('?') ? `&${qs}` : `?${qs}`;
    }

    if (ep.method === 'POST') {
      const bodyParam = ep.params?.find(p => p.name === 'body');
      let bodyStr = '{}';
      if (bodyParam?.placeholder) {
        try {
          bodyStr = JSON.stringify(JSON.parse(bodyParam.placeholder));
        } catch(e) {
          bodyStr = bodyParam.placeholder.replace(/\s+/g, ' '); // simple fallback
        }
        bodyStr = bodyStr.replace(/'/g, "'\\''"); // Escape single quotes for bash
      }
      ep.curlExample = `curl -X POST ${fullUrl} \\\n  -H "Content-Type: application/json" \\\n  -d '${bodyStr}'`;
    } else {
      ep.curlExample = `curl ${fullUrl}`;
    }
  }

  ep.displayPath = ep.path.startsWith('http') ? ep.path : ep.path.replace(/^\/api\/v1/, '');
  if (ep.displayPath === '') ep.displayPath = '/';

  return ep;
}

const rawGroups = [
  {
    name: 'Core API',
    items: [
      { id:'today', method:'GET', path:'/api/v1/today.json', label:'Today Theme', desc:'获取每日主题的完整数据。包含 34 个 CSS 自定义属性、自定义 CSS 动画、声明式装饰元素数组。', usage:'将 cssVars 注入 :root，推荐配合 localStorage 缓存。', cache:'浏览器 1h / CDN 24h',
        notes:'返回的 cssVars 对象包含 --color-primary、--color-bg、--color-surface、--color-text、--radii、--shadow 等 34 个标准 CSS 自定义属性。同时返回 decorations 数组（可直接渲染为 SVG 或 DOM 装饰）、animations 对象（包含 @keyframes 定义）、以及 meta 元数据（主题名、日期、节日信息）。支持 ?tz= 参数按目标时区计算日期。',
        responseFields:[
          {name:'cssVars',type:'object',desc:'34 个 CSS 自定义属性键值对'},
          {name:'decorations',type:'array',desc:'声明式装饰元素（位置、形状、颜色）'},
          {name:'animations',type:'object',desc:'CSS @keyframes 动画定义'},
          {name:'meta',type:'object',desc:'主题名、日期、节日、调色板等元数据'},
        ],
        params:[
          {name:'tz',type:'text',label:'时区',placeholder:'Asia/Shanghai',optional:true},
          {name:'overrides',type:'text',label:'CSS覆盖',placeholder:'--radii:0px',optional:true},
        ]
      },
      { id:'today-css', method:'GET', path:'/api/v1/today.css', label:'Today CSS', desc:'返回今日主题的纯 CSS（:root {} 变量块）。通过 link 标签阻塞引入可消除 FOUC。', usage:'在 head 中添加 <link rel="stylesheet" href="/api/v1/today.css">', cache:'浏览器 1h / CDN 24h',
        notes:'与 today.json 不同，此端点直接返回可用的 CSS 文本（Content-Type: text/css）。因为是阻塞样式表，浏览器会在渲染前等待其加载完成，彻底消除无样式内容闪烁（FOUC）。适合对首屏视觉一致性要求极高的页面。支持 ?tz= 和 ?overrides= 参数，行为与 today.json 一致。',
        params:[{name:'tz',type:'text',label:'时区',placeholder:'Asia/Shanghai',optional:true}]
      },
      { id:'today-safe', method:'GET', path:'https://themedist-monitor.vercel.app/api/v1/today-safe', label:'Safe Proxy', desc:'安全主题代理。从 ThemeDist 获取最新数据并进行严格的 XSS 清洗与验证。', usage:'适用于直接注入外部站点的场景，返回 _meta 安全元数据。', cache:'无缓存',
        notes:'此端点运行在独立域名 themedist-monitor.vercel.app 上，作为安全隔离层。所有 CSS 属性值经过 DOMPurify 级清洗，移除 potential XSS 向量（expression()、url()、javascript: 等）。返回的 _meta.safe 布尔值标识数据是否通过全部安全检查。适用于用户生成内容（UGC）平台或第三方嵌入场景。'
      },
      { id:'date-lookup', method:'GET', path:'/api/v1/date={date}', label:'Date Lookup', desc:'按日期查询主题，格式 MM-DD（如 02-14 查询情人节）。', usage:'用于日历组件、节日预览等场景。', cache:'浏览器 1h',
        notes:'路径参数 {date} 必须为 MM-DD 格式（如 01-01、12-25）。查询逻辑按优先级：精确日期匹配 → 同月同日（忽略年份）→ 最近节日回退。返回的数据结构与 today.json 完全一致。未来日期不会返回错误，而是返回该日期对应的历史主题；如果该日期无历史数据，则回退到当日主题。',
        params:[{name:'date',type:'text',label:'日期',placeholder:'02-14',optional:false,isPath:true}]
      },
      { id:'preset', method:'GET', path:'/api/v1/theme/{id}.json', label:'Theme Detail', desc:'获取指定预设或社区主题的完整数据。', usage:'用于固定主题或主题商店详情页。', cache:'预设 365d / 社区 1h',
        notes:'预设主题 ID 如 yozakura-reverie、ocean-depths、cyber-neon 等从静态 CDN 提供，缓存 365 天（immutable）。社区主题 ID（DIY 提交的）从数据库查询，缓存 1 小时。返回结构同 today.json，包含完整 cssVars、decorations、animations、meta。不存在的 ID 返回 404。',
        params:[{name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false,isPath:true}]
      },
      { id:'random', method:'GET', path:'/api/v1/theme/random.json', label:'Random Theme', desc:'随机获取一个主题。支持池子过滤和确定性随机种子。', usage:'用于换肤按钮。相同 seed 始终返回相同结果。', cache:'不缓存',
        notes:'?pool=static 仅从预设主题池中随机；?pool=community 仅从社区池随机；?pool=all 或省略则混合两个池子。?seed= 接受任意字符串，相同种子始终返回相同主题（基于 deterministic hash，非 Math.random）。适用场景：每日换肤（seed=日期）、用户专属主题（seed=用户ID）、A/B 测试。',
        params:[{name:'pool',type:'select',label:'来源池',options:['','static','community','all'],optional:true}, {name:'seed',type:'text',label:'随机种子',placeholder:'42',optional:true}]
      },
      { id:'index-data', method:'GET', path:'/api/v1/index-data.json', label:'Index Data', desc:'首页聚合数据。包含当日主题、推荐列表、节假日映射等，减少多次 API 调用。', usage:'用于构建首页仪表盘。', cache:'浏览器 1h / CDN 24h',
        notes:'一次性返回首页所需的全部数据：today（今日主题完整数据）、featured（推荐主题列表，4-8 个）、upcoming（未来 7 天节日预览）、popular（热门主题排行）。相比分别调用 today + 多个 theme/{id}，可减少 5-10 次 HTTP 请求。推荐在首页 SSR 时服务端 fetch 后注入页面，实现零客户端请求。'
      },
    ]
  },
  {
    name: 'Diagnostics & Export',
    items: [
      { id:'wcag', method:'GET', path:'/api/v1/theme/{id}/wcag.json', label:'WCAG Audit', desc:'WCAG 2.1 无障碍诊断。评估颜色对比度及 AA/AAA 合规性。', usage:'诊断报告包含 compliant 总览标记和 warnings 修复建议。', cache:'浏览器 1h' },
      { id:'scale', method:'GET', path:'/api/v1/theme/{id}/scale.json', label:'Tailwind Scale', desc:'基于黑白插值法生成完整的 Tailwind 风格 50~950 色阶。', usage:'返回 primary/secondary/accent/background 四组 11 级色阶。', cache:'365d immutable' },
      { id:'shadcn', method:'GET', path:'/api/v1/theme/{id}/export/shadcn.css', label:'Shadcn UI', desc:'Shadcn UI 适配器，转换为 HSL 通道变量体系，自动推断前景色。', usage:'可直接复制输出到 globals.css 中。', cache:'365d immutable' },
      { id:'shiki', method:'GET', path:'/api/v1/theme/{id}/shiki.json', label:'Shiki Theme', desc:'将主题变量映射为 Shiki / VS Code 的 TextMate Token 颜色。', usage:'用于代码高亮组件或直接导入 VS Code。', cache:'365d immutable' },
      { id:'extract', method:'POST', path:'/api/v1/extract-theme.json', label:'Image Extra', desc:'图片取色 API。纯 JS 进行 K-means 聚类并用语义引擎映射为 UI 标准变量。', usage:'POST 图片 URL，获取生成的 34 个 CSS 变量。', cache:'不缓存',
        params:[{name:'body',type:'textarea',label:'JSON Body',placeholder:'{\n  "imageUrl": "https://example.com/poster.jpg"\n}',optional:false}]
      }
    ]
  },
  {
    name: 'Tools & Assets',
    items: [
      { id:'tailwind-config', method:'GET', path:'/api/v1/tailwind-config.json', label:'Tailwind Conf', desc:'生成 Tailwind CSS v3/v4 配置片段，处理 RGB 通道不透明度支持。', usage:'直接集成至 tailwind.config.js。', cache:'浏览器 1h' },
      { id:'tokens', method:'GET', path:'/api/v1/tokens.json', label:'Design Tokens', desc:'导出符合 W3C DTCG 规范的 JSON 设计令牌。', usage:'用于导入 Figma 或 Style Dictionary。', cache:'浏览器 1h' },
      { id:'svg-pattern', method:'GET', path:'/api/v1/today/pattern.css', label:'SVG Pattern', desc:'根据今日主题色生成几何图案背景纹理。', usage:'通过 <link> 引入并作为 background-image 使用。', cache:'浏览器 1h' },
      { id:'weather-js', method:'GET', path:'/api/v1/today/weather.js', label:'Weather Particles', desc:'天气粒子动画脚本。云/雨/雪/雷暴特效。', usage:'引入 <script src="...">，自动定位并渲染 Canvas/DOM 粒子。', cache:'浏览器 1h / CDN 24h' },
      { id:'favicon', method:'GET', path:'/api/v1/today/favicon.svg', label:'Dynamic Favicon', desc:'动态 Favicon。根据今日主题主色和字母实时生成 SVG。', usage:'在 <head> 中作为 icon 引入。', cache:'浏览器 1h' },
      { id:'palette-badge', method:'GET', path:'/api/v1/today/palette.svg', label:'Palette Badge', desc:'今日主题调色盘 SVG 徽章，用于嵌入 README。', usage:'作为 <img> 标签引入即可。', cache:'浏览器 1h' },
      { id:'search-color', method:'GET', path:'/api/v1/search/color.json', label:'Color Search', desc:'RGB 欧几里得距离计算相似颜色主题。', usage:'传入 hex 寻找最匹配的主题。', cache:'浏览器 1h',
        params:[{name:'hex',type:'text',label:'Hex颜色',placeholder:'ff6b6b',optional:false}, {name:'limit',type:'text',label:'数量限制',placeholder:'10',optional:true}]
      },
      { id:'og-image', method:'GET', path:'/api/v1/theme/{id}/og.svg', label:'OG Image SVG', desc:'1200x630 的社交分享图 SVG 渲染端点。', usage:'用于 og:image meta 标签。', cache:'365d immutable' }
    ]
  },
  {
    name: 'Environment Context',
    items: [
      { id:'weather-theme', method:'GET', path:'/api/v1/weather-theme.json', label:'Weather Adaptive', desc:'跨平台嗅探地理位置，调用 Open-Meteo 并匹配对应的天气氛围主题。', usage:'支持通过 ?lat= & ?lon= 覆盖 IP 检测结果。', cache:'30min',
        params:[{name:'lat',type:'text',label:'纬度',placeholder:'35.68',optional:true}, {name:'lon',type:'text',label:'经度',placeholder:'139.76',optional:true}]
      },
      { id:'status-override', method:'GET', path:'/api/v1/status-override.json', label:'Status Override', desc:'系统状态主题。维护(纯灰)/哀悼(暗黑+滤镜)/故障(红色警示)。', usage:'用于兜底页及重大状态提示。', cache:'5min' }
    ]
  },
  {
    name: 'Community Data',
    items: [
      { id:'diy-list', method:'GET', path:'/api/v1/diy/themes.json', label:'Themes List', desc:'分页、排序、过滤获取社区已审核的主题。', usage:'支持多种维度的 tag 查询。', cache:'1min',
        params:[{name:'sort',type:'select',label:'排序',options:['new','hot'],optional:true}, {name:'page',type:'text',label:'页码',placeholder:'1',optional:true}, {name:'size',type:'text',label:'数量',placeholder:'20',optional:true}, {name:'tag',type:'select',label:'标签',options:['','dark','light','warm','cool','vibrant','minimal','nature','tech'],optional:true}]
      },
      { id:'diy-single', method:'GET', path:'/api/v1/diy/theme.json', label:'Theme Detail', desc:'获取单个社区主题，包含点赞数和作者信息。', usage:'?id= 传入主题ID。', cache:'5min' },
      { id:'diy-submit', method:'POST', path:'/api/v1/diy/submit.json', label:'Submit Theme', desc:'提交新主题进入待审队列。', usage:'提供严格的数据 Schema 验证，返回 warnings。', cache:'不缓存',
        params:[{name:'body',type:'textarea',label:'Body',placeholder:'{\n  "name": "Cyber",\n  "author": "You",\n  "cssVars": {"--color-primary":"#ff0","--color-bg":"#000"}\n}',optional:false}]
      },
      { id:'diy-like', method:'POST', path:'/api/v1/diy/like.json', label:'Like Theme', desc:'为社区主题点赞。基于 IP + UA + UUID 防刷保护。', usage:'请求限流 10次/分钟。', cache:'不缓存' }
    ]
  },
  {
    name: 'AI & Telemetry',
    items: [
      { id:'ai-generate', method:'POST', path:'/api/v1/ai/generate.json', label:'AI Generate', desc:'根据描述生成 CSS 配色。支持规则引擎或 DeepSeek。', usage:'POST 描述文本。', cache:'不缓存',
        params:[{name:'body',type:'textarea',label:'Body',placeholder:'{\n  "prompt": "neon cyberpunk matrix"\n}',optional:false}]
      },
      { id:'ai-describe', method:'POST', path:'/api/v1/ai/describe.json', label:'AI Describe', desc:'输入 CSS 变量，AI 分析并返回中文风格描述。', usage:'逆向推理主题风格。', cache:'不缓存' }
    ]
  }
];

let epIndex = 0;
const flat = rawGroups.flatMap((g, gi) =>
  g.items.map(ep => parseEndpoint({ ...ep, _idx: epIndex++, _gid: gi }))
);
const flatJSON = JSON.stringify(flat);
---

<Layout title="API Playground">
  <div class="dashboard-layout">

    <!-- Ambient background -->
    <div class="pg-amb">
      <div class="pg-amb-orb"></div>
      <div class="pg-amb-orb"></div>
      <div class="pg-amb-grain"></div>
    </div>

    <!-- ====== LEFT SIDEBAR ====== -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2"/></svg>
        <span style="font-weight:700; font-size:15px; margin-left:12px; letter-spacing: -0.01em;">API Playground</span>
      </div>

      <div class="sidebar-scroll" id="pg-sidebar">
        {rawGroups.map(g => (
          <div class="nav-group">
            <div class="nav-group-title">{g.name}</div>
            {g.items.map(ep => {
              const flatItem = flat.find(f => f.id === ep.id);
              return (
                <button class="nav-item" data-idx={String(flatItem?._idx)} onclick={`window.__selectEndpoint(${flatItem?._idx})`}>
                  <span class={`method ${ep.method}`}>{ep.method}</span>
                  <span class="path" title={flatItem?.displayPath}>{flatItem?.displayPath}</span>
                </button>
              )
            })}
          </div>
        ))}

        <div class="nav-group" style="margin-top: 24px; border-top: 1px solid var(--border-subtle); padding-top: 24px;">
           <button class="nav-item custom" id="custom-url-toggle">
             <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 3H4a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1v-3"/><path d="M16 2L9 9"/><path d="M11 2h5v5"/></svg>
             <span class="path" style="margin-left:8px; font-weight: 500;">Custom Request</span>
           </button>
        </div>
      </div>
    </aside>

    <!-- ====== RIGHT MAIN ====== -->
    <main class="main-content">

      <!-- Fixed Header -->
      <div class="main-header">
        <header class="page-header">
          <h1 class="page-title" id="docs-title">API Playground</h1>
          <p class="page-desc" id="docs-desc">Select an endpoint from the sidebar to explore and test.</p>
        </header>

        <!-- Fixed Top URL Bar -->
        <div class="url-bar-container">
          <select class="url-method" id="method-select">
            <option value="GET">GET</option>
            <option value="POST">POST</option>
          </select>
          <div class="url-input-wrap">
            <span class="url-prefix" id="url-prefix">{siteUrl}</span>
            <input type="text" class="url-input" id="url-input" value="/api/v1/today.json" spellcheck="false" autocomplete="off" />
          </div>
          <button class="btn-send" id="pg-send" onclick="window.__doSend()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9 22 2z"/></svg>
            Send Request
          </button>
          <span class="kbd-hint"><kbd>Ctrl</kbd>+<kbd>Enter</kbd></span>
        </div>

        <div class="rate-limit-hint" id="pg-send-hint"></div>
      </div>

      <!-- 2-Column Content Grid -->
      <div class="content-grid">

        <!-- LEFT COL: Request Config -->
        <div class="request-col">

          <div class="panel-title">
            <span>Parameters</span>
            <button class="btn-add" id="param-add">+ Add</button>
          </div>
          <div class="params-box">
            <div class="params-list" id="params-list"></div>
            <div id="no-params" class="empty-state">No parameters required.</div>
          </div>

          <div id="body-section" style="display:none;">
            <div class="panel-title">
              <span>Body <span class="badge" style="margin-left:8px; background:var(--bg-base); border: 1px solid var(--border-subtle); color:var(--text-secondary); padding: 2px 6px; border-radius: 4px; font-size:10px;">JSON</span></span>
              <button class="btn-add" id="body-format">Format JSON</button>
            </div>
            <textarea class="body-editor" id="body-editor" spellcheck="false"></textarea>
            <div class="feedback" id="body-feedback"></div>
          </div>

          <!-- Light Docs Area -->
          <div class="docs-mini">
            <div class="panel-title" style="margin-top:24px;">Documentation</div>
            <div class="docs-card">
              <p id="docs-desc-mini" class="text-muted" style="font-size:13px; margin:0 0 16px;">—</p>
              <div class="docs-meta" style="display:flex; gap:32px; margin-bottom:16px;">
                <div><span style="font-size:10px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--text-muted);">Cache Policy</span><br><span id="docs-cache" style="font-size:12px;color:var(--accent); font-family: var(--font-mono);">—</span></div>
                <div><span style="font-size:10px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--text-muted);">Usage Hint</span><br><span id="docs-usage" style="font-size:12px;color:var(--text-primary);">—</span></div>
              </div>
              <div id="docs-notes" style="font-size:12.5px;color:var(--text-secondary);line-height:1.6;margin-bottom:16px;background:var(--bg-base);padding:12px;border-radius:6px;border:1px dashed var(--border-subtle);"></div>
              <div id="docs-fields" style="display:none;margin-bottom:12px;">
                <span style="font-size:10px;font-weight:600;text-transform:uppercase;color:var(--text-muted);">Response Fields</span>
                <table class="res-headers-table" id="docs-fields-table" style="margin-top:8px;"></table>
              </div>
            </div>
            <pre id="docs-curl" class="code-block curl-block"></pre>
            <button class="btn-add" id="copy-curl-btn" style="margin-top:12px; width: 100%;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              Copy cURL Command
            </button>
          </div>

        </div>

        <!-- RIGHT COL: Response -->
        <div class="response-col">
          <div class="panel-title" style="flex-shrink:0;">Response</div>

          <!-- Tabs -->
          <div class="res-tabs" id="res-tabs">
            <button class="res-tab active" data-tab="response">Response Preview</button>
            <button class="res-tab" data-tab="history">Request History</button>
            <button class="res-tab-btn" id="history-clear" title="Clear all history" style="display:none;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
            </button>
          </div>

          <!-- Response Box -->
          <div class="response-box" id="response-box">
            <div class="res-toolbar" id="res-toolbar" style="display:none;">
              <div class="res-status-wrap">
                <span id="res-status" class="status-code"></span>
                <span id="res-time" class="res-time"></span>
                <span id="res-size" class="res-size"></span>
              </div>
              <button class="btn-icon" id="res-copy" title="Copy response">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              </button>
            </div>

            <div class="res-content-area">
              <div id="pg-empty" class="empty-state empty-state-full">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.2" style="margin-bottom:16px;"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                <p style="margin:0 0 6px; color:var(--text-primary); font-weight:500;">Ready to send</p>
                <p style="margin:0; font-size:12px; color:var(--text-secondary);">Hit <strong style="color:var(--accent)">Send Request</strong> to execute, or press <kbd>Ctrl+Enter</kbd></p>
              </div>

              <div id="pg-loading" class="empty-state empty-state-full" style="display:none;">
                <div class="spinner"></div>
                <span style="color:var(--text-primary); font-weight:500; font-size:13px;">Executing request...</span>
                <span style="color:var(--text-muted); font-size:11px; margin-top:6px; display:block; font-family:var(--font-mono);" id="pg-loading-url"></span>
              </div>

              <div id="pg-error" class="error-state" style="display:none;">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                  <strong style="color:#ef4444;">Request Failed</strong>
                </div>
                <span id="pg-error-msg" style="font-size:12px; color:var(--text-secondary); line-height: 1.5;"></span>
              </div>

              <div id="res-content" style="display:none; flex-direction:column; flex:1; min-height:0; overflow:hidden;">
                <details class="res-headers">
                  <summary>Headers (<span id="hdr-count"></span>)</summary>
                  <table class="res-headers-table" id="res-headers"></table>
                </details>

                <div id="res-preview" class="res-preview" style="display:none;"></div>
                <pre id="res-body" class="code-block fill-block"></pre>
              </div>
            </div>
          </div>

          <!-- History Panel -->
          <div class="history-panel" id="history-panel" style="display:none;">
            <div class="history-list" id="history-list"></div>
            <div class="empty-state empty-state-full" id="history-empty">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.2" style="margin-bottom:16px;"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <p style="color:var(--text-primary); font-weight:500; font-size:13px; margin:0 0 6px;">No request history yet.</p>
              <p style="color:var(--text-secondary); font-size:12px; margin:0;">Requests you send will appear here.</p>
            </div>
          </div>

        </div>
      </div>

    </main>
  </div>
</Layout>

<style is:global>
  :root {
    /* Safe fallbacks in case Layout.astro variables are absent */
    --bg-base: var(--color-bg, #09090b);
    --bg-sidebar: var(--color-bg, #09090b);
    --bg-surface: var(--color-surface, #121214);
    --bg-elevated: color-mix(in srgb, var(--color-surface, #18181b) 55%, var(--color-bg, #09090b));
    --border-subtle: var(--color-border, #27272a);
    --border-strong: color-mix(in srgb, var(--color-border, #27272a) 180%, var(--color-text-muted, #a1a1aa));
    --text-primary: var(--color-text, #f4f4f5);
    --text-secondary: var(--color-text-muted, #a1a1aa);
    --text-muted: color-mix(in srgb, var(--color-text-muted, #a1a1aa) 55%, transparent);
    
    --accent: var(--color-primary, #8b5cf6);
    --accent-blue: #3b82f6;
    --accent-green: #10b981;
    --accent-red: #ef4444;
    
    --font-mono: var(--font-mono, 'JetBrains Mono', 'Fira Code', 'SF Mono', Consolas, monospace);
    --font-body: var(--font-body, 'Inter', system-ui, -apple-system, sans-serif);
    
    --ambient-1: color-mix(in srgb, var(--accent) 15%, transparent);
    --ambient-2: color-mix(in srgb, var(--accent-blue) 15%, transparent);
    
    --radii: 8px;
    --glass-blur: blur(12px);
  }

  html, body {
    margin: 0; padding: 0;
    height: 100%;
    background: var(--bg-base);
    color: var(--text-primary);
    font-family: var(--font-body);
  }
</style>

<style>
  .dashboard-layout {
    display: flex;
    height: 100vh;
    overflow: hidden;
    position: relative;
    z-index: 1;
    transition: background 0.6s ease, color 0.6s ease;
  }

  /* ====== AMBIENT BACKGROUND ====== */
  .pg-amb { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
  .pg-amb-orb {
    position: absolute; border-radius: 50%; filter: blur(120px);
    animation: orbDrift 20s ease-in-out infinite alternate;
    will-change: transform; opacity: 0.6;
  }
  .pg-amb-orb:nth-child(1) { width: 500px; height: 500px; top: -15%; left: -5%; background: var(--ambient-1); animation-delay: 0s; }
  .pg-amb-orb:nth-child(2) { width: 400px; height: 400px; bottom: -10%; right: -5%; background: var(--ambient-2); animation-delay: -5s; }
  .pg-amb-grain {
    position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat; background-size: 256px 256px;
  }

  @keyframes orbDrift {
    0%   { transform: translate(0, 0) scale(1); }
    50%  { transform: translate(5%, 3%) scale(1.05); }
    100% { transform: translate(-3%, 4%) scale(0.95); }
  }

  /* ====== SIDEBAR ====== */
  .sidebar {
    width: 280px; flex-shrink: 0;
    border-right: 1px solid var(--border-subtle);
    display: flex; flex-direction: column;
    background: color-mix(in srgb, var(--bg-sidebar) 70%, transparent);
    backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur);
    position: relative; z-index: 2;
  }
  .sidebar-header {
    height: 64px; display: flex; align-items: center; padding: 0 24px;
    border-bottom: 1px solid var(--border-subtle); flex-shrink: 0;
    color: var(--text-primary);
  }
  .sidebar-scroll { flex: 1; overflow-y: auto; padding: 24px 0; }
  .sidebar-scroll::-webkit-scrollbar { width: 4px; }
  .sidebar-scroll::-webkit-scrollbar-track { background: transparent; }
  .sidebar-scroll::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 99px; }

  .nav-group { margin-bottom: 24px; }
  .nav-group-title {
    padding: 0 24px; font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 12px; font-weight: 700;
  }
  .nav-item {
    display: flex; align-items: center; gap: 12px; width: 100%; padding: 8px 24px 8px 22px;
    border: none; background: transparent; color: var(--text-secondary); font-size: 13px;
    cursor: pointer; text-align: left; border-left: 2px solid transparent; transition: all 0.2s;
  }
  .nav-item:hover { color: var(--text-primary); background: color-mix(in srgb, var(--text-primary) 4%, transparent); }
  .nav-item.active {
    border-left-color: var(--accent); color: var(--text-primary);
    background: color-mix(in srgb, var(--accent) 8%, transparent); font-weight: 500;
  }
  .nav-item.custom { padding-left: 24px; }
  .nav-item.custom.active { padding-left: 22px; }

  .method { font-family: var(--font-mono); font-size: 10px; font-weight: 700; min-width: 32px; letter-spacing: 0.02em; }
  .method.GET { color: var(--accent-green); }
  .method.POST { color: var(--accent-blue); }
  .path { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-family: var(--font-mono); font-size: 12.5px; }

  /* ====== MAIN CONTENT ====== */
  .main-content {
    flex: 1; display: flex; flex-direction: column; overflow: hidden;
    background: color-mix(in srgb, var(--bg-surface) 60%, transparent);
    position: relative; z-index: 1; min-width: 0;
  }

  .main-header { flex-shrink: 0; padding: 48px 48px 0 48px; }
  .page-header { margin-bottom: 24px; }
  .page-title { font-size: 28px; font-weight: 700; margin: 0 0 8px 0; color: var(--text-primary); letter-spacing: -0.02em; }
  .page-desc { font-size: 14px; color: var(--text-secondary); margin: 0; max-width: 800px; line-height: 1.6; }

  /* URL Bar */
  .url-bar-container {
    display: flex; align-items: center; border: 1px solid var(--border-subtle); border-radius: var(--radii);
    background: var(--bg-elevated); overflow: hidden; transition: border-color 0.2s, box-shadow 0.2s;
    backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
  .url-bar-container:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 15%, transparent), 0 4px 20px rgba(0,0,0,0.2);
  }
  .url-method {
    padding: 0 16px; background: transparent; border: none; border-right: 1px solid var(--border-subtle);
    color: var(--text-primary); font-weight: 700; font-family: var(--font-mono); font-size: 13px;
    outline: none; cursor: pointer; align-self: stretch; transition: background 0.2s;
  }
  .url-method:focus, .url-method:hover { background: color-mix(in srgb, var(--text-primary) 5%, transparent); }
  .url-input-wrap { flex: 1; display: flex; align-items: center; padding: 0 16px; min-width: 0; }
  .url-prefix { color: var(--text-muted); font-family: var(--font-mono); font-size: 13.5px; user-select: none; flex-shrink: 0; }
  .url-input {
    flex: 1; background: transparent; border: none; color: var(--text-primary);
    font-family: var(--font-mono); font-size: 13.5px; outline: none; padding: 14px 0 14px 4px; min-width: 0;
  }
  .btn-send {
    display: flex; align-items: center; justify-content: center;
    padding: 0 24px; background: var(--accent); color: #fff;
    border: none; font-weight: 600; font-size: 13.5px; cursor: pointer; align-self: stretch;
    transition: background 0.2s, opacity 0.2s; font-family: var(--font-body); white-space: nowrap;
  }
  .btn-send:hover { background: color-mix(in srgb, var(--accent) 80%, #fff); }
  .btn-send:disabled { opacity: 0.5; cursor: not-allowed; }

  kbd {
    background: var(--bg-surface); border: 1px solid var(--border-subtle); border-bottom-width: 2px;
    border-radius: 4px; padding: 2px 6px; font-family: var(--font-mono); font-size: 10px; color: var(--text-secondary);
    margin: 0 2px;
  }
  .kbd-hint { font-size: 11px; color: var(--text-muted); padding: 0 16px 0 8px; user-select: none; white-space: nowrap; display: flex; align-items: center; }

  .rate-limit-hint { min-height: 24px; font-size: 12px; color: var(--accent-red); font-weight: 500; margin-top: 8px; }

  /* Content Grid */
  .content-grid {
    flex: 1; min-height: 0; overflow: hidden; display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 32px; padding: 24px 48px 48px 48px;
  }
  @media (max-width: 1100px) { .content-grid { grid-template-columns: 1fr; overflow-y: auto; } .main-content { overflow-y: auto; } }
  @media (max-width: 768px) { .dashboard-layout { flex-direction: column; } .sidebar { width: 100%; height: 250px; border-right: none; border-bottom: 1px solid var(--border-subtle); } .main-header, .content-grid { padding: 24px; } }

  .panel-title {
    font-size: 13px; font-weight: 700; color: var(--text-primary); margin: 0 0 16px 0;
    text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
  }

  /* ====== REQUEST COLUMN ====== */
  .request-col { overflow-y: auto; min-height: 0; padding-right: 4px; display: flex; flex-direction: column; }
  .request-col::-webkit-scrollbar { width: 5px; }
  .request-col::-webkit-scrollbar-track { background: transparent; }
  .request-col::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 99px; }

  /* ====== PARAMETERS ====== */
  .params-box {
    background: var(--bg-elevated); border: 1px solid var(--border-subtle);
    border-radius: var(--radii); padding: 8px; margin-bottom: 24px; flex-shrink: 0;
  }
  .params-list { display: flex; flex-direction: column; gap: 4px; }

  .param-row {
    display: grid; grid-template-columns: 140px auto 1fr 32px; align-items: center; gap: 8px;
    border-radius: 6px; background: var(--bg-base); border: 1px solid transparent;
    transition: all 0.2s; padding: 2px 4px;
  }
  .param-row:hover { border-color: color-mix(in srgb, var(--accent) 20%, var(--border-subtle)); background: color-mix(in srgb, var(--accent) 3%, var(--bg-base)); }
  .param-row:focus-within { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 15%, transparent); }

  .param-key {
    background: transparent; border: none; color: var(--accent); font-family: var(--font-mono);
    font-size: 12.5px; font-weight: 600; outline: none; padding: 8px; width: 100%; box-sizing: border-box;
  }
  .param-key::placeholder { color: color-mix(in srgb, var(--accent) 30%, transparent); font-weight: 400; }

  .param-eq { color: var(--text-muted); font-family: var(--font-mono); font-size: 13px; padding: 0; user-select: none; }

  .param-val, .param-val-sel {
    background: transparent; border: none; color: var(--text-primary); font-family: var(--font-mono);
    font-size: 13px; outline: none; padding: 8px; width: 100%; box-sizing: border-box;
  }
  .param-val::placeholder { color: var(--text-muted); }
  .param-val-sel { color: var(--text-secondary); cursor: pointer; }

  .param-del {
    width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
    background: transparent; border: none; color: var(--text-muted); border-radius: 5px;
    cursor: pointer; opacity: 0; transition: all 0.2s;
  }
  .param-row:hover .param-del, .param-row:focus-within .param-del { opacity: 1; }
  .param-del:hover { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 15%, transparent); }

  .btn-icon {
    width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
    background: transparent; border: none; color: var(--text-secondary); border-radius: 6px;
    cursor: pointer; transition: all 0.2s; flex-shrink: 0;
  }
  .btn-icon:hover { background: color-mix(in srgb, var(--text-primary) 8%, transparent); color: var(--text-primary); }
  .btn-icon.copied { color: var(--accent-green); }

  .btn-add {
    background: color-mix(in srgb, var(--text-primary) 5%, transparent);
    border: 1px solid var(--border-subtle); color: var(--text-secondary); font-size: 11.5px; font-weight: 600;
    padding: 6px 12px; border-radius: 6px; cursor: pointer; transition: all 0.2s; font-family: var(--font-body);
    display: flex; align-items: center; justify-content: center;
  }
  .btn-add:hover { background: color-mix(in srgb, var(--text-primary) 10%, transparent); color: var(--text-primary); border-color: var(--border-strong); }

  .empty-state { text-align: center; color: var(--text-muted); font-size: 13px; padding: 24px; }
  .empty-state-full { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; flex: 1; min-height: 200px; padding: 48px 24px; }
  .error-state { padding: 24px; background: color-mix(in srgb, var(--accent-red) 10%, transparent); border-bottom: 1px solid color-mix(in srgb, var(--accent-red) 20%, transparent); }

  /* Body Editor */
  .body-editor {
    width: 100%; min-height: 140px; height: 220px; max-height: 500px;
    background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radii);
    color: var(--text-primary); font-family: var(--font-mono); font-size: 13px; line-height: 1.5;
    padding: 16px; resize: vertical; outline: none; transition: border-color 0.2s; box-sizing: border-box;
  }
  .body-editor:focus { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 15%, transparent); }
  .feedback { font-size: 12px; margin-top: 8px; min-height: 18px; font-weight: 500; }
  .feedback.ok { color: var(--accent-green); }
  .feedback.err { color: var(--accent-red); }

  /* Light Docs */
  .docs-card {
    background: transparent; border: 1px solid var(--border-subtle);
    border-radius: var(--radii); padding: 16px 20px; margin-bottom: 16px;
  }
  .curl-block {
    white-space: pre-wrap; word-break: break-all; margin: 0; padding: 16px;
    background: #000; border: 1px solid var(--border-subtle); border-radius: var(--radii);
    color: #a1a1aa; font-family: var(--font-mono); font-size: 12.5px; line-height: 1.6;
  }

  /* ====== RESPONSE COLUMN ====== */
  .response-col { display: flex; flex-direction: column; overflow: hidden; min-height: 0; }

  /* Response Tabs */
  .res-tabs { display: flex; align-items: center; gap: 8px; border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; margin-bottom: 16px; }
  .res-tab {
    padding: 10px 16px; background: transparent; border: none; color: var(--text-secondary);
    font-size: 13px; font-weight: 600; cursor: pointer; font-family: var(--font-body);
    border-bottom: 2px solid transparent; transition: all 0.2s; margin-bottom: -1px;
  }
  .res-tab:hover { color: var(--text-primary); }
  .res-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .res-tab-btn {
    margin-left: auto; padding: 6px 8px; background: transparent; border: none;
    color: var(--text-muted); cursor: pointer; border-radius: 4px; transition: all 0.2s;
  }
  .res-tab-btn:hover { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 15%, transparent); }

  /* ====== RESPONSE BOX ====== */
  .response-box { flex: 1; min-height: 0; background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radii); display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
  .res-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-bottom: 1px solid var(--border-subtle); background: var(--bg-surface); flex-shrink: 0; }
  .res-status-wrap { display: flex; align-items: center; gap: 16px; }
  .status-code { font-family: var(--font-mono); font-size: 12px; font-weight: 700; padding: 4px 10px; border-radius: 4px; letter-spacing: 0.05em; }
  .status-code.ok { color: var(--accent-green); background: color-mix(in srgb, var(--accent-green) 15%, transparent); }
  .status-code.err { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 15%, transparent); }
  .res-time { font-family: var(--font-mono); font-size: 12.5px; font-weight: 500; }
  .res-time.fast { color: var(--accent-green); }
  .res-time.medium { color: #fbbf24; }
  .res-time.slow { color: var(--accent-red); }
  .res-size { color: var(--text-secondary); font-family: var(--font-mono); font-size: 12.5px; }

  .res-content-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0; }
  #res-content { overflow: hidden; }

  .res-headers { background: var(--bg-surface); border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; }
  .res-headers summary { padding: 12px 16px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); cursor: pointer; list-style: none; user-select: none; transition: background 0.2s; }
  .res-headers summary:hover { background: color-mix(in srgb, var(--text-primary) 4%, transparent); color: var(--text-primary); }
  .res-headers summary::-webkit-details-marker { display: none; }
  .res-headers-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 12px; }
  .res-headers-table td { padding: 8px 16px; border-top: 1px solid var(--border-subtle); color: var(--text-secondary); }
  .res-headers-table td:first-child { color: var(--text-primary); font-weight: 600; width: 30%; }

  .fill-block {
    flex: 1; margin: 0; padding: 20px; background: transparent; border: none; overflow-y: auto;
    color: var(--text-secondary); font-family: var(--font-mono); font-size: 13.5px; line-height: 1.6;
    white-space: pre-wrap; word-break: break-all; min-height: 0;
  }
  .fill-block::-webkit-scrollbar { width: 6px; height: 6px; }
  .fill-block::-webkit-scrollbar-track { background: transparent; }
  .fill-block::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 99px; }

  .res-preview { padding: 32px; display: flex; justify-content: center; align-items: center; background: repeating-conic-gradient(#18181b 0% 25%, #27272a 0% 50%) 50% / 20px 20px; border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; min-height: 200px; }
  .res-preview img { max-width: 100%; max-height: 400px; object-fit: contain; border-radius: var(--radii); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }

  .spinner { width: 28px; height: 28px; border: 2.5px solid var(--border-subtle); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s cubic-bezier(0.5, 0.1, 0.4, 0.9) infinite; margin: 0 auto 16px; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Syntax Highlighting */
  .hl-key { color: #7dd3fc; font-weight: 500; }
  .hl-str { color: #a7f3d0; }
  .hl-num { color: #fca5a5; }
  .hl-bool { color: #c4b5fd; font-weight: 600; }

  /* ====== HISTORY PANEL ====== */
  .history-panel {
    flex: 1; min-height: 0; overflow-y: auto; display: flex; flex-direction: column;
    background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radii);
  }
  .history-panel::-webkit-scrollbar { width: 5px; }
  .history-panel::-webkit-scrollbar-track { background: transparent; }
  .history-panel::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 99px; }

  .history-list { display: flex; flex-direction: column; }
  .history-item {
    display: flex; align-items: center; gap: 16px; padding: 16px 20px;
    border-bottom: 1px solid var(--border-subtle); cursor: pointer;
    transition: background 0.2s, border-color 0.2s; border-left: 3px solid transparent; position: relative;
  }
  .history-item:hover { background: color-mix(in srgb, var(--accent) 4%, transparent); border-left-color: var(--accent); }
  .history-item:last-child { border-bottom: none; }

  .history-item-status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; background: var(--accent-green); box-shadow: 0 0 8px var(--accent-green); }
  .history-item-status-dot.err { background: var(--accent-red); box-shadow: 0 0 8px var(--accent-red); }

  .history-item-method {
    font-family: var(--font-mono); font-size: 11px; font-weight: 700; padding: 4px 8px; border-radius: 4px;
    min-width: 40px; text-align: center; flex-shrink: 0; letter-spacing: 0.05em;
  }
  .history-item-method.GET { color: var(--accent-green); background: color-mix(in srgb, var(--accent-green) 15%, transparent); }
  .history-item-method.POST { color: var(--accent-blue); background: color-mix(in srgb, var(--accent-blue) 15%, transparent); }

  .history-item-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; }
  .history-item-path { font-family: var(--font-mono); font-size: 13.5px; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .history-item-meta { display: flex; align-items: center; gap: 16px; font-family: var(--font-mono); font-size: 11.5px; color: var(--text-secondary); }
  .history-item-status-code { font-weight: 700; }
  .history-item-status-code.ok { color: var(--accent-green); }
  .history-item-status-code.err { color: var(--accent-red); }
  .history-item-duration.fast { color: var(--accent-green); }
  .history-item-duration.medium { color: #fbbf24; }
  .history-item-duration.slow { color: var(--accent-red); }
  .history-item-time { font-size: 11px; color: var(--text-muted); white-space: nowrap; }

  .history-item-actions { display: flex; gap: 8px; flex-shrink: 0; align-items: center; opacity: 0.3; transition: opacity 0.2s; }
  .history-item:hover .history-item-actions { opacity: 1; }
  .history-item-action {
    display: flex; align-items: center; gap: 6px; padding: 6px 12px;
    background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 6px;
    color: var(--text-secondary); font-family: var(--font-body); font-size: 12px; font-weight: 600;
    cursor: pointer; transition: all 0.2s; white-space: nowrap;
  }
  .history-item-action:hover { background: color-mix(in srgb, var(--accent) 15%, transparent); border-color: var(--accent); color: var(--text-primary); }
  .history-item-action.delete { border-color: transparent; color: var(--text-muted); background: transparent; padding: 6px; }
  .history-item-action.delete:hover { color: var(--accent-red); background: color-mix(in srgb, var(--accent-red) 15%, transparent); }
</style>

<script define:vars={{ siteUrl, flatJSON }}>
  window.__SITE_URL__ = siteUrl;
  window.__FLAT_JSON__ = flatJSON;
</script>

<script>
  var siteUrl = window.__SITE_URL__ || window.location.origin;
  var FLAT = JSON.parse(window.__FLAT_JSON__);
  var activeEP = FLAT[0];
  var isCustom = false;
  var lastResBody = '';
  
  // Manage Blob URLs to prevent memory leaks
  var activeBlobUrls = [];
  function cleanupBlobs() {
    while(activeBlobUrls.length > 5) {
      URL.revokeObjectURL(activeBlobUrls.shift());
    }
  }

  // ── Debounce & Quota ──
  var lastRequestTime = 0;
  var DEBOUNCE_MS = 500;
  var DAILY_LIMIT = 100;
  var dailyCount = 0;

  function loadDailyCount() {
    try {
      var data = JSON.parse(localStorage.getItem('pg-daily') || '{}');
      var today = new Date().toISOString().slice(0, 10);
      dailyCount = (data.date === today) ? (data.count || 0) : 0;
    } catch(e) { dailyCount = 0; }
  }

  function incrementDailyCount() {
    dailyCount++;
    var today = new Date().toISOString().slice(0, 10);
    try { localStorage.setItem('pg-daily', JSON.stringify({ date: today, count: dailyCount })); } catch(e) {}
    updateQuotaHint();
    return dailyCount;
  }

  function updateQuotaHint() {
    var hint = getEl('pg-send-hint');
    var remaining = DAILY_LIMIT - dailyCount;
    if (remaining <= 20) {
      hint.style.color = remaining <= 5 ? 'var(--accent-red)' : '#fbbf24';
      hint.textContent = 'Daily quota: ' + dailyCount + '/' + DAILY_LIMIT + ' (' + remaining + ' left)';
    } else {
      hint.textContent = '';
    }
  }

  // ── Response Cache (in-memory) ──
  var responseCache = new Map();
  var CACHE_TTL = 5 * 60 * 1000; 

  function getCached(method, url) {
    var key = method + '::' + url;
    var entry = responseCache.get(key);
    if (!entry) return null;
    if (Date.now() - entry.time > CACHE_TTL) {
      responseCache.delete(key); return null;
    }
    return entry;
  }

  function setCached(method, url, data) {
    var key = method + '::' + url;
    if (responseCache.size >= 30) {
      var firstKey = responseCache.keys().next().value;
      responseCache.delete(firstKey);
    }
    responseCache.set(key, { time: Date.now(), data: data });
  }

  // ── History ──
  var HISTORY_KEY = 'pg-history';
  var HISTORY_MAX = 50;
  var historyEntries = [];

  function loadHistory() {
    try {
      var raw = localStorage.getItem(HISTORY_KEY);
      historyEntries = raw ? JSON.parse(raw) : [];
    } catch(e) { historyEntries = []; }
  }

  function persistHistory() {
    try { localStorage.setItem(HISTORY_KEY, JSON.stringify(historyEntries)); } catch(e) {}
  }

  function addHistoryEntry(entry) {
    historyEntries.unshift(entry);
    if (historyEntries.length > HISTORY_MAX) historyEntries = historyEntries.slice(0, HISTORY_MAX);
    persistHistory();
  }

  function deleteHistoryEntry(id) {
    historyEntries = historyEntries.filter(function(e) { return e.id !== id; });
    persistHistory(); renderHistoryPanel();
  }

  function clearAllHistory() {
    historyEntries = []; persistHistory(); renderHistoryPanel();
  }

  // Utilities
  function formatBytes(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(2) + ' MB';
  }

  function formatDuration(ms) {
    if (ms < 1000) return ms + 'ms';
    if (ms < 10000) return (ms / 1000).toFixed(1) + 's';
    return (ms / 1000).toFixed(0) + 's';
  }

  function durationClass(ms) { return ms < 200 ? 'fast' : (ms < 800 ? 'medium' : 'slow'); }
  function formatTimestamp(ts) {
    var diff = Date.now() - ts;
    if (diff < 60000) return 'just now';
    if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';
    if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';
    return Math.floor(diff / 86400000) + 'd ago';
  }

  function getEl(s) { return document.getElementById(s); }
  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // ── Sync URL & Prefix ──
  function syncURLPrefix() {
    var path = getEl('url-input').value.trim();
    var isAbs = path.startsWith('http://') || path.startsWith('https://');
    getEl('url-prefix').style.display = isAbs ? 'none' : 'inline-block';
  }
  getEl('url-input').addEventListener('input', syncURLPrefix);

  // ── Rendering Docs & Content ──
  function showDocs(ep) {
    getEl('docs-title').textContent = ep.label || 'Custom Request';
    getEl('docs-desc').textContent = ep.desc || 'Construct and test any API endpoint.';
    getEl('docs-desc-mini').textContent = ep.desc || 'Custom request configuration.';
    getEl('docs-usage').textContent = ep.usage || 'N/A';
    getEl('docs-cache').textContent = ep.cache || 'No cache';
    getEl('docs-curl').textContent = ep.curlExample || ('curl ' + siteUrl + (ep.path || '/'));

    var notesEl = getEl('docs-notes');
    if (ep.notes) { notesEl.innerHTML = esc(ep.notes); notesEl.style.display = ''; } else { notesEl.style.display = 'none'; }

    var fieldsEl = getEl('docs-fields');
    var fieldsTable = getEl('docs-fields-table');
    if (ep.responseFields && ep.responseFields.length) {
      fieldsTable.innerHTML = ep.responseFields.map(f =>
        '<tr><td><code>' + esc(f.name) + '</code> <br><span style="color:var(--text-muted);font-size:10px;">' + esc(f.type) + '</span></td><td>' + esc(f.desc) + '</td></tr>'
      ).join('');
      fieldsEl.style.display = '';
    } else { fieldsEl.style.display = 'none'; }
  }

  getEl('copy-curl-btn').addEventListener('click', function() {
    var curlCode = getEl('docs-curl').textContent;
    navigator.clipboard.writeText(curlCode).then(function() {
      var btn = getEl('copy-curl-btn');
      var original = btn.innerHTML;
      btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied Successfully';
      btn.style.color = 'var(--accent-green)';
      btn.style.borderColor = 'var(--accent-green)';
      setTimeout(function() { btn.innerHTML = original; btn.style.color = ''; btn.style.borderColor = ''; }, 2000);
    });
  });

  // ── Selection Logic ──
  function selectEndpoint(idx) {
    isCustom = false;
    getEl('custom-url-toggle').classList.remove('active');
    activeEP = FLAT[idx];

    getEl('method-select').value = activeEP.method;
    getEl('url-input').value = activeEP.path;
    syncURLPrefix();

    renderParams();
    highlightSidebar();
    showDocs(activeEP);

    var isPost = activeEP.method === 'POST' || activeEP.method === 'PUT';
    getEl('body-section').style.display = isPost ? 'block' : 'none';
    if (isPost) {
      var bp = (activeEP.params || []).find(function(p) { return p.name === 'body'; });
      if (bp && bp.placeholder) {
        try { getEl('body-editor').value = JSON.stringify(JSON.parse(bp.placeholder), null, 2); } 
        catch(e) { getEl('body-editor').value = bp.placeholder; }
      } else { getEl('body-editor').value = ''; }
    }

    getEl('pg-empty').style.display = 'flex';
    getEl('pg-loading').style.display = 'none';
    getEl('pg-error').style.display = 'none';
    getEl('res-content').style.display = 'none';
    getEl('res-toolbar').style.display = 'none';
  }
  window.__selectEndpoint = selectEndpoint;

  function highlightSidebar() {
    document.querySelectorAll('.nav-item').forEach(function(el) {
      el.classList.toggle('active', el.getAttribute('data-idx') === String(activeEP._idx));
    });
  }

  // ── Params Rendering ──
  function renderParams() {
    var list = getEl('params-list'); list.innerHTML = '';
    var params = isCustom ? [] : (activeEP.params || []);

    if (params.length === 0 || (params.length === 1 && params[0].name === 'body')) {
      getEl('no-params').style.display = 'block'; list.style.display = 'none'; return;
    }

    getEl('no-params').style.display = 'none'; list.style.display = 'flex';

    params.forEach(function(p) {
      if (p.name === 'body') return;
      var row = document.createElement('div'); row.className = 'param-row';
      var valHTML = p.type === 'select'
        ? '<select class="param-val-sel" data-param="' + p.name + '">' + (p.options||[]).map(function(o){ return '<option value="' + o + '">' + (o||'—') + '</option>'; }).join('') + '</select>'
        : '<input class="param-val" type="text" data-param="' + p.name + '" placeholder="' + (p.placeholder||'') + '" />';

      row.innerHTML =
        '<input class="param-key" type="text" value="' + p.name + '" readonly />' +
        '<span class="param-eq">=</span>' + valHTML +
        '<button class="param-del" title="Clear value">' +
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>' +
        '</button>';
      row.querySelector('.param-del').addEventListener('click', function() {
        var input = row.querySelector('.param-val, .param-val-sel');
        if (input) { if (input.tagName === 'SELECT') input.selectedIndex = 0; else input.value = ''; }
      });
      list.appendChild(row);
    });
  }

  getEl('param-add').addEventListener('click', function() {
    getEl('no-params').style.display = 'none'; getEl('params-list').style.display = 'flex';
    var row = document.createElement('div'); row.className = 'param-row';
    row.innerHTML =
      '<input class="param-key" type="text" placeholder="Key" />' +
      '<span class="param-eq">=</span>' +
      '<input class="param-val" type="text" placeholder="Value" />' +
      '<button class="param-del" title="Remove">' +
        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>' +
      '</button>';
    row.querySelector('.param-del').addEventListener('click', function() {
      row.remove();
      if(getEl('params-list').children.length===0) { getEl('no-params').style.display = 'block'; getEl('params-list').style.display = 'none'; }
    });
    getEl('params-list').appendChild(row);
  });

  // ── Custom URL ──
  getEl('custom-url-toggle').addEventListener('click', function() {
    isCustom = true;
    document.querySelectorAll('.nav-item').forEach(function(el) { el.classList.remove('active'); });
    getEl('custom-url-toggle').classList.add('active');

    getEl('url-input').value = '/api/v1/'; syncURLPrefix();
    getEl('params-list').innerHTML = ''; getEl('no-params').style.display = 'block'; getEl('params-list').style.display = 'none';
    getEl('body-section').style.display = getEl('method-select').value === 'POST' ? 'block' : 'none';
    showDocs({ label: 'Custom Request', method: 'GET', path: '/api/v1/', desc: 'Construct dynamic requests to any endpoint.' });
  });

  getEl('method-select').addEventListener('change', function() {
    getEl('body-section').style.display = (this.value === 'POST' || this.value === 'PUT') ? 'block' : 'none';
  });

  function buildURL() {
    var path = getEl('url-input').value.trim();
    var isAbs = path.startsWith('http://') || path.startsWith('https://');
    if (!isAbs && path.charAt(0) !== '/') path = '/' + path;

    var rows = getEl('params-list').querySelectorAll('.param-row');
    var qp = [];
    rows.forEach(function(row) {
      var keyInput = row.querySelector('.param-key');
      var valInput = row.querySelector('.param-val, .param-val-sel');
      var key = keyInput ? keyInput.value.trim() : '';
      var val = valInput ? valInput.value.trim() : '';

      if (!key) return;
      if (path.includes('{' + key + '}')) {
        path = path.replace('{' + key + '}', encodeURIComponent(val));
      } else if (val) {
        qp.push(encodeURIComponent(key) + '=' + encodeURIComponent(val));
      }
    });

    path = path.replace(/\{[^}]+\}/g, '');
    if (qp.length) path += (path.includes('?') ? '&' : '?') + qp.join('&');
    return isAbs ? path : siteUrl + path;
  }

  // Body Formatter
  getEl('body-format').addEventListener('click', function() {
    var val = getEl('body-editor').value;
    if(!val.trim()) return;
    try {
      getEl('body-editor').value = JSON.stringify(JSON.parse(val), null, 2);
      getEl('body-feedback').textContent = 'Valid JSON'; getEl('body-feedback').className = 'feedback ok';
    } catch(e) {
      getEl('body-feedback').textContent = 'Invalid JSON: ' + e.message; getEl('body-feedback').className = 'feedback err';
    }
    setTimeout(function() { getEl('body-feedback').textContent = ''; }, 3000);
  });

  // ── Safe JSON Highlight ──
  function hlJSON(t) {
    var escaped = esc(t);
    // Keys
    escaped = escaped.replace(/(&quot;.*?&quot;)(?=\s*:)/g, '<span class="hl-key">$1</span>');
    // String Values
    escaped = escaped.replace(/:\s*(&quot;.*?&quot;)/g, ': <span class="hl-str">$1</span>');
    // Booleans/Null
    escaped = escaped.replace(/\b(true|false|null)\b/g, '<span class="hl-bool">$1</span>');
    // Numbers
    escaped = escaped.replace(/:\s*(-?\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)/g, ': <span class="hl-num">$1</span>');
    return escaped;
  }

  // ── Tab Switching ──
  function switchTab(tabName) {
    document.querySelectorAll('.res-tab').forEach(function(t) { t.classList.toggle('active', t.getAttribute('data-tab') === tabName); });
    getEl('response-box').style.display = tabName === 'response' ? 'flex' : 'none';
    getEl('history-panel').style.display = tabName === 'history' ? 'flex' : 'none';
  }

  document.querySelectorAll('.res-tab').forEach(function(tab) {
    tab.addEventListener('click', function() { switchTab(this.getAttribute('data-tab')); });
  });

  getEl('history-clear').addEventListener('click', function() { if (confirm('Clear all request history?')) clearAllHistory(); });

  // ── History Rendering ──
  function renderHistoryPanel() {
    var list = getEl('history-list'); var empty = getEl('history-empty'); var clearBtn = getEl('history-clear');

    if (historyEntries.length === 0) {
      list.innerHTML = ''; empty.style.display = 'flex'; clearBtn.style.display = 'none'; return;
    }
    empty.style.display = 'none'; clearBtn.style.display = 'block';

    list.innerHTML = historyEntries.map(function(e) {
      var ok = e.status < 400;
      return '<div class="history-item" data-id="' + e.id + '">' +
        '<span class="history-item-status-dot' + (ok ? '' : ' err') + '"></span>' +
        '<span class="history-item-method ' + e.method + '">' + e.method + '</span>' +
        '<span class="history-item-body">' +
          '<span class="history-item-path" title="' + esc(e.path) + '">' + esc(e.path) + '</span>' +
          '<span class="history-item-meta">' +
            '<span class="history-item-status-code ' + (ok ? 'ok' : 'err') + '">' + e.status + ' ' + e.statusText + '</span>' +
            '<span class="history-item-duration ' + durationClass(e.duration) + '">' + formatDuration(e.duration) + '</span>' +
            '<span>' + formatBytes(e.size) + '</span>' +
            '<span class="history-item-time">' + formatTimestamp(e.timestamp) + '</span>' +
          '</span>' +
        '</span>' +
        '<span class="history-item-actions">' +
          '<button class="history-item-action" data-action="rerun">' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>' +
            ' Rerun' +
          '</button>' +
          '<button class="history-item-action delete" data-action="delete" title="Delete">' +
            '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>' +
          '</button>' +
        '</span>' +
      '</div>';
    }).join('');

    list.querySelectorAll('.history-item-action').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var id = this.closest('.history-item').getAttribute('data-id');
        var action = this.getAttribute('data-action');
        if (action === 'rerun') rerunHistoryEntry(id);
        if (action === 'delete') deleteHistoryEntry(id);
      });
    });

    list.querySelectorAll('.history-item').forEach(function(item) {
      item.addEventListener('click', function() { viewHistoryResponse(this.getAttribute('data-id')); });
    });
  }

  function rerunHistoryEntry(id) {
    var entry = historyEntries.find(function(e) { return e.id === id; });
    if (!entry) return;
    switchTab('response'); getEl('method-select').value = entry.method; getEl('url-input').value = entry.path; syncURLPrefix(); doSend();
  }

  function viewHistoryResponse(id) {
    var entry = historyEntries.find(function(e) { return e.id === id; });
    if (!entry) return;
    switchTab('response');

    getEl('pg-empty').style.display = 'none'; getEl('pg-loading').style.display = 'none'; getEl('pg-error').style.display = 'none';
    getEl('res-content').style.display = 'flex'; getEl('res-toolbar').style.display = 'flex';

    getEl('res-status').className = 'status-code ' + (entry.status < 400 ? 'ok' : 'err');
    getEl('res-status').textContent = entry.status + ' ' + entry.statusText + ' (History)';
    getEl('res-time').textContent = formatDuration(entry.duration); getEl('res-time').className = 'res-time ' + durationClass(entry.duration);
    getEl('res-size').textContent = formatBytes(entry.size);

    var formatted = esc(entry.responseBody);
    if (entry.responseBody.startsWith('[Binary Image Data]')) {
       formatted = '<div class="empty-state"><i>Image binary data not stored in history. Rerun to view.</i></div>';
    } else if (entry.contentType && entry.contentType.includes('json')) {
      try { formatted = hlJSON(JSON.stringify(JSON.parse(entry.responseBody), null, 2)); } catch(e) {}
    }
    
    getEl('res-body').innerHTML = formatted; getEl('res-preview').style.display = 'none'; getEl('res-headers').innerHTML = ''; getEl('hdr-count').textContent = '0';
  }

  // ── Action: Send ──
  function doSend() {
    var now = Date.now();
    if (now - lastRequestTime < DEBOUNCE_MS) return;
    lastRequestTime = now;

    if (dailyCount >= DAILY_LIMIT) {
      getEl('pg-empty').style.display = 'none'; getEl('res-content').style.display = 'none'; getEl('res-toolbar').style.display = 'none';
      getEl('pg-loading').style.display = 'none'; getEl('pg-error').style.display = 'block';
      getEl('pg-error-msg').textContent = 'Daily request limit reached (' + DAILY_LIMIT + '/' + DAILY_LIMIT + '). Try again tomorrow.';
      return;
    }

    var m = getEl('method-select').value;
    var url = buildURL();

    if (m === 'GET') {
      var cached = getCached(m, url);
      if (cached) { displayResponse(cached.data, true); return; }
    }

    getEl('pg-empty').style.display = 'none'; getEl('res-content').style.display = 'none'; getEl('res-toolbar').style.display = 'none';
    getEl('pg-error').style.display = 'none'; getEl('pg-loading').style.display = 'flex';
    getEl('pg-loading-url').textContent = m + ' ' + url; getEl('pg-send').disabled = true;

    var t0 = performance.now();
    var bodyVal = getEl('body-editor').value.trim();
    var headers = {}; if ((m === 'POST' || m === 'PUT') && bodyVal) headers['Content-Type'] = 'application/json';

    fetch(url, { method: m, headers: headers, body: (m === 'POST' || m === 'PUT') && bodyVal ? bodyVal : undefined })
    .then(async function(res) {
      var elapsed = Math.round(performance.now() - t0);
      var hdrRows = '', hdrNum = 0;
      res.headers.forEach(function(v, k) { hdrRows += '<tr><td>' + esc(k) + '</td><td>' + esc(v) + '</td></tr>'; hdrNum++; });
      getEl('res-headers').innerHTML = hdrRows; getEl('hdr-count').textContent = hdrNum;

      var contentType = res.headers.get('content-type') || '';
      var isImage = contentType.includes('image/');
      
      var text = '', blobUrl = '', bodySize = 0;
      if (isImage) {
        var blob = await res.blob();
        bodySize = blob.size;
        blobUrl = URL.createObjectURL(blob);
        activeBlobUrls.push(blobUrl); cleanupBlobs();
        text = '[Binary Image Data]';
      } else {
        text = await res.text();
        bodySize = new Blob([text]).size;
      }

      lastResBody = text;
      var responseData = { status: res.status, statusText: res.statusText, elapsed: elapsed, bodySize: bodySize, contentType: contentType, text: text, blobUrl: blobUrl, ok: res.ok };
      
      if (m === 'GET' && res.ok && !isImage) setCached(m, url, responseData);
      displayResponse(responseData, false);
      incrementDailyCount();

      addHistoryEntry({
        id: Date.now().toString(36) + Math.random().toString(36).slice(2, 7),
        timestamp: Date.now(), method: m, path: getEl('url-input').value.trim(), fullUrl: url,
        status: res.status, statusText: res.statusText, duration: elapsed, size: bodySize, contentType: contentType,
        responseBody: isImage ? '[Binary Image Data]' : (text.length > 20480 ? text.slice(0, 20480) + '\n... (truncated)' : text)
      });
      renderHistoryPanel();
    }).catch(function(err) {
      getEl('pg-loading').style.display = 'none'; getEl('pg-error').style.display = 'block';
      getEl('pg-error-msg').textContent = 'Network or CORS error. ' + (err.message || 'Failed to connect.');
    }).finally(function() {
      getEl('pg-send').disabled = false;
    });
  }

  function displayResponse(data, fromCache) {
    var preview = getEl('res-preview');
    if (data.blobUrl) {
      preview.innerHTML = '<img src="' + data.blobUrl + '" alt="Response Image Preview" />';
      preview.style.display = 'flex';
    } else {
      preview.style.display = 'none';
    }

    var formattedText = esc(data.text);
    if (data.contentType && data.contentType.includes('json') && data.text !== '[Binary Image Data]') {
      try { formattedText = hlJSON(JSON.stringify(JSON.parse(data.text), null, 2)); } catch(e) {}
    }
    getEl('res-body').innerHTML = formattedText;

    getEl('res-status').className = 'status-code ' + (data.ok ? 'ok' : 'err');
    getEl('res-status').textContent = data.status + ' ' + data.statusText + (fromCache ? ' (Cached)' : '');
    getEl('res-time').textContent = fromCache ? '0ms' : formatDuration(data.elapsed);
    getEl('res-time').className = 'res-time' + (fromCache ? ' fast' : ' ' + durationClass(data.elapsed));
    getEl('res-size').textContent = formatBytes(data.bodySize);

    getEl('pg-loading').style.display = 'none'; getEl('res-toolbar').style.display = 'flex'; getEl('res-content').style.display = 'flex';
  }
  window.__doSend = doSend;

  document.addEventListener('keydown', function(e) { if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); doSend(); } });

  getEl('res-copy').addEventListener('click', function() {
    navigator.clipboard.writeText(lastResBody).then(function() {
      var btn = getEl('res-copy');
      btn.classList.add('copied'); btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
      setTimeout(function() {
        btn.classList.remove('copied'); btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
      }, 2000);
    });
  });

  // Init
  loadDailyCount(); updateQuotaHint(); loadHistory(); renderHistoryPanel(); selectEndpoint(0);
</script>
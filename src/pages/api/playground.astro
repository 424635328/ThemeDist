---
import Layout from '../../layouts/Layout.astro';

const siteUrl = Astro.url.origin;

interface Param {
  name: string; type: string; label: string; placeholder: string; optional: boolean; options?: string[];
}
interface EP {
  id: string; method: string; path: string; label: string; desc: string;
  usage: string;
  cache: string;
  responseFields?: { name: string; type: string; desc: string }[];
  params?: Param[];
  curlExample: string;
  notes?: string;
}

const groups: { name: string; items: EP[] }[] = [
  {
    name: 'Core',
    items: [
      { id:'today', method:'GET', path:'/api/v1/today.json', label:'Today Theme',
        desc:'获取每日主题的完整数据。包含 34 个 CSS 自定义属性、自定义 CSS 动画、声明式装饰元素数组、Logo 信息、主题目录索引。颜色变量自动附带 -rgb 通道变体，支持 Tailwind alpha-value。',
        usage:'客户端 GET 此端点，将 cssVars 注入 :root，customCss 创建 style 标签（textContent 安全注入），extensions 通过 createElement + template 安全渲染为 DOM 元素。推荐配合 localStorage 缓存：同日访问跳过网络请求。',
        cache:'浏览器 1h / CDN 24h (stale-while-revalidate)',
        responseFields:[
          {name:'date',type:'string',desc:'ISO 日期 YYYY-MM-DD（UTC 时区）'},
          {name:'generatedAt',type:'string',desc:'ISO 8601 生成时间戳'},
          {name:'preset',type:'string',desc:'预设标识符 (kebab-case)'},
          {name:'presetName',type:'string',desc:'人类可读名称'},
          {name:'dailyIsCommunity',type:'boolean',desc:'true 表示今日主题来自社区投稿'},
          {name:'apiVersion',type:'string',desc:'API 版本号，当前为 "v1"'},
          {name:'cssVars',type:'object',desc:'34 个 CSS 自定义属性（5 组：Colors/Typography/Spacing/Effects/Ambient）'},
          {name:'customCss',type:'string',desc:'主题专属 CSS 动画。无内容时为空字符串 ""'},
          {name:'extensions',type:'array',desc:'声明式装饰元素（floating+decorative）。无内容时为空数组 []'},
          {name:'logoText',type:'string|null',desc:'主题 Logo 文字标识'},
          {name:'logoColors',type:'array|null',desc:'Logo 渐变色 hex 数组'},
          {name:'available',type:'number',desc:'可用主题总数'},
          {name:'directory',type:'array',desc:'轻量索引 [{preset,name,primary,accent,logoText}]'},
        ],
        params:[
          {name:'tz',type:'text',label:'时区',placeholder:'Asia/Shanghai',optional:true},
          {name:'overrides',type:'text',label:'CSS覆盖',placeholder:'--radii:0px;--font-body:monospace',optional:true},
        ],
        notes:'GET 无速率限制。?overrides= 最多 20 对，自动 XSS 清洗。?tz= 无效时区自动回退 UTC。使用 overrides 时响应额外包含 appliedOverrides:true。',
        curlExample:`curl ${siteUrl}/api/v1/today.json | jq .`,
      },
      { id:'today-css', method:'GET', path:'/api/v1/today.css', label:'Today CSS',
        desc:'返回今日主题的纯 CSS（:root {} 变量块）。通过 link 标签阻塞引入可消除 FOUC（无样式内容闪烁）。',
        usage:'在 head 中添加 <link rel="stylesheet" href="/api/v1/today.css">。浏览器会阻塞渲染等待 CSS 加载完成。推荐对首屏体验敏感的场景使用。',
        cache:'浏览器 1h / CDN 24h',
        params:[
          {name:'tz',type:'text',label:'时区',placeholder:'Asia/Shanghai',optional:true},
        ],
        notes:'返回 text/css MIME。支持 ?tz= 和 ?overrides= 参数。',
        curlExample:`curl ${siteUrl}/api/v1/today.css`,
      },
      { id:'today-safe', method:'GET', path:'/api/v1/today-safe', label:'Safe Proxy',
        desc:'安全主题代理。从 ThemeDist 获取最新 today.json（Vercel 优先，Netlify 备用），经 HTML 剥离→XSS 扫描→Schema 校验后输出。下游可直接安全消费。',
        usage:'用于需要在第三方页面渲染 ThemeDist 主题但不想自行处理 XSS 清洗的场景。返回 _meta 对象含 sanitized/schemaValid/timestamp。',
        cache:'—',
        responseFields:[
          {name:'date',type:'string',desc:'ISO 日期'},
          {name:'preset',type:'string',desc:'预设标识符'},
          {name:'presetName',type:'string',desc:'主题可读名称'},
          {name:'author',type:'string',desc:'"themedist" 或社区作者名'},
          {name:'cssVars',type:'object',desc:'已完成 XSS 清洗的 CSS 变量'},
          {name:'customCss',type:'string',desc:'已完成 XSS 清洗的 CSS'},
          {name:'extensions',type:'array',desc:'已完成 XSS 清洗的装饰片段'},
          {name:'directory',type:'array',desc:'主题目录列表'},
          {name:'_meta',type:'object',desc:'{sanitized, schemaValid, timestamp}'},
        ],
        notes:'此端点部署在独立监控服务 themedist-monitor.vercel.app 上。502 表示双上游均不可达。',
        curlExample:'curl https://themedist-monitor.vercel.app/api/v1/today-safe | jq .',
      },
      { id:'date-lookup', method:'GET', path:'/api/v1/date=MM-DD', label:'Date Lookup',
        desc:'按日期查询主题，格式 MM-DD。可用于查询特定节日的主题（如 /api/v1/date=02-14 查询情人节、/api/v1/date=01-01 查询元旦）。',
        usage:'用于日历组件、节日预览等场景。',
        cache:'浏览器 1h',
        params:[
          {name:'date',type:'text',label:'日期(MM-DD)',placeholder:'02-14',optional:false},
        ],
        notes:'日期格式必须为 MM-DD（前导零）。',
        curlExample:`curl ${siteUrl}/api/v1/date=02-14 | jq .`,
      },
      { id:'preset', method:'GET', path:'/api/v1/theme/{id}.json', label:'Preset/Community Theme',
        desc:'获取指定预设或社区主题的完整数据。与 today.json 结构一致但不含 date、generatedAt、available、directory。支持预设和社区 ID 两种。',
        usage:'从 today.json 的 directory 中选择 preset 调用。也可传入社区主题 ID（如 community-xxx）。预设端点 365 天 CDN 不可变缓存。',
        cache:'预设 365d immutable / 社区 1h',
        responseFields:[
          {name:'preset',type:'string',desc:'主题标识符'},
          {name:'presetName',type:'string',desc:'可读名称'},
          {name:'cssVars',type:'object',desc:'34 个 CSS 变量'},
          {name:'customCss',type:'string',desc:'主题专属 CSS'},
          {name:'extensions',type:'array',desc:'装饰元素数组'},
          {name:'logoText',type:'string|null',desc:'Logo 文字'},
          {name:'logoColors',type:'array|null',desc:'Logo 渐变色'},
        ],
        params:[
          {name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false},
        ],
        notes:'社区主题无 logoText/logoColors。社区主题通过 community- 前缀标识。',
        curlExample:`curl ${siteUrl}/api/v1/theme/yozakura-reverie.json | jq .`,
      },
      { id:'random', method:'GET', path:'/api/v1/theme/random.json', label:'Random Theme',
        desc:'随机获取一个主题。?pool=static|community|all 筛选池子，?seed=N 确定性随机。',
        usage:'用于随机换肤按钮或主题发现。相同 seed 始终返回相同结果。',
        cache:'不缓存',
        params:[
          {name:'pool',type:'select',label:'池子',options:['','static','community','all'],optional:true},
          {name:'seed',type:'text',label:'种子',placeholder:'42',optional:true},
        ],
        curlExample:`curl "${siteUrl}/api/v1/theme/random.json?pool=all&seed=42" | jq .`,
      },
      { id:'index-data', method:'GET', path:'/api/v1/index-data.json', label:'Index Data',
        desc:'首页聚合数据。包含当日主题、推荐列表、社区统计等一站式数据，减少多次 API 调用。',
        usage:'用于构建首页仪表盘。构建时预计算日池/节日映射/目录。',
        cache:'浏览器 1h / CDN 24h',
        curlExample:`curl ${siteUrl}/api/v1/index-data.json | jq .`,
      },
    ]
  },
  {
    name: 'Diagnostics & Export',
    items: [
      { id:'wcag', method:'GET', path:'/api/v1/theme/{id}/wcag.json', label:'WCAG Audit',
        desc:'WCAG 2.1 无障碍诊断。评估主题颜色对比度，检查正文、主色、辅色在背景上的可读性。返回每条颜色组合的对比度数值及 AA/AAA 级别通过情况。',
        usage:'用于在设计系统或主题上线前验证无障碍合规性。含 compliant 总览标记和 warnings 修复建议。',
        cache:'浏览器 1h',
        params:[
          {name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false},
        ],
        curlExample:`curl ${siteUrl}/api/v1/theme/yozakura-reverie/wcag.json | jq .`,
      },
      { id:'scale', method:'GET', path:'/api/v1/theme/{id}/scale.json', label:'Color Scale',
        desc:'Tailwind 风格 50~950 色阶生成。基于黑白色插值法，从主题主色/辅色/强调色/背景色生成 11 级色阶。返回 4 组 scales（primary/secondary/accent/background）。',
        usage:'用于需要更细粒度色阶的 UI 场景（如 hover/focus 状态色、border 色、disabled 色等）。',
        cache:'365d immutable',
        params:[
          {name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false},
        ],
        notes:'每组含 50/100/200/300/400/500/600/700/800/900/950 共 11 级。',
        curlExample:`curl ${siteUrl}/api/v1/theme/yozakura-reverie/scale.json | jq .`,
      },
      { id:'shadcn', method:'GET', path:'/api/v1/theme/{id}/export/shadcn.css', label:'Shadcn UI Export',
        desc:'Shadcn UI 适配器。将主题 CSS 变量转换为 Shadcn UI 所需的 HSL 通道体系（--background、--primary、--foreground 等）。前景色自动根据背景亮度推断。',
        usage:'返回完整 CSS（@layer base { :root {} }），可直接复制到 Shadcn UI 项目的 globals.css。',
        cache:'365d immutable',
        params:[
          {name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false},
        ],
        curlExample:`curl ${siteUrl}/api/v1/theme/yozakura-reverie/export/shadcn.css`,
      },
      { id:'shiki', method:'GET', path:'/api/v1/theme/{id}/shiki.json', label:'Shiki Highlight Theme',
        desc:'Shiki/VS Code 代码高亮主题。将主题 CSS 变量映射为 TextMate Token 颜色，可直接用作代码高亮主题。',
        usage:'返回 tokenColors 和 semanticTokenColors，可直接导入 Shiki/VS Code 配置。',
        cache:'365d immutable',
        params:[
          {name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false},
        ],
        curlExample:`curl ${siteUrl}/api/v1/theme/yozakura-reverie/shiki.json | jq .`,
      },
      { id:'og-svg', method:'GET', path:'/api/v1/theme/{id}/og.svg', label:'OG Image',
        desc:'OG 社交分享卡片 SVG。1200×630，含主题色板与名称，用于 Open Graph 预览图。',
        usage:'<meta property="og:image" content="/api/v1/theme/yozakura-reverie/og.svg">',
        cache:'365d immutable',
        params:[
          {name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false},
        ],
        curlExample:`curl ${siteUrl}/api/v1/theme/yozakura-reverie/og.svg`,
      },
      { id:'extract-theme', method:'POST', path:'/api/v1/extract-theme.json', label:'Image Extract',
        desc:'图片取色 API。服务端下载图片后用纯 JS 解码（jpeg-js/pngjs，零原生依赖），K-means 聚类提取 Top 5 主色调，色彩语义引擎映射为标准 UI 变量（背景两极化、主色对比度筛选、正文自动适配）。',
        usage:'POST JSON: {"imageUrl":"https://example.com/poster.jpg"}。仅支持 JPEG/PNG，最大 5MB，超时 5s。返回 sourcePalette（5 个 hex）、isDark、cssVars（34 个）、customCss。',
        cache:'不缓存',
        params:[
          {name:'body',type:'textarea',label:'请求体(JSON)',placeholder:'{\n  "imageUrl": "https://example.com/poster.jpg"\n}',optional:false},
        ],
        curlExample:`curl -X POST ${siteUrl}/api/v1/extract-theme.json -H 'Content-Type: application/json' -d '{"imageUrl":"https://example.com/poster.jpg"}'`,
      },
    ]
  },
  {
    name: 'Tools',
    items: [
      { id:'tailwind-config', method:'GET', path:'/api/v1/tailwind-config.json', label:'Tailwind Config',
        desc:'一键生成 Tailwind CSS v3/v4 配置片段。所有颜色使用 RGB 通道变量支持不透明度修饰符（bg-primary/50 等）。',
        usage:'返回完整 tailwind.config.js 或 CSS @theme 块。',
        cache:'浏览器 1h',
        curlExample:`curl ${siteUrl}/api/v1/tailwind-config.json | jq .`,
      },
      { id:'tokens', method:'GET', path:'/api/v1/tokens.json', label:'Design Tokens (DTCG)',
        desc:'W3C DTCG 设计令牌导出。将主题 CSS 变量转换为标准化层级结构（color/typography/space/effects）。',
        usage:'用于与 Figma Tokens、Style Dictionary 等设计工具集成。',
        cache:'浏览器 1h',
        curlExample:`curl ${siteUrl}/api/v1/tokens.json | jq .`,
      },
      { id:'today-pattern', method:'GET', path:'/api/v1/today/pattern.css', label:'SVG Pattern CSS',
        desc:'动态 SVG 背景纹理。根据今日主题色实时生成几何图案 SVG，转为 data URI 嵌入 CSS，可作 background-image。',
        usage:'<link rel="stylesheet" href="/api/v1/today/pattern.css"> 或 CSS @import。',
        cache:'浏览器 1h',
        curlExample:`curl ${siteUrl}/api/v1/today/pattern.css`,
      },
      { id:'today-weather-js', method:'GET', path:'/api/v1/today/weather.js', label:'Weather Particles JS',
        desc:'天气粒子渲染脚本。云/雨/雪/太阳/闪电粒子动画，script src 引入即自动渲染 canvas 粒子层。',
        usage:'<script src="/api/v1/today/weather.js" defer></script>。自动在页面创建 canvas 天气粒子。',
        cache:'浏览器 1h / CDN 24h',
        curlExample:`curl ${siteUrl}/api/v1/today/weather.js`,
      },
      { id:'today-favicon', method:'GET', path:'/api/v1/today/favicon.svg', label:'Dynamic Favicon',
        desc:'动态 Favicon SVG。根据今日主题主色生成圆角矩形 + Logo 首字母的动态图标。每日自动变色。',
        usage:'<link rel="icon" type="image/svg+xml" href="/api/v1/today/favicon.svg">',
        cache:'浏览器 1h',
        curlExample:`curl ${siteUrl}/api/v1/today/favicon.svg`,
      },
      { id:'today-fonts', method:'GET', path:'/api/v1/today/fonts.css', label:'Auto Fonts CSS',
        desc:'自动字体注入。提取今日主题的字体设置，生成 Google Fonts @import 和 font-family 声明。',
        usage:'<link rel="stylesheet" href="/api/v1/today/fonts.css">。自动处理 Google Fonts CDN 引用。',
        cache:'浏览器 1h',
        curlExample:`curl ${siteUrl}/api/v1/today/fonts.css`,
      },
      { id:'today-palette', method:'GET', path:'/api/v1/today/palette.svg', label:'Palette Badge SVG',
        desc:'今日主题调色盘 SVG 徽章。可嵌入 README/Blog Footer 展示当日主题配色。',
        usage:'<img src="/api/v1/today/palette.svg" alt="Today Palette">',
        cache:'浏览器 1h',
        curlExample:`curl ${siteUrl}/api/v1/today/palette.svg`,
      },
      { id:'search-color', method:'GET', path:'/api/v1/search/color.json', label:'Color Search',
        desc:'颜色相似度搜索。RGB 欧几里得距离排序，找出与目标颜色最接近的主题。',
        usage:'传入 hex 颜色值和可选 limit 参数。返回按相似度排序的主题列表。',
        cache:'浏览器 1h',
        params:[
          {name:'hex',type:'text',label:'颜色值',placeholder:'#ff6b6b',optional:false},
          {name:'limit',type:'text',label:'结果数量',placeholder:'10',optional:true},
        ],
        curlExample:`curl "${siteUrl}/api/v1/search/color.json?hex=ff6b6b&limit=10" | jq .`,
      },
      { id:'recommend', method:'GET', path:'/api/v1/recommend/{id}.json', label:'Smart Recommend',
        desc:'智能推荐引擎。Jaccard 标签相似度 + 颜色距离加权，推荐与指定主题风格相近的主题。',
        usage:'传入主题 ID，返回风格最相似的主题列表。用于"相似主题"推荐栏目。',
        cache:'浏览器 1h',
        params:[
          {name:'id',type:'text',label:'主题ID',placeholder:'yozakura-reverie',optional:false},
        ],
        curlExample:`curl ${siteUrl}/api/v1/recommend/yozakura-reverie.json | jq .`,
      },
      { id:'trending', method:'GET', path:'/api/v1/trending.json', label:'Trending',
        desc:'趋势排行榜。热度 = 点赞数×10 + 使用量×1。发现社区中最受欢迎的主题。',
        usage:'无需参数。返回按热度降序排列的主题列表。',
        cache:'5min',
        curlExample:`curl ${siteUrl}/api/v1/trending.json | jq .`,
      },
    ]
  },
  {
    name: 'Environment',
    items: [
      { id:'weather', method:'GET', path:'/api/v1/weather-theme.json', label:'Weather-Adaptive',
        desc:'天气自适应主题。嗅探式跨平台地理位置检测（Vercel x-vercel-ip-latitude/longitude / Netlify x-nf-geo），调用免费 Open-Meteo API 获取实时天气，自动匹配对应氛围的主题。返回城市名（OpenStreetMap Nominatim 逆地理编码）。',
        usage:'支持 ?lat= 和 ?lon= 覆盖 IP 检测。天气→主题映射：晴天→sunny-day / 阴→cloudy-grey / 雨→rainy-mood / 雪→snow-white / 雷暴→thunderstorm。API 超时 3s，失败降级为 Clear Sky+今日主题。',
        cache:'30min',
        params:[
          {name:'lat',type:'text',label:'纬度',placeholder:'35.68',optional:true},
          {name:'lon',type:'text',label:'经度',placeholder:'139.76',optional:true},
        ],
        curlExample:`curl "${siteUrl}/api/v1/weather-theme.json?lat=35.68&lon=139.76" | jq .`,
      },
      { id:'status-override', method:'GET', path:'/api/v1/status-override.json', label:'Status Override',
        desc:'系统状态覆盖主题。用于维护页、哀悼日、故障降级等场景。maintenance→纯灰 / mourning→暗黑灰调+grayscale 滤镜 / incident→红色警示。',
        usage:'?status=maintenance|mourning|incident。',
        cache:'5min',
        params:[
          {name:'status',type:'select',label:'状态',options:['maintenance','mourning','incident'],optional:false},
        ],
        curlExample:`curl "${siteUrl}/api/v1/status-override.json?status=maintenance" | jq .`,
      },
      { id:'badge', method:'GET', path:'/api/v1/badge/{username}.svg', label:'GitHub Badge',
        desc:'GitHub 动态徽章 SVG。shields.io 风格作者统计，可嵌入 README 展示主题贡献者信息。',
        usage:'将 {username} 替换为 GitHub 用户名。返回 SVG 可在 img 或 Markdown 中引用。',
        cache:'浏览器 1h',
        params:[
          {name:'username',type:'text',label:'GitHub用户',placeholder:'424635328',optional:false},
        ],
        curlExample:`curl ${siteUrl}/api/v1/badge/424635328.svg`,
      },
    ]
  },
  {
    name: 'Community',
    items: [
      { id:'diy-list', method:'GET', path:'/api/v1/diy/themes.json', label:'Community List',
        desc:'社区投稿主题列表。支持分页（page/size）、排序（new/hot）、标签筛选（dark/light/warm/cool/vibrant/minimal/nature/tech）。返回含 id、author、likes、status、tags 等社区特有字段。',
        usage:'GET 无速率限制。sort=new 按时间降序，sort=hot 按点赞降序。max size=50。',
        cache:'浏览器 1min',
        params:[
          {name:'sort',type:'select',label:'排序',options:['new','hot'],optional:true},
          {name:'page',type:'text',label:'页码',placeholder:'1',optional:true},
          {name:'size',type:'text',label:'条数',placeholder:'20',optional:true},
          {name:'tag',type:'select',label:'标签',options:['','dark','light','warm','cool','vibrant','minimal','nature','tech'],optional:true},
        ],
        curlExample:`curl "${siteUrl}/api/v1/diy/themes.json?sort=hot&page=1&size=20" | jq .`,
      },
      { id:'diy-single', method:'GET', path:'/api/v1/diy/theme.json', label:'Single Theme',
        desc:'获取单个社区主题详情。含点赞数、作者信息、审核状态。通过 ?id= 参数指定主题 ID。',
        usage:'返回完整 CSS 变量、作者、标签、点赞数、状态（pending/approved/rejected）。',
        cache:'浏览器 5min',
        params:[
          {name:'id',type:'text',label:'主题ID',placeholder:'abc12345',optional:false},
        ],
        curlExample:`curl "${siteUrl}/api/v1/diy/theme.json?id=abc12345" | jq .`,
      },
      { id:'diy-submit', method:'POST', path:'/api/v1/diy/submit.json', label:'Submit Theme',
        desc:'提交社区主题到审核队列。必填 name（≤100字符）、author（≤50字符）、cssVars（必须含 --color-primary 和 --color-bg）。可选 customCss（≤16KB）、extensions（≤20个，仅支持 floating+decorative）、tags（≤5个）。',
        usage:'成功返回 201：{success:true, theme:{id,name,...}, warnings?:[...]}。warnings 表示字段被自动调整（如不支持的类型被移除）。键名自动补齐 -- 前缀。',
        cache:'不缓存',
        params:[
          {name:'body',type:'textarea',label:'请求体(JSON)',placeholder:'{\n  "name": "My Theme",\n  "author": "You",\n  "cssVars": {\n    "--color-primary": "#ff6b6b",\n    "--color-bg": "#1a1a2e"\n  },\n  "tags": ["dark", "vibrant"]\n}',optional:false},
        ],
        notes:'限流 3次/分钟。customCss 自动剥离 @import、url(http)、expression()、javascript:。extensions 中 javascript 类型会被静默移除并在 warnings 中提示。',
        curlExample:`curl -X POST ${siteUrl}/api/v1/diy/submit.json -H 'Content-Type: application/json' -d '{"name":"My Theme","author":"You","cssVars":{"--color-primary":"#ff6b6b","--color-bg":"#1a1a2e"},"tags":["dark"]}'`,
      },
      { id:'diy-like', method:'POST', path:'/api/v1/diy/like.json', label:'Like Theme',
        desc:'点赞社区主题。基于 IP+User-Agent+UUID 三重去重，同一用户对同一主题仅计一次。',
        usage:'POST {"id":"abc12345"}。返回 {likes:number, voted:boolean}。',
        cache:'不缓存',
        params:[
          {name:'body',type:'textarea',label:'请求体(JSON)',placeholder:'{\n  "id": "abc12345"\n}',optional:false},
        ],
        notes:'限流 10次/分钟。点赞数实时同步至排行榜（热度=点赞×10+使用量×1）。',
        curlExample:`curl -X POST ${siteUrl}/api/v1/diy/like.json -H 'Content-Type: application/json' -d '{"id":"abc12345"}'`,
      },
    ]
  },
  {
    name: 'AI',
    items: [
      { id:'ai-generate', method:'POST', path:'/api/v1/ai/generate.json', label:'AI Generate',
        desc:'AI 主题生成。支持规则引擎（内置）或客户端 DeepSeek 直调（用户自带 Key，客户端直接调用，max_tokens:10000）。根据文本描述生成完整 CSS 变量主题。',
        usage:'POST {"prompt":"a dark cyberpunk theme with neon green accents"}。',
        cache:'不缓存',
        params:[
          {name:'body',type:'textarea',label:'请求体(JSON)',placeholder:'{\n  "prompt": "a dark cyberpunk theme with neon green accents"\n}',optional:false},
        ],
        curlExample:`curl -X POST ${siteUrl}/api/v1/ai/generate.json -H 'Content-Type: application/json' -d '{"prompt":"dark cyberpunk neon green"}'`,
      },
      { id:'ai-describe', method:'POST', path:'/api/v1/ai/describe.json', label:'AI Describe',
        desc:'AI 逆向描述。分析 CSS 变量集合，输出中文风格描述。可用于"这个主题是什么风格"的查询。',
        usage:'POST {"cssVars":{"--color-primary":"#3b82f6",...}}。返回中文风格分析文本。',
        cache:'不缓存',
        params:[
          {name:'body',type:'textarea',label:'请求体(JSON)',placeholder:'{\n  "cssVars": {\n    "--color-primary": "#3b82f6",\n    "--color-bg": "#0f172a",\n    "--color-accent": "#f59e0b"\n  }\n}',optional:false},
        ],
        curlExample:`curl -X POST ${siteUrl}/api/v1/ai/describe.json -H 'Content-Type: application/json' -d '{"cssVars":{"--color-primary":"#3b82f6","--color-bg":"#0f172a"}}'`,
      },
    ]
  },
  {
    name: 'Telemetry & Pools',
    items: [
      { id:'telemetry', method:'POST', path:'/api/v1/telemetry/hit', label:'Telemetry Hit',
        desc:'匿名遥测上报。HyperLogLog 统计独立域名 + Sorted Set 记录主题使用计数。不存储个人信息。',
        usage:'POST {"preset":"yozakura-reverie"}。客户端应仅在首次加载时上报。',
        cache:'不缓存',
        params:[
          {name:'body',type:'textarea',label:'请求体(JSON)',placeholder:'{\n  "preset": "yozakura-reverie"\n}',optional:false},
        ],
        curlExample:`curl -X POST ${siteUrl}/api/v1/telemetry/hit -H 'Content-Type: application/json' -d '{"preset":"yozakura-reverie"}'`,
      },
      { id:'pool-create', method:'POST', path:'/api/v1/pool/create.json', label:'Create Pool',
        desc:'创建自定义主题轮换池。指定一组主题 preset，系统每日从中轮换选择。',
        usage:'POST {"name":"my-pool","presets":["minimal-blue","yozakura-reverie"]}。返回创建的 pool ID。',
        cache:'不缓存',
        params:[
          {name:'body',type:'textarea',label:'请求体(JSON)',placeholder:'{\n  "name": "my-pool",\n  "presets": ["minimal-blue", "yozakura-reverie"]\n}',optional:false},
        ],
        curlExample:`curl -X POST ${siteUrl}/api/v1/pool/create.json -H 'Content-Type: application/json' -d '{"name":"my-pool","presets":["minimal-blue","yozakura-reverie"]}'`,
      },
      { id:'pool-get', method:'GET', path:'/api/v1/pool/{poolId}.json', label:'Pool Rotation',
        desc:'查询自定义轮换池的每日主题。从指定池子中按日轮换选择。',
        usage:'创建池子后，通过池子 ID 获取当日选中主题。',
        cache:'1h',
        params:[
          {name:'poolId',type:'text',label:'池子ID',placeholder:'abc123',optional:false},
        ],
        curlExample:`curl ${siteUrl}/api/v1/pool/abc123.json | jq .`,
      },
    ]
  },
  {
    name: 'Admin',
    items: [
      { id:'admin-health', method:'GET', path:'/api/v1/admin/health.json', label:'Health Check',
        desc:'Redis 健康检查。返回 pending/approved 计数，验证数据库连接状态。',
        usage:'管理面板首页数据。Redis 不可用时返回降级状态。',
        cache:'不缓存',
        curlExample:`curl ${siteUrl}/api/v1/admin/health.json | jq .`,
      },
      { id:'admin-login', method:'POST', path:'/api/v1/admin/login.json', label:'Admin Login',
        desc:'管理员登录。Cookie 认证，HttpOnly + SameSite strict，写操作需 CSRF Token。',
        usage:'POST {"password":"..."}。成功返回 Set-Cookie 头。',
        cache:'不缓存',
        params:[
          {name:'body',type:'textarea',label:'请求体(JSON)',placeholder:'{\n  "password": "..."\n}',optional:false},
        ],
        notes:'单管理员。失败返回 401。',
        curlExample:`curl -X POST ${siteUrl}/api/v1/admin/login.json -H 'Content-Type: application/json' -d '{"password":"..."}'`,
      },
      { id:'admin-review', method:'GET', path:'/api/v1/admin/review.json', label:'Review Queue',
        desc:'审核待审主题 / 批量批准。GET 获取待审列表（需 Cookie 认证），POST 批量操作（需 CSRF Token）。',
        usage:'管理面板核心功能。主题提交后默认进入待审队列，管理员审核通过后发布至社区商店。',
        cache:'不缓存',
        notes:'需先登录获取 Cookie。GET 待审列表，POST 批准/拒绝。',
        curlExample:`curl ${siteUrl}/api/v1/admin/review.json -H 'Cookie: ...' | jq .`,
      },
    ]
  },
];

// Flatten with indices
var epIndex = 0;
var flat: any[] = [];
groups.forEach(function(g: any, gi: number) {
  g.items.forEach(function(ep: any, ei: number) {
    ep._idx = epIndex++;
    ep._gid = gi;
    flat.push(ep);
  });
});

var flatJSON = JSON.stringify(flat);
---

<Layout>
  <section style="padding:24px 16px;max-width:1560px;margin:0 auto">
    <div class="pg-topbar">
      <div>
        <p class="t-label" style="margin:0">Developer Tools</p>
        <h1 style="margin:2px 0 0;font-size:1.3rem;font-weight:700;letter-spacing:-0.02em">API Playground</h1>
      </div>
      <div class="pg-topbar__actions">
        <button class="pg-mobile-toggle" id="mobile-sidebar-toggle" type="button" aria-label="Toggle sidebar">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect y="2" width="18" height="2" rx="1" fill="currentColor"/><rect y="8" width="18" height="2" rx="1" fill="currentColor"/><rect y="14" width="18" height="2" rx="1" fill="currentColor"/></svg>
        </button>
        <div class="pg-topbar__hint">
          <kbd>Ctrl</kbd> + <kbd>Enter</kbd> to send
        </div>
      </div>
    </div>

    <div class="pg-shell" id="pg-shell">
      <!-- ====== SIDEBAR ====== -->
      <nav class="pg-sidebar" id="pg-sidebar">
        <div class="pg-sidebar__section">
          <div class="pg-sidebar__label">Endpoints</div>
          <div class="pg-search">
            <svg class="pg-search__icon" width="14" height="14" viewBox="0 0 18 18" fill="none"><circle cx="7.5" cy="7.5" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M11.5 11.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <input class="pg-search__input" id="ep-search" type="text" placeholder="Filter endpoints..." autocomplete="off" />
          </div>
          <div class="pg-ep-list" id="ep-list">
            {groups.map(function(g: any) { return (
              <div class="pg-ep-group" data-group={g.name}>
                <button class="pg-ep-group__name" type="button" onclick="this.parentElement.classList.toggle('collapsed')">{g.name}</button>
                {g.items.map(function(ep: any) { return (
                  <button class="pg-ep-item" data-idx={String(ep._idx)} data-label={ep.label} data-path={ep.path} type="button"
                    onclick={'window.__selectEndpoint(' + ep._idx + ')'}>
                    <span class={'pg-ep-item__method pg-ep-method--' + ep.method.toLowerCase()}>{ep.method}</span>
                    <span class="pg-ep-item__label">{ep.label}</span>
                  </button>
                ); })}
              </div>
            ); })}
          </div>
        </div>

        <button class="pg-custom-trigger" id="custom-url-toggle" type="button">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none"><path d="M7 3H4a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1v-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 2L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M11 2h5v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Custom URL
        </button>

        <div class="pg-sidebar__section" id="history-section" style="display:none">
          <div class="pg-sidebar__label">History <button class="pg-history-clear" id="history-clear" type="button">Clear</button></div>
          <div class="pg-history-list" id="history-list"></div>
        </div>
      </nav>

      <!-- ====== MAIN: Request + Docs ====== -->
      <div class="pg-main">
        <div class="pg-panel" style="height:100%;overflow-y:auto">
          <!-- URL bar -->
          <div class="pg-url-section">
            <div class="pg-url-row">
              <select class="pg-method-select" id="method-select">
                <option value="GET">GET</option>
                <option value="POST">POST</option>
              </select>
              <div class="pg-url-input-wrap">
                <span class="pg-url-prefix">{siteUrl}</span>
                <input class="pg-url-input" id="url-input" type="text" value="/api/v1/today.json" autocomplete="off" spellcheck="false" />
              </div>
              <button class="pg-send-btn" id="pg-send" type="button" onclick="window.__doSend()">
                <svg width="14" height="14" viewBox="0 0 18 18" fill="none"><path d="M2 9l14-7-7 14-2-5-5-2z" fill="currentColor"/></svg>
                <span id="pg-send-label">Send</span>
              </button>
            </div>
          </div>

          <!-- API Docs Panel -->
          <div class="pg-docs" id="pg-docs">
            <div class="pg-docs__empty" id="pg-docs-empty">
              <div class="pg-docs__quickstart">
                <h3>Quick Start</h3>
                <pre class="pg-docs__qs-code"><code>fetch('{siteUrl}/api/v1/today.json')
  .then(r => r.json())
  .then(t => {`{`}
    Object.entries(t.cssVars).forEach(([k,v]) =>
      document.documentElement.style.setProperty(k,v));
    if (t.customCss) {`{`}
      let s = document.createElement('style');
      s.textContent = t.customCss;
      document.head.appendChild(s);
    {`}`}
  {`}`});</code></pre>
                <p class="pg-docs__qs-hint">Select an endpoint from the sidebar to explore the full API, or use Custom URL for any path.</p>
              </div>
            </div>
            <div class="pg-docs__content" id="pg-docs-content" style="display:none">
              <div class="pg-docs__header">
                <h2 class="pg-docs__title" id="docs-title"></h2>
                <span class="pg-cache-badge" id="docs-cache"></span>
              </div>
              <p class="pg-docs__desc" id="docs-desc"></p>
              <div class="pg-docs__section"><h3>Usage</h3><p class="pg-docs__text" id="docs-usage"></p></div>
              <div class="pg-docs__section" id="docs-notes-block" style="display:none"><h3>Notes</h3><div class="pg-docs__notes" id="docs-notes"></div></div>
              <div class="pg-docs__section" id="docs-response-block" style="display:none">
                <h3>Response Fields</h3>
                <div class="pg-table-wrap"><table class="pg-docs-table" id="docs-response-table"></table></div>
              </div>
              <div class="pg-docs__section"><h3>cURL Example</h3><pre class="pg-docs__curl" id="docs-curl"></pre></div>
            </div>
          </div>

          <!-- Query params -->
          <div class="pg-params" id="params-container">
            <div class="pg-params__head">
              <span class="pg-params__title">Query Parameters</span>
              <button class="pg-params__add" id="param-add" type="button">+ Add</button>
            </div>
            <div id="params-list"></div>
            <div class="pg-no-params" id="no-params">No parameters for this endpoint</div>
          </div>

          <!-- Body (POST) -->
          <div class="pg-body-section" id="body-section" style="display:none">
            <div class="pg-body__head">
              <span class="pg-params__title">Request Body</span>
              <div class="pg-body__actions">
                <button class="pg-body__btn" id="body-format" type="button">Prettify</button>
                <button class="pg-body__btn" id="body-validate" type="button">Validate</button>
              </div>
            </div>
            <textarea class="pg-body-editor" id="body-editor" rows="8" placeholder='{"key":"value"}' spellcheck="false"></textarea>
            <span class="pg-body-feedback" id="body-feedback"></span>
          </div>

          <!-- Rate limit bar -->
          <div class="pg-rate" id="pg-rate" style="display:none">
            <div class="pg-rate__bar"><div class="pg-rate__fill" id="rate-fill"></div></div>
            <span class="pg-rate__text" id="rate-text"></span>
          </div>

          <span class="pg-send-hint" id="pg-send-hint"></span>
        </div>
      </div>

      <!-- ====== RIGHT: Response ====== -->
      <div class="pg-response" id="res-panel">
        <div class="pg-panel" style="height:100%;display:flex;flex-direction:column">
          <div class="pg-panel__head">
            <span class="pg-panel__title">Response</span>
            <div class="pg-res__meta" id="res-meta" style="display:none">
              <span class="pg-res-status" id="res-status"></span>
              <span class="pg-res-time" id="res-time"></span>
              <button class="pg-res-copy" id="res-copy" type="button">Copy</button>
            </div>
          </div>

          <div class="pg-res-empty" id="pg-empty">
            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" opacity="0.25">
              <rect x="10" y="10" width="28" height="28" rx="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M18 21l4 4 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p>Click <strong>Send</strong> or press <strong>Ctrl+Enter</strong> to call the API</p>
          </div>

          <div class="pg-res-loading" id="pg-loading" style="display:none">
            <div class="pg-spinner"></div>
            <span>Sending request...</span>
          </div>

          <div class="pg-res-error" id="pg-error" style="display:none">
            <span class="pg-res-error__icon">!</span>
            <div><strong id="pg-error-title">Request Failed</strong><p id="pg-error-msg"></p></div>
          </div>

          <div class="pg-res-content" id="res-content" style="display:none">
            <details class="pg-res-headers" id="res-headers-block" open>
              <summary class="pg-res-headers__toggle">Response Headers <span class="pg-res-count" id="hdr-count"></span></summary>
              <div class="pg-res-headers__table-wrap">
                <table class="pg-res-headers__table" id="res-headers"></table>
              </div>
            </details>
            <div class="pg-res-body" id="res-body-block">
              <div class="pg-res-body__head">
                <span class="pg-res-body__label">Response Body</span>
                <button class="pg-res-body__maximize" id="res-maximize" type="button" title="Toggle full-width">⤢</button>
              </div>
              <pre class="pg-res-body__code" id="res-body"></pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ siteUrl, flatJSON }}>
  window.__SITE_URL__ = siteUrl;
  window.__FLAT_JSON__ = flatJSON;
</script>

<script>
  var siteUrl = window.__SITE_URL__;
  var RATE_WINDOW = 60000;
  var RATE_LIMITS = { GET: 30, POST: 5 };
  var STORAGE_KEY = 'td-pg-rate';
  var HIST_KEY = 'td-pg-history';
  var FLAT = JSON.parse(window.__FLAT_JSON__);
  var activeEP = FLAT[0];
  var isCustom = false;
  var lastResBody = '';
  var lastResCT = '';
  var retryTimer = 0;
  var maxed = false;

  // ── Rate helpers ──
  function getHits() { try { return JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { return []; } }
  function recordHit(method) {
    var now = Date.now();
    var hist = getHits().filter(function(h) { return h.method === method && now - h.ts < RATE_WINDOW; });
    hist.push({ method: method, ts: now });
    sessionStorage.setItem(STORAGE_KEY, JSON.stringify(hist));
    return hist;
  }
  function checkRate(method) {
    var hist = getHits().filter(function(h) { return h.method === method && Date.now() - h.ts < RATE_WINDOW; });
    var limit = RATE_LIMITS[method] || 30;
    var rem = Math.max(0, limit - hist.length);
    var blocked = rem === 0;
    var ws = 0;
    if (blocked) { var o = hist.reduce(function(m,h) { return h.ts < m ? h.ts : m; }, Infinity); ws = Math.ceil((RATE_WINDOW - (Date.now() - o)) / 1000); }
    return { count: hist.length, limit: limit, remaining: rem, blocked: blocked, waitSec: ws };
  }

  // ── DOM access ──
  function getEl(s) { return document.getElementById(s); }

  // ── Docs render ──
  function showDocs(ep) {
    getEl('pg-docs-empty').style.display = 'none';
    getEl('pg-docs-content').style.display = 'block';
    getEl('docs-title').textContent = ep.method + ' ' + (ep.label || '');
    getEl('docs-desc').textContent = ep.desc || '';
    getEl('docs-usage').textContent = ep.usage || '';
    getEl('docs-curl').textContent = ep.curlExample || buildURL();
    // cache badge
    var cb = getEl('docs-cache');
    cb.textContent = ep.cache || '—';
    cb.className = 'pg-cache-badge ' + (
      ep.cache.indexOf('365') !== -1 ? 'pg-cache--immutable' :
      ep.cache.indexOf('24h') !== -1 || ep.cache.indexOf('CDN') !== -1 ? 'pg-cache--long' :
      ep.cache.indexOf('不缓存') !== -1 ? 'pg-cache--none' : 'pg-cache--medium'
    );
    // notes
    if (ep.notes) { getEl('docs-notes-block').style.display = 'block'; getEl('docs-notes').textContent = ep.notes; }
    else { getEl('docs-notes-block').style.display = 'none'; }
    // response fields
    var rf = ep.responseFields;
    if (rf && rf.length) {
      getEl('docs-response-block').style.display = 'block';
      getEl('docs-response-table').innerHTML = '<thead><tr><th>Field</th><th>Type</th><th>Description</th></tr></thead><tbody>' +
        rf.map(function(f) { return '<tr><td class="pg-docs-field">' + esc(f.name) + '</td><td class="pg-docs-type">' + esc(f.type) + '</td><td>' + esc(f.desc) + '</td></tr>'; }).join('') + '</tbody>';
    } else { getEl('docs-response-block').style.display = 'none'; }
  }

  // ── Select endpoint ──
  function selectEndpoint(idx) {
    isCustom = false;
    getEl('custom-url-toggle').classList.remove('active');
    activeEP = FLAT[idx];
    getEl('method-select').value = activeEP.method;
    getEl('method-select').disabled = false;
    getEl('url-input').value = activeEP.path;
    getEl('url-input').readOnly = false;
    renderParams();
    highlightSidebar();
    updateRateUI();
    showDocs(activeEP);
    getEl('body-section').style.display = activeEP.method === 'POST' ? 'block' : 'none';
    if (activeEP.method === 'POST') {
      var bp = (activeEP.params || []).find(function(p) { return p.name === 'body'; });
      if (bp && !getEl('body-editor').value) getEl('body-editor').value = bp.placeholder || '';
    }
    if (window.innerWidth < 1150) getEl('pg-sidebar').classList.remove('open');
  }
  window.__selectEndpoint = selectEndpoint;

  function highlightSidebar() {
    var items = document.querySelectorAll('.pg-ep-item');
    for (var i = 0; i < items.length; i++) {
      items[i].classList.toggle('active', items[i].getAttribute('data-idx') === String(activeEP._idx));
    }
  }

  // ── Filter endpoints ──
  getEl('ep-search').addEventListener('input', function() {
    var q = this.value.toLowerCase();
    var groups = document.querySelectorAll('.pg-ep-group');
    for (var i = 0; i < groups.length; i++) {
      var g = groups[i];
      var vis = false;
      var items = g.querySelectorAll('.pg-ep-item');
      for (var j = 0; j < items.length; j++) {
        var it = items[j];
        var ok = !q || (it.getAttribute('data-label') || '').toLowerCase().indexOf(q) !== -1 || (it.getAttribute('data-path') || '').toLowerCase().indexOf(q) !== -1;
        it.style.display = ok ? '' : 'none';
        if (ok) vis = true;
      }
      g.style.display = vis ? '' : 'none';
    }
  });

  // ── Params ──
  function renderParams() {
    var list = getEl('params-list');
    list.innerHTML = '';
    var params = isCustom ? [] : (activeEP.params || []);
    if (params.length === 0) { getEl('no-params').style.display = 'block'; getEl('body-section').style.display = activeEP.method === 'POST' ? 'block' : 'none'; return; }
    getEl('no-params').style.display = 'none';
    for (var i = 0; i < params.length; i++) {
      (function(p) {
        if (p.name === 'body') return;
        var row = document.createElement('div');
        row.className = 'pg-param-row';
        var valHTML;
        if (p.type === 'select') {
          valHTML = '<select class="pg-param-val pg-input" data-param="' + p.name + '">' + (p.options || []).map(function(o) { return '<option value="' + o + '">' + (o || '—') + '</option>'; }).join('') + '</select>';
        } else {
          valHTML = '<input class="pg-param-val pg-input" type="text" data-param="' + p.name + '" placeholder="' + (p.placeholder || '') + '" />';
        }
        row.innerHTML = '<input class="pg-param-key" type="text" value="' + p.name + '" ' + (p.optional ? '' : 'data-required="true"') + ' readonly /><span class="pg-param-eq">=</span>' + valHTML + '<button class="pg-param-del" type="button">&times;</button>';
        row.querySelector('.pg-param-del').addEventListener('click', function() { row.remove(); updateParamState(); });
        list.appendChild(row);
      })(params[i]);
    }
  }
  function updateParamState() { getEl('no-params').style.display = getEl('params-list').querySelectorAll('.pg-param-row').length === 0 ? 'block' : 'none'; }

  getEl('param-add').addEventListener('click', function() {
    getEl('no-params').style.display = 'none';
    var row = document.createElement('div');
    row.className = 'pg-param-row pg-param-row--custom';
    row.innerHTML = '<input class="pg-param-key pg-input" type="text" placeholder="key" /><span class="pg-param-eq">=</span><input class="pg-param-val pg-input" type="text" placeholder="value" /><button class="pg-param-del" type="button">&times;</button>';
    var fk = row.querySelector('.pg-param-key');
    fk.readOnly = false; fk.classList.add('pg-input');
    row.querySelector('.pg-param-del').addEventListener('click', function() { row.remove(); updateParamState(); });
    getEl('params-list').appendChild(row);
  });

  // ── Custom URL ──
  getEl('custom-url-toggle').addEventListener('click', function() {
    isCustom = !isCustom;
    this.classList.toggle('active', isCustom);
    var items = document.querySelectorAll('.pg-ep-item');
    for (var i = 0; i < items.length; i++) items[i].classList.remove('active');
    if (isCustom) {
      getEl('method-select').disabled = false;
      getEl('url-input').value = '/api/v1/';
      getEl('url-input').readOnly = false;
      getEl('params-list').innerHTML = '';
      getEl('no-params').style.display = 'block';
      getEl('body-section').style.display = 'none';
      getEl('pg-rate').style.display = 'none';
      getEl('pg-docs-empty').style.display = 'block';
      getEl('pg-docs-content').style.display = 'none';
    } else { selectEndpoint(activeEP._idx); }
    updateRateUI();
  });

  // ── Build URL ──
  function buildURL() {
    var path = getEl('url-input').value.trim();
    if (path.charAt(0) !== '/') path = '/' + path;
    var rows = getEl('params-list').querySelectorAll('.pg-param-row');
    var qp = [];
    for (var i = 0; i < rows.length; i++) {
      var key = (rows[i].querySelector('.pg-param-key') || {}).value || '';
      var val = (rows[i].querySelector('.pg-param-val') || {}).value || '';
      if (!key) continue;
      if (path.indexOf('{' + key + '}') !== -1) { path = path.replace('{' + key + '}', encodeURIComponent(val)); }
      else if (val) { qp.push(encodeURIComponent(key) + '=' + encodeURIComponent(val)); }
    }
    if (qp.length) path += '?' + qp.join('&');
    return siteUrl + path;
  }

  // ── Rate UI ──
  function updateRateUI() {
    var m = getEl('method-select').value;
    var r = checkRate(m);
    var pgRate = getEl('pg-rate');
    if (r.count > 0) {
      pgRate.style.display = 'flex';
      var pct = Math.min(100, (r.count / r.limit) * 100);
      getEl('rate-fill').style.width = pct + '%';
      getEl('rate-fill').style.background = pct >= 90 ? '#ef4444' : pct >= 60 ? '#f59e0b' : 'var(--color-primary)';
      getEl('rate-text').textContent = r.count + '/' + r.limit + ' · ' + (r.blocked ? 'blocked ' + r.waitSec + 's' : r.remaining + ' remaining');
      getEl('rate-text').style.color = r.blocked ? '#ef4444' : '';
    } else { pgRate.style.display = 'none'; }
    var sendBtn = getEl('pg-send');
    var hint = getEl('pg-send-hint');
    if (r.blocked) { sendBtn.disabled = true; hint.textContent = 'Rate limited — retry in ' + r.waitSec + 's'; hint.style.color = '#ef4444'; scheduleRetry(r.waitSec); }
    else { sendBtn.disabled = false; hint.textContent = ''; }
  }

  function scheduleRetry(sec) {
    clearInterval(retryTimer);
    retryTimer = setInterval(function() {
      var r = checkRate(getEl('method-select').value);
      if (r.blocked) { getEl('pg-send-hint').textContent = 'Rate limited — retry in ' + r.waitSec + 's'; }
      else { clearInterval(retryTimer); updateRateUI(); }
    }, 1000);
  }
  getEl('method-select').addEventListener('change', updateRateUI);

  // ── History ──
  function getHistory() { try { return JSON.parse(sessionStorage.getItem(HIST_KEY) || '[]'); } catch(e) { return []; } }
  function saveHistory(entry) {
    var h = getHistory(); h.unshift(entry); if (h.length > 20) h.length = 20;
    sessionStorage.setItem(HIST_KEY, JSON.stringify(h)); renderHistory();
  }
  function renderHistory() {
    var h = getHistory();
    if (h.length === 0) { getEl('history-section').style.display = 'none'; return; }
    getEl('history-section').style.display = 'block';
    var html = '';
    for (var i = 0; i < h.length; i++) {
      var e = h[i];
      html += '<button class="pg-history-item" data-idx="' + i + '" type="button">' +
        '<span class="pg-history-method pg-ep-method--' + e.method.toLowerCase() + '">' + e.method + '</span>' +
        '<span class="pg-history-status' + (e.status >= 400 ? ' pg-history-status--err' : '') + '">' + e.status + '</span>' +
        '<span class="pg-history-url" title="' + esc(e.url) + '">' + esc(e.endpoint || e.url.slice(0, 35)) + '</span>' +
        '<span class="pg-history-time">' + e.elapsed + 'ms</span></button>';
    }
    getEl('history-list').innerHTML = html;
    var btns = getEl('history-list').querySelectorAll('.pg-history-item');
    for (var j = 0; j < btns.length; j++) {
      btns[j].addEventListener('click', function() {
        var entry = h[parseInt(this.getAttribute('data-idx'))];
        if (!entry) return;
        if (entry.endpoint && !isCustom) {
          var ep = FLAT.find(function(e) { return e.label === entry.endpoint; });
          if (ep) selectEndpoint(ep._idx);
        }
        getEl('url-input').value = entry.url;
        getEl('method-select').value = entry.method;
        updateRateUI();
        getEl('pg-send').scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }
  }
  getEl('history-clear').addEventListener('click', function() { sessionStorage.removeItem(HIST_KEY); renderHistory(); });

  // ── JSON utils ──
  function tryFmt(t) { try { return JSON.stringify(JSON.parse(t), null, 2); } catch(e) { return null; } }
  function isValid(t) { try { JSON.parse(t); return true; } catch(e) { return false; } }

  getEl('body-format').addEventListener('click', function() {
    var f = tryFmt(getEl('body-editor').value);
    if (f) { getEl('body-editor').value = f; getEl('body-feedback').textContent = 'Formatted'; getEl('body-feedback').className = 'pg-body-feedback ok'; }
    else   { getEl('body-feedback').textContent = 'Invalid JSON'; getEl('body-feedback').className = 'pg-body-feedback err'; }
    setTimeout(function() { getEl('body-feedback').textContent = ''; }, 2000);
  });
  getEl('body-validate').addEventListener('click', function() {
    if (isValid(getEl('body-editor').value)) { getEl('body-feedback').textContent = 'Valid JSON'; getEl('body-feedback').className = 'pg-body-feedback ok'; }
    else {
      var msg = 'Invalid JSON';
      try { JSON.parse(getEl('body-editor').value); } catch(e) { msg += ' — ' + e.message; }
      getEl('body-feedback').textContent = msg; getEl('body-feedback').className = 'pg-body-feedback err';
    }
    setTimeout(function() { getEl('body-feedback').textContent = ''; }, 3000);
  });

  // ── Highlight ──
  function hlJSON(t) {
    return t.replace(/("(?:[^"\\]|\\.)*")\s*:/g, '<span class="hl-key">$1</span>:')
      .replace(/"((?:[^"\\]|\\.)*)"/g, '<span class="hl-str">"$1"</span>')
      .replace(/\b(true|false|null)\b/g, '<span class="hl-bool">$1</span>')
      .replace(/:\s*(-?\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)/g, ': <span class="hl-num">$1</span>');
  }
  function hlCSS(t) {
    return t.replace(/(\/\*[\s\S]*?\*\/)/g, '<span class="hl-comment">$1</span>')
      .replace(/(@[a-z-]+)/g, '<span class="hl-atrule">$1</span>')
      .replace(/([a-z-]+)\s*:/g, '<span class="hl-prop">$1</span>:')
      .replace(/:\s*([^;{]+)/g, ': <span class="hl-val">$1</span>')
      .replace(/(--[\w-]+)/g, '<span class="hl-var">$1</span>');
  }
  function fmtBody(t, ct) {
    if (ct.indexOf('json') !== -1) { try { return hlJSON(JSON.stringify(JSON.parse(t), null, 2)); } catch(e) { return esc(t); } }
    if (ct.indexOf('css') !== -1) return hlCSS(t);
    if (ct.indexOf('html') !== -1) return esc(t);
    try { return hlJSON(JSON.stringify(JSON.parse(t), null, 2)); } catch(e) { return esc(t); }
  }
  function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // ── Send ──
  function doSend() {
    var m = getEl('method-select').value;
    var r = checkRate(m);
    if (r.blocked) { getEl('pg-send-hint').textContent = 'Rate limited — retry in ' + r.waitSec + 's'; getEl('pg-send-hint').style.color = '#ef4444'; return; }
    var url = buildURL();
    hideAllRes();
    getEl('pg-loading').style.display = 'flex';
    getEl('pg-send').disabled = true;
    getEl('pg-send-label').textContent = 'Sending...';
    getEl('pg-send-hint').textContent = '';
    var t0 = performance.now();
    var bodyVal = getEl('body-editor').value.trim();
    fetch(url, { method: m, headers: m === 'POST' && bodyVal ? { 'Content-Type': 'application/json' } : {}, body: m === 'POST' && bodyVal ? bodyVal : undefined }).then(function(res) {
      var elapsed = Math.round(performance.now() - t0);
      recordHit(m);
      var hdrRows = '', hdrNum = 0;
      res.headers.forEach(function(v, k) { hdrRows += '<tr><td class="pg-hdr-key">' + esc(k) + '</td><td class="pg-hdr-val">' + esc(v) + '</td></tr>'; hdrNum++; });
      getEl('res-headers').innerHTML = hdrRows;
      getEl('hdr-count').textContent = '(' + hdrNum + ')';
      return res.text().then(function(text) {
        lastResCT = res.headers.get('content-type') || '';
        lastResBody = text;
        getEl('res-body').innerHTML = fmtBody(text, lastResCT);
        var cls = res.ok ? 'pg-res-status--ok' : 'pg-res-status--err';
        getEl('res-status').className = 'pg-res-status ' + cls;
        getEl('res-status').textContent = res.status + ' ' + res.statusText;
        getEl('res-time').textContent = elapsed + 'ms';
        hideAllRes();
        getEl('res-meta').style.display = 'flex';
        getEl('res-content').style.display = 'flex';
        getEl('res-headers-block').setAttribute('open', '');
        saveHistory({ method: m, url: url.replace(siteUrl, ''), status: res.status, elapsed: elapsed, ts: Date.now(), endpoint: isCustom ? null : activeEP.label });
        if (window.innerWidth < 1150) getEl('res-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }).catch(function(err) {
      hideAllRes();
      getEl('pg-error').style.display = 'flex';
      getEl('pg-error-title').textContent = 'Network Error';
      getEl('pg-error-msg').textContent = err.message || 'Failed to connect.';
    }).then(function() {
      getEl('pg-send').disabled = false;
      getEl('pg-send-label').textContent = 'Send';
      updateRateUI();
    });
  }
  window.__doSend = doSend;

  function hideAllRes() {
    getEl('pg-empty').style.display = 'none';
    getEl('pg-loading').style.display = 'none';
    getEl('pg-error').style.display = 'none';
    getEl('res-content').style.display = 'none';
    getEl('res-meta').style.display = 'none';
  }

  // ── Ctrl+Enter ──
  document.addEventListener('keydown', function(e) { if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); doSend(); } });

  // ── Copy ──
  getEl('res-copy').addEventListener('click', function() {
    try { navigator.clipboard.writeText(lastResBody); } catch(e) {}
    try { var ta = document.createElement('textarea'); ta.value = lastResBody; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); } catch(e) {}
    this.textContent = 'Copied!'; this.classList.add('copied');
    setTimeout(function() { getEl('res-copy').textContent = 'Copy'; getEl('res-copy').classList.remove('copied'); }, 1500);
  });

  // ── Maximize ──
  getEl('res-maximize').addEventListener('click', function() {
    maxed = !maxed;
    var sidebar = getEl('pg-sidebar');
    var main = document.querySelector('.pg-main');
    var resp = getEl('res-panel');
    if (maxed) { sidebar.style.display = 'none'; main.style.display = 'none'; resp.style.gridColumn = 'span 3'; }
    else { sidebar.style.display = ''; main.style.display = ''; resp.style.gridColumn = ''; }
  });

  // ── Mobile sidebar ──
  getEl('mobile-sidebar-toggle').addEventListener('click', function() { getEl('pg-sidebar').classList.toggle('open'); });
  document.addEventListener('click', function(e) {
    if (window.innerWidth >= 1150) return;
    var sb = getEl('pg-sidebar');
    var mt = getEl('mobile-sidebar-toggle');
    if (!sb.contains(e.target) && e.target !== mt && !mt.contains(e.target)) { sb.classList.remove('open'); }
  });

  // ── Init ──
  highlightSidebar();
  updateRateUI();
  renderHistory();
  showDocs(activeEP);
</script>

<style>
  /* ===== TOP BAR ===== */
  .pg-topbar { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:14px; gap:12px; flex-wrap:wrap; }
  .pg-topbar__actions { display:flex; align-items:center; gap:8px; margin-top:4px; }
  .pg-topbar__hint { display:flex; align-items:center; gap:4px; font-size:10px; color:var(--color-text-muted); }
  .pg-topbar__hint kbd { display:inline-block; padding:2px 5px; border-radius:4px; font-size:9px; font-weight:600; font-family:"JetBrains Mono",monospace; background:color-mix(in srgb,var(--color-text-muted) 10%,transparent); border:1px solid var(--color-border); color:var(--color-text-muted); }
  .pg-mobile-toggle { display:none; width:34px; height:34px; border-radius:7px; border:1.5px solid var(--color-border); background:transparent; color:var(--color-text); cursor:pointer; align-items:center; justify-content:center; }
  @media (max-width:1150px) { .pg-mobile-toggle { display:flex; } }

  /* ===== SHELL ===== */
  .pg-shell { display:grid; grid-template-columns:270px 1fr 1fr; gap:0; border:1px solid var(--color-border); border-radius:14px; overflow:hidden; background:color-mix(in srgb,var(--color-surface) 40%,transparent); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px); min-height:calc(100vh - 150px); }
  @media (max-width:1150px) {
    .pg-shell { grid-template-columns:1fr; }
    .pg-sidebar { display:none; position:fixed; top:0; left:0; bottom:0; width:280px; z-index:500; border-right:1px solid var(--color-border); box-shadow:8px 0 32px rgba(0,0,0,0.3); overflow-y:auto; background:color-mix(in srgb,var(--color-bg) 92%,transparent); backdrop-filter:blur(24px); }
    .pg-sidebar.open { display:flex; }
    .pg-response { min-height:50vh; }
    .pg-topbar__hint { display:none; }
  }

  /* ===== SIDEBAR ===== */
  .pg-sidebar { border-right:1px solid var(--color-border); display:flex; flex-direction:column; background:color-mix(in srgb,var(--color-bg) 30%,transparent); overflow:hidden; }
  .pg-sidebar__section { padding:10px; display:flex; flex-direction:column; overflow:hidden; }
  .pg-sidebar__section:first-child { flex:1; min-height:0; }
  .pg-sidebar__label { font-size:10px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:6px; display:flex; align-items:center; justify-content:space-between; }

  .pg-search { position:relative; margin-bottom:4px; }
  .pg-search__icon { position:absolute; left:8px; top:50%; transform:translateY(-50%); color:var(--color-text-muted); pointer-events:none; }
  .pg-search__input { width:100%; height:30px; padding:0 8px 0 26px; border-radius:6px; border:1.5px solid var(--color-border); background:color-mix(in srgb,var(--color-bg) 50%,transparent); color:var(--color-text); font-size:11px; font-family:"Inter",sans-serif; outline:none; transition:border-color 0.2s; }
  .pg-search__input:focus { border-color:var(--color-primary); }
  .pg-search__input::placeholder { color:var(--color-text-muted); opacity:0.5; }

  .pg-ep-list { overflow-y:auto; flex:1; min-height:0; }
  .pg-ep-group { margin-bottom:1px; }
  .pg-ep-group__name {
    width:100%; padding:6px 8px;
    font-size:9px; font-weight:700; letter-spacing:0.07em;
    text-transform:uppercase; color:var(--color-primary);
    background:transparent; border:none;
    cursor:pointer; text-align:left;
    display:flex; align-items:center; gap:4px;
  }
  .pg-ep-group__name::before { content:'▾'; font-size:8px; transition:transform 0.2s; }
  .pg-ep-group.collapsed .pg-ep-item { display:none; }
  .pg-ep-group.collapsed .pg-ep-group__name::before { transform:rotate(-90deg); }

  .pg-ep-item {
    display:flex; align-items:center; gap:6px;
    width:100%; padding:5px 8px;
    border:none; border-radius:5px;
    background:transparent; color:var(--color-text-muted);
    font-size:11px; font-family:"Inter",sans-serif;
    cursor:pointer; transition:all 0.12s;
    text-align:left;
  }
  .pg-ep-item:hover { background:color-mix(in srgb,var(--color-primary) 8%,transparent); color:var(--color-text); }
  .pg-ep-item.active { background:color-mix(in srgb,var(--color-primary) 12%,transparent); color:var(--color-primary); font-weight:600; box-shadow:inset 3px 0 0 var(--color-primary); }
  .pg-ep-item__method { font-size:8px; font-weight:800; letter-spacing:0.04em; padding:1px 5px; border-radius:3px; color:#fff; flex-shrink:0; min-width:28px; text-align:center; }
  .pg-ep-method--get  { background:#16a34a; }
  .pg-ep-method--post { background:#2563eb; }
  .pg-ep-item__label { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

  .pg-custom-trigger { display:flex; align-items:center; gap:5px; width:calc(100% - 10px); margin:0 5px 5px; padding:6px 8px; border:1.5px dashed var(--color-border); border-radius:7px; background:transparent; color:var(--color-text-muted); font-size:10px; font-weight:600; font-family:"Inter",sans-serif; cursor:pointer; transition:all 0.2s; }
  .pg-custom-trigger:hover { border-color:var(--color-primary); color:var(--color-primary); }
  .pg-custom-trigger.active { border-style:solid; border-color:var(--color-primary); background:color-mix(in srgb,var(--color-primary) 8%,transparent); color:var(--color-primary); }

  .pg-history-clear { font-size:9px; font-weight:600; letter-spacing:0.03em; background:none; border:none; color:var(--color-text-muted); cursor:pointer; font-family:inherit; padding:2px 5px; border-radius:4px; }
  .pg-history-clear:hover { color:#ef4444; background:rgba(239,68,68,0.1); }
  .pg-history-list { display:flex; flex-direction:column; gap:1px; overflow-y:auto; max-height:180px; }
  .pg-history-item { display:flex; align-items:center; gap:4px; width:100%; padding:3px 5px; border:none; border-radius:4px; background:transparent; font-family:"JetBrains Mono",monospace; cursor:pointer; font-size:9px; color:var(--color-text-muted); text-align:left; transition:background 0.15s; }
  .pg-history-item:hover { background:color-mix(in srgb,var(--color-primary) 6%,transparent); }
  .pg-history-method { font-size:7px; font-weight:800; padding:1px 4px; border-radius:3px; color:#fff; min-width:24px; text-align:center; }
  .pg-history-status { font-weight:700; color:#16a34a; min-width:20px; }
  .pg-history-status--err { color:#ef4444; }
  .pg-history-url { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .pg-history-time { font-size:8px; opacity:0.5; }

  /* ===== MAIN ===== */
  .pg-main { border-right:1px solid var(--color-border); display:flex; flex-direction:column; }
  .pg-panel { display:flex; flex-direction:column; }
  .pg-panel__head { display:flex; align-items:center; justify-content:space-between; padding:10px 14px; border-bottom:1px solid var(--color-border); gap:8px; flex-shrink:0; }
  .pg-panel__title { font-size:10px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:var(--color-text-muted); }

  /* URL bar */
  .pg-url-section { padding:12px 14px 8px; }
  .pg-url-row { display:flex; gap:0; }
  .pg-method-select { width:68px; height:36px; padding:0 5px; border:1.5px solid var(--color-border); border-right:none; border-radius:8px 0 0 8px; background:color-mix(in srgb,var(--color-bg) 60%,transparent); color:var(--color-text); font-size:10px; font-weight:700; font-family:"JetBrains Mono",monospace; cursor:pointer; outline:none; -webkit-appearance:none; appearance:none; }
  .pg-method-select:focus { border-color:var(--color-primary); }
  .pg-url-input-wrap { flex:1; display:flex; align-items:center; border:1.5px solid var(--color-border); border-right:none; background:color-mix(in srgb,var(--color-bg) 40%,transparent); overflow:hidden; }

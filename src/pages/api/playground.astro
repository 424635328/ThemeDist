---
import Layout from '../../layouts/Layout.astro';

const siteUrl = Astro.url.origin;

interface Param {
  name: string; type: string; label: string; placeholder?: string; optional: boolean; options?: string[]; isPath?: boolean;
}
interface EP {
  id: string; method: string; path: string; label: string; desc: string;
  usage: string; cache: string;
  responseFields?: { name: string; type: string; desc: string }[];
  params?: Param[];
  curlExample?: string; notes?: string;
  _idx?: number; _gid?: number; displayPath?: string;
}

function parseEndpoint(ep: EP): EP {
  const pathParamsMatch = ep.path.match(/\{([^}]+)\}/g);
  const pathParams = pathParamsMatch ? pathParamsMatch.map(m => m.slice(1, -1)) : [];

  if (pathParams.length > 0) {
    if (!ep.params) ep.params = [];
    pathParams.forEach(pp => {
      if (!ep.params!.find(p => p.name === pp)) {
        ep.params!.unshift({ name: pp, type: 'text', label: `路径参数 ${pp}`, placeholder: '...', optional: false, isPath: true });
      } else {
        const existing = ep.params!.find(p => p.name === pp);
        if (existing) existing.isPath = true;
      }
    });
  }

  if (!ep.curlExample) {
    let curlPath = ep.path;
    ep.params?.filter(p => p.isPath).forEach(p => { curlPath = curlPath.replace(`{${p.name}}`, p.placeholder || 'xxx'); });
    const isAbs = curlPath.startsWith('http');
    ep.curlExample = `curl ${isAbs ? '' : siteUrl}${curlPath}`;
  }

  ep.displayPath = ep.path.startsWith('http') ? ep.path : ep.path.replace(/^\/api\/v1/, '');
  if (ep.displayPath === '') ep.displayPath = '/';

  return ep;
}


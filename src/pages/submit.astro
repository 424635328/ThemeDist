  function updatePreview(vars, css, themeName = "未命名主题") {
    if (vars) vars = normalizeCssVarKeys(vars);
    currentVars = vars;
    currentCss = css;

    const iframe = $('preview-iframe');
    const placeholder = $('preview-placeholder');

    if (!vars) {
      placeholder.style.opacity = '1';
      iframe.classList.remove('active');
      updateSubmitBtn();
      renderEditorSwatches(null);
      return;
    }

    placeholder.style.opacity = '0';
    iframe.classList.add('active');

    const doc = iframe.contentDocument || iframe.contentWindow?.document;
    if (!doc) return;

    // 1. Live injection of CSS Variables & Custom CSS via DOM
    const styleEl = doc.getElementById('theme-style');
    if (styleEl) {
      const varsCSS = Object.entries(vars).map(([k, v]) => `${k}:${v}`).join(';');
      // 使用 textContent 自动防范跨站注入，保障安全
      styleEl.textContent = `:root { ${varsCSS} }\n${css || ''}`;
    }

    // 2. Set Theme metadata within sandbox
    const titleEl = doc.getElementById('preview-title');
    if (titleEl) titleEl.textContent = themeName;

    // 3. Render Effects (e.g. Sakura)
    const effectsContainer = doc.getElementById('effects-container');
    if (effectsContainer) {
      effectsContainer.innerHTML = ''; // 清除旧特效
      if (themeName === "樱花梦境" || (css && css.includes('.sakura-petal'))) {
        let effectsHtml = '';
        for (let i = 0; i < 15; i++) {
          effectsHtml += `<div class="sakura-petal" style="left:${Math.random() * 100}%; animation-delay:${Math.random() * 5}s; animation-duration:${Math.random() * 4 + 4}s"></div>`;
        }
        effectsContainer.innerHTML = effectsHtml;
      }

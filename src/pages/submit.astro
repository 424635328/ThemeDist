  // ─── Submissions LocalStorage History CRUD ───
  const STORAGE_KEY = 'td_submitted_themes';
  const STATUS_CACHE_TTL = 10 * 60 * 1000; // 10 min before re-checking

  function getHistory() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; } }

  function saveHistory(list) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(list.slice(0, 10))); } catch {}
  }

  function updateCachedStatus(id, status) {
    const list = getHistory();
    const entry = list.find(h => h.id === id);
    if (entry) {
      entry._status = status;
      entry._checked = Date.now();
      saveHistory(list);
    }
  }

  function getCachedStatus(h) {
    if (!h._status || !h._checked) return null;
    if (Date.now() - h._checked > STATUS_CACHE_TTL) return null;
    return h._status;
  }

  function saveToHistory(item) {
    const history = getHistory();
    if (!history.some(h => h.id === item.id)) {
      history.unshift(item);
      saveHistory(history);
    }
    renderHistory();
  }

  function renderStatusLabel(status) {
    if (status === 'active') return '<span class="recent-status active" title="该主题仍在数据库中">收录中</span>';
    if (status === 'expired') return '<span class="recent-status expired" title="已从数据库移除（24h TTL）">已过期</span>';
    return '<span class="recent-status checking">检测中…</span>';
  }

  async function renderHistory() {
    const list = getHistory();
    const section = $('recent-section');
    const container = $('recent-list');
    if (!list.length) { section.style.display = 'none'; return; }
    section.style.display = 'block';

    // Render with cached status (or "checking" if no cache)
    const renderItem = (h) => {
      const cached = getCachedStatus(h);
      return `
        <div class="recent-item" data-rid="${escapeAttr(h.id)}">
          <div class="recent-item-left">
            <span class="recent-name">${escapeHtml(h.name)}</span>
            <code class="recent-id">${h.id}</code>
            ${renderStatusLabel(cached)}
          </div>
          <div class="recent-item-right">
            <span class="recent-author">${escapeHtml(h.author)}</span>
            <a href="/share?id=${h.id}" class="text-btn recent-link">进入主页</a>
          </div>
        </div>`;
    };
    container.innerHTML = list.map(renderItem).join('');

    // Only re-check items without valid cache
    const toCheck = list.filter(h => !getCachedStatus(h));
    for (const h of toCheck) {
      const statusEl = container.querySelector(`[data-rid="${escapeAttr(h.id)}"] .recent-status`);
      try {
        const res = await fetch(`/api/diy/theme.json?id=${encodeURIComponent(h.id)}`);
        const status = res.ok ? 'active' : 'expired';
        updateCachedStatus(h.id, status);
        if (statusEl) {
          statusEl.className = 'recent-status ' + status;
          statusEl.textContent = status === 'active' ? '收录中' : '已过期';
          statusEl.title = status === 'active' ? '该主题仍在数据库中' : '已从数据库移除（24h TTL）';
        }
      } catch {
        if (statusEl) {
          statusEl.className = 'recent-status unknown';
          statusEl.textContent = '未知';
        }
      }
    }
  }

  // ─── Submit execution ───
  $('btn-submit').addEventListener('click', async () => {
    const btn = $('btn-submit');
    if (btn.disabled || !currentVars || submitting) return;

    const name = $('name-input').value.trim();
    const author = $('author-input').value.trim();
    const css = $('css-input').value.trim();

    // Client-side pre-flight: normalize & validate required vars
    const normalizedVars = normalizeCssVarKeys(currentVars);
    const missing = validateRequiredVars(normalizedVars);
    if (missing) {
      window.__toast?.(`缺少必填变量: ${missing.join(', ')}。请检查 JSON 或重新生成。`);
      showError(`缺少必填变量: ${missing.join(', ')}`);
      return;
    }

    submitting = true;
    btn.classList.add('loading');
    btn.innerHTML = '<span class="spinner"></span> 发布中…';
    btn.disabled = true;

    try {
      const res = await fetch('/api/diy/submit.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name, author, cssVars: normalizedVars, customCss: css || undefined,
          tags: (() => { try { return JSON.parse($('name-input').dataset.tags || '[]'); } catch { return undefined; } })(),
        }),
      });

      const data = await res.json();

      if (res.ok && data.theme) {
        const resultEl = $('submit-result');
        resultEl.style.display = 'block';
        const shareUrl = `${location.origin}/share?id=${data.theme.id}`;
        resultEl.innerHTML = `
          <div style="padding:18px;border-radius:14px;background:color-mix(in srgb, #22c55e 10%, transparent);border:1.5px solid rgba(34, 197, 94, 0.3);margin-top:16px">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
              <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#22c55e" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="#22c55e" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span style="font-weight:700;font-size:14px;color:#22c55e">主题已成功提交！</span>
            </div>
            <div style="font-size:13px;margin-bottom:4px;color:var(--color-text)">
              分享码: <code style="font-weight:700;font-size:14px;color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 12%, transparent);padding:2px 8px;border-radius:4px">${data.theme.id}</code>
            </div>
            <div style="font-size:11px;color:var(--color-text-muted);margin-bottom:10px;line-height:1.5">
              当前处于<strong style="color:#f59e0b">待审核</strong>状态，24 小时内管理员审核通过后将<strong>永久收录</strong>至主题商店。
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
              <input readonly value="${shareUrl}" style="flex:1;min-width:200px;height:34px;padding:0 10px;border-radius:8px;border:1px solid var(--color-border);background:var(--color-bg);color:var(--color-text);font-size:12px;font-family:'JetBrains Mono',monospace" onclick="this.select()" />
              <button class="btn btn-outline copy-share-btn" data-url="${shareUrl}" data-code="${data.theme.id}" style="height:34px;padding:0 14px;font-size:12px;white-space:nowrap">
                复制链接
              </button>
              <a href="/share?id=${data.theme.id}" class="btn btn-primary" style="height:34px;padding:0 14px;font-size:12px;text-decoration:none;white-space:nowrap;display:inline-flex;align-items:center;justify-content:center">前往详情页</a>
            </div>
          </div>
        `;

        saveToHistory({ id: data.theme.id, name, author, createdAt: new Date().toISOString() });

        $('name-input').value = ''; $('author-input').value = '';
        $('name-counter').textContent = '0/40'; $('author-counter').textContent = '0/20';
        window.__toast?.('发布并登记到本地历史成功！');
      } else {
        const resultEl = $('submit-result'); resultEl.style.display = 'block';
        resultEl.innerHTML = `<div style="padding:14px;border-radius:12px;background:color-mix(in srgb, #ef4444 10%, transparent);border:1.5px solid rgba(239, 68, 68, 0.3);color:#ef4444;font-size:13px;font-weight:700">提交失败: ${escapeHtml(data.error || '服务器拒绝了当前提交')}</div>`;
      }
    } catch {
      const resultEl = $('submit-result'); resultEl.style.display = 'block';
      resultEl.innerHTML = `<div style="padding:14px;border-radius:12px;background:color-mix(in srgb, #ef4444 10%, transparent);border:1.5px solid rgba(239, 68, 68, 0.3);color:#ef4444;font-size:13px;font-weight:700">网络传输故障，请稍后检查重试</div>`;
    } finally {
      submitting = false; btn.classList.remove('loading');
      btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v10M4 8l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg> 发布到社区商店`;
      updateSubmitBtn();
    }
  });

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.copy-share-btn');
    if (!btn) return;
    navigator.clipboard.writeText(btn.dataset.url || '').then(() => {
      const orig = btn.innerHTML; btn.innerHTML = '已复制'; btn.style.color = '#22c55e'; btn.style.borderColor = '#22c55e';
      setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; btn.style.borderColor = ''; }, 1500);
    });
  });

  function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function escapeAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // Normalize CSS variable keys: ensure -- prefix, trim whitespace
  function normalizeCssVarKeys(vars) {
    const out = {};
    for (const [k, v] of Object.entries(vars)) {
      let key = k.trim();
      if (!key.startsWith('--')) key = '--' + key.replace(/^-+/, '');
      out[key] = typeof v === 'string' ? v.trim() : v;
    }
    return out;
  }

  // Check required vars before submit — returns missing keys or null
  function validateRequiredVars(vars) {
    if (!vars || typeof vars !== 'object') return ['cssVars 对象为空'];
    const keys = Object.keys(vars);
    const missing = [];
    if (!keys.some(k => k === '--color-primary')) missing.push('--color-primary');
    if (!keys.some(k => k === '--color-bg')) missing.push('--color-bg');
    return missing.length ? missing : null;
  }

  const spinnerCSS = document.createElement('style');
  spinnerCSS.textContent = `.spinner { display:inline-block;width:14px;height:14px; border:2.5px solid rgba(255,255,255,0.3); border-top-color:#fff; border-radius:50%; animation:spin 0.6s linear infinite; } @keyframes spin { to { transform:rotate(360deg); } } .spinner-sm { display:inline-block; border-radius:50%; border-top-color:currentColor; animation:spin 0.6s linear infinite; }`;
  document.head.appendChild(spinnerCSS);

  initIframe(() => { loadThemeData(DEFAULT_THEME); });
  renderHistory();
</script>
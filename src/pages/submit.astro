            toast.innerHTML = icon + '<span>' + message + '</span>';
            toastContainer.appendChild(toast);
            setTimeout(() => { toast.style.animation = 'slideOut 0.3s ease forwards'; setTimeout(() => toast.remove(), 300); }, 3000);
          };


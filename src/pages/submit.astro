---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="submit-container">
    <div class="submit-grid">

      <!-- LEFT: Editor Form -->
      <div class="form-wrapper">
        <div class="card card-glass form-card">
          <div class="form-section-header">
            <span class="section-badge">Data Editor</span>
            <h2 class="section-title">主题数据配置</h2>
          </div>

          <!-- Import Options Group -->
          <div class="import-group">
            <button id="btn-import" class="btn btn-outline import-btn" title="从剪贴板读取构建器复制的数据">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 6v8a2 2 0 002 2h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              从剪贴板导入
            </button>
            <button id="btn-demo" class="btn btn-outline demo-btn" title="加载一组精美动态樱花主题体验">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1v14M1 8h14" stroke-linecap="round"/><circle cx="8" cy="8" r="3" fill="var(--color-surface)"/></svg>
              加载樱花示例
            </button>
          </div>

          <!-- AI Generation Bar -->
          <div class="ai-gen-bar">
            <div class="ai-gen-row">
              <input id="ai-description" type="text" class="text-input ai-input" placeholder="用文字描述你心中的主题… 如：深色赛博朋克风，紫绿霓虹" maxlength="200" />
              <button id="btn-ai-generate" class="btn btn-primary ai-gen-btn">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5L13 6l-3.5 1.5L8 11l-1.5-3.5L3 6l3.5-1.5L8 1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M5 12l1 1.5 2.5.5-2 1.5.5 2.5L5 16l-2.5-1 .5-2.5L1 11l2.5-.5L5 12z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
                AI 生成
              </button>
            </div>
            <div class="ai-key-bar">
              <button id="btn-toggle-apikey" class="ai-key-toggle" type="button">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M10 8a2 2 0 11-4 0 2 2 0 014 0z" stroke="currentColor" stroke-width="1.5"/><path d="M15 8s-3 5.5-7 5.5S1 8 1 8s3-5.5 7-5.5S15 8 15 8z" stroke="currentColor" stroke-width="1.5"/></svg>
                <span id="ai-key-indicator">未设置 API Key</span>
              </button>
              <div id="ai-key-panel" class="ai-key-panel" hidden>
                <div class="ai-key-header">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="3" y="7" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M5 7V5a3 3 0 016 0v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                  <span>DeepSeek API 密钥（可选）</span>
                </div>
                <div class="ai-key-notice">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 2l6 11H2L8 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 6v3.5M8 11.5h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                  <span><strong>隐私声明：</strong>你的 API Key <strong>仅存储在当前浏览器 localStorage 中</strong>，生成请求由浏览器<strong>直接发送至 DeepSeek API</strong>，<strong>不会经过本服务器</strong>。</span>
                </div>
                <div class="ai-key-tip">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 1v14M1 8h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                  <span><strong>建议：</strong>填入 DeepSeek API Key 后使用大模型生成，配色质量和特效创意远超规则引擎。免费申请 Key 请访问 <a href="https://platform.deepseek.com/api_keys" target="_blank" rel="noopener" style="color:var(--color-primary);text-decoration:underline">platform.deepseek.com</a>。</span>
                </div>
                <div class="ai-key-input-row">
                  <input id="ai-apikey" type="password" class="text-input" placeholder="sk-..." autocomplete="off" spellcheck="false" />
                  <button id="btn-save-apikey" class="btn btn-primary" type="button" style="height:36px;padding:0 14px;font-size:12px;white-space:nowrap">保存</button>
                  <button id="btn-clear-apikey" class="btn btn-outline" type="button" style="height:36px;padding:0 14px;font-size:12px;white-space:nowrap">清除</button>
                </div>
                <p id="ai-key-feedback" class="ai-key-feedback"></p>
              </div>
            </div>
            <p id="ai-status" class="ai-status-text"></p>
          </div>

          <!-- Code Editors Tab Container -->
          <div class="tabs-container">
            <button id="tab-btn-vars" class="tab-btn active" type="button">🎨 核心 CSS 变量</button>
            <button id="tab-btn-css" class="tab-btn" type="button">✨ 自定义 CSS (可选)</button>
          </div>

          <!-- Tab 1: CSS Variables JSON -->
          <div id="tab-content-vars" class="tab-content active">
            <div class="input-block">
              <div class="block-header">
                <label for="vars-input" class="input-label">JSON 代码 <span class="required">*</span></label>
                <button id="btn-format" class="text-btn" title="自动排版美化 JSON 代码">格式化</button>
              </div>
              <textarea
                id="vars-input"
                spellcheck="false"
                placeholder='{"--color-primary":"#ff8fa3","--color-bg":"#fff0f3",...}'
                class="code-textarea"
              ></textarea>
              <div id="vars-error-container" class="validation-error-container">
                <span id="vars-error" class="validation-error"></span>
                <button id="btn-autofix" class="text-btn autofix-btn" style="display: none;">尝试自动修复</button>
              </div>

              <!-- Inline parsed palette helper -->
              <div class="palette-preview-panel">
                <span class="palette-title">已识别的色彩配置：</span>
                <div id="editor-swatches" class="editor-swatches-strip"></div>
              </div>
            </div>
          </div>

          <!-- Tab 2: Custom CSS Area -->
          <div id="tab-content-css" class="tab-content">
            <div class="input-block">
              <label for="css-input" class="input-label">额外的自定义 CSS 样式规则</label>
              <textarea
                id="css-input"
                spellcheck="false"
                placeholder="/* 可以在这里编写针对当前主题的专属 CSS 动画、粒子效果等 */"
                class="code-textarea css-textarea"
              ></textarea>
            </div>
          </div>

          <!-- Meta Area -->
          <div class="meta-row">
            <div class="input-block">
              <label for="name-input" class="input-label">主题名称 <span class="required">*</span></label>
              <div class="input-wrapper">
                <input id="name-input" type="text" maxlength="40" placeholder="如: 霓虹都市" class="text-input" />
                <span class="char-counter" id="name-counter">0/40</span>
              </div>
            </div>
            <div class="input-block">
              <label for="author-input" class="input-label">作者昵称 <span class="required">*</span></label>
              <div class="input-wrapper">
                <input id="author-input" type="text" maxlength="20" placeholder="你的署名" class="text-input" />
                <span class="char-counter" id="author-counter">0/20</span>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <button id="btn-submit" class="btn btn-primary submit-main-btn" disabled>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v10M4 8l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            发布到社区商店
          </button>

          <!-- Submit result container -->
          <div id="submit-result" class="result-alert-box"></div>
        </div>

        <!-- Submitted History -->
        <div id="recent-section" class="recent-submissions" style="display: none;">
          <h3 class="recent-title">我的提交记录</h3>
          <p class="recent-hint">状态每 10 分钟自动刷新 · <span class="hint-dot hint-active"></span>收录中 <span class="hint-dot hint-expired"></span>已过期</p>
          <div id="recent-list" class="recent-list"></div>
        </div>
      </div>

      <!-- RIGHT: Interactive Live Sandbox Preview -->
      <div class="preview-sticky">
        <div class="preview-header-meta">
          <div class="badge-live-dot-wrapper" style="display:flex;align-items:center;gap:8px;margin-left:auto">
            <span class="badge-live-dot">LIVE SENSING</span>
            <span id="sensing-detailed-status" class="sensing-details" style="font-size:10px;font-weight:700;letter-spacing:0.04em;color:var(--color-text-muted);opacity:0.85">Idle</span>
          </div>
        </div>

        <div id="preview-shell" class="preview-browser">
          <div class="browser-bar">
            <div class="browser-dots">
              <span class="dot-red"></span>
              <span class="dot-yellow"></span>
              <span class="dot-green"></span>
            </div>
            <span class="browser-url">themedist.preview.local</span>
          </div>

          <!-- Loading Indicator -->
          <div id="browser-loading-bar" class="browser-loading-bar"></div>
          
          <!-- SandBox Iframe -->
          <div class="iframe-container">
            <iframe id="preview-iframe" class="sandbox-iframe" title="实时隔离渲染沙箱" sandbox="allow-same-origin allow-scripts"></iframe>
            <div id="preview-placeholder" class="preview-empty-placeholder" style="opacity: 0;">
              <div class="placeholder-icon">🎨</div>
              <p>粘贴 JSON 变量或点击 “加载精美示例”<br/>在此处实时交互预览您的主题设计</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  /* ─── Grid layout & Containers ─── */
  .submit-container { max-width: 100%; margin: 0 auto; padding: 0 16px 40px; }
  .submit-grid { display: grid; grid-template-columns: 400px 1fr; gap: 24px; align-items: start; }

  /* ─── Forms & Typography ─── */
  .form-card { padding: 20px; border: 1px solid var(--color-border); background: var(--glass-bg); backdrop-filter: blur(var(--glass-blur)); box-shadow: var(--shadow-md); border-radius: 16px; }
  .form-section-header { margin-bottom: 14px; }
  .section-badge { font-size: 9px; font-weight: 700; letter-spacing: 0.08em; color: var(--color-primary); text-transform: uppercase; display: inline-block; margin-bottom: 2px; }
  .section-title { font-size: 15px; font-weight: 800; color: var(--color-text); }

  /* ─── Import row ─── */
  .import-group { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }

  /* AI Generation Bar */
  .ai-gen-bar { margin-bottom: 12px; }
  .ai-gen-row { display: flex; gap: 6px; align-items: center; }
  .ai-input { flex: 1; height: 36px; padding: 0 10px; border-radius: 8px; border: 1.5px solid var(--color-border); background: color-mix(in srgb, var(--color-surface) 40%, transparent); color: var(--color-text); font-size: 12px; font-family: inherit; outline: none; transition: border-color 0.25s, box-shadow 0.25s; }
  .ai-input:focus { border-color: var(--color-primary); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 12%, transparent); }
  .ai-gen-btn { white-space: nowrap; height: 36px; padding: 0 14px; font-size: 12px; font-weight: 700; border-radius: 8px; display: inline-flex; align-items: center; gap: 4px; }
  .ai-gen-btn.loading { opacity: 0.7; pointer-events: none; }
  .ai-status-text { font-size: 10px; color: var(--color-text-muted); margin: 2px 0 0; min-height: 1.2em; }

  /* AI API Key Management */
  .ai-key-bar { margin-top: 8px; }
  .ai-key-toggle { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 6px; border: 1px solid var(--color-border); background: transparent; color: var(--color-text-muted); font-size: 11px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all 0.2s; }
  .ai-key-toggle:hover { border-color: var(--color-primary); color: var(--color-text); }
  .ai-key-toggle.key-set { border-color: #10b981; color: #10b981; }
  .ai-key-panel { margin-top: 8px; padding: 14px; border-radius: 10px; border: 1.5px solid var(--color-border); background: color-mix(in srgb, var(--color-surface) 30%, transparent); }
  .ai-key-header { display: flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: var(--color-text); margin-bottom: 8px; }
  .ai-key-notice, .ai-key-tip { display: flex; gap: 6px; font-size: 11px; line-height: 1.5; padding: 8px 10px; border-radius: 8px; margin-bottom: 10px; }
  .ai-key-notice { color: var(--color-text-muted); background: color-mix(in srgb, #f59e0b 6%, transparent); border: 1px solid color-mix(in srgb, #f59e0b 15%, transparent); }
  .ai-key-tip { color: var(--color-text-muted); background: color-mix(in srgb, var(--color-primary) 5%, transparent); border: 1px solid color-mix(in srgb, var(--color-primary) 14%, transparent); }
  .ai-key-input-row { display: flex; gap: 6px; align-items: center; }
  .ai-key-input-row input { flex: 1; height: 36px; padding: 0 10px; font-size: 12px; font-family: 'JetBrains Mono', monospace; }
  .ai-key-feedback { font-size: 10px; margin: 6px 0 0; min-height: 1.2em; color: var(--color-text-muted); }
  .ai-key-feedback.success { color: #10b981; }
  .ai-key-feedback.error { color: #ef4444; }
  .import-btn, .demo-btn { height: 34px; font-size: 12px; font-weight: 600; border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 5px; transition: all 0.2s; }
  .import-btn:hover { border-color: var(--color-primary); color: var(--color-primary); background: color-mix(in srgb, var(--color-primary) 6%, transparent); }
  .demo-btn:hover { border-color: var(--color-accent); color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 6%, transparent); }

  /* ─── Tabs Switcher UI ─── */
  .tabs-container { display: flex; border-bottom: 1.5px solid var(--color-border); margin-bottom: 10px; gap: 4px; }
  .tab-btn { background: none; border: none; padding: 7px 12px; font-size: 12px; font-weight: 700; color: var(--color-text-muted); cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.2s ease; border-radius: 6px 6px 0 0; }
  .tab-btn:hover { color: var(--color-text); background: color-mix(in srgb, var(--color-text) 4%, transparent); }
  .tab-btn.active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .tab-content { display: none; }
  .tab-content.active { display: block; animation: fadeInTab 0.25s ease; }
  @keyframes fadeInTab { from { opacity: 0; transform: translateY(2px); } to { opacity: 1; transform: translateY(0); } }

  /* ─── Input Fields ─── */
  .input-block { margin-bottom: 12px; }
  .block-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
  .input-label { display: block; font-size: 11px; font-weight: 700; color: var(--color-text-muted); }
  .required { color: var(--color-primary); margin-left: 2px; }
  .text-btn { background: none; border: none; padding: 2px 6px; font-size: 10px; font-weight: 700; color: var(--color-primary); cursor: pointer; border-radius: 4px; transition: background 0.2s; }
  .text-btn:hover { background: color-mix(in srgb, var(--color-primary) 10%, transparent); }

  .code-textarea { width: 100%; height: 180px; padding: 10px; border-radius: 10px; border: 1.5px solid var(--color-border); background: color-mix(in srgb, var(--color-text) 2%, var(--color-bg)); color: var(--color-text); font-family: 'JetBrains Mono', monospace; font-size: 11px; line-height: 1.5; resize: vertical; outline: none; transition: all 0.2s ease; }
  .code-textarea:focus { border-color: var(--color-primary); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 10%, transparent); }
  .css-textarea { height: 180px; }
  
  .validation-error-container { display: flex; justify-content: space-between; align-items: center; margin-top: 4px; min-height: 18px; }
  .validation-error { font-size: 10px; color: #ef4444; font-weight: 700; display: none; }
  .autofix-btn { color: #ef4444; border: 1px solid color-mix(in srgb, #ef4444 30%, transparent); padding: 1px 5px; border-radius: 4px; font-size: 10px; }
  .autofix-btn:hover { background: color-mix(in srgb, #ef4444 10%, transparent); }

  .palette-preview-panel { margin-top: 6px; padding: 8px 10px; border-radius: 8px; background: color-mix(in srgb, var(--color-text) 2%, var(--color-bg)); border: 1px dashed var(--color-border); }
  .palette-title { font-size: 10px; font-weight: 700; color: var(--color-text-muted); display: block; margin-bottom: 4px; }
  .editor-swatches-strip { display: flex; gap: 6px; flex-wrap: wrap; align-items: flex-start; }
  .palette-group-label { width: 100%; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); opacity: 0.5; margin: 2px 0; }
  .editor-swatch { display: flex; align-items: center; gap: 6px; padding: 4px 8px; background: var(--color-surface); border: 1.5px solid var(--color-border); border-radius: 8px; cursor: pointer; transition: all 0.15s; }
  .editor-swatch:hover { border-color: var(--color-primary); transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
  .editor-swatch-color { width: 16px; height: 16px; border-radius: 4px; border: 1px solid rgba(0,0,0,0.12); flex-shrink: 0; }
  .editor-swatch-info { display: flex; flex-direction: column; gap: 1px; }
  .editor-swatch-name { font-size: 10px; font-weight: 700; color: var(--color-text); line-height: 1; }
  .editor-swatch-val { font-size: 9px; font-family: 'JetBrains Mono', monospace; color: var(--color-text-muted); font-weight: 500; line-height: 1; }

  .meta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 16px; }
  .input-wrapper { position: relative; display: flex; align-items: center; }
  .text-input { width: 100%; height: 36px; padding: 0 50px 0 10px; border-radius: 8px; border: 1.5px solid var(--color-border); background: color-mix(in srgb, var(--color-surface) 30%, transparent); color: var(--color-text); font-size: 12px; font-family: inherit; outline: none; transition: all 0.2s ease; }
  .text-input:focus { border-color: var(--color-primary); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 10%, transparent); }
  .char-counter { position: absolute; right: 10px; font-size: 9px; font-weight: 700; color: var(--color-text-muted); opacity: 0.6; pointer-events: none; }

  .submit-main-btn { width: 100%; height: 42px; font-size: 13px; font-weight: 700; margin-top: 14px; border-radius: 10px; gap: 6px; }
  .submit-main-btn:disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }

  .result-alert-box { display: none; margin-top: 14px; animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  @keyframes slideIn { from { opacity: 0; transform: translateY(10px); } }

  /* ─── Sandbox Iframe Preview ─── */
  .preview-sticky { position: sticky; top: 90px; }
  .preview-header-meta { display: flex; justify-content: flex-end; align-items: flex-start; margin-bottom: 12px; gap: 16px; }
  .badge-live-dot { display: inline-flex; align-items: center; gap: 5px; font-size: 9px; font-weight: 800; color: var(--color-accent); letter-spacing: 0.04em; transition: color 0.3s; user-select: none; }
  .badge-live-dot::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); transition: background 0.3s, box-shadow 0.3s; animation: livePulse 1.5s ease-in-out infinite alternate; }
  @keyframes livePulse { 0% { opacity: 0.3; transform: scale(0.9); } 100% { opacity: 1; transform: scale(1.15); } }
  
  .badge-live-dot.sensing { color: #f59e0b; }
  .badge-live-dot.sensing::before { background: #f59e0b; animation: sensingPulse 0.6s ease-in-out infinite alternate; }
  @keyframes sensingPulse { 0% { opacity: 0.7; transform: scale(1); box-shadow: 0 0 0 0px rgba(245, 158, 11, 0.4); } 100% { opacity: 1; transform: scale(1.3); box-shadow: 0 0 0 4px rgba(245, 158, 11, 0); } }
  .badge-live-dot.synced { color: #22c55e; }
  .badge-live-dot.synced::before { background: #22c55e; animation: none; opacity: 1; transform: scale(1); }

  .preview-browser { border-radius: 14px; overflow: hidden; border: 2px solid var(--color-border); background: var(--color-bg); box-shadow: var(--shadow-lg); transition: border-color 0.3s, box-shadow 0.3s; }
  .preview-browser.compiling { border-color: #f59e0b; box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.15), var(--shadow-lg); }
  .preview-browser.error-state { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15), var(--shadow-lg); }
  .preview-browser.synced-state { border-color: #22c55e; box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.15), var(--shadow-lg); }

  .browser-bar { padding: 8px 14px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; border-bottom: 1px solid var(--color-border); background: color-mix(in srgb, var(--color-surface) 40%, transparent); user-select: none; }
  .browser-loading-bar { height: 2px; width: 0%; background: var(--color-primary, #6366f1); transition: width 0.25s ease, opacity 0.2s ease, background-color 0.2s; opacity: 0; }
  .browser-dots { display: flex; gap: 6px; }
  .browser-dots span { width: 10px; height: 10px; border-radius: 50%; }
  .dot-red { background: #ff5f57; } .dot-yellow { background: #ffbd2e; } .dot-green { background: #28ca41; }
  .browser-url { font-size: 11px; font-family: 'JetBrains Mono', monospace; color: var(--color-text-muted); opacity: 0.8; background: color-mix(in srgb, var(--color-bg) 80%, transparent); padding: 2px 16px; border-radius: 50px; border: 1px solid var(--color-border); }

  /* 16:9 沙箱比例，桌面端专属 */
  .iframe-container { position: relative; width: 100%; aspect-ratio: 16 / 9; background: var(--color-bg); }
  .sandbox-iframe { width: 100%; height: 100%; border: none; opacity: 0; transition: opacity 0.4s ease; background: transparent; }
  .sandbox-iframe.active { opacity: 1; }
  .preview-empty-placeholder { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 20px; pointer-events: none; transition: opacity 0.3s ease; }

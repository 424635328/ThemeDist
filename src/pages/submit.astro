  function buildDeepSeekPrompt(description) {
    return `你是一位专业的主题配色设计师。根据用户的文字描述，生成一套完整的 CSS 变量主题配色方案。

用户描述: "${description}"

## 强制要求
- 所有 CSS 变量键名必须以双横线 -- 开头，如 "--color-primary" 而非 "color-primary"
- --color-primary 和 --color-bg 为必填项，缺一不可
- 必须返回完整 34 个 CSS 变量，一个不能少

## 色彩设计法则
- 主色(primary)定义性格，背景(bg)→表面(surface)→边框(border)→主文字(text) 亮度递增（深色）或递减（浅色）

## 特效设计要求
- 必须根据描述生成纯 CSS 特效动画（@keyframes），不可返回空。

返回纯净 JSON 格式（禁止 Markdown 代码块包裹）：
{
  "name": "主题名称",
  "tags": ["dark"],
  "cssVars": {
    "--color-primary": "#hex",
    "--color-secondary": "#hex",
    "--color-accent": "#hex",
    "--color-bg": "#hex",
    "--color-surface": "#hex",
    "--color-text": "#hex",
    "--color-text-muted": "#hex",
    "--color-border": "rgba(...)",
    ...全部 34 个变量
  },
  "customCss": "/* @keyframes 动画 */"
}`;
  }

  async function callDeepSeek(apiKey, description) {
    const res = await fetch('https://api.deepseek.com/v1/chat/completions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${apiKey}` },
      body: JSON.stringify({
        model: 'deepseek-chat',
        messages: [{ role: 'user', content: buildDeepSeekPrompt(description) }],
        temperature: 0.8,
        max_tokens: 10000,
      }),
    });
    if (!res.ok) throw new Error(`DeepSeek API 请求失败`);
    const data = await res.json();
    const cleanJson = (data.choices?.[0]?.message?.content || '').replace(/^```(?:json)?\s*/i, '').replace(/\s*```$/i, '').trim();
    return JSON.parse(cleanJson);
  }

  function sanitizeCustomCSS(css) {
    if (!css || typeof css !== 'string') return '';
    let s = css.trim().replace(/^```(?:css)?\s*/i, '').replace(/\s*```$/i, '').replace(/^["']|["']$/g, '').trim();
    if (/^(none|null|无|没有|空|n\/a|\s*)$/i.test(s)) return '';
    return s;
  }

  function generateFallbackCSS(text) {
    return `/* 通用氛围粒子特效 */
body::after {
  content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 9999;
  background-image: radial-gradient(1.5px 1.5px at 20% 30%, color-mix(in srgb, var(--color-primary) 25%, transparent) 50%, transparent 50%),
    radial-gradient(1px 1px at 55% 65%, color-mix(in srgb, var(--color-primary) 20%, transparent) 50%, transparent 50%);
  animation: ambientDrift 6s ease-in-out infinite alternate;
}
@keyframes ambientDrift { 0%{opacity:0.3;transform:translateY(0)} 100%{opacity:0.8;transform:translateY(-10px)} }`;
  }

  $('btn-ai-generate').addEventListener('click', async () => {
    const desc = $('ai-description').value.trim();
    if (!desc) { $('ai-status').textContent = '请先输入主题描述'; return; }

    const btn = $('btn-ai-generate');
    const apiKey = getStoredApiKey();
    const useDeepSeek = !!apiKey;
    btn.classList.add('loading');
    btn.innerHTML = '<span class="spinner-sm" style="width:14px;height:14px;border-width:2px;display:inline-block;margin-right:4px"></span> 生成中…';
    $('ai-status').textContent = useDeepSeek ? '正在调用 DeepSeek v4 Flash 生成主题…' : '正在生成主题配色…';

    try {
      let data;
      if (useDeepSeek) {
        data = await callDeepSeek(apiKey, desc);
        data.generatedBy = 'deepseek';
      } else {
        const res = await fetch('/api/ai/generate.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ description: desc }),
        });
        if (!res.ok) throw new Error('生成失败');
        data = await res.json();
      }

      if (!data.cssVars || typeof data.cssVars !== 'object') throw new Error('AI 返回的 CSS 变量格式异常');

      // Normalize keys: ensure all CSS var keys have -- prefix
      data.cssVars = normalizeCssVarKeys(data.cssVars);

      const STRUCTURAL_DEFAULTS = {
        '--font-heading': "'Inter', system-ui, sans-serif", '--font-body': "'Inter', system-ui, sans-serif", '--font-mono': "'JetBrains Mono', monospace",
        '--text-base': 'clamp(1rem, 0.9rem + 0.5vw, 1.125rem)', '--text-lg': 'calc(var(--text-base) * 1.25)', '--text-xl': 'calc(var(--text-lg) * 1.25)', '--text-2xl': 'calc(var(--text-xl) * 1.25)', '--text-sm': 'calc(var(--text-base) / 1.25)',
        '--space-unit': '0.25rem', '--space-1': 'calc(0.25rem * 1)', '--space-2': 'calc(0.25rem * 2)', '--space-3': 'calc(0.25rem * 3)', '--space-4': 'calc(0.25rem * 4)', '--space-6': 'calc(0.25rem * 6)', '--space-8': 'calc(0.25rem * 8)', '--space-12': 'calc(0.25rem * 12)',
        '--content-max': '72rem', '--noise-opacity': '0',
      };
      for (const [k, v] of Object.entries(STRUCTURAL_DEFAULTS)) { if (!(k in data.cssVars)) data.cssVars[k] = v; }

      const rawCss = data.customCss || '';
      const cleanedCss = sanitizeCustomCSS(rawCss);
      const isValidCss = cleanedCss.length >= 20 && (cleanedCss.includes('{') || cleanedCss.includes('@keyframes') || cleanedCss.includes('@media'));
      const finalCss = isValidCss ? cleanedCss : generateFallbackCSS(desc);

      $('vars-input').value = JSON.stringify(data.cssVars, null, 2);
      $('name-input').value = (data.name || '').slice(0, 40);
      $('css-input').value = finalCss;
      if (data.tags?.length) $('name-input').dataset.tags = JSON.stringify(data.tags);
      else delete $('name-input').dataset.tags;

      $('vars-input').dispatchEvent(new Event('input'));
      window.__toast?.(`主题「${data.name || '未命名'}」已生成`);
      $('ai-status').textContent = useDeepSeek ? `由 DeepSeek V4 Flash 生成 — ${data.name || ''}` : `由规则引擎生成 — ${data.name || ''}`;
    } catch (err) {
      $('ai-status').textContent = '生成失败：' + (err.message || '请稍后重试');
      window.__toast?.(err.message || 'AI 生成暂时不可用');
    } finally {
      btn.classList.remove('loading');
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5L13 6l-3.5 1.5L8 11l-1.5-3.5L3 6l3.5-1.5L8 1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M5 12l1 1.5 2.5.5-2 1.5.5 2.5L5 16l-2.5-1 .5-2.5L1 11l2.5-.5L5 12z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg> AI 生成';
    }
  });


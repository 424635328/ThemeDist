  function validateVars(vars) {
    if (!vars || typeof vars !== 'object' || Array.isArray(vars)) return false;
    const keys = Object.keys(vars);
    if (keys.length < 5) return false;
    for (const [k, v] of Object.entries(vars)) {
      if (typeof k !== 'string' || typeof v !== 'string' || !k.startsWith('--')) return false;
    }
    return true;
  }

  // 🎨 Editor Live parsed swatches renderer
  function renderEditorSwatches(vars) {
    const swatchesContainer = $('editor-swatches');
    if (!vars) { swatchesContainer.innerHTML = ''; return; }
    const isColorVal = (v) => typeof v === 'string' && (v.startsWith('#') || v.startsWith('rgb') || v.startsWith('hsl') || v.startsWith('rgba'));
    const colorSwatches = Object.entries(vars).filter(([k, v]) => isColorVal(v) && k.startsWith('--color-'));
    const ambientSwatches = Object.entries(vars).filter(([k, v]) => isColorVal(v) && k.startsWith('--ambient-'));

    if (colorSwatches.length === 0 && ambientSwatches.length === 0) {
      swatchesContainer.innerHTML = '<span style="font-size:11px;color:var(--color-text-muted)">（暂无可识别的颜色变量）</span>';
      return;
    }

    const renderChip = ([key, val]) => `
      <div class="editor-swatch" title="${key}: ${val} — 点击复制" data-swatch-val="${val}">
        <div class="editor-swatch-color" style="background: ${val}"></div>
        <div class="editor-swatch-info"><span class="editor-swatch-name">${key.replace('--color-', '').replace('--ambient-', '')}</span><span class="editor-swatch-val">${val}</span></div>
      </div>`;

    let html = '';
    if (colorSwatches.length > 0) html += '<span class="palette-group-label">色板</span>' + colorSwatches.map(renderChip).join('');
    if (ambientSwatches.length > 0) html += '<span class="palette-group-label">氛围</span>' + ambientSwatches.map(renderChip).join('');
    swatchesContainer.innerHTML = html;
  }


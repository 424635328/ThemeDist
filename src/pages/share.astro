---
import Layout from '../layouts/Layout.astro';

const id = Astro.url.searchParams.get('id') || '';
---

<Layout>
  <!-- Data Bridge Container -->
  <div 
    id="share-page-container" 
    data-theme-id={id} 
    class="share-layout-container"
  >
    <section class="section text-center" style="padding-bottom:24px">
      <p class="t-label">Community Showcase</p>
      <h1 class="t-heading mt-2" id="theme-title">加载主题中…</h1>
      <p class="t-subhead mt-2 share-code-badge" id="share-code-wrapper" style="display:none">
        分享码: <code id="share-code" class="code-badge">{id}</code>
      </p>
    </section>

    <section class="showcase-section">
      <!-- 1. No ID state -->
      <div id="no-id-state" class="empty-state-card" style="display:none">
        <div class="empty-icon">🔗</div>
        <h2 class="empty-title">缺少有效的主题分享码</h2>
        <p class="empty-desc">请通过主题商店、或是附带 <code>?id=分享码</code> 参数的链接进行访问</p>
        <div class="empty-actions">
          <a href="/theme-store" class="btn btn-outline">前往主题商店</a>
          <a href="/submit" class="btn btn-primary">提交你自己的主题</a>
        </div>
      </div>

      <!-- 2. Loading State Skeleton -->
      <div id="loading-state" class="loading-wrapper">
        <div class="spinner-core"></div>
        <p class="loading-text">正在从云端检索主题资产，请稍后…</p>
      </div>

      <!-- 3. Error state -->
      <div id="error-state" class="empty-state-card" style="display:none">
        <div class="empty-icon">🔍</div>
        <h2 class="empty-title">未能检索到该主题</h2>
        <p class="empty-desc">该分享码可能已经过期、或输入了错误的字符，请核对后再试</p>
        <div class="empty-actions">
          <a href="/theme-store" class="btn btn-outline">返回主题商店</a>
          <a href="/submit" class="btn btn-primary">发布新主题</a>
        </div>
      </div>

      <!-- 4. Real Theme Content Display -->
      <div id="theme-content" class="theme-content-grid" style="display:none">
        
        <!-- LEFT PANEL: Metadata & Palette & Variables Table -->
        <div class="content-left">
          <!-- Author & Controls Meta bar -->
          <div class="meta-action-bar">
            <div class="author-info">
              <div class="author-avatar" id="author-avatar"></div>
              <div class="author-details">
                <span class="author-name" id="author-name">-</span>
                <span class="theme-date" id="theme-date">-</span>
              </div>
            </div>

            <div class="control-buttons">
              <button id="btn-like" class="like-btn-detail" title="觉得好看就点个赞吧">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none" id="heart-icon"><path d="M8 14s-6-3.5-6-7.5a3.5 3.5 0 016-2.2 3.5 3.5 0 016 2.2C14 10.5 8 14 8 14z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span id="like-count">0</span>
              </button>
              <button id="btn-share-url" class="btn btn-outline share-copy-btn">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="6" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="13" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="13" cy="11" r="2" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="7" x2="11" y2="5.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="8" y1="9" x2="11" y2="10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                复制链接
              </button>
              <button id="btn-apply" class="btn btn-primary apply-main-btn">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                应用此主题
              </button>
            </div>
          </div>

          <!-- Color Palette section -->
          <div class="card card-glass section-card">
            <h3 class="card-section-title">Color Palette / 核心色盘</h3>
            <p class="card-section-desc">点击下方任意圆形色卡，可一键复制该颜色的十六进制 Hex 值。</p>
            <div id="swatches" class="palette-grid"></div>
          </div>

          <!-- CSS Variables Table -->
          <div class="card card-glass section-card variables-card">
            <div class="table-header">
              <h3 class="card-section-title">CSS Variables / 主题自定义属性</h3>
            </div>
            <div class="table-wrapper">
              <table class="variables-table" id="vars-table">
                <thead>
                  <tr>
                    <th>CSS 变量名称</th>
                    <th>对应色值</th>
                    <th style="width: 50px; text-align: center;">色块</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- RIGHT PANEL: Safe Isolated Iframe Interactive Sandbox -->
        <div class="content-right">
          <div class="preview-browser-shell">
            <div class="browser-bar">
              <div class="browser-dots">
                <span class="dot-red"></span>
                <span class="dot-yellow"></span>
                <span class="dot-green"></span>
              </div>
              <span class="browser-url">sandbox-viewer.local</span>
            </div>

            <div class="iframe-box">
              <iframe id="preview-iframe" class="preview-sandbox-iframe" title="隔离样式渲染沙箱"></iframe>
            </div>
          </div>
        </div>

      </div>
    </section>
  </div>
</Layout>

<style>
  /* ─── Layout containers ─── */
  .share-layout-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }
  .code-badge {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    padding: 2px 10px;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  /* ─── Skeleton Loading ─── */
  .loading-wrapper {
    text-align: center;
    padding: 80px 20px;
    animation: pulseGhost 1.8s ease-in-out infinite alternate;
  }
  .spinner-core {
    width: 40px;
    height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    margin: 0 auto 16px;
  }
  .loading-text {
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  @keyframes pulseGhost {
    0% { opacity: 0.6; }
    100% { opacity: 1; }
  }

  /* ─── Empty/Error State Cards ─── */
  .empty-state-card {
    background: var(--glass-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 60px 24px;
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
    box-shadow: var(--shadow-md);
  }
  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }
  .empty-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  .empty-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 24px;
    line-height: 1.6;
  }
  .empty-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
  }

  /* ─── Core Showcase Grid ─── */
  .theme-content-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 32px;
    align-items: start;
    animation: fadeInContainer 0.4s ease-out forwards;
  }
  @keyframes fadeInContainer {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── Left Panels Styles ─── */
  .meta-action-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .author-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .author-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 800;
    color: #fff;
    box-shadow: 0 4px 10px color-mix(in srgb, var(--color-primary) 30%, transparent);
    border: 1.5px solid var(--color-border);
  }
  .author-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .author-name {
    font-weight: 700;
    font-size: 14px;
    color: var(--color-text);
  }
  .theme-date {
    font-size: 11px;
    color: var(--color-text-muted);
  }

  /* Buttons */
  .control-buttons {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .like-btn-detail {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 40px;
    padding: 0 16px;
    border-radius: 10px;
    border: 1.5px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
  }
  .like-btn-detail:hover {
    border-color: #ef4444;
    color: #ef4444;
  }
  .like-btn-detail.liked {
    background: color-mix(in srgb, #ef4444 8%, transparent);
    border-color: #ef4444;
    color: #ef4444;
  }
  .like-btn-detail.liked svg path {
    fill: #ef4444;
    stroke: #ef4444;
  }
  .share-copy-btn {
    height: 40px;
    padding: 0 16px;
    font-size: 12px;
    border-radius: 10px;
    gap: 6px;
  }
  .apply-main-btn {
    height: 40px;
    padding: 0 18px;
    font-size: 12px;
    border-radius: 10px;
    font-weight: 700;
    gap: 6px;
  }

  /* Section cards */
  .section-card {
    padding: 24px;
    margin-bottom: 24px;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
  .card-section-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .card-section-desc {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  /* Circular swatches layout */
  .palette-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .palette-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .swatch-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .swatch-circle:hover {
    transform: scale(1.15);
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
    z-index: 5;
  }
  .swatch-circle:active {
    transform: scale(0.95);
  }
  .swatch-label {
    font-size: 9px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-text-muted);
  }

  /* Variables Table Section */
  .variables-card {
    padding: 0;
    overflow: hidden;
  }
  .table-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
  }
  .table-wrapper {
    max-height: 380px;
    overflow-y: auto;
  }
  .variables-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    text-align: left;
  }
  .variables-table th {
    background: color-mix(in srgb, var(--color-surface) 20%, transparent);
    padding: 10px 16px;
    font-size: 10px;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1.5px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .variables-table td {
    padding: 10px 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .table-row-clickable {
    transition: background 0.15s;
  }
  .table-row-clickable:hover {
    background: color-mix(in srgb, var(--color-primary) 4%, transparent);
  }
  .var-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
  }
  .var-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--color-text-muted);
  }
  .table-swatch {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: transform 0.15s;
    vertical-align: middle;
  }
  .table-swatch:hover {
    transform: scale(1.25);
  }

  /* ─── Right Sandbox Preview Panel ─── */
  .content-right {
    position: sticky;
    top: 90px;
  }
  .preview-browser-shell {
    border-radius: 20px;
    overflow: hidden;
    border: 2.5px solid var(--color-border);
    background: var(--color-bg);
    box-shadow: var(--shadow-lg);
  }
  .browser-bar {
    padding: 12px 16px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    border-bottom: 1.5px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 40%, transparent);
    user-select: none;
  }
  .browser-dots {
    display: flex;
    gap: 6px;
  }
  .browser-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green { background: #28ca41; }
  .browser-url {
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-text-muted);
    opacity: 0.8;
    background: color-mix(in srgb, var(--color-bg) 80%, transparent);
    padding: 2px 16px;
    border-radius: 50px;
    border: 1px solid var(--color-border);
  }
  .iframe-box {
    width: 100%;
    height: 480px;
    background: var(--color-bg);
  }
  .preview-sandbox-iframe {
    width: 100%;
    height: 100%;
    border: none;
    background: transparent;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* ─── Responsive ─── */
  @media (max-width: 880px) {
    .theme-content-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .content-right {
      position: static;
    }
    .iframe-box {
      height: 380px;
    }
    .meta-action-bar {
      flex-direction: column;
      align-items: flex-start;
    }
    .control-buttons {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }
    .apply-main-btn {
      flex: 1;
      min-width: 120px;
    }
  }
</style>

<script>
  // 🛡️ Web sandbox iframe template (Strictly isolates and renders custom user styles/animations safely)
  const SANDBOX_HTML_TEMPLATE = `
    <!DOCTYPE html>
    <html lang="zh">
    <head>
      <meta charset="UTF-8">
      <style id="base-style">
        body {
          margin: 0;
          padding: 24px;
          background: var(--color-bg, #0f0f23);
          color: var(--color-text, #f4f4f5);
          font-family: system-ui, -apple-system, sans-serif;
          transition: background 0.3s, color 0.3s, border-color 0.3s;
          min-height: 100vh;
          box-sizing: border-box;
          overflow-x: hidden;
          position: relative;
        }
        .header-meta {
          font-size: 11px;
          font-weight: 700;
          color: var(--color-text-muted, #71717a);
          text-transform: uppercase;
          letter-spacing: 0.06em;
        }
        .main-title {
          font-size: 22px;
          font-weight: 800;
          margin: 6px 0 12px;
          color: var(--color-primary, #6366f1);
        }
        .body-desc {
          font-size: 13px;
          color: var(--color-text-muted, #71717a);
          line-height: 1.6;
          margin-bottom: 20px;
        }
        .btn-preview-primary {
          background: var(--color-primary, #6366f1);
          color: #fff;
          border: none;
          padding: 10px 20px;
          border-radius: var(--radii, 10px);
          font-weight: 600;
          cursor: pointer;
          font-size: 13px;
          transition: filter 0.2s;
        }
        .btn-preview-primary:hover {
          filter: brightness(1.1);
        }
        .btn-preview-secondary {
          background: transparent;
          border: 1.5px solid var(--color-border, rgba(255,255,255,0.15));
          color: var(--color-text, #f4f4f5);
          padding: 9px 18px;
          border-radius: var(--radii, 10px);
          font-weight: 600;
          cursor: pointer;
          font-size: 13px;
        }
        .btn-row {
          display: flex;
          gap: 10px;
          margin-bottom: 24px;
        }
        .preview-card {
          background: var(--color-surface, #1e1e38);
          border: 1.5px solid var(--color-border, rgba(255,255,255,0.15));
          border-radius: var(--radii, 12px);
          padding: 20px;
          box-shadow: 0 4px 16px rgba(0,0,0,0.12);
          backdrop-filter: blur(var(--glass-blur, 8px));
        }
        .card-heading {
          font-weight: 700;
          font-size: 14px;
        }
        .card-body-text {
          font-size: 12px;
          color: var(--color-text-muted, #71717a);
          margin: 6px 0 14px;
          line-height: 1.5;
        }
        .swatches {
          display: flex;
          gap: 6px;
          flex-wrap: wrap;
        }
        .swatch-item {
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 4px;
        }
        .swatch-color {
          width: 28px;
          height: 28px;
          border-radius: 6px;
          border: 1.5px solid var(--color-border, rgba(255,255,255,0.15));
        }
        .swatch-label {
          font-size: 9px;
          font-family: monospace;
          color: var(--color-text-muted, #71717a);
        }
      </style>
      <style id="theme-style"></style>
    </head>
    <body>
      <div id="sakura-container" style="position:absolute; inset:0; pointer-events:none; overflow:hidden;"></div>
      
      <div class="header-meta">Community Sandboxed Sandbox</div>
      <div class="main-title" id="preview-title">-</div>
      <div class="body-desc" id="preview-desc">
        隔离预览区域已经实时呈现了该作者分享的主题设计，文字、容器色均已同步。
      </div>

      <div class="btn-row">
        <button class="btn-preview-primary">主要操作</button>
        <button class="btn-preview-secondary">次要操作</button>
      </div>

      <div class="preview-card">
        <div class="card-heading">信息卡片示例</div>
        <p class="card-body-text">卡片用于聚合局部业务。请观察 card-surface 与 page-bg 在多层叠加时的对比度是否理想。</p>
        
        <div class="swatches" id="swatches-container"></div>
      </div>
    </body>
    </html>
  `;

  // Standard safe data bridge from HTML
  const bridge = document.getElementById('share-page-container');
  const themeId = bridge?.dataset.themeId || '';

  if (!themeId) {
    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('no-id-state').style.display = 'block';
  }

  let themeData = null;

  async function loadTheme() {
    if (!themeId) return;
    try {
      const res = await fetch(`/api/diy/theme.json?id=${encodeURIComponent(themeId)}`);
      if (!res.ok) throw new Error('Not found');
      themeData = await res.json();
      renderTheme(themeData);
    } catch {
      document.getElementById('loading-state').style.display = 'none';
      document.getElementById('error-state').style.display = 'block';
    }
  }

  // Init sandboxed Iframe structure
  function initIframe(t) {
    const iframe = document.getElementById('preview-iframe');
    const doc = iframe.contentDocument || iframe.contentWindow?.document;
    if (!doc) return;
    
    doc.open();
    doc.write(SANDBOX_HTML_TEMPLATE);
    doc.close();

    // After document is populated, inject CSS variables, names, and swatches
    const styleEl = doc.getElementById('theme-style');
    if (styleEl) {
      const varsCSS = Object.entries(t.cssVars).map(([k, v]) => `${k}:${v}`).join(';');
      styleEl.textContent = `
        :root { ${varsCSS} }
        ${t.customCss || ''}
      `;
    }

    const titleEl = doc.getElementById('preview-title');
    if (titleEl) titleEl.textContent = t.name;

    const swatchesContainer = doc.getElementById('swatches-container');
    if (swatchesContainer) {
      const colors = ['--color-primary', '--color-secondary', '--color-accent', '--color-bg', '--color-surface'];
      swatchesContainer.innerHTML = colors.map(k => `
        <div class="swatch-item">
          <div class="swatch-color" style="background: var(${k})"></div>
          <span class="swatch-label">${k.replace('--color-', '')}</span>
        </div>
      `).join('');
    }

    // Trigger flower simulator if sakura is inside demo name
    const sakuraContainer = doc.getElementById('sakura-container');
    if (sakuraContainer && t.name === "樱花梦境") {
      sakuraContainer.innerHTML = '';
      for (let i = 0; i < 8; i++) {
        const petal = doc.createElement('div');
        petal.className = 'sakura-petal';
        petal.style.left = Math.random() * 100 + '%';
        petal.style.animationDelay = Math.random() * 5 + 's';
        petal.style.animationDuration = (Math.random() * 3 + 3) + 's';
        sakuraContainer.appendChild(petal);
      }
    }
  }

  function renderTheme(t) {
    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('theme-content').style.display = 'grid';

    document.getElementById('theme-title').textContent = t.name;
    document.title = `${t.name} — ThemeDist Community`;

    const shareCodeWrapper = document.getElementById('share-code-wrapper');
    if (shareCodeWrapper) shareCodeWrapper.style.display = 'block';

    const avatar = document.getElementById('author-avatar');
    avatar.textContent = t.author.charAt(0).toUpperCase();
    document.getElementById('author-name').textContent = t.author;

    const d = new Date(t.createdAt);
    document.getElementById('theme-date').textContent = d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

    document.getElementById('like-count').textContent = t.likes;
    document.getElementById('share-code').textContent = themeId;

    const vars = t.cssVars;
    const colorKeys = ['--color-primary','--color-secondary','--color-accent','--color-bg','--color-surface','--color-text','--color-text-muted','--color-border'];
    
    // Render color swatches card with explicit dataset bindings
    document.getElementById('swatches').innerHTML = colorKeys.filter(k => vars[k]).map(k => `
      <div class="palette-item">
        <div 
          class="swatch-circle" 
          data-color="${vars[k]}" 
          style="background:${vars[k]}" 
          title="${k}: ${vars[k]} — 点击复制"
        ></div>
        <span class="swatch-label">${k.replace('--color-','')}</span>
      </div>
    `).join('');

    // Populate standard variables dictionary table
    document.querySelector('#vars-table tbody').innerHTML = Object.entries(vars).map(([k, v]) => `
      <tr class="table-row-clickable">
        <td class="var-name" data-copy="${k}">${k}</td>
        <td class="var-value" data-copy="${v}">${v}</td>
        <td style="text-align: center;">
          <div class="table-swatch" data-copy="${v}" style="background:${v};" title="点击复制 Hex 值"></div>
        </td>
      </tr>
    `).join('');

    // Sync Isolated Preview SandBox
    initIframe(t);
  }

  // Apply action flow
  document.getElementById('btn-apply').addEventListener('click', () => {
    if (!themeData) return;
    const url = new URL(location.origin + '/');
    url.searchParams.set('theme', themeId);
    url.searchParams.set('diy', '1');
    sessionStorage.setItem('td-diy-vars', JSON.stringify(themeData.cssVars));
    sessionStorage.setItem('td-diy-css', themeData.customCss || '');
    sessionStorage.setItem('td-diy-exts', '[]');
    sessionStorage.setItem('td-diy-name', themeData.name);
    localStorage.setItem('themeDistApplied', JSON.stringify({ preset: themeId, name: themeData.name }));
    
    window.__toast?.('正在应用主题并重定向…');
    setTimeout(() => {
      location.href = url.toString();
    }, 1000);
  });

  // Share action flow
  document.getElementById('btn-share-url').addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(location.href);
      window.__toast?.('分享链接已复制至剪贴板');
    } catch { 
      window.__toast?.('复制失败，请手动在浏览器栏复制链接'); 
    }
  });

  // Delegated Copy events from Palette Swatches and Variables Table Rows
  document.addEventListener('click', (e) => {
    const target = e.target;
    
    // 1. From swatches circle
    const swatch = target.closest('.swatch-circle');
    if (swatch) {
      const color = swatch.dataset.color || '';
      navigator.clipboard.writeText(color).then(() => {
        window.__toast?.(`${color} 色值复制成功`);
      });
      return;
    }

    // 2. From table row items
    const clickable = target.closest('[data-copy]');
    if (clickable) {
      const content = clickable.dataset.copy || '';
      navigator.clipboard.writeText(content).then(() => {
        window.__toast?.(`已复制: ${content}`);
      });
    }
  });

  // Likes interactive system
  const likeBtn = document.getElementById('btn-like');
  const likeCountEl = document.getElementById('like-count');
  const likeKey = `td-like-${themeId}`;

  if (localStorage.getItem(likeKey) === '1') {
    likeBtn.classList.add('liked');
  }

  likeBtn.addEventListener('click', async () => {
    if (likeBtn.classList.contains('liked')) {
      window.__toast?.('您已经为该主题点过赞了');
      return;
    }
    try {
      const res = await fetch('/api/diy/like.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: themeId }),
      });
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      likeCountEl.textContent = data.likes;
      likeBtn.classList.add('liked');
      localStorage.setItem(likeKey, '1');
      window.__toast?.('感谢点赞！');
    } catch {
      window.__toast?.('点赞暂时不可用，请稍后重试');
    }
  });

  // Render trigger
  loadTheme();
</script>
---
import Layout from '../layouts/Layout.astro';

const id = Astro.url.searchParams.get('id') || '';
const siteUrl = Astro.url.origin;
---

<Layout>
  <section class="section text-center" style="padding-bottom:24px">
    <p class="t-label">Community Theme</p>
    <h1 class="t-heading mt-2" id="theme-title">社区主题</h1>
    <p class="t-subhead mt-2" style="max-width:560px;margin-inline:auto;font-size:1rem">
      分享码: <code id="share-code" style="font-weight:700;font-size:1.05rem">{id}</code>
    </p>
  </section>

  <section style="max-width:960px;margin:0 auto;padding:0 32px 80px">
    <!-- No ID state -->
    <div id="no-id-state" style="display:none;text-align:center;padding:60px 20px">
      <div style="font-size:48px;margin-bottom:12px">🔗</div>
      <h2 style="font-size:20px;margin-bottom:8px">缺少分享码</h2>
      <p class="text-muted" style="font-size:14px;margin-bottom:20px">请在 URL 中添加 <code>?id=分享码</code> 参数</p>
      <a href="/submit" class="btn btn-primary" style="height:42px;padding:0 28px;font-size:14px;text-decoration:none">提交你的主题</a>
    </div>

    <!-- Loading -->
    <div id="loading-state" style="text-align:center;padding:60px 20px">
      <div class="spinner-lg" style="width:36px;height:36px;border:3px solid var(--color-border);border-top-color:var(--color-primary);border-radius:50%;animation:spin 0.7s linear infinite;margin:0 auto 16px"></div>
      <p class="text-muted" style="font-size:14px">加载主题中…</p>
    </div>

    <!-- Error -->
    <div id="error-state" style="display:none;text-align:center;padding:60px 20px">
      <div style="font-size:48px;margin-bottom:12px">🔍</div>
      <h2 style="font-size:20px;margin-bottom:8px">主题未找到</h2>
      <p class="text-muted" style="font-size:14px;margin-bottom:20px">分享码可能已失效或不存在</p>
      <a href="/submit" class="btn btn-primary" style="height:42px;padding:0 28px;font-size:14px;text-decoration:none">提交你的主题</a>
    </div>

    <!-- Theme content -->
    <div id="theme-content" style="display:none">
      <!-- Meta bar -->
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:24px">
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <div style="display:flex;align-items:center;gap:6px" id="author-badge">
            <div style="width:28px;height:28px;border-radius:50%;background:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff" id="author-avatar"></div>
            <span style="font-weight:600;font-size:14px" id="author-name"></span>
          </div>
          <span style="color:var(--color-text-muted);font-size:12px" id="theme-date"></span>
        </div>
        <div style="display:flex;gap:8px;align-items:center">
          <button id="btn-like" class="like-btn" style="display:inline-flex;align-items:center;gap:6px;height:40px;padding:0 18px;border-radius:12px;border:1.5px solid var(--color-border);background:transparent;color:var(--color-text);font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.2s">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none" id="heart-icon"><path d="M8 14s-6-3.5-6-7.5a3.5 3.5 0 016-2.2 3.5 3.5 0 016 2.2C14 10.5 8 14 8 14z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span id="like-count">0</span>
          </button>
          <button id="btn-share-url" class="btn btn-outline" style="height:40px;padding:0 16px;font-size:12px">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="6" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="13" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="13" cy="11" r="2" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="7" x2="11" y2="5.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="8" y1="9" x2="11" y2="10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            复制链接
          </button>
          <button id="btn-apply" class="btn btn-primary" style="height:40px;padding:0 20px;font-size:12px">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            应用
          </button>
        </div>
      </div>

      <!-- Color swatches -->
      <div class="card card-glass" style="padding:28px;margin-bottom:24px">
        <div style="display:flex;flex-direction:column;gap:16px">
          <p style="font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase">Color Palette</p>
          <div id="swatches" style="display:flex;flex-wrap:wrap;gap:10px"></div>
        </div>
      </div>

      <!-- Live preview -->
      <div class="card card-glass" style="padding:28px">
        <p style="font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase;margin-bottom:16px">组件预览</p>
        <div id="preview-area"></div>
      </div>

      <!-- CSS Variables table -->
      <div class="card card-glass" style="padding:0;overflow:hidden;margin-top:24px">
        <div style="padding:18px 20px;border-bottom:1px solid var(--color-border)">
          <p style="font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);text-transform:uppercase">CSS 变量</p>
        </div>
        <div style="max-height:360px;overflow-y:auto">
          <table style="width:100%;border-collapse:collapse;font-size:12px" id="vars-table">
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  #btn-like:hover { border-color: #ef4444; color: #ef4444; }
  #btn-like.liked { background: #ef444410; border-color: #ef4444; color: #ef4444; }
  #btn-like.liked #heart-icon path { fill: #ef4444; stroke: #ef4444; }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (max-width: 640px) {
    [style*="justify-content:space-between"] { flex-direction: column; align-items: flex-start; }
  }
</style>

<script define:vars={{ id, siteUrl }}>
  const themeId = id;

  if (!themeId) {
    document.getElementById('loading-state')!.style.display = 'none';
    document.getElementById('no-id-state')!.style.display = 'block';
  }

  let themeData: any = null;

  async function loadTheme() {
    if (!themeId) return;
    try {
      const res = await fetch(`/api/diy/theme.json?id=${encodeURIComponent(themeId)}`);
      if (!res.ok) throw new Error('Not found');
      themeData = await res.json();
      renderTheme(themeData);
    } catch {
      document.getElementById('loading-state')!.style.display = 'none';
      document.getElementById('error-state')!.style.display = 'block';
    }
  }

  function renderTheme(t: any) {
    document.getElementById('loading-state')!.style.display = 'none';
    document.getElementById('theme-content')!.style.display = 'block';

    document.getElementById('theme-title')!.textContent = t.name;
    document.title = `${t.name} — ThemeDist Community`;

    document.getElementById('author-avatar')!.textContent = t.author.charAt(0).toUpperCase();
    document.getElementById('author-name')!.textContent = t.author;

    const d = new Date(t.createdAt);
    document.getElementById('theme-date')!.textContent = d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

    document.getElementById('like-count')!.textContent = t.likes;
    document.getElementById('share-code')!.textContent = themeId;

    const vars = t.cssVars;
    const colorKeys = ['--color-primary','--color-secondary','--color-accent','--color-bg','--color-surface','--color-text','--color-text-muted','--color-border'];
    document.getElementById('swatches')!.innerHTML = colorKeys.filter(k => vars[k]).map(k => `
      <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
        <span style="width:48px;height:48px;border-radius:14px;background:${vars[k]};border:2px solid var(--color-border);transition:transform 0.2s;cursor:pointer" title="${k}: ${vars[k]} — 点击复制" onclick="navigator.clipboard.writeText('${vars[k].replace(/'/g, "\\'")}')" onmouseover="this.style.transform='scale(1.15)'" onmouseout="this.style.transform=''"></span>
        <span style="font-size:9px;font-family:'JetBrains Mono',monospace;color:var(--color-text-muted)">${k.replace('--color-','')}</span>
      </div>
    `).join('');

    const primary = vars['--color-primary'] || '#6366f1';
    const secondary = vars['--color-secondary'] || '#8b5cf6';
    const accent = vars['--color-accent'] || '#06b6d4';
    const bg = vars['--color-bg'] || '#0f0f23';
    const surface = vars['--color-surface'] || bg;
    const text = vars['--color-text'] || '#fff';
    const muted = vars['--color-text-muted'] || '#888';
    const border = vars['--color-border'] || 'rgba(255,255,255,0.1)';

    document.getElementById('preview-area')!.innerHTML = `
      <div style="display:flex;flex-direction:column;gap:16px">
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <div style="flex:1;min-width:70px;padding:20px 12px;border-radius:14px;background:${primary};color:#fff;text-align:center;font-weight:700;font-size:13px;box-shadow:0 8px 24px ${primary}44">Primary</div>
          <div style="flex:1;min-width:70px;padding:20px 12px;border-radius:14px;background:${secondary};color:#fff;text-align:center;font-weight:700;font-size:13px">Secondary</div>
          <div style="flex:1;min-width:70px;padding:20px 12px;border-radius:14px;background:${accent};color:#fff;text-align:center;font-weight:700;font-size:13px">Accent</div>
        </div>
        <div style="padding:20px;border-radius:14px;background:${surface};border:1px solid ${border}">
          <div style="font-weight:700;font-size:15px;color:${text}">卡片标题</div>
          <div style="font-size:13px;color:${muted};margin-top:6px;line-height:1.6">这是使用该主题配色的卡片示例。文字使用 text，辅助信息使用 muted 颜色。</div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button style="padding:10px 22px;border-radius:12px;background:linear-gradient(135deg,${primary},${secondary});color:#fff;border:none;font-weight:600;font-size:13px;cursor:default">主要按钮</button>
          <button style="padding:10px 22px;border-radius:12px;border:1.5px solid ${border};background:transparent;color:${text};font-weight:600;font-size:13px;cursor:default">边框按钮</button>
          <button style="padding:10px 22px;border-radius:12px;border:none;background:transparent;color:${muted};font-weight:600;font-size:13px;cursor:default">链接按钮</button>
        </div>
        <div style="padding:14px 18px;border-radius:12px;background:${primary}14;border-left:3px solid ${primary};font-size:13px;color:${text}">带强调色的提示信息框</div>
      </div>
    `;

    document.querySelector('#vars-table tbody')!.innerHTML = Object.entries(vars).map(([k, v]) => `
      <tr style="border-bottom:1px solid var(--color-border)">
        <td style="padding:8px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600">${k}</td>
        <td style="padding:8px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--color-text-muted)">${v}</td>
        <td style="padding:8px 16px;width:40px">
          <span style="display:inline-block;width:22px;height:22px;border-radius:6px;background:${v};border:1px solid var(--color-border);cursor:pointer;transition:transform 0.15s" title="点击复制" onclick="navigator.clipboard.writeText('${(v as string).replace(/'/g, "\\'")}')" onmouseover="this.style.transform='scale(1.3)'" onmouseout="this.style.transform=''"></span>
        </td>
      </tr>
    `).join('');
  }

  document.getElementById('btn-apply')!.addEventListener('click', () => {
    if (!themeData) return;
    const url = new URL(location.origin + '/');
    url.searchParams.set('theme', themeId);
    url.searchParams.set('diy', '1');
    sessionStorage.setItem('td-diy-vars', JSON.stringify(themeData.cssVars));
    sessionStorage.setItem('td-diy-css', themeData.customCss || '');
    sessionStorage.setItem('td-diy-exts', '[]');
    sessionStorage.setItem('td-diy-name', themeData.name);
    localStorage.setItem('themeDistApplied', JSON.stringify({ preset: themeId, name: themeData.name }));
    location.href = url.toString();
  });

  document.getElementById('btn-share-url')!.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(location.href);
      (window as any).__toast?.('分享链接已复制');
    } catch { (window as any).__toast?.('复制失败'); }
  });

  const likeBtn = document.getElementById('btn-like')!;
  const likeCountEl = document.getElementById('like-count')!;

  const likeKey = `td-like-${themeId}`;
  if (localStorage.getItem(likeKey) === '1') {
    likeBtn.classList.add('liked');
  }

  likeBtn.addEventListener('click', async () => {
    if (likeBtn.classList.contains('liked')) {
      (window as any).__toast?.('你已经点过赞了');
      return;
    }
    try {
      const res = await fetch('/api/diy/like.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: themeId }),
      });
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      likeCountEl.textContent = data.likes;
      likeBtn.classList.add('liked');
      localStorage.setItem(likeKey, '1');
    } catch {
      (window as any).__toast?.('点赞失败，请稍后重试');
    }
  });

  loadTheme();
</script>

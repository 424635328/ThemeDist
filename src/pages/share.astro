---
import Layout from '../layouts/Layout.astro';

// 服务端/构建时获取 ID
const id = Astro.url.searchParams.get('id') || '';
---

<Layout>
  <!-- Data Bridge Container -->
  <div 
    id="share-page-container" 
    data-theme-id={id} 
    class="share-layout-container"
  >
    <section class="share-header">
      <span class="share-label">Interactive Theme Preview</span>
      <div class="title-row">
        <h1 class="share-title" id="theme-title">加载主题中…</h1>
        <span class="share-code-badge" id="share-code-wrapper" style="display:none">
          分享码 <code id="share-code" class="code-badge">{id}</code>
        </span>
      </div>
    </section>

    <section class="showcase-section">
      <!-- 1. No ID state -->
      <div id="no-id-state" class="empty-state-card" style="display:none">
        <div class="empty-icon" aria-hidden="true">🔗</div>
        <h2 class="empty-title">缺少有效的主题分享码</h2>
        <p class="empty-desc">请通过主题商店、或是附带 <code>?id=分享码</code> 参数的链接进行访问</p>
        <div class="empty-actions">
          <a href="/theme-store" class="btn btn-outline">前往主题商店</a>
          <a href="/submit" class="btn btn-primary">提交你自己的主题</a>
        </div>
      </div>

      <!-- 2. Loading State Skeleton -->
      <div id="loading-state" class="loading-wrapper">
        <div class="spinner-core"></div>
        <p class="loading-text">正在从云端检索并构建沙箱，请稍后…</p>
      </div>

      <!-- 3. Error state -->
      <div id="error-state" class="empty-state-card" style="display:none">
        <div class="empty-icon" aria-hidden="true">🔍</div>
        <h2 class="empty-title">未能检索到该主题</h2>
        <p class="empty-desc">该分享码可能已经过期、或输入了错误的字符，请核对后再试</p>
        <div class="empty-actions">
          <a href="/theme-store" class="btn btn-outline">返回主题商店</a>
          <a href="/submit" class="btn btn-primary">发布新主题</a>
        </div>
      </div>

      <!-- 4. Real Theme Content Display (Full Width Layout) -->
      <div id="theme-content" class="theme-preview-layout" style="display:none">
        
        <!-- Top Toolbar: Metadata & Controls -->
        <div class="preview-toolbar card-glass">
          <div class="author-info">
            <div class="author-avatar" id="author-avatar"></div>
            <div class="author-details">
              <span class="author-name" id="author-name">-</span>
              <span class="theme-date" id="theme-date">-</span>
            </div>
          </div>

          <!-- Viewport Size Toggles -->
          <div class="viewport-controls" aria-label="切换预览设备">
            <button class="viewport-btn active" data-view="desktop" title="桌面端预览">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
            </button>
            <button class="viewport-btn" data-view="tablet" title="平板端预览">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
            </button>
            <button class="viewport-btn" data-view="mobile" title="移动端预览">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
            </button>
          </div>

          <div class="control-buttons">
            <button id="btn-like" class="btn btn-icon btn-outline" title="觉得好看就点个赞吧" aria-label="点赞主题">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" id="heart-icon"><path d="M8 14s-6-3.5-6-7.5a3.5 3.5 0 016-2.2 3.5 3.5 0 016 2.2C14 10.5 8 14 8 14z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span id="like-count" style="margin-left:4px;font-weight:600">0</span>
            </button>
            <button id="btn-share-url" class="btn btn-outline share-copy-btn" aria-label="复制分享链接">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" style="margin-right:6px"><circle cx="6" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="13" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="13" cy="11" r="2" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="7" x2="11" y2="5.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="8" y1="9" x2="11" y2="10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              分享
            </button>
            <button id="btn-apply" class="btn btn-primary apply-main-btn" aria-label="应用此主题">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="margin-right:6px"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              应用主题
            </button>
          </div>
        </div>

        <!-- Main Sandbox Showcase -->
        <div class="preview-browser-shell view-desktop" id="browser-shell">
          <div class="browser-bar">
            <div class="browser-dots" aria-hidden="true">
              <span class="dot-red"></span>
              <span class="dot-yellow"></span>
              <span class="dot-green"></span>
            </div>
            <div class="browser-url-wrapper">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              <span class="browser-url">preview.themedist.app</span>
            </div>
            <div class="browser-actions"></div>
          </div>

          <div class="iframe-box">
            <!-- Sandbox 增加 allow-scripts 以允许内部执行交互逻辑 -->
            <iframe id="preview-iframe" class="preview-sandbox-iframe" title="交互式样式渲染沙箱" sandbox="allow-same-origin allow-scripts"></iframe>
          </div>
        </div>

      </div>
    </section>
  </div>
</Layout>

<style>
  /* ─── Layout containers ─── */
  .share-layout-container { max-width: 1280px; margin: 0 auto; padding: 0 24px 80px; }

  /* ─── Share Header ─── */
  .share-header { text-align: center; padding-bottom: 8px; }
  .share-label {
    display: inline-block;
    font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-text-muted); opacity: 0.55; margin-bottom: 4px;
  }
  .title-row {
    display: flex; align-items: center; justify-content: center; gap: 10px; flex-wrap: wrap;
  }
  .share-title {
    font-size: clamp(1.4rem, 2.8vw, 1.8rem);
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.2;
    color: var(--color-text); margin: 0;
  }
  .share-code-badge {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 0.8rem; color: var(--color-text-muted);
  }
  .code-badge {
    font-size: 0.8rem; font-weight: 700;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    padding: 2px 10px; border-radius: 5px;
    border: 1px solid color-mix(in srgb, var(--color-primary) 18%, transparent);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.3px;
  }

  /* ─── Skeleton Loading ─── */
  .loading-wrapper { text-align: center; padding: 100px 20px; animation: pulseGhost 1.8s ease-in-out infinite alternate; }
  .spinner-core { width: 40px; height: 40px; border: 3px solid var(--color-border); border-top-color: var(--color-primary); border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 16px; }
  .loading-text { font-size: 13px; color: var(--color-text-muted); font-weight: 500; }
  @keyframes pulseGhost { 0% { opacity: 0.6; } 100% { opacity: 1; } }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ─── Empty/Error State Cards ─── */
  .empty-state-card { background: color-mix(in srgb, var(--color-surface) 60%, transparent); backdrop-filter: blur(12px); border: 1px solid var(--color-border); border-radius: 16px; padding: 60px 24px; text-align: center; max-width: 500px; margin: 40px auto; box-shadow: var(--shadow-md); }
  .empty-icon { font-size: 48px; margin-bottom: 16px; }
  .empty-title { font-size: 18px; font-weight: 800; color: var(--color-text); margin-bottom: 8px; }
  .empty-desc { font-size: 13px; color: var(--color-text-muted); margin-bottom: 24px; line-height: 1.6; }
  .empty-actions { display: flex; justify-content: center; gap: 12px; }

  /* ─── Theme Preview Layout ─── */
  .theme-preview-layout { display: flex; flex-direction: column; gap: 24px; animation: fadeInContainer 0.5s ease-out forwards; }
  @keyframes fadeInContainer { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

  /* ─── Top Toolbar ─── */
  .preview-toolbar { display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-radius: 16px; background: color-mix(in srgb, var(--color-surface) 60%, transparent); backdrop-filter: blur(20px); border: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent); box-shadow: 0 4px 20px rgba(0,0,0,0.05); flex-wrap: wrap; gap: 16px; position: sticky; top: 20px; z-index: 50; }
  .author-info { display: flex; align-items: center; gap: 12px; min-width: 200px; }
  .author-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--color-primary); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 800; color: #fff; box-shadow: 0 4px 10px color-mix(in srgb, var(--color-primary) 30%, transparent); border: 2px solid color-mix(in srgb, var(--color-surface) 80%, transparent); }
  .author-details { display: flex; flex-direction: column; }
  .author-name { font-weight: 700; font-size: 14px; color: var(--color-text); }
  .theme-date { font-size: 11px; color: var(--color-text-muted); }

  /* Viewport Toggles */
  .viewport-controls { display: flex; align-items: center; background: color-mix(in srgb, var(--color-bg) 50%, transparent); border: 1px solid color-mix(in srgb, var(--color-border) 40%, transparent); padding: 4px; border-radius: 10px; gap: 4px; }
  .viewport-btn { width: 36px; height: 32px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; border-radius: 6px; color: var(--color-text-muted); cursor: pointer; transition: all 0.2s; }
  .viewport-btn:hover { color: var(--color-text); background: color-mix(in srgb, var(--color-surface) 80%, transparent); }
  .viewport-btn.active { background: var(--color-surface); color: var(--color-primary); box-shadow: var(--shadow-sm); border: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent); }

  /* Right Buttons */
  .control-buttons { display: flex; align-items: center; gap: 10px; min-width: 200px; justify-content: flex-end; }
  button { outline: none; }
  button:focus-visible { box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 40%, transparent); }
  .btn-icon { padding: 0 12px; height: 38px; border-radius: 10px; }
  .btn-icon.liked { background: color-mix(in srgb, #ef4444 8%, transparent); border-color: #ef4444; color: #ef4444; }
  .btn-icon.liked svg path { fill: #ef4444; stroke: #ef4444; }
  .share-copy-btn, .apply-main-btn { height: 38px; padding: 0 16px; font-size: 13px; border-radius: 10px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .apply-main-btn { box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 30%, transparent); }
  .apply-main-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 16px color-mix(in srgb, var(--color-primary) 40%, transparent); }

  /* ─── Browser Shell (Dynamic Width) ─── */
  .preview-browser-shell { margin: 0 auto; border-radius: 16px; overflow: hidden; border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent); background: var(--color-bg); box-shadow: 0 20px 40px rgba(0,0,0,0.1), 0 0 0 4px color-mix(in srgb, var(--color-surface) 30%, transparent); transition: max-width 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), height 0.5s cubic-bezier(0.2, 0.8, 0.2, 1); width: 100%; display: flex; flex-direction: column; }
  .preview-browser-shell.view-desktop { max-width: 1200px; height: 760px; }
  .preview-browser-shell.view-tablet { max-width: 768px; height: 900px; }
  .preview-browser-shell.view-mobile { max-width: 375px; height: 812px; }

  /* 假浏览器头部 */
  .browser-bar { padding: 12px 16px; display: grid; grid-template-columns: 80px 1fr 80px; align-items: center; border-bottom: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent); background: color-mix(in srgb, var(--color-surface) 60%, transparent); backdrop-filter: blur(10px); user-select: none; flex-shrink: 0; }
  .browser-dots { display: flex; gap: 8px; }
  .browser-dots span { width: 12px; height: 12px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.1); }
  .dot-red { background: #ff5f57; } .dot-yellow { background: #ffbd2e; } .dot-green { background: #28ca41; }
  .browser-url-wrapper { justify-self: center; display: flex; align-items: center; gap: 6px; background: color-mix(in srgb, var(--color-bg) 60%, transparent); padding: 4px 20px; border-radius: 6px; border: 1px solid color-mix(in srgb, var(--color-border) 40%, transparent); color: var(--color-text-muted); }
  .browser-url { font-size: 11px; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.5px; opacity: 0.8; }

  .iframe-box { width: 100%; flex: 1; background: var(--color-bg); position: relative; }
  .preview-sandbox-iframe { width: 100%; height: 100%; border: none; background: transparent; transition: opacity 0.3s; }

  @media (max-width: 880px) {
    .preview-toolbar { flex-direction: column; justify-content: center; }
    .author-info, .control-buttons, .viewport-controls { width: 100%; justify-content: center; }
    .preview-browser-shell.view-desktop { height: 600px; }
  }
</style>

<script>
  // 🛡️ XSS 防御: 严格转义 HTML 实体
  function escapeHtml(unsafe) {
    return (unsafe || '').toString()
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  // 🏛️ Web Sandbox Iframe Template: 多页面路由 & 深度结合主题参数
  const SANDBOX_HTML_TEMPLATE = `
    <!DOCTYPE html>
    <html lang="zh">
    <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <style id="base-style">
        :root {
          --ui-transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        /* 深度结合主题参数构建根布局 */
        body {
          font-family: var(--font-body, system-ui, -apple-system, sans-serif);
          background-color: var(--color-bg);
          color: var(--color-text);
          min-height: 100vh;
          overflow-x: hidden;
          font-size: var(--text-base);
          background-image: 
            radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--ambient-1, var(--color-primary)) 12%, transparent) 0%, transparent 40%),
            radial-gradient(circle at 0% 100%, color-mix(in srgb, var(--ambient-2, var(--color-secondary)) 12%, transparent) 0%, transparent 40%);
        }
        
        /* Layout Structure */
        .app-layout { display: flex; height: 100vh; }
        
        /* Sidebar (使用主题的玻璃态和边距) */
        .sidebar {
          width: 260px;
          background: var(--glass-bg, color-mix(in srgb, var(--color-surface) 80%, transparent));
          border-right: 1px solid var(--color-border);
          padding: var(--space-6) var(--space-4);
          display: flex; flex-direction: column; gap: var(--space-2);
          backdrop-filter: var(--glass-blur, blur(12px));
          -webkit-backdrop-filter: var(--glass-blur, blur(12px));
          z-index: 10;
        }
        .sidebar-brand {
          font-family: var(--font-heading);
          font-size: var(--text-lg);
          font-weight: 800;
          color: var(--color-primary);
          padding: 0 var(--space-4) var(--space-6);
          display: flex; align-items: center; gap: 8px;
        }
        .nav-item {
          padding: 10px 16px; border-radius: var(--radii);
          color: var(--color-text-muted); font-size: var(--text-sm); font-weight: 600;
          cursor: pointer; transition: var(--ui-transition);
          display: flex; align-items: center; gap: 12px;
        }
        .nav-item:hover { color: var(--color-text); background: color-mix(in srgb, var(--color-text) 5%, transparent); }
        .nav-item.active {
          color: var(--color-primary);
          background: color-mix(in srgb, var(--color-primary) 12%, transparent);
          font-weight: 700;
        }

        .main-content { 
          flex: 1; padding: var(--space-8); overflow-y: auto; position: relative; 
          max-width: var(--content-max); margin: 0 auto;
        }
        
        /* Views SPA Routing */
        .view-section { display: none; animation: fadeIn 0.4s ease forwards; }
        .view-section.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Typography */
        .page-header { margin-bottom: var(--space-8); }
        .page-title { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 800; color: var(--color-text); letter-spacing: -0.02em; }
        .page-subtitle { font-size: var(--text-sm); color: var(--color-text-muted); margin-top: var(--space-2); }

        /* Cards (深度结合主题投影和圆角) */
        .grid-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-6); margin-bottom: var(--space-6); }
        .card {
          background: var(--color-surface);
          border: 1px solid var(--color-border);
          border-radius: var(--radii);
          padding: var(--space-6);
          box-shadow: var(--shadow-sm);
          transition: var(--ui-transition);
        }
        .card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); border-color: color-mix(in srgb, var(--color-border) 100%, var(--color-text) 20%); }
        .card-header { font-size: var(--text-base); font-weight: 700; margin-bottom: var(--space-4); display: flex; align-items: center; justify-content: space-between; }
        
        /* Forms & Buttons */
        .form-group { margin-bottom: var(--space-4); }
        .label { display: block; font-size: calc(var(--text-sm) * 0.9); font-weight: 700; color: var(--color-text-muted); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .input, .textarea {
          width: 100%; padding: 12px 16px;
          background: color-mix(in srgb, var(--color-bg) 50%, transparent);
          border: 1.5px solid var(--color-border);
          border-radius: calc(var(--radii) - 2px);
          color: var(--color-text); font-size: var(--text-sm); font-family: var(--font-body);
          transition: var(--ui-transition); outline: none;
        }
        .input:focus, .textarea:focus { border-color: var(--color-primary); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent); background: var(--color-surface); }
        .textarea { resize: vertical; min-height: 80px; }
        
        .btn-group { display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-4);}
        .btn {
          padding: 10px 20px; font-size: var(--text-sm); font-weight: 600; cursor: pointer;
          border-radius: calc(var(--radii) - 2px); transition: var(--ui-transition);
          display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: var(--font-body);
        }
        .btn:disabled { opacity: 0.6; cursor: not-allowed; }
        .btn-primary { background: var(--color-primary); color: #ffffff; border: none; box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 30%, transparent); }
        .btn-primary:not(:disabled):hover { filter: brightness(1.1); transform: translateY(-1px); box-shadow: var(--shadow-md); }
        .btn-secondary { background: color-mix(in srgb, var(--color-secondary, var(--color-primary)) 15%, transparent); color: var(--color-secondary, var(--color-text)); border: none; }
        .btn-secondary:not(:disabled):hover { background: color-mix(in srgb, var(--color-secondary, var(--color-primary)) 25%, transparent); }
        .btn-outline { background: transparent; border: 1.5px solid var(--color-border); color: var(--color-text); }
        .btn-outline:not(:disabled):hover { background: color-mix(in srgb, var(--color-text) 5%, transparent); border-color: var(--color-text-muted); }

        /* Toggles Switch */
        .toggle-row { display: flex; justify-content: space-between; align-items: center; padding: var(--space-3) 0; border-bottom: 1px solid var(--color-border); }
        .toggle-row:last-child { border-bottom: none; }
        .toggle-info strong { display: block; font-size: var(--text-sm); color: var(--color-text); }
        .toggle-info span { font-size: calc(var(--text-sm) * 0.9); color: var(--color-text-muted); }
        .toggle { width: 44px; height: 24px; background: color-mix(in srgb, var(--color-border) 80%, transparent); border-radius: 20px; position: relative; cursor: pointer; transition: var(--ui-transition); }
        .toggle::after { content:''; position:absolute; top:3px; left:3px; width:18px; height:18px; background:var(--color-surface); border-radius:50%; transition: var(--ui-transition); box-shadow: var(--shadow-sm); }
        .toggle.on { background: var(--color-primary); }
        .toggle.on::after { transform: translateX(20px); }

        /* Profile Layout */
        .profile-header { display: flex; align-items: center; gap: var(--space-6); margin-bottom: var(--space-6); }
        .avatar-lg { width: 80px; height: 80px; border-radius: 50%; background: var(--color-secondary); border: 2px solid var(--color-surface); box-shadow: var(--shadow-md); display: flex; align-items: center; justify-content: center; font-size: 24px; color: var(--color-text); font-weight: 800; font-family: var(--font-heading); }

        /* Status Badge */
        .badge {
          padding: 4px 10px; border-radius: 20px; font-size: calc(var(--text-sm) * 0.85); font-weight: 700;
          background: color-mix(in srgb, var(--color-accent) 20%, transparent);
          color: var(--color-text); border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
        }

        /* Toast Notifications */
        .toast-container { position: fixed; bottom: 30px; right: 30px; display: flex; flex-direction: column; gap: 10px; z-index: 9999; }
        .toast {
          background: var(--glass-bg, var(--color-surface)); backdrop-filter: var(--glass-blur, blur(10px));
          color: var(--color-text); border: 1px solid var(--color-border);
          padding: 12px 20px; border-radius: var(--radii); box-shadow: var(--shadow-lg);
          font-size: var(--text-sm); font-weight: 600; display: flex; align-items: center; gap: 10px;
          animation: slideUp 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }
        .toast.success { border-left: 4px solid var(--color-primary); }
        @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes slideOut { to { transform: translateY(10px); opacity: 0; } }

        /* Responsive */
        @media (max-width: 768px) {
          .app-layout { flex-direction: column; }
          .sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--color-border); flex-direction: row; padding: 12px 16px; overflow-x: auto; align-items: center;}
          .sidebar-brand { padding: 0 16px 0 0; margin-right: 16px; border-right: 1px solid var(--color-border); }
          .nav-item { white-space: nowrap; }
          .main-content { padding: var(--space-4); }
          .toast-container { bottom: 20px; right: 20px; left: 20px; align-items: center; }
        }
      </style>
      <style id="theme-style">{{INJECT_STYLES}}</style>
      <style id="custom-effects-style">{{INJECT_CUSTOM_CSS}}</style>
    </head>
    <body>
      <div id="effects-container">{{INJECT_EFFECTS_HTML}}</div>
      <div class="toast-container" id="toast-container"></div>
      
      <div class="app-layout">
        <aside class="sidebar" id="sidebar-nav">
          <div class="sidebar-brand">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            ThemeDist
          </div>
          <div class="nav-item active" data-target="dashboard">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Dashboard
          </div>
          <div class="nav-item" data-target="profile">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Profile
          </div>
          <div class="nav-item" data-target="settings">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
            Settings
          </div>
        </aside>

        <main class="main-content">
          
          <!-- VIEW 1: Dashboard -->
          <div id="view-dashboard" class="view-section active">
            <header class="page-header">
              <h1 class="page-title">{{INJECT_TITLE}}</h1>
              <p class="page-subtitle">沉浸式主题预览 · 观察容器背景与层级边框的交织表现</p>
            </header>

            <div class="grid-row">
              <div class="card">
                <div class="card-header">
                  <span>Total Revenue</span>
                  <span class="badge">+14.5%</span>
                </div>
                <div style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); font-family: var(--font-mono);">45,231</div>
                <p style="font-size: calc(var(--text-sm)*0.9); color: var(--color-text-muted); margin-top: 8px;">Compared to last month</p>
              </div>
              
              <div class="card">
                <div class="card-header">
                  <span>Active Users</span>
                  <span class="badge" style="background: color-mix(in srgb, var(--color-secondary) 15%, transparent); color: var(--color-text); border-color: color-mix(in srgb, var(--color-secondary) 30%, transparent);">Active</span>
                </div>
                <div style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-text); font-family: var(--font-mono);">2,845</div>
                <p style="font-size: calc(var(--text-sm)*0.9); color: var(--color-text-muted); margin-top: 8px;">Currently on your website</p>
              </div>
            </div>

            <div class="card">
              <div class="card-header">Form Controls Interface</div>
              <div class="form-group">
                <label class="label">Email Address</label>
                <input type="email" class="input" id="demo-input-email" placeholder="you@example.com" value="user@themedist.app">
              </div>
              <div class="form-group">
                <label class="label">Project Description</label>
                <input type="text" class="input" id="demo-input-desc" placeholder="Enter details...">
              </div>
              <div class="btn-group">
                <button class="btn btn-primary" id="btn-save">Save Changes</button>
                <button class="btn btn-secondary" id="btn-discard">Discard</button>
                <button class="btn btn-outline" id="btn-cancel">Clear Form</button>
              </div>
            </div>
          </div>

          <!-- VIEW 2: Profile -->
          <div id="view-profile" class="view-section">
            <header class="page-header">
              <h1 class="page-title">User Profile</h1>
              <p class="page-subtitle">Manage your personal information and biography.</p>
            </header>
            
            <div class="card">
              <div class="profile-header">
                <div class="avatar-lg">TD</div>
                <div>
                  <h2 style="font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 800;">Theme Designer</h2>
                  <p style="color: var(--color-text-muted); font-size: var(--text-sm); margin-top:4px;">designer@themedist.app</p>
                </div>
              </div>

              <div class="form-group">
                <label class="label">Display Name</label>
                <input type="text" class="input" value="Theme Designer">
              </div>
              <div class="form-group">
                <label class="label">Biography</label>
                <textarea class="textarea" placeholder="Tell us about yourself...">Crafting beautiful digital experiences with colors and shadows.</textarea>
              </div>
              <div class="btn-group">
                <button class="btn btn-primary" onclick="window.showToast('Profile updated!', 'success')">Update Profile</button>
              </div>
            </div>
          </div>

          <!-- VIEW 3: Settings -->
          <div id="view-settings" class="view-section">
            <header class="page-header">
              <h1 class="page-title">Preferences</h1>
              <p class="page-subtitle">Customize your application experience.</p>
            </header>

            <div class="card">
              <div class="card-header">General Settings</div>
              
              <div class="toggle-row">
                <div class="toggle-info">
                  <strong>Enable Notifications</strong>
                  <span>Receive alerts for important updates.</span>
                </div>
                <div class="toggle on" onclick="this.classList.toggle('on')"></div>
              </div>

              <div class="toggle-row">
                <div class="toggle-info">
                  <strong>Use Glassmorphism</strong>
                  <span>Apply blur effects to sidebars and cards.</span>
                </div>
                <div class="toggle on" onclick="this.classList.toggle('on')"></div>
              </div>

              <div class="toggle-row">
                <div class="toggle-info">
                  <strong>Auto-play Animations</strong>
                  <span>Allow decorative effects (like falling petals) to play.</span>
                </div>
                <div class="toggle on" onclick="this.classList.toggle('on')"></div>
              </div>
            </div>
          </div>

        </main>
      </div>

      <!-- 交互逻辑脚本 (Iframe 内部隔离执行) -->
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          // Toast 弹窗系统暴露给全局
          const toastContainer = document.getElementById('toast-container');
          window.showToast = function(message, type = 'default') {
            const toast = document.createElement('div');
            toast.className = 'toast ' + (type === 'success' ? 'success' : '');
            
            const icon = type === 'success' 
              ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>'
              : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>';
            
            toast.innerHTML = icon + '<span>' + message + '</span>';
            toastContainer.appendChild(toast);

            setTimeout(() => {
              toast.style.animation = 'slideOut 0.3s ease forwards';
              setTimeout(() => toast.remove(), 300);
            }, 3000);
          };

          // Sidebar Tab 切换逻辑 (SPA Routing)
          const navItems = document.querySelectorAll('.nav-item');
          const views = document.querySelectorAll('.view-section');
          
          navItems.forEach(item => {
            item.addEventListener('click', () => {
              // 1. 更新侧边栏 active 状态
              navItems.forEach(n => n.classList.remove('active'));
              item.classList.add('active');
              
              // 2. 切换主视图区域
              const target = item.dataset.target;
              views.forEach(v => {
                v.classList.remove('active');
                if (v.id === 'view-' + target) {
                  v.classList.add('active');
                }
              });
            });
          });

          // Dashboard 按钮操作模拟
          const btnSave = document.getElementById('btn-save');
          const btnDiscard = document.getElementById('btn-discard');
          const btnCancel = document.getElementById('btn-cancel');
          const inputs = document.querySelectorAll('.input');

          if(btnSave) {
            btnSave.addEventListener('click', () => {
              const originalText = btnSave.innerHTML;
              btnSave.disabled = true;
              btnSave.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg> Saving...';
              
              if(!document.getElementById('spin-style')) {
                const style = document.createElement('style');
                style.id = 'spin-style';
                style.innerHTML = '@keyframes spinner { to { transform: rotate(360deg); } } .spin { animation: spinner 1s linear infinite; }';
                document.head.appendChild(style);
              }

              setTimeout(() => {
                btnSave.disabled = false;
                btnSave.innerHTML = originalText;
                window.showToast('Changes applied and saved to cloud!', 'success');
              }, 1200);
            });
          }

          if(btnDiscard) btnDiscard.addEventListener('click', () => window.showToast('Changes discarded.', 'default'));
          if(btnCancel) btnCancel.addEventListener('click', () => {
            inputs.forEach(input => input.value = '');
            window.showToast('Form fields have been cleared.', 'default');
          });
        });
      <\/script>
    </body>
    </html>
  `;

  const bridge = document.getElementById('share-page-container');
  const themeId = bridge?.dataset.themeId || new URLSearchParams(window.location.search).get('id') || '';

  if (!themeId) {
    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('no-id-state').style.display = 'block';
  }

  let themeData = null;

  async function loadTheme() {
    if (!themeId) return;
    try {
      // 真实请求主题数据
      const res = await fetch(`/api/diy/theme.json?id=${encodeURIComponent(themeId)}`);
      if (!res.ok) throw new Error('Not found');
      themeData = await res.json();
      renderTheme(themeData);
    } catch (e) {
      document.getElementById('loading-state').style.display = 'none';
      document.getElementById('error-state').style.display = 'block';
      console.error("Theme Load Error:", e);
    }
  }

  function initIframe(t) {
    const iframe = document.getElementById('preview-iframe');
    
    // 构造注入的样式变量字符串，进行严格转义
    const varsCSS = Object.entries(t.cssVars).map(([k, v]) => `${k}:${v}`).join(';');
    const injectedStyles = `:root { ${varsCSS} }`;
    const customCssRaw = t.customCss || '';
    
    // 如果主题包含 sakura 樱花特效（利用名字或CSS中是否包含 .sakura-petal 探测）
    let effectsHtml = '';
    if (t.name === "樱花梦境" || customCssRaw.includes('.sakura-petal')) {
      for (let i = 0; i < 15; i++) {
        effectsHtml += `<div class="sakura-petal" style="left:${Math.random() * 100}%; animation-delay:${Math.random() * 5}s; animation-duration:${Math.random() * 4 + 4}s"></div>`;
      }
    }

    const finalHtml = SANDBOX_HTML_TEMPLATE
      .replace('{{INJECT_STYLES}}', injectedStyles)
      .replace('{{INJECT_CUSTOM_CSS}}', customCssRaw)
      .replace('{{INJECT_TITLE}}', escapeHtml(t.name))
      .replace('{{INJECT_EFFECTS_HTML}}', effectsHtml); // 避免直接转义HTML，仅做组装

    iframe.srcdoc = finalHtml;
  }

  function renderTheme(t) {
    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('theme-content').style.display = 'flex';

    document.getElementById('theme-title').textContent = t.name;
    document.title = `${t.name} — Theme Preview`;

    const shareCodeWrapper = document.getElementById('share-code-wrapper');
    if (shareCodeWrapper) shareCodeWrapper.style.display = 'block';

    const safeAuthor = escapeHtml(t.author) || 'Anonymous';
    const avatar = document.getElementById('author-avatar');
    avatar.textContent = safeAuthor.charAt(0).toUpperCase();
    document.getElementById('author-name').textContent = safeAuthor;

    const d = new Date(t.createdAt);
    document.getElementById('theme-date').textContent = d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

    document.getElementById('like-count').textContent = parseInt(t.likes) || 0;
    document.getElementById('share-code').textContent = themeId;

    // 初始化独立的 iframe 预览环境
    initIframe(t);
  }

  // Viewport Toggles (视口大小切换)
  const browserShell = document.getElementById('browser-shell');
  const viewportBtns = document.querySelectorAll('.viewport-btn');
  
  viewportBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      // 移除旧的 view class 和激活状态
      viewportBtns.forEach(b => b.classList.remove('active'));
      browserShell.classList.remove('view-desktop', 'view-tablet', 'view-mobile');
      
      // 添加新的
      const view = btn.dataset.view;
      btn.classList.add('active');
      browserShell.classList.add(`view-${view}`);
    });
  });

  // 应用主题动作
  document.getElementById('btn-apply').addEventListener('click', () => {
    if (!themeData) return;
    const preset = 'community-' + themeId;
    localStorage.setItem('themeDistApplied', JSON.stringify({ preset, name: themeData.name }));
    location.href = '/?theme=' + encodeURIComponent(preset);
  });

  // 分享动作
  document.getElementById('btn-share-url').addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(location.href);
      window.__toast?.('分享链接已复制至剪贴板');
    } catch { 
      window.__toast?.('复制失败，请手动在浏览器栏复制链接'); 
    }
  });

  // 点赞动作
  const likeBtn = document.getElementById('btn-like');
  const likeCountEl = document.getElementById('like-count');
  const likeKey = `td-like-${themeId}`;
  const clientIdKey = 'td-client-id';
  let clientId = localStorage.getItem(clientIdKey);
  if (!clientId) {
    clientId = crypto.randomUUID?.() || Array.from({ length: 12 }, () => Math.random().toString(36)[2]).join('');
    localStorage.setItem(clientIdKey, clientId);
  }

  if (localStorage.getItem(likeKey) === '1') {
    likeBtn.classList.add('liked');
  }

  likeBtn.addEventListener('click', async () => {
    if (likeBtn.classList.contains('liked')) {
      window.__toast?.('您已经为该主题点过赞了');
      return;
    }
    try {
      const res = await fetch('/api/diy/like.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-client-id': clientId },
        body: JSON.stringify({ id: themeId }),
      });
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      likeCountEl.textContent = parseInt(data.likes) || 0;
      likeBtn.classList.add('liked');
      localStorage.setItem(likeKey, '1');
      window.__toast?.('感谢点赞！');
    } catch {
      window.__toast?.('点赞暂时不可用，请稍后重试');
    }
  });

  // 触发主流程
  loadTheme();
</script>
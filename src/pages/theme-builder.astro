---
import Layout from '../layouts/Layout.astro';
import { getAllThemes, getDailyTheme } from '../utils/daily-theme';
import { getDailyCommunityTheme } from '../utils/omni-bridge';

const communityDaily = await getDailyCommunityTheme();
const themes = getAllThemes();
const todayTheme = communityDaily || getDailyTheme();
const selectedPreset = Astro.url.searchParams.get('theme') || todayTheme.preset;
const selected = themes.find(t => t.preset === selectedPreset) || themes[0];

const initialVarsJSON = JSON.stringify(selected.cssVars, null, 2);
const initialCustomCSS = selected.customCss || '';
const initialThemeData = {
  cssVars: selected.cssVars,
  customCss: selected.customCss || null,
  extensions: selected.extensions || null,
  presetName: selected.presetName,
};
---

<Layout>
  <section style="max-width:1300px;margin:0 auto;padding:0 32px 80px">
    <div class="builder-header">
      <div class="builder-header-text">
        <p class="t-label" style="margin:0">Builder</p>
        <h1 class="t-heading" style="margin:2px 0 0;font-size:1.5rem">主题构建</h1>
        <p class="t-subhead" style="margin:2px 0 0;font-size:0.85rem">选择一个预设主题，或直接编辑 CSS 变量和自定义样式代码，实时预览效果。</p>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:280px 1fr;gap:24px;align-items:start">

      <!-- ===========================================
           LEFT: Theme List
           =========================================== -->
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <p class="t-label" style="margin-bottom:0">预设主题</p>
          <span style="font-size:11px;color:var(--color-text-muted);font-family:'JetBrains Mono',monospace">{themes.length}</span>
        </div>
        <input
          type="text"
          id="builder-search"
          placeholder="筛选…"
          style="width:100%;height:36px;padding:0 12px;border-radius:10px;border:1.5px solid var(--color-border);background:color-mix(in srgb, var(--color-surface) 30%, transparent);color:var(--color-text);font-size:13px;font-family:inherit;outline:none;margin-bottom:10px;transition:border-color 0.2s"
        />
        <div style="display:flex;flex-direction:column;gap:5px;max-height:calc(100vh - 320px);overflow-y:auto;padding-right:4px" id="theme-list">
          {themes.map((t) => {
            const isActive = t.preset === selectedPreset;
            const isToday = t.preset === todayTheme.preset;
            return (
              <button
                class="card card-interact theme-item"
                data-name={t.presetName.toLowerCase()}
                data-preset={t.preset}
                style={`width:100%;text-align:left;padding:11px 14px;cursor:pointer;font-family:inherit;font-size:13px;border-radius:14px;${isActive ? 'border-color:var(--color-primary);background:color-mix(in srgb, var(--color-primary) 10%, transparent);box-shadow:0 0 0 1px color-mix(in srgb, var(--color-primary) 30%, transparent);' : ''}`}
              >
                <div style="display:flex;align-items:center;gap:8px">
                  <div style="display:flex;gap:2px;flex-shrink:0">
                    <span style=`width:14px;height:14px;border-radius:4px;background:${t.cssVars['--color-primary']}`></span>
                    <span style=`width:14px;height:14px;border-radius:4px;background:${t.cssVars['--color-secondary']}`></span>
                    <span style=`width:14px;height:14px;border-radius:4px;background:${t.cssVars['--color-accent']}`></span>
                  </div>
                  <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:600;color:var(--color-text)">{t.presetName}</span>
                  {isToday ? <span style="font-size:10px;font-weight:600;color:var(--color-primary);flex-shrink:0">今日</span> : ''}
                  {isActive ? <span style="margin-left:auto;width:7px;height:7px;border-radius:50%;background:var(--color-primary);flex-shrink:0"></span> : ''}
                </div>
              </button>
            );
          })}
        </div>
      </div>

      <!-- ===========================================
           RIGHT: Editor + Preview
           =========================================== -->
      <div>

        <!-- Tab bar -->
        <div style="display:flex;gap:4px;margin-bottom:16px;border-bottom:1px solid var(--color-border);padding-bottom:0">
          <button class="editor-tab active" data-tab="preview" id="tab-preview">组件预览</button>
          <button class="editor-tab" data-tab="vars" id="tab-vars">CSS 变量</button>
          <button class="editor-tab" data-tab="css" id="tab-css">自定义 CSS</button>
          <button class="editor-tab" data-tab="exts" id="tab-exts">Extensions</button>
          <button class="editor-tab" data-tab="image" id="tab-image">图片取色</button>
          <div style="margin-left:auto;display:flex;gap:8px;align-items:center">
            <span id="edit-status" style="font-size:11px;color:var(--color-text-muted)"></span>
            <button id="btn-reset" style="font-size:11px;font-weight:600;padding:5px 12px;border-radius:7px;border:1px solid var(--color-border);background:transparent;color:var(--color-text-muted);cursor:pointer;font-family:inherit;transition:all 0.2s;display:none">重置</button>
          </div>
        </div>

        <!-- ===== TAB: Preview ===== -->
        <div class="editor-panel" id="panel-preview">
          <div class="card card-glass" style="padding:28px">
            <div style="display:flex;flex-direction:column;gap:18px">
              <div>
                <p style="font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);margin-bottom:10px;text-transform:uppercase">Buttons</p>
                <div style="display:flex;gap:8px;flex-wrap:wrap">
                  <button class="btn btn-primary" style="height:40px;padding:0 20px;font-size:13px">主要按钮</button>
                  <button class="btn btn-outline" style="height:40px;padding:0 20px;font-size:13px">边框按钮</button>
                  <button class="btn btn-ghost" style="font-size:13px">链接</button>
                </div>
              </div>

              <div>
                <p style="font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);margin-bottom:10px;text-transform:uppercase">Cards &amp; Surface</p>
                <div style="padding:18px;border-radius:14px;background:var(--color-surface);border:1px solid var(--color-border)">
                  <div style="font-weight:700;font-size:14px">通知标题</div>
                  <div style="font-size:13px;color:var(--color-text-muted);margin-top:4px">使用 muted 颜色区分信息层级</div>
                </div>
              </div>

              <div>
                <p style="font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);margin-bottom:10px;text-transform:uppercase">Alert &amp; Typography</p>
                <div style="padding:12px 18px;border-radius:12px;background:color-mix(in srgb, var(--color-primary) 8%, transparent);border-left:3px solid var(--color-primary);font-size:14px;margin-bottom:10px">
                  带强调色的提示信息
                </div>
                <p style="font-size:14px;line-height:1.7">
                  正文使用 <code>var(--color-text)</code>，
                  链接使用 <code>var(--color-primary)</code>，
                  辅助文字使用 <span style="color:var(--color-text-muted)">muted</span>。
                </p>
              </div>

              <div>
                <p style="font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-muted);margin-bottom:10px;text-transform:uppercase">Color Swatches</p>
                <div style="display:flex;gap:8px;flex-wrap:wrap">
                  {['--color-primary','--color-secondary','--color-accent','--color-bg','--color-surface','--color-text','--color-text-muted','--color-border'].map(v => (
                    <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
                      <span style=`width:36px;height:36px;border-radius:10px;background:${selected.cssVars[v]};border:1.5px solid var(--color-border)` title={v}></span>
                      <span style="font-size:9px;font-family:'JetBrains Mono',monospace;color:var(--color-text-muted)">{v.replace('--color-','')}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ===== TAB: CSS Vars Editor ===== -->
        <div class="editor-panel" id="panel-vars" style="display:none">
          <div style="margin-bottom:8px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <span style="font-size:12px;color:var(--color-text-muted)">编辑 JSON 格式的 CSS 变量，修改即时生效。</span>
            <span id="vars-error" style="font-size:11px;color:#ef4444;font-weight:600;display:none"></span>
            <span id="vars-ok" style="font-size:11px;color:#22c55e;font-weight:600;display:none">✓ 有效</span>
            <span id="vars-count" style="font-size:11px;color:var(--color-text-muted);margin-left:auto;font-family:'JetBrains Mono',monospace"></span>
            <button class="mini-btn-format" data-target="vars-editor" title="格式化 JSON" style="font-size:10px;font-weight:600;padding:3px 10px;border-radius:5px;border:1px solid var(--color-border);background:transparent;color:var(--color-text-muted);cursor:pointer;font-family:inherit">格式化</button>
          </div>
          <textarea
            id="vars-editor"
            spellcheck="false"
            style="width:100%;height:420px;padding:20px;border-radius:14px;border:1.5px solid var(--color-border);background:color-mix(in srgb, var(--color-text) 3%, var(--color-bg));color:var(--color-text);font-family:'JetBrains Mono','Fira Code',monospace;font-size:12px;line-height:1.65;resize:vertical;outline:none;tab-size:2"
          >{initialVarsJSON}</textarea>
        </div>

        <!-- ===== TAB: Custom CSS Editor ===== -->
        <div class="editor-panel" id="panel-css" style="display:none">
          <div style="margin-bottom:8px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <span style="font-size:12px;color:var(--color-text-muted)">编写自定义 CSS，即时注入页面。可用于微调样式或添加动画。</span>
            <span id="css-count" style="font-size:11px;color:var(--color-text-muted);margin-left:auto;font-family:'JetBrains Mono',monospace"></span>
          </div>
          <textarea
            id="css-editor"
            spellcheck="false"
            placeholder="/* 例如：修改卡片圆角 */&#10;.card { border-radius: 30px; }&#10;&#10;/* 或添加自定义动画 */&#10;@keyframes pulse {&#10;  0%, 100% { opacity: 1; }&#10;  50% { opacity: 0.5; }&#10;}"
            style="width:100%;height:420px;padding:20px;border-radius:14px;border:1.5px solid var(--color-border);background:color-mix(in srgb, var(--color-text) 3%, var(--color-bg));color:var(--color-text);font-family:'JetBrains Mono','Fira Code',monospace;font-size:12px;line-height:1.65;resize:vertical;outline:none;tab-size:2"
          >{initialCustomCSS}</textarea>
        </div>

        <!-- ===== TAB: Extensions Editor ===== -->
        <div class="editor-panel" id="panel-exts" style="display:none">
          <div style="margin-bottom:8px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <div>
              <span style="font-size:12px;color:var(--color-text-muted)"><code>floating</code> 浮动字符 · <code>decorative</code> 装饰 HTML。修改即时生效。</span>
              <div id="exts-hint-builder" style="font-size:10px;color:var(--color-text-muted);margin-top:2px;line-height:1.4"></div>
            </div>
            <span id="exts-count" style="font-size:11px;color:var(--color-text-muted);margin-left:auto;font-family:'JetBrains Mono',monospace"></span>
            <button class="mini-btn-format" data-target="exts-editor" title="格式化 JSON" style="font-size:10px;font-weight:600;padding:3px 10px;border-radius:5px;border:1px solid var(--color-border);background:transparent;color:var(--color-text-muted);cursor:pointer;font-family:inherit">格式化</button>
          </div>
          <textarea
            id="exts-editor"
            spellcheck="false"
            placeholder='[{"type":"floating","char":"🪷","top":"20%","left":"5%","fontSize":"30px","opacity":0.3,"animation":"swing 4s ease-in-out infinite"}]'
            style="width:100%;height:420px;padding:20px;border-radius:14px;border:1.5px solid var(--color-border);background:color-mix(in srgb, var(--color-text) 3%, var(--color-bg));color:var(--color-text);font-family:'JetBrains Mono','Fira Code',monospace;font-size:12px;line-height:1.65;resize:vertical;outline:none;tab-size:2"
          >{selected.extensions ? JSON.stringify(selected.extensions, null, 2) : ''}</textarea>
        </div>

        <!-- ===== TAB: Image to Theme ===== -->
        <div class="editor-panel" id="panel-image" style="display:none">
          <div class="card card-glass" style="padding:28px;text-align:center">
            <p class="text-muted" style="font-size:13px;line-height:1.65;margin-bottom:20px">
              上传一张图片，自动提取主色调并生成主题 CSS 变量。<br/>
              也可生成 AI 提示词，让 AI 参考图片设计更精致的主题。
            </p>

            <!-- Upload zone -->
            <div id="image-drop-zone" style="border:2px dashed var(--color-border);border-radius:16px;padding:48px 24px;cursor:pointer;transition:all 0.25s;margin-bottom:20px">
              <div style="font-size:40px;margin-bottom:10px">🖼️</div>
              <p style="font-weight:600;font-size:14px;margin-bottom:4px">点击上传或拖放图片</p>
              <p style="font-size:12px;color:var(--color-text-muted)">支持 JPG / PNG / WebP，最大 10MB</p>
              <input type="file" id="image-input" accept="image/*" style="display:none" />
            </div>

            <!-- Preview + palette -->
            <div id="image-result" style="display:none">
              <div style="display:flex;gap:20px;flex-wrap:wrap;align-items:start;margin-bottom:20px">
                <div style="flex-shrink:0">
                  <img id="image-preview" style="max-width:200px;max-height:200px;border-radius:12px;border:1px solid var(--color-border);object-fit:cover" alt="" />
                </div>
                <div style="flex:1;min-width:200px;text-align:left">
                  <p style="font-weight:700;font-size:14px;margin-bottom:10px">提取的调色板</p>
                  <div id="palette-swatches" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px"></div>
                  <p style="font-size:11px;color:var(--color-text-muted);margin-bottom:12px">
                    颜色按面积占比排序，可拖动色块调整顺序和映射。
                  </p>
                  <div style="display:flex;flex-wrap:wrap;gap:6px">
                    <button id="btn-apply-palette" class="btn btn-primary" style="height:34px;padding:0 16px;font-size:12px">应用为主题</button>
                    <button id="btn-copy-palette-ai" class="btn btn-outline" style="height:34px;padding:0 16px;font-size:12px">
                      <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M4 4h8v8H4zM2 6v6h2V6H2zM12 6v6h2V6h-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      复制 AI 提示词
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Hidden canvas for color extraction -->
        <canvas id="color-canvas" style="display:none"></canvas>

        <!-- Action bar -->
        <div style="display:flex;gap:8px;margin-top:14px;align-items:center;flex-wrap:wrap">
          <button id="btn-apply-site" class="btn btn-primary" style="height:38px;padding:0 18px;font-size:12px">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            应用到本站
          </button>
          <button id="btn-copy-diy" class="btn btn-outline" style="height:38px;padding:0 18px;font-size:12px">复制 DIY 主题</button>
          <button id="btn-copy-ai" class="btn btn-outline" style="height:38px;padding:0 18px;font-size:12px">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 4h8v8H4zM2 6v6h2V6H2zM12 6v6h2V6h-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            复制给 AI
          </button>
          <button id="btn-format" class="btn btn-ghost" style="height:38px;padding:0 14px;font-size:12px" title="格式化 JSON (Ctrl+Shift+F)">格式化</button>
          <span style="font-size:11px;color:var(--color-text-muted);margin-left:8px" id="diy-hint"></span>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .builder-header { max-width: 100%; margin-bottom: 20px; }
  .builder-header-text { flex: 1; min-width: 0; }

  #builder-search:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 12%, transparent);
  }
  .theme-item { transition: all 0.2s ease; }
  .theme-item:hover { border-color: var(--color-primary); }

  .editor-tab {
    padding: 10px 18px;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 13px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    margin-bottom: -1px;
  }
  .editor-tab:hover { color: var(--color-text); }
  .editor-tab.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }
  .editor-tab[data-badge]:not([data-badge=""])::after {
    content: attr(data-badge);
    margin-left: 6px;
    font-size: 10px;
    font-weight: 700;
    padding: 1px 7px;
    border-radius: 99px;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
    vertical-align: middle;
  }
  .editor-tab[data-badge="●"]::after {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    padding: 0 5px;
    font-size: 7px;
  }
  .mini-btn-format {
    transition: all 0.2s;
  }
  .mini-btn-format:hover {
    color: var(--color-primary) !important;
    border-color: var(--color-primary) !important;
    background: color-mix(in srgb, var(--color-primary) 8%, transparent) !important;
  }

  #vars-editor:focus, #css-editor:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 10%, transparent);
  }
  #image-drop-zone:hover, #image-drop-zone.drag-over {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 5%, transparent);
  }
  .palette-swatch {
    width: 48px; height: 48px;
    border-radius: 12px;
    border: 2px solid var(--color-border);
    cursor: grab;
    transition: transform 0.15s;
    position: relative;
  }
  .palette-swatch:hover { transform: scale(1.12); border-color: var(--color-primary); }
  .palette-swatch .swatch-label {
    position: absolute; bottom: -18px; left: 50%; transform: translateX(-50%);
    font-size: 9px; font-family: 'JetBrains Mono',monospace; color: var(--color-text-muted);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    [style*="grid-template-columns:280px"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script define:vars={{ initialThemeData, selectedPreset }}>
  // ── Initial theme data (injected at build time) ──
  const __INITIAL = initialThemeData;

  // ── State ──
  let currentVars = {};
  let originalVars = {};
  let originalCustomCSS = '';
  let originalExtensions = [];
  let hasEdits = false;
  let diyStyleEl = null;
  let extensionsContainer = null;
  let currentPreset = selectedPreset;

  function getDIYStyle() {
    if (!diyStyleEl) {
      diyStyleEl = document.createElement('style');
      diyStyleEl.id = 'td-diy-css';
      document.head.appendChild(diyStyleEl);
    }
    return diyStyleEl;
  }

  function getExtensionsContainer() {
    if (!extensionsContainer) {
      extensionsContainer = document.createElement('div');
      extensionsContainer.id = 'td-extensions';
      document.body.insertBefore(extensionsContainer, document.body.firstChild);
    }
    return extensionsContainer;
  }

  function removeExtensions() {
    if (extensionsContainer) {
      extensionsContainer.remove();
      extensionsContainer = null;
    }
    // Also clean up any standalone extension elements that might be direct body children
    document.querySelectorAll('.omni-petal, .omni-stardust, .cinematic-vignette, .yozakura-glow, .summer-bubble, .ice-particle').forEach(el => el.remove());
  }

  function _bSafeVal(v) { return (v||'').toString().slice(0,128).replace(/[;{}]/g,'').replace(/url\s*\(/gi,'').replace(/expression\s*\(/gi,'').replace(/javascript\s*:/gi,'').replace(/@import/gi,'').trim(); }
  function _bSafeDim(v) { var s = _bSafeVal(v); return /^-?[\d.]+(?:%|px|em|rem|vh|vw|s|ms)?$/i.test(s) ? s : ''; }
  function injectExtensions(exts) {
    removeExtensions();
    if (!exts || exts.length === 0) return;
    const container = getExtensionsContainer();
    exts.slice(0,20).forEach(function(ext) {
      if (ext.type === 'floating' && ext.char) {
        var el = document.createElement('div');
        var t = _bSafeDim(ext.top), l = _bSafeDim(ext.left), r = _bSafeDim(ext.right), bb = _bSafeDim(ext.bottom);
        var fs = _bSafeDim(ext.fontSize), anim = _bSafeVal(ext.animation);
        var z = (typeof ext.zIndex === 'number' && ext.zIndex > -2 && ext.zIndex < 100000) ? ext.zIndex : null;
        var op = (typeof ext.opacity === 'number' && ext.opacity >= 0 && ext.opacity <= 1) ? ext.opacity : null;
        el.style.cssText = [
          'position:fixed', 'pointer-events:none',
          t && 'top:' + t, l && 'left:' + l, r && 'right:' + r, bb && 'bottom:' + bb,
          fs && 'font-size:' + fs, anim && 'animation:' + anim,
          z != null && 'z-index:' + z, op != null && 'opacity:' + op
        ].filter(Boolean).join(';');
        el.textContent = String(ext.char).slice(0,4);
        container.appendChild(el);
      } else if (ext.type === 'decorative') {
        var tpl = document.createElement('template');
        tpl.innerHTML = ext.html;
        var frag = tpl.content.cloneNode(true);
        frag.querySelectorAll('*').forEach(function(el) {
          Array.from(el.attributes).forEach(function(attr) {
            if (/^on/i.test(attr.name)) el.removeAttribute(attr.name);
          });
        });
        container.appendChild(frag);
      }
    });
  }

  // ── Tab switching ──
  const tabs = document.querySelectorAll('.editor-tab');
  const panels = document.querySelectorAll('.editor-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => t.classList.remove('active'));

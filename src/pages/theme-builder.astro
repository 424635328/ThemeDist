    transition: transform 0.15s;
    position: relative;
  }
  .palette-swatch:hover { transform: scale(1.12); border-color: var(--color-primary); }
  .palette-swatch .swatch-label {
    position: absolute; bottom: -18px; left: 50%; transform: translateX(-50%);
    font-size: 9px; font-family: 'JetBrains Mono',monospace; color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ── Action Bar ── */
  .action-bar {
    display: flex;
    gap: 8px;
    margin-top: 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  .action-group {
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .action-group + .action-group {
    padding-left: 8px;
    border-left: 1px solid var(--color-border);
  }

  /* ── Sidebar Toggle (mobile) ── */
  .sidebar-toggle {
    display: none;
    width: 100%;

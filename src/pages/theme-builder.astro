  function processImage(file: File) {
    if (file.size > 10*1024*1024) { (window as any).__toast?.('图片不能超过 10MB'); return; }
    const reader = new FileReader();
    reader.onload = () => {
      const img = new Image();
      img.onload = () => {
        const maxDim = 120, scale = Math.min(maxDim/img.width, maxDim/img.height);
        colorCanvas.width = Math.floor(img.width*scale); colorCanvas.height = Math.floor(img.height*scale);
        const ctx = colorCanvas.getContext('2d')!;
        ctx.drawImage(img, 0, 0, colorCanvas.width, colorCanvas.height);
        extractedColors = extractColors(ctx, colorCanvas.width, colorCanvas.height);
        displayPalette(extractedColors);
        imagePreview.src = reader.result as string;
        imageResult.style.display = 'block';
      };
      img.src = reader.result as string;
    };
    reader.readAsDataURL(file);
  }

  function extractColors(ctx: CanvasRenderingContext2D, w: number, h: number): string[] {
    const data = ctx.getImageData(0,0,w,h).data;
    const pixels: Array<[number,number,number]> = [];
    for (let i=0;i<data.length;i+=4) { if (data[i+3]>=128) pixels.push([data[i],data[i+1],data[i+2]]); }
    if (pixels.length<100) return ['#000000','#ffffff','#888888'];
    const k=8;
    const centroids=kMeansInit(pixels,k);
    const clusters=kMeansCluster(pixels,centroids,15);
    const palette=clusters.map(c=>({color:rgbToHex(Math.round(c.centroid[0]),Math.round(c.centroid[1]),Math.round(c.centroid[2])),size:c.pixels.length})).sort((a,b)=>b.size-a.size).map(c=>c.color);
    const unique=[palette[0]];
    for (let i=1;i<palette.length;i++) {
      const [r1,g1,b1]=hexToRgb(palette[i]); let tooClose=false;
      for (const ex of unique) {
        const [r2,g2,b2]=hexToRgb(ex);
        if (Math.sqrt(((r1-r2)*0.299)**2+((g1-g2)*0.587)**2+((b1-b2)*0.114)**2)<35) { tooClose=true; break; }
      }
      if (!tooClose) unique.push(palette[i]);
      if (unique.length>=8) break;
    }
    return unique;
  }

  function kMeansInit(pixels: Array<[number,number,number]>, k: number): Array<[number,number,number]> {
    const cents: Array<[number,number,number]> = [pixels[Math.floor(Math.random()*pixels.length)]];
    for (let c=1;c<k;c++) {
      const dists=pixels.map(p=>{let minD=Infinity;for(const ct of cents){const d=(p[0]-ct[0])**2+(p[1]-ct[1])**2+(p[2]-ct[2])**2;if(d<minD)minD=d;}return minD;});
      const total=dists.reduce((a,b)=>a+b,0);let r=Math.random()*total,idx=0;
      for (let i=0;i<dists.length;i++){r-=dists[i];if(r<=0){idx=i;break;}}
      cents.push(pixels[Math.min(idx,pixels.length-1)]);
    }
    return cents;
  }

  function kMeansCluster(pixels: Array<[number,number,number]>, centroids: Array<[number,number,number]>, maxIters: number) {
    const k=centroids.length;
    let clusters: Array<{centroid:[number,number,number];pixels:Array<[number,number,number]>}> = [];
    for (let iter=0;iter<maxIters;iter++) {
      clusters=centroids.map(c=>({centroid:[...c] as [number,number,number],pixels:[] as Array<[number,number,number]>}));
      for (const p of pixels) { let minD=Infinity,bestC=0;for(let c=0;c<k;c++){const ct=centroids[c];const d=(p[0]-ct[0])**2+(p[1]-ct[1])**2+(p[2]-ct[2])**2;if(d<minD){minD=d;bestC=c;}}clusters[bestC].pixels.push(p); }
      let changed=false;
      for (let c=0;c<k;c++){if(clusters[c].pixels.length===0)continue;let sr=0,sg=0,sb=0;for(const p of clusters[c].pixels){sr+=p[0];sg+=p[1];sb+=p[2];}const n=clusters[c].pixels.length;const nr=sr/n,ng=sg/n,nb=sb/n;if(Math.abs(centroids[c][0]-nr)>1||Math.abs(centroids[c][1]-ng)>1||Math.abs(centroids[c][2]-nb)>1)changed=true;centroids[c]=[nr,ng,nb];}
      if(!changed)break;
    }
    return clusters;
  }

  function displayPalette(colors: string[]) {
    const map = [{label:'primary',desc:'主色'},{label:'secondary',desc:'辅色'},{label:'accent',desc:'强调色'},{label:'bg',desc:'背景'},{label:'surface',desc:'表面'},{label:'text',desc:'文字'}];
    paletteSwatches.innerHTML = colors.slice(0,6).map((c,i)=>{const s=map[i]||{label:`c${i}`,desc:''};return `<div class="palette-swatch" style="background:${c}" title="${c} — ${s.desc}"><span class="swatch-label">${s.label}</span></div>`;}).join('');
  }

  function generateThemeFromColors(colors: string[]): Record<string, string> {
    const withLum=colors.map(c=>({color:c,lum:relativeLuminance(c)}));
    const sorted=[...withLum].sort((a,b)=>a.lum-b.lum);
    const vibrant=[...withLum].sort((a,b)=>saturation(b.color)-saturation(a.color));
    const d=sorted[0].color,l=sorted[sorted.length-1].color;
    const mv=vibrant[vibrant.length-1].color,sv=vibrant.length>1?vibrant[vibrant.length-2].color:mv,tv=vibrant.length>2?vibrant[vibrant.length-3].color:mv;
    return {
      '--color-primary':mv,'--color-secondary':sv,'--color-accent':tv,'--color-bg':d,'--color-surface':lightenColor(d,0.06),'--color-text':isDark(l)?'#ffffff':l,'--color-text-muted':lightenColor(d,0.45),'--color-border':hexToRgba(mv,0.18),
      '--font-heading':"'Inter', system-ui, sans-serif",'--font-body':"'Inter', system-ui, sans-serif",'--font-mono':"'JetBrains Mono', monospace",
      '--text-base':'clamp(1rem, 0.9rem + 0.5vw, 1.125rem)','--text-lg':'calc(var(--text-base) * 1.25)','--text-xl':'calc(var(--text-lg) * 1.25)','--text-2xl':'calc(var(--text-xl) * 1.25)','--text-sm':'calc(var(--text-base) / 1.25)',
      '--space-unit':'0.25rem','--space-1':'0.25rem','--space-2':'0.5rem','--space-3':'0.75rem','--space-4':'1rem','--space-6':'1.5rem','--space-8':'2rem','--space-12':'3rem','--radii':'0.75rem','--content-max':'72rem',
      '--shadow-sm':'0 1px 2px rgba(0,0,0,0.08)','--shadow-md':'0 4px 12px rgba(0,0,0,0.12)','--shadow-lg':'0 12px 32px rgba(0,0,0,0.18)','--glass-bg':'color-mix(in srgb, var(--color-bg) 85%, transparent)','--glass-blur':'blur(16px)','--noise-opacity':'0',
      '--ambient-1':hexToRgba(mv,0.15),'--ambient-2':hexToRgba(sv,0.1),
    };
  }


    border: 1px solid var(--color-border);
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 130px;
  }
  .contrast-pair { color: var(--color-text-muted); font-size: 10px; }
  .contrast-ratio { font-weight: 700; font-size: 14px; }
  .contrast-badges { display: flex; gap: 6px; font-size: 10px; }
  .wcag-pass { color: #22c55e; }
  .wcag-fail { color: #f59e0b; }

  /* ── Vars Editor ── */
  .vars-mode-btn {
    height: 30px;
    padding: 0 14px;
    border-radius: 8px;
    border: 1px solid var(--color-border);

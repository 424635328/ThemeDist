    font-size: 12px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: all 0.2s;
  }
  .vars-mode-btn:hover { color: var(--color-text); }
  .vars-mode-btn.active {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .vars-visual-panel {
    max-height: 500px;
    overflow-y: auto;
    padding-right: 4px;
  }
  .vars-section { margin-bottom: 16px; }
  .vars-section-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .vars-fields {
    display: flex;
    flex-direction: column;
    gap: 5px;

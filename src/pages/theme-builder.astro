  .vars-row-color:hover { transform: scale(1.1); }
  .vars-row-color::-webkit-color-swatch-wrapper { padding: 0; }
  .vars-row-color::-webkit-color-swatch { border: none; border-radius: 5px; }
  .vars-row-input {
    flex: 1;
    height: 30px;

  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .builder-layout {
      grid-template-columns: 1fr;
      padding: 0 20px 60px;
    }
    .builder-sidebar {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 500;
      background: color-mix(in srgb, var(--color-bg) 95%, transparent);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      padding: 20px;
      overflow-y: auto;
    }
    .builder-sidebar.open { display: block; }
    .sidebar-toggle { display: flex; }
    .editor-tab { padding: 10px 12px; font-size: 12px; }
    .editor-tab svg { display: none; }
    .tab-status { gap: 3px; }
    .vars-row-label { width: 100px; font-size: 10px; }
    .action-group + .action-group { padding-left: 0; border-left: none; }
    .action-bar { gap: 6px; }
  }
</style>

<script define:vars={{ initialThemeData, selectedPreset }}>
  // ═══════════════════════════════════════════════════════
  // 1. Constants
  // ═══════════════════════════════════════════════════════
  const MAX_HISTORY = 60;
  const DEBOUNCE_MS = 280;

  const COLOR_KEYS = new Set([
    '--color-primary','--color-secondary','--color-accent',
    '--color-bg','--color-surface','--color-text','--color-text-muted',
    '--color-border','--ambient-1','--ambient-2'
  ]);
  const TYPE_KEYS = new Set([
    '--font-heading','--font-body','--font-mono',
    '--text-base','--text-lg','--text-xl','--text-2xl','--text-sm',
  ]);
  const LAYOUT_KEYS = new Set([
    '--space-unit','--radii','--content-max',
    '--space-1','--space-2','--space-3','--space-4','--space-6','--space-8','--space-12',
  ]);
  const EFFECTS_KEYS = new Set([
    '--shadow-sm','--shadow-md','--shadow-lg','--glass-bg','--glass-blur','--noise-opacity',
  ]);

  // ═══════════════════════════════════════════════════════
  // 2. State
  // ═══════════════════════════════════════════════════════
  const __INITIAL = initialThemeData;
  let currentVars: Record<string, string> = {};
  let originalVars: Record<string, string> = {};
  let originalCustomCSS = '';
  let originalExtensions: Array<{type: string; content: string}> = [];
  let hasEdits = false;
  let currentPreset = selectedPreset;
  let diyStyleEl: HTMLStyleElement | null = null;
  let extensionsContainer: HTMLDivElement | null = null;

  // History
  interface Snap { vars: Record<string, string>; css: string }
  const history: Snap[] = [];
  let historyIdx = -1;
  let historyLock = false;

  // ═══════════════════════════════════════════════════════
  // 3. DOM refs
  // ═══════════════════════════════════════════════════════
  const $ = (id: string) => document.getElementById(id)!;
  const varsEditor = $('vars-editor') as HTMLTextAreaElement;
  const cssEditor = $('css-editor') as HTMLTextAreaElement;
  const varsError = $('vars-error');
  const varsOk = $('vars-ok');
  const editStatus = $('edit-status');
  const btnReset = $('btn-reset');
  const btnUndo = $('btn-undo') as HTMLButtonElement;
  const btnRedo = $('btn-redo') as HTMLButtonElement;
  const diyHint = $('diy-hint');
  const themeList = $('theme-list');
  const builderSearch = $('builder-search') as HTMLInputElement;
  const searchClear = $('search-clear');
  const themeCount = $('theme-count');
  const varsVisual = $('vars-visual');

  // ═══════════════════════════════════════════════════════
  // 4. Extensions & DOM injection
  // ═══════════════════════════════════════════════════════
  function getDIYStyle(): HTMLStyleElement {
    if (!diyStyleEl) {
      diyStyleEl = document.createElement('style');
      diyStyleEl.id = 'td-diy-css';
      document.head.appendChild(diyStyleEl);
    }
    return diyStyleEl;
  }
  function getExtensionsContainer(): HTMLDivElement {
    if (!extensionsContainer) {
      extensionsContainer = document.createElement('div');
      extensionsContainer.id = 'td-extensions';
      document.body.insertBefore(extensionsContainer, document.body.firstChild);
    }
    return extensionsContainer;
  }
  function removeExtensions() {
    if (extensionsContainer) { extensionsContainer.remove(); extensionsContainer = null; }
    document.querySelectorAll('.omni-petal,.omni-stardust,.cinematic-vignette,.yozakura-glow,.summer-bubble,.ice-particle,.abyss-shard,.abyss-ember,.abyss-ambient,.omni-wave,.omni-firework,.omni-flower,.omni-raindrop,.omni-heart,.omni-star,.omni-lotus,.omni-steam,.omni-paw,.omni-coin,.dec-icon,.interactive-drink').forEach(el => el.remove());
  }
  function injectExtensions(exts: Array<{type: string; content: string}>) {
    removeExtensions();
    if (!exts || exts.length === 0) return;
    getExtensionsContainer().innerHTML = exts.map(e => e.content).join('');
  }

  // ═══════════════════════════════════════════════════════
  // 5. Apply helpers
  // ═══════════════════════════════════════════════════════
  function applyVars(vars: Record<string, string>) {
    const root = document.documentElement;
    for (const [k, v] of Object.entries(vars)) root.style.setProperty(k, v);
  }
  function applyCustomCSS(css: string) {
    getDIYStyle().textContent = css;
  }
  function markEdited() {
    hasEdits = true;
    updateEditUI();
  }
  function updateEditUI() {
    if (hasEdits) {
      editStatus.textContent = '已修改';
      editStatus.style.color = '#f59e0b';
      btnReset.style.display = '';
      diyHint.textContent = 'DIY 版本';
    } else {
      editStatus.textContent = '';
      btnReset.style.display = 'none';
      diyHint.textContent = '';
    }
  }

  // ═══════════════════════════════════════════════════════
  // 6. History / Undo / Redo
  // ═══════════════════════════════════════════════════════
  function pushHistory() {
    if (historyLock) return;
    history.length = historyIdx + 1;
    history.push({ vars: { ...currentVars }, css: cssEditor.value });
    if (history.length > MAX_HISTORY) history.shift();
    historyIdx = history.length - 1;
    updateUndoRedoUI();
  }
  function undo() {
    if (historyIdx <= 0) return;
    historyLock = true;
    historyIdx--;
    restoreSnap(history[historyIdx]);
    historyLock = false;
    updateUndoRedoUI();
    markEdited();
  }
  function redo() {
    if (historyIdx >= history.length - 1) return;
    historyLock = true;
    historyIdx++;
    restoreSnap(history[historyIdx]);
    historyLock = false;
    updateUndoRedoUI();
    markEdited();
  }
  function restoreSnap(s: Snap) {
    currentVars = { ...s.vars };
    applyVars(currentVars);
    applyCustomCSS(s.css);
    varsEditor.value = JSON.stringify(currentVars, null, 2);
    cssEditor.value = s.css;
    updateAllPreviews();
  }
  function updateUndoRedoUI() {
    btnUndo.disabled = historyIdx <= 0;
    btnRedo.disabled = historyIdx >= history.length - 1;
  }
  btnUndo.addEventListener('click', undo);
  btnRedo.addEventListener('click', redo);

  // ═══════════════════════════════════════════════════════
  // 7. Tab switching
  // ═══════════════════════════════════════════════════════
  const tabs = document.querySelectorAll('.editor-tab');
  const panels = document.querySelectorAll('.editor-panel');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      panels.forEach(p => (p as HTMLElement).style.display = 'none');
      const panel = document.getElementById('panel-' + target);
      if (panel) panel.style.display = '';
      if (target === 'vars') syncVarsEditor();
      if (target === 'preview') updateAllPreviews();
    });
  });
  function syncVarsEditor() {
    varsEditor.value = JSON.stringify(currentVars, null, 2);
    if (varsVisual.style.display !== 'none') renderVisualVars();
    varsError.style.display = 'none';
    varsOk.style.display = 'none';
  }

  // ═══════════════════════════════════════════════════════
  // 8. Theme loading (from API)
  // ═══════════════════════════════════════════════════════
  async function loadThemeFromPreset(preset: string) {
    try {
      const res = await fetch(`/api/theme/${preset}.json`);
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      loadTheme(data.cssVars, data.customCss || '', data.extensions || []);
      currentPreset = preset;
    } catch {
      (window as any).__toast?.('主题加载失败');
    }
  }
  function loadTheme(vars: Record<string, string>, customCSS: string, exts: Array<{type: string; content: string}>) {
    historyLock = true;
    originalVars = { ...vars };
    currentVars = { ...vars };
    originalCustomCSS = customCSS;
    originalExtensions = exts;
    hasEdits = false;
    applyVars(vars);
    applyCustomCSS(customCSS);
    injectExtensions(exts);
    updateEditUI();
    varsEditor.value = JSON.stringify(vars, null, 2);
    cssEditor.value = customCSS;
    varsError.style.display = 'none';
    varsOk.style.display = 'none';
    updateAllPreviews();
    // Reset history
    history.length = 0;
    historyIdx = -1;
    pushHistory();
    updateUndoRedoUI();
    historyLock = false;
  }

  // Sidebar click → load theme
  themeList.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.theme-item') as HTMLElement | null;
    if (!btn) return;
    const preset = btn.dataset.preset!;
    if (preset === currentPreset && !hasEdits) return;

    // Update active state
    themeList.querySelectorAll('.theme-item').forEach(b => { (b as HTMLElement).dataset.active = '0'; });
    btn.dataset.active = '1';

    // Update URL
    const url = new URL(location.href);
    url.searchParams.set('theme', preset);
    history.replaceState(null, '', url.toString());

    loadThemeFromPreset(preset);

    if (window.innerWidth <= 900) {
      document.querySelector('.builder-sidebar')?.classList.remove('open');
      ($('sidebar-toggle') as HTMLElement).textContent = '主题列表';
    }
  });

  // ═══════════════════════════════════════════════════════
  // 9. Live preview rendering (swatches + contrast + fonts)
  // ═══════════════════════════════════════════════════════
  function updateAllPreviews() {
    renderLiveSwatches();
    renderContrastChecks();
    renderVisualVars();
  }

  function renderLiveSwatches() {
    const keys = ['--color-primary','--color-secondary','--color-accent','--color-bg','--color-surface','--color-text','--color-text-muted','--color-border'];
    const el = $('live-swatches');
    el.innerHTML = keys.map(key => {
      const val = currentVars[key] || '#000';
      return `<div class="swatch-item">
        <div class="swatch-color" style="background:${val}" title="${key}: ${val}" data-hex="${val}"></div>
        <span class="swatch-hex">${key.replace('--color-','')}</span>
      </div>`;
    }).join('');
    el.querySelectorAll('.swatch-color').forEach(sw => {
      sw.addEventListener('click', () => {
        const hex = (sw as HTMLElement).dataset.hex || '';
        navigator.clipboard.writeText(hex).then(() => (window as any).__toast?.(`已复制 ${hex}`)).catch(() => {});
      });
    });
  }

  function renderContrastChecks() {
    const bg = currentVars['--color-bg'] || '#000';
    const surface = currentVars['--color-surface'] || '#111';
    const text = currentVars['--color-text'] || '#fff';
    const muted = currentVars['--color-text-muted'] || '#888';
    const primary = currentVars['--color-primary'] || '#6C5CE7';
    const pairs = [
      { label: 'text / bg', fg: text, bg },
      { label: 'text / surface', fg: text, bg: surface },
      { label: 'muted / bg', fg: muted, bg },
      { label: 'primary / bg', fg: primary, bg },
    ];
    const el = $('contrast-checks');
    el.innerHTML = pairs.map(p => {
      const r = getContrastRatio(p.fg, p.bg);
      const aa = r >= 4.5, aaa = r >= 7;
      return `<div class="contrast-item">
        <span class="contrast-pair">${p.label}</span>
        <span class="contrast-ratio">${r.toFixed(2)}:1</span>
        <div class="contrast-badges">
          <span class="${aa ? 'wcag-pass' : 'wcag-fail'}">AA ${aa ? '✓' : '✗'}</span>
          <span class="${aaa ? 'wcag-pass' : 'wcag-fail'}">AAA ${aaa ? '✓' : '✗'}</span>
        </div>
      </div>`;
    }).join('');
  }

  // ═══════════════════════════════════════════════════════
  // 10. Visual CSS vars editor
  // ═══════════════════════════════════════════════════════
  let varsMode: 'visual' | 'json' = 'visual';

  document.querySelectorAll('.vars-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      varsMode = (btn as HTMLElement).dataset.mode as 'visual' | 'json';
      document.querySelectorAll('.vars-mode-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      varsVisual.style.display = varsMode === 'visual' ? '' : 'none';
      varsEditor.style.display = varsMode === 'json' ? '' : 'none';
      if (varsMode === 'json') varsEditor.value = JSON.stringify(currentVars, null, 2);
      if (varsMode === 'visual') renderVisualVars();
    });
  });

  function categorizeVar(key: string): 'color'|'type'|'layout'|'effects' {
    if (COLOR_KEYS.has(key)) return 'color';
    if (TYPE_KEYS.has(key)) return 'type';
    if (LAYOUT_KEYS.has(key)) return 'layout';
    if (EFFECTS_KEYS.has(key)) return 'effects';
    const val = currentVars[key] || '';
    if (/^(#|rgb|hsl|color-mix|rgba|hsla)/.test(val)) return 'color';
    if (/font|text-/.test(key)) return 'type';
    if (/shadow|glass|noise|blur/.test(key)) return 'effects';
    return 'layout';
  }

  function renderVisualVars() {
    const sections: Record<string, string[]> = { color:[], type:[], layout:[], effects:[] };
    for (const key of Object.keys(currentVars)) sections[categorizeVar(key)].push(key);
    const ids: Record<string, string> = { color:'vars-color-fields', type:'vars-type-fields', layout:'vars-layout-fields', effects:'vars-effects-fields' };
    for (const [cat, keys] of Object.entries(sections)) {
      const el = document.getElementById(ids[cat]);
      if (el) el.innerHTML = keys.map(k => createVarRow(k, currentVars[k])).join('');
    }
    wireVisualInputs();
  }

  function createVarRow(key: string, value: string): string {
    const isColor = COLOR_KEYS.has(key) || /^(#|rgb|hsl|color-mix|rgba|hsla)/.test(value);
    const short = key.replace('--', '').replace('color-', '');
    const hex = parseColorToHex(value);
    if (isColor) {
      return `<div class="vars-row" data-var="${key}">
        <span class="vars-row-label" title="${key}">${short}</span>
        <input type="color" class="vars-row-color" value="${hex}" data-var="${key}" />
        <input type="text" class="vars-row-input" value="${escHtml(value)}" data-var="${key}" />
      </div>`;
    }
    return `<div class="vars-row" data-var="${key}">
      <span class="vars-row-label" title="${key}">${short}</span>
      <input type="text" class="vars-row-input vars-row-input--wide" value="${escHtml(value)}" data-var="${key}" />
    </div>`;
  }

  function wireVisualInputs() {

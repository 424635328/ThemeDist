    const paletteDesc = extractedColors.slice(0, 6).map((c, i) => {
      const names = ['主色 primary', '辅色 secondary', '强调 accent', '背景 bg', '表面 surface', '文字 text'];
      return `${names[i] || '颜色' + i}: ${c}`;
    }).join('\n');

    const vars = generateThemeFromColors(extractedColors);
    const themeJSON = JSON.stringify({
      cssVars: vars,
      customCss: "",
      extensions: [],
    }, null, 2);

    const prompt = `I have an image with these dominant colors:
${paletteDesc}

Please generate a complete theme based on these colors. Here is a starter theme JSON:

\`\`\`json
${themeJSON}
\`\`\`

Requirements:
1. Injects all CSS variables from the starter theme JSON into :root using document.documentElement.style.setProperty() on page load
2. Uses the CSS variables throughout the page (buttons, cards, typography, backgrounds)
3. Has a glass-morphism dark design with ambient background orbs using --ambient-1 and --ambient-2
4. Includes localStorage caching so the theme persists across page loads
5. Allows customCss injection via a <style> tag appended to <head>
6. Add subtle animations and particle effects that match the color mood

You may adjust the color roles (primary, secondary, accent, bg, surface, text) if the starter assignments don't feel optimal — the starter JSON is just a best-guess mapping from the palette extraction.

Theme color summary: primary=${vars['--color-primary']}, bg=${vars['--color-bg']}, surface=${vars['--color-surface']}, text=${vars['--color-text']}.`;

    try {
      await navigator.clipboard.writeText(prompt);
      window.__toast?.('AI 提示词已复制，可粘贴给 AI 生成站点');
    } catch {
      window.__toast?.('复制失败');
    }
  });

  // ── Color utility helpers ──
  function rgbToHex(r, g, b) {
    return '#' + [r, g, b].map(n => Math.max(0, Math.min(255, n)).toString(16).padStart(2, '0')).join('');
  }

  function hexToRgb(hex) {
    const c = hex.replace('#', '');
    return [
      parseInt(c.slice(0, 2), 16),
      parseInt(c.slice(2, 4), 16),
      parseInt(c.slice(4, 6), 16),
    ];
  }

  function hexToRgba(hex, alpha) {
    const [r, g, b] = hexToRgb(hex);
    return `rgba(${r},${g},${b},${alpha})`;
  }

  function relativeLuminance(hex) {
    const [r, g, b] = hexToRgb(hex).map(c => {
      const s = c / 255;
      return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
    });
    return 0.2126 * r + 0.7152 * g + 0.0722 * b;
  }

  function saturation(hex) {
    const [r, g, b] = hexToRgb(hex).map(c => c / 255);
    const max = Math.max(r, g, b);
    const min = Math.min(r, g, b);
    return max === 0 ? 0 : (max - min) / max;
  }

  function isDark(hex) {
    return relativeLuminance(hex) < 0.3;
  }

  function lightenColor(hex, amount) {
    const [r, g, b] = hexToRgb(hex);
    const f = (c) => Math.min(255, Math.max(0, Math.round(c + amount * 255)));
    return rgbToHex(f(r), f(g), f(b));
  }

  // ── Handle ?diy=1 for applying DIY theme from other pages ──
  if (new URLSearchParams(location.search).get('diy') === '1') {
    const diyVars = sessionStorage.getItem('td-diy-vars');
    const diyCSS = sessionStorage.getItem('td-diy-css');
    const diyName = sessionStorage.getItem('td-diy-name');
    if (diyVars) {
      try {
        const vars = JSON.parse(diyVars);
        applyVars(vars);
        currentVars = vars;
        if (diyCSS) applyCustomCSS(diyCSS);
        varsEditor.value = JSON.stringify(vars, null, 2);
        cssEditor.value = diyCSS || '';
        markEdited();
        if (diyName) diyHint.textContent = '已加载 DIY 主题: ' + diyName;
      } catch { /* ignore */ }
    }
  }

  // ── Init state from server-injected theme data ──
  (function initState() {
    currentVars = __INITIAL.cssVars;
    originalVars = { ...__INITIAL.cssVars };
    originalCustomCSS = __INITIAL.customCss || '';
    originalExtensions = __INITIAL.extensions || [];
    window._initialExts = [...originalExtensions];
    applyVars(currentVars);
    applyCustomCSS(originalCustomCSS);
    if (originalExtensions.length > 0) {
      injectExtensions(originalExtensions);
    }
    if (extsEditor) extsEditor.value = originalExtensions.length > 0 ? JSON.stringify(originalExtensions, null, 2) : '';
    updateCounts();
    updateExtsWarning();
  })();

  // ── Copy for AI: generates a structured prompt + theme data ──
  document.getElementById('btn-copy-ai').addEventListener('click', async () => {
    const exts = parseExtsEditor();
    const hasExtensions = exts.length > 0;
    const themeJSON = JSON.stringify({
      cssVars: currentVars,
      customCss: cssEditor.value || null,
      extensions: hasExtensions ? exts : undefined
    }, null, 2);

    const extNote = hasExtensions
      ? `\n7. Renders the "extensions" declarative array as floating decorative elements using document.createElement (safe, no innerHTML)`
      : '';

    const prompt = `I need to build a website that uses this exact theme. Here is the theme data in JSON format:

\`\`\`json
${themeJSON}
\`\`\`

Please generate a complete HTML page that:
1. Fetches this theme JSON from an API endpoint (you decide the endpoint path)
2. Injects all CSS variables from "cssVars" into :root using document.documentElement.style.setProperty()
3. If "customCss" is not null, creates a <style> tag with that CSS and appends it to <head>
4. Uses the CSS variables throughout the page (buttons, cards, typography, backgrounds)
5. Includes localStorage caching so the theme persists across page loads
6. Has a glass-morphism dark design with ambient background orbs${extNote}

Theme color summary: primary=${currentVars['--color-primary']}, bg=${currentVars['--color-bg']}, text=${currentVars['--color-text']}.`;

    try {
      await navigator.clipboard.writeText(prompt);
      window.__toast?.('AI 提示词已复制，可粘贴给 AI 生成站点');
    } catch {
      window.__toast?.('复制失败');
    }
  });

  // ── Format helpers ──
  function formatVarsJSON() {
    try {
      const parsed = JSON.parse(varsEditor.value);
      varsEditor.value = JSON.stringify(parsed, null, 2);
      currentVars = parsed;
      applyVars(currentVars);
      varsError.style.display = 'none';
      varsOk.style.display = 'inline';
      setTimeout(() => { varsOk.style.display = 'none'; }, 1500);
      updateCounts();
      return true;
    } catch (e) {
      varsError.textContent = '无法格式化: ' + (e.message || 'JSON 无效');
      varsError.style.display = 'inline';
      return false;
    }
  }

  function formatExtsJSON() {
    try {
      const raw = extsEditor.value.trim();
      if (!raw) return;
      const parsed = JSON.parse(raw);
      extsEditor.value = JSON.stringify(parsed, null, 2);
      originalExtensions = Array.isArray(parsed) ? parsed : [];
      injectExtensions(originalExtensions);
      markEdited();
      updateExtsWarning();
      updateCounts();
      window.__toast?.('Extensions 已格式化');
    } catch (e) {
      window.__toast?.('Extensions JSON 无效');
    }
  }

  // Smart format: acts on whichever editor tab is active
  document.getElementById('btn-format').addEventListener('click', () => {
    const activeTab = document.querySelector('.editor-tab.active');
    if (!activeTab) { formatVarsJSON(); return; }
    const t = activeTab.dataset.tab;
    if (t === 'vars') { formatVarsJSON(); document.getElementById('tab-vars').click(); }
    else if (t === 'exts') { formatExtsJSON(); document.getElementById('tab-exts').click(); }
    else if (t === 'css') { document.getElementById('tab-vars').click(); formatVarsJSON(); }
    else { formatVarsJSON(); document.getElementById('tab-vars').click(); }
  });

  // Mini format buttons (per-editor)
  document.querySelectorAll('.mini-btn-format').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      if (target === 'vars-editor') formatVarsJSON();
      else if (target === 'exts-editor') formatExtsJSON();
    });
  });

  // ── Real-time extensions type validation ──
  function updateExtsWarning() {
    const hint = document.getElementById('exts-hint-builder');
    if (!hint) return;
    const raw = extsEditor.value.trim();
    if (!raw) { hint.innerHTML = ''; return; }
    let parsed;
    try { parsed = JSON.parse(raw); } catch { hint.innerHTML = '<span style="color:#ef4444;font-weight:600">JSON 格式错误</span>'; return; }
    if (!Array.isArray(parsed)) { hint.innerHTML = '<span style="color:#f59e0b;font-weight:600">⚠ 扩展应为 JSON 数组格式，而非单个对象。请用 [...] 包裹。</span>'; return; }
    if (parsed.length === 0) { hint.innerHTML = ''; return; }
    const bad = parsed.filter(e => e && typeof e === 'object' && e.type && !['floating','decorative'].includes(e.type));
    if (bad.length > 0) {
      const types = [...new Set(bad.map(e => e.type))].join(', ');
      hint.innerHTML = `<span style="color:#f59e0b;font-weight:600">⚠ 检测到不支持的类型: ${types}。请改用 "floating" 或 "decorative"。</span>`;
    } else {
      const f = parsed.filter(e => e && e.type === 'floating').length;
      const d = parsed.filter(e => e && e.type === 'decorative').length;
      hint.innerHTML = `<span style="color:#22c55e">✓ 有效</span> · ${f} 浮动 + ${d} 装饰`;
    }
  }

  // ── Update editor counts + tab badges ──
  function updateCounts() {
    const varsCount = document.getElementById('vars-count');
    if (varsCount) varsCount.textContent = Object.keys(currentVars).length + ' 变量';
    const cssCount = document.getElementById('css-count');
    if (cssCount) cssCount.textContent = cssEditor.value.trim() ? (cssEditor.value.length > 500 ? Math.round(cssEditor.value.length/100)/10 + 'k' : cssEditor.value.length) + ' 字符' : '空';
    const extsCount = document.getElementById('exts-count');
    if (extsCount) {
      const exts = parseExtsEditor();
      extsCount.textContent = exts.length > 0 ? exts.length + ' 个扩展' : '空';
    }
    // Tab badges
    const cssTab = document.getElementById('tab-css');
    if (cssTab) cssTab.setAttribute('data-badge', cssEditor.value.trim() ? '●' : '');
    const extsTab = document.getElementById('tab-exts');
    if (extsTab) extsTab.setAttribute('data-badge', parseExtsEditor().length > 0 ? parseExtsEditor().length : '');
  }

  // ── File input: import theme JSON ──
  // (Support drag & drop of .json files onto the vars editor)
  varsEditor.addEventListener('dragover', (e) => {
    e.preventDefault();
    varsEditor.style.borderColor = 'var(--color-primary)';
  });
  varsEditor.addEventListener('dragleave', () => {
    varsEditor.style.borderColor = '';
  });
  varsEditor.addEventListener('drop', (e) => {
    e.preventDefault();
    varsEditor.style.borderColor = '';
    const file = e.dataTransfer?.files?.[0];
    if (!file || !file.name.endsWith('.json')) return;
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const data = JSON.parse(reader.result);
        // Accept both raw cssVars and { cssVars: {...} } wrapper
        const vars = data.cssVars || data;
        const css = data.customCss || '';
        const exts = Array.isArray(data.extensions) ? data.extensions : [];
        if (typeof vars === 'object' && vars['--color-primary']) {
          varsEditor.value = JSON.stringify(vars, null, 2);
          cssEditor.value = css;
          if (extsEditor) extsEditor.value = exts.length > 0 ? JSON.stringify(exts, null, 2) : '';
          currentVars = vars;
          originalExtensions = exts;
          applyVars(vars);
          applyCustomCSS(css);
          injectExtensions(exts);
          markEdited();
          window.__toast?.('主题已导入');
        } else {
          window.__toast?.('无效的主题文件格式');
        }
      } catch {
        window.__toast?.('JSON 解析失败');
      }
    };
    reader.readAsText(file);
  });
</script>

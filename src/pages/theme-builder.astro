  }
  .mini-btn:disabled {
    opacity: 0.35;
    cursor: default;
  }

  /* ── Preview Panel ── */
  .preview-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);

  });

  function processImage(file) {
    if (file.size > 10 * 1024 * 1024) {
      window.__toast?.('图片不能超过 10MB');
      return;
    }
    const reader = new FileReader();
    reader.onload = () => {
      const img = new Image();
      img.onload = () => {
        // Draw to canvas for pixel extraction
        const maxDim = 120;
        const scale = Math.min(maxDim / img.width, maxDim / img.height);
        colorCanvas.width = Math.floor(img.width * scale);
        colorCanvas.height = Math.floor(img.height * scale);
        const ctx = colorCanvas.getContext('2d');
        ctx.drawImage(img, 0, 0, colorCanvas.width, colorCanvas.height);

        // Extract dominant colors
        extractedColors = extractColors(ctx, colorCanvas.width, colorCanvas.height);
        displayPalette(extractedColors);

        // Show preview
        imagePreview.src = reader.result;
        imageResult.style.display = 'block';
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  }

  function extractColors(ctx, w, h) {
    const data = ctx.getImageData(0, 0, w, h).data;
    const pixels = [];

    // Sample pixels (skip alpha < 128)
    for (let i = 0; i < data.length; i += 4) {
      if (data[i + 3] < 128) continue; // skip transparent
      pixels.push([data[i], data[i + 1], data[i + 2]]);
    }

    if (pixels.length < 100) return ['#000000', '#ffffff', '#888888', '#cccccc', '#666666'];

    // K-means clustering (k=12 — enough for 5+ unique after dedup)
    const k = 12;
    const centroids = kMeansInit(pixels, k, 10);
    const clusters = kMeansCluster(pixels, centroids, 15);

    // Get centroid colors, sorted by cluster size (largest first)
    const palette = clusters
      .map(c => {
        const avg = c.centroid;
        return {
          color: rgbToHex(Math.round(avg[0]), Math.round(avg[1]), Math.round(avg[2])),
          size: c.pixels.length,
        };
      })
      .sort((a, b) => b.size - a.size)
      .map(c => c.color);

    // Remove near-duplicates (perceptually weighted distance)
    function dedupWithThreshold(colors, threshold) {
      const result = [colors[0]];
      for (let i = 1; i < colors.length; i++) {
        const [r1, g1, b1] = hexToRgb(colors[i]);
        let tooClose = false;
        for (const existing of result) {
          const [r2, g2, b2] = hexToRgb(existing);
          const dr = (r1 - r2) * 0.299;
          const dg = (g1 - g2) * 0.587;
          const db = (b1 - b2) * 0.114;
          const dist = Math.sqrt(dr * dr + dg * dg + db * db);
          if (dist < threshold) { tooClose = true; break; }
        }
        if (!tooClose) result.push(colors[i]);
        if (result.length >= 8) break;
      }
      return result;
    }

    let unique = dedupWithThreshold(palette, 30);
    // Fallback: lower threshold to ensure at least 5 colors
    if (unique.length < 5) unique = dedupWithThreshold(palette, 18);
    // Still not enough: supplement with generated variants from extracted colors
    if (unique.length < 5) {
      const byLum = [...unique].sort((a, b) => relativeLuminance(a) - relativeLuminance(b));
      const darkest = byLum[0];
      // Generate additional colors by lightening the darkest color at different steps
      const steps = [0.06, 0.15, 0.28, 0.42, 0.58];
      for (const step of steps) {
        if (unique.length >= 5) break;
        const variant = lightenColor(darkest, step);
        // Only add if perceptually distinct from all existing
        const [r1, g1, b1] = hexToRgb(variant);
        const tooClose = unique.some(c => {
          const [r2, g2, b2] = hexToRgb(c);
          const dr = (r1 - r2) * 0.299, dg = (g1 - g2) * 0.587, db = (b1 - b2) * 0.114;
          return Math.sqrt(dr * dr + dg * dg + db * db) < 18;
        });
        if (!tooClose) unique.push(variant);
      }
    }

    return unique;
  }

  // K-means++ initialization
  function kMeansInit(pixels, k, iters) {
    const centroids = [pixels[Math.floor(Math.random() * pixels.length)]];
    for (let c = 1; c < k; c++) {
      const dists = pixels.map(p => {
        let minD = Infinity;
        for (const ct of centroids) {
          const dr = p[0] - ct[0], dg = p[1] - ct[1], db = p[2] - ct[2];
          const d = dr * dr + dg * dg + db * db;
          if (d < minD) minD = d;
        }
        return minD;
      });
      const total = dists.reduce((a, b) => a + b, 0);
      let r = Math.random() * total, idx = 0;
      for (let i = 0; i < dists.length; i++) {
        r -= dists[i];
        if (r <= 0) { idx = i; break; }
      }
      centroids.push(pixels[Math.min(idx, pixels.length - 1)]);
    }
    return centroids;
  }

  function kMeansCluster(pixels, centroids, maxIters) {
    const k = centroids.length;
    const clusters = [];

    for (let iter = 0; iter < maxIters; iter++) {
      // Reset clusters
      clusters.length = 0;
      for (let c = 0; c < k; c++) clusters.push({ centroid: [...centroids[c]], pixels: [] });

      // Assign pixels to nearest centroid
      for (const p of pixels) {
        let minD = Infinity, bestC = 0;
        for (let c = 0; c < k; c++) {
          const ct = centroids[c];
          const dr = p[0] - ct[0], dg = p[1] - ct[1], db = p[2] - ct[2];
          const d = dr * dr + dg * dg + db * db;
          if (d < minD) { minD = d; bestC = c; }
        }
        clusters[bestC].pixels.push(p);
      }

      // Update centroids
      let changed = false;
      for (let c = 0; c < k; c++) {
        if (clusters[c].pixels.length === 0) continue;
        let sr = 0, sg = 0, sb = 0;
        for (const p of clusters[c].pixels) { sr += p[0]; sg += p[1]; sb += p[2]; }
        const n = clusters[c].pixels.length;
        const nr = sr / n, ng = sg / n, nb = sb / n;
        if (Math.abs(centroids[c][0] - nr) > 1 || Math.abs(centroids[c][1] - ng) > 1 || Math.abs(centroids[c][2] - nb) > 1) {
          changed = true;
        }
        centroids[c] = [nr, ng, nb];
      }
      if (!changed) break;
    }

    return clusters;
  }

  function displayPalette(colors) {
    // Map to semantic roles
    const semanticMap = [
      { label: 'primary', desc: '主色' },
      { label: 'secondary', desc: '辅色' },
      { label: 'accent', desc: '强调色' },
      { label: 'bg', desc: '背景' },
      { label: 'surface', desc: '表面' },
      { label: 'text', desc: '文字' },
    ];

    paletteSwatches.innerHTML = colors.slice(0, 6).map((color, i) => {
      const s = semanticMap[i] || { label: `c${i}`, desc: '' };
      return `<div class="palette-swatch" style="background:${color}" title="${color} — ${s.desc}">
        <span class="swatch-label">${s.label}</span>
      </div>`;
    }).join('');
  }

  function generateThemeFromColors(colors) {
    // Sort colors by perceived brightness
    const withLum = colors.map(c => ({ color: c, lum: relativeLuminance(c) }));
    const sorted = [...withLum].sort((a, b) => a.lum - b.lum); // dark → light
    const vibrant = [...withLum].sort((a, b) => saturation(b.color) - saturation(a.color)); // dull → vibrant

    const darkest = sorted[0].color;
    const lightest = sorted[sorted.length - 1].color;
    const mostVibrant = vibrant[vibrant.length - 1].color;
    const secondVibrant = vibrant.length > 1 ? vibrant[vibrant.length - 2].color : mostVibrant;
    const thirdVibrant = vibrant.length > 2 ? vibrant[vibrant.length - 3].color : mostVibrant;

    const surfaceColor = lightenColor(darkest, 0.06);
    const textColor = isDark(lightest) ? '#ffffff' : lightest;
    const mutedColor = lightenColor(darkest, 0.45);

    return {
      '--color-primary': mostVibrant,
      '--color-secondary': secondVibrant,
      '--color-accent': thirdVibrant,
      '--color-bg': darkest,
      '--color-surface': surfaceColor,
      '--color-text': textColor,
      '--color-text-muted': mutedColor,
      '--color-border': hexToRgba(mostVibrant, 0.18),
      // Keep defaults for non-color vars
      '--font-heading': "'Inter', system-ui, sans-serif",
      '--font-body': "'Inter', system-ui, sans-serif",
      '--font-mono': "'JetBrains Mono', monospace",
      '--text-base': 'clamp(1rem, 0.9rem + 0.5vw, 1.125rem)',
      '--text-lg': 'calc(var(--text-base) * 1.25)',
      '--text-xl': 'calc(var(--text-lg) * 1.25)',
      '--text-2xl': 'calc(var(--text-xl) * 1.25)',
      '--text-sm': 'calc(var(--text-base) / 1.25)',
      '--space-unit': '0.25rem',
      '--space-1': '0.25rem', '--space-2': '0.5rem', '--space-3': '0.75rem',
      '--space-4': '1rem', '--space-6': '1.5rem', '--space-8': '2rem', '--space-12': '3rem',
      '--radii': '0.75rem',
      '--content-max': '72rem',
      '--shadow-sm': '0 1px 2px rgba(0,0,0,0.08)',
      '--shadow-md': '0 4px 12px rgba(0,0,0,0.12)',
      '--shadow-lg': '0 12px 32px rgba(0,0,0,0.18)',
      '--glass-bg': 'color-mix(in srgb, var(--color-bg) 85%, transparent)',
      '--glass-blur': 'blur(16px)',
      '--noise-opacity': '0',
      '--ambient-1': hexToRgba(mostVibrant, 0.15),
      '--ambient-2': hexToRgba(secondVibrant, 0.1),
    };
  }

  // Apply palette as theme
  document.getElementById('btn-apply-palette').addEventListener('click', () => {
    if (extractedColors.length < 5) {
      window.__toast?.('需要至少 5 种颜色，请尝试色彩更丰富的图片');
      return;
    }
    const vars = generateThemeFromColors(extractedColors);
    currentVars = vars;
    applyVars(vars);
    varsEditor.value = JSON.stringify(vars, null, 2);
    cssEditor.value = '';
    applyCustomCSS('');
    removeExtensions();
    markEdited();
    hasEdits = true;
    updateEditUI();
    window.__toast?.('调色板已应用，可在 CSS 变量面板微调');
    // Switch to preview tab
    document.getElementById('tab-preview').click();
  });

  // Copy AI prompt with palette description
  document.getElementById('btn-copy-palette-ai').addEventListener('click', async () => {
    if (extractedColors.length < 5) {
      window.__toast?.('提取的颜色不足，请尝试色彩更丰富的图片');
      return;

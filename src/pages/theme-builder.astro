  // ═══════════════════════════════════════════════════════
  // 18. Color utility functions
  // ═══════════════════════════════════════════════════════
  function rgbToHex(r:number,g:number,b:number):string{return '#'+[r,g,b].map(n=>Math.max(0,Math.min(255,n)).toString(16).padStart(2,'0')).join('');}
  function hexToRgb(hex:string):[number,number,number]{const c=hex.replace('#','');return[parseInt(c.slice(0,2),16),parseInt(c.slice(2,4),16),parseInt(c.slice(4,6),16)];}
  function hexToRgba(hex:string,alpha:number):string{const[r,g,b]=hexToRgb(hex);return `rgba(${r},${g},${b},${alpha})`;}
  function relativeLuminance(hex:string):number{const[r,g,b]=hexToRgb(hex).map(c=>{const s=c/255;return s<=0.03928?s/12.92:Math.pow((s+0.055)/1.055,2.4);});return 0.2126*r+0.7152*g+0.0722*b;}
  function saturation(hex:string):number{const[r,g,b]=hexToRgb(hex).map(c=>c/255);const max=Math.max(r,g,b),min=Math.min(r,g,b);return max===0?0:(max-min)/max;}
  function isDark(hex:string):boolean{return relativeLuminance(hex)<0.3;}
  function lightenColor(hex:string,amount:number):string{const[r,g,b]=hexToRgb(hex);const f=(c:number)=>Math.min(255,Math.max(0,Math.round(c+amount*255)));return rgbToHex(f(r),f(g),f(b));}
  function getContrastRatio(fg:string,bg:string):number{const l1=relativeLuminance(fg),l2=relativeLuminance(bg);return (Math.max(l1,l2)+0.05)/(Math.min(l1,l2)+0.05);}
  function parseColorToHex(v:string):string{if(!v)return '#000000';if(/^#[0-9a-fA-F]{6}$/.test(v))return v;if(/^#[0-9a-fA-F]{3}$/.test(v))return '#'+v[1]+v[1]+v[2]+v[2]+v[3]+v[3];const m=v.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);if(m)return rgbToHex(+m[1],+m[2],+m[3]);return'#000000';}
  function escHtml(s:string):string{return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

  // ═══════════════════════════════════════════════════════
  // 19. Init
  // ═══════════════════════════════════════════════════════
  (function init() {
    currentVars = __INITIAL.cssVars;
    originalVars = { ...__INITIAL.cssVars };
    originalCustomCSS = __INITIAL.customCss || '';
    originalExtensions = __INITIAL.extensions || [];
    if (originalExtensions.length > 0) injectExtensions(originalExtensions);

    updateAllPreviews();
    pushHistory();

    if (new URLSearchParams(location.search).get('diy') === '1') {
      const dv = sessionStorage.getItem('td-diy-vars');
      const dc = sessionStorage.getItem('td-diy-css');
      const dn = sessionStorage.getItem('td-diy-name');
      if (dv) { try { const v=JSON.parse(dv); applyVars(v); currentVars=v; if(dc)applyCustomCSS(dc); varsEditor.value=JSON.stringify(v,null,2); cssEditor.value=dc||''; markEdited(); if(dn)diyHint.textContent='已加载: '+dn; updateAllPreviews(); } catch{/* */} }
    }

    setInterval(() => {
      const cs=getComputedStyle(document.documentElement);
      ['font-heading-preview','font-body-preview','font-mono-preview'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.fontFamily=cs.getPropertyValue('--'+id.replace('-preview','')).trim()||el.style.fontFamily;});
    }, 2000);

    const activeEl = themeList.querySelector('.theme-item[data-active="1"]');
    if (activeEl) activeEl.scrollIntoView({ block: 'center', behavior: 'smooth' });
  })();
</script>

</style>

<script>
  // ══════════════════════════════════════════════════
  // 1. Hero Canvas — Floating particles
  // ══════════════════════════════════════════════════
  (function() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const primary = '{primary}';
    const secondary = '{secondary}';
    const accent = '{accent}';

    function hexToRgb(h: string): [number, number, number] {
      const c = h.replace('#', '');
      return [parseInt(c.slice(0,2),16), parseInt(c.slice(2,4),16), parseInt(c.slice(4,6),16)];
    }

    const colors = [primary, secondary, accent].map(hexToRgb);
    const particles: Array<{x:number;y:number;vx:number;vy:number;r:number;o:number;c:[number,number,number];life:number;maxLife:number}> = [];

    function resize() {
      const wrap = canvas!.parentElement;
      if (!wrap) return;
      canvas!.width = wrap.offsetWidth;
      canvas!.height = wrap.offsetHeight;
    }

    function spawn() {
      if (particles.length > 50) return;
      const c = colors[Math.floor(Math.random() * colors.length)];
      particles.push({
        x: Math.random() * canvas!.width,
        y: canvas!.height + 20,
        vx: (Math.random() - 0.5) * 0.6,
        vy: -(0.4 + Math.random() * 1.2),
        r: 2 + Math.random() * 4,
        o: 0,
        c,
        life: 0,
        maxLife: 120 + Math.random() * 200,
      });
    }

    function draw() {
      ctx!.clearRect(0, 0, canvas!.width, canvas!.height);
      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.life++;

        const progress = p.life / p.maxLife;
        p.o = progress < 0.1 ? progress / 0.1 : progress > 0.7 ? (1 - progress) / 0.3 : 1;

        if (p.life > p.maxLife || p.y < -40) {
          particles.splice(i, 1);
          continue;
        }

        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${p.c[0]},${p.c[1]},${p.c[2]},${(p.o * 0.5).toFixed(2)})`;
        ctx!.fill();
      }

      if (Math.random() < 0.3) spawn();
      requestAnimationFrame(draw);
    }

    resize();
    window.addEventListener('resize', resize);
    for (let i = 0; i < 15; i++) spawn();
    draw();
  })();

  // ══════════════════════════════════════════════════
  // 2. 3D Card Tilt
  // ══════════════════════════════════════════════════
  (function() {
    const card = document.getElementById('hero-card');
    const wrap = card?.closest('.hero-wrap');
    if (!card || !wrap) return;

    wrap.addEventListener('mousemove', (e) => {
      const rect = wrap.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      card.style.transform = `rotateY(${x * 12}deg) rotateX(${-y * 8}deg) translateZ(0)`;
    });

    wrap.addEventListener('mouseleave', () => {
      card.style.transform = 'rotateY(0deg) rotateX(0deg) translateZ(0)';
    });
  })();

  // ══════════════════════════════════════════════════
  // 3. Stats Counter Animation
  // ══════════════════════════════════════════════════
  (function() {
    const statCards = document.querySelectorAll('.stat-value');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        const suffix = el.dataset.suffix || '';
        const duration = 1600;
        const start = performance.now();

        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(target * eased);
          el.textContent = current + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    statCards.forEach(el => observer.observe(el));
  })();

  // ══════════════════════════════════════════════════
  // 4. Theme Showcase Preview
  // ══════════════════════════════════════════════════
  (function() {
    const cards = document.querySelectorAll('.showcase-card');
    const indicator = document.getElementById('preview-indicator')!;
    const previewName = document.getElementById('preview-name')!;
    const resetBtn = document.getElementById('preview-reset')!;
    let originalVars: Record<string, string> = {};
    const root = document.documentElement;

    // Snapshot original vars
    const varNames = ['--color-primary','--color-secondary','--color-accent','--color-bg','--color-surface','--color-text','--color-text-muted','--color-border'];
    varNames.forEach(v => { originalVars[v] = getComputedStyle(root).getPropertyValue(v).trim(); });

    function applyVars(vars: Record<string, string>) {
      Object.entries(vars).forEach(([k, v]) => root.style.setProperty(k, v));
    }

    function resetVars() {
      applyVars(originalVars);
      indicator.style.display = 'none';
      cards.forEach(c => c.classList.remove('active'));
    }

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const vars = JSON.parse(card.getAttribute('data-vars') || '{}');
        const name = card.getAttribute('data-name') || '';
        applyVars(vars);
        previewName.textContent = name;
        indicator.style.display = 'block';
        cards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
    });

    resetBtn.addEventListener('click', resetVars);
  })();

  // ══════════════════════════════════════════════════
  // 5. Code Tab Switcher
  // ══════════════════════════════════════════════════
  (function() {
    const tabs = document.querySelectorAll('.code-tab');
    const panels = document.querySelectorAll('.code-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const idx = tab.getAttribute('data-tab')!;
        tabs.forEach(t => t.setAttribute('aria-selected', 'false'));
        tab.setAttribute('aria-selected', 'true');
        panels.forEach(p => {
          (p as HTMLElement).style.display = p.getAttribute('data-panel') === idx ? '' : 'none';
        });
      });
    });
  })();

  // ══════════════════════════════════════════════════
  // 6. Scroll Reveal
  // ══════════════════════════════════════════════════
  (function() {
    const reveals = document.querySelectorAll('.reveal-scroll');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    reveals.forEach(el => observer.observe(el));
  })();
</script>

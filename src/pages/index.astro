<style>
/* ============================================
   HERO
   ============================================ */
.hp-hero {
  position: relative;
  text-align: center;
  padding: 64px 24px 80px;
  overflow: hidden;
}

/* ambient orbs */
.hp-hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
.hp-orb {
  position: absolute; border-radius: 50%;
  filter: blur(80px); opacity: 0.28;
  animation: hpOrbFloat 8s ease-in-out infinite;
}
.hp-orb--1 {
  width: 420px; height: 420px;
  background: color-mix(in srgb, var(--color-primary) 50%, transparent);
  top: -120px; right: -80px;
  animation-delay: 0s;
}
.hp-orb--2 {
  width: 300px; height: 300px;
  background: color-mix(in srgb, var(--color-secondary) 45%, transparent);
  bottom: -60px; left: -60px;
  animation-delay: -3s;
}
.hp-orb--3 {
  width: 200px; height: 200px;
  background: color-mix(in srgb, var(--color-accent) 40%, transparent);
  top: 40%; left: 50%;
  animation-delay: -5.5s;
}
@keyframes hpOrbFloat {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33%      { transform: translate(30px, -20px) scale(1.08); }
  66%      { transform: translate(-20px, 15px) scale(0.94); }
}

/* pill */
.hp-pill {
  position: relative; z-index: 1;
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 22px; border-radius: 99px; margin-bottom: 32px;
  background: color-mix(in srgb, var(--color-primary) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--color-primary) 22%, var(--color-border));
  font-size: 13px; font-weight: 600; color: var(--color-primary); letter-spacing: 0.02em;
}
.hp-pill-dot {
  width: 7px; height: 7px; border-radius: 50%; background: var(--color-primary);
  box-shadow: 0 0 8px color-mix(in srgb, var(--color-primary) 60%, transparent);
  animation: hpPillPulse 2.5s ease-in-out infinite;
}
@keyframes hpPillPulse {
  0%, 100% { opacity: 0.5; transform: scale(0.8); }
  50%      { opacity: 1;   transform: scale(1.1); }
}
.hp-pill-divider { opacity: 0.4; }
.hp-pill-date { opacity: 0.7; font-weight: 500; }

/* headline */
.hp-headline {
  position: relative; z-index: 1;
  max-width: 780px; margin: 0 auto;
  font-size: clamp(2.6rem, 7vw, 4.4rem);
  font-weight: 800; letter-spacing: -0.04em; line-height: 1.1;
}
.hp-gradient {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 50%, var(--color-secondary) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  background-size: 200% 200%;
  animation: hpGradShift 6s ease-in-out infinite;
}
@keyframes hpGradShift {
  0%, 100% { background-position: 0% 50%; }
  50%      { background-position: 100% 50%; }
}

/* sub */
.hp-sub {
  position: relative; z-index: 1;
  max-width: 580px; margin: 24px auto 0;
  font-size: 1.1rem; line-height: 1.7; color: var(--color-text-muted);
}
.hp-sub strong { color: var(--color-text); font-weight: 700; }

/* actions */
.hp-actions {
  position: relative; z-index: 1;
  margin-top: 36px;
  display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
}

/* buttons */
.hp-btn {
  display: inline-flex; align-items: center; gap: 8px;
  height: 50px; padding: 0 28px; border-radius: 14px;
  font-size: 15px; font-weight: 600; letter-spacing: -0.01em;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1.2);
  cursor: pointer; border: none; font-family: inherit;
}
.hp-btn--primary {
  background: var(--color-primary);
  color: #fff;
  box-shadow: 0 4px 20px color-mix(in srgb, var(--color-primary) 40%, transparent);
}
.hp-btn--primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px color-mix(in srgb, var(--color-primary) 55%, transparent);
}
.hp-btn--primary:active { transform: translateY(0) scale(0.97); }
.hp-btn--ghost {
  background: color-mix(in srgb, var(--color-primary) 8%, transparent);

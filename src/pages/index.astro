---
import Layout from '../layouts/Layout.astro';
import { getDailyTheme, getAllThemes } from '../utils/daily-theme';
import { getDailyCommunityTheme } from '../utils/omni-bridge';

const communityDaily = await getDailyCommunityTheme();
const today = communityDaily || getDailyTheme();
const allThemes = getAllThemes();

const primary = today.cssVars['--color-primary'];
const secondary = today.cssVars['--color-secondary'];
const accent = today.cssVars['--color-accent'];
const siteUrl = Astro.url.origin;

const injectCode = `// ThemeDist — 生产级主题接入（推荐）
// 当日缓存 localStorage，跨日自动刷新，网络故障降级

(async () => {
  const KEY = 'td_theme';
  const today = new Date().toISOString().slice(0, 10);

  // ① 命中当日缓存 → 直接应用（零网络开销）
  const cached = JSON.parse(localStorage.getItem(KEY) || 'null');
  if (cached?.date === today) return applyTheme(cached);

  // ② 请求今日主题
  try {
    const res = await fetch('${siteUrl}/api/today.json');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const t = await res.json();
    const data = { date: t.date, cssVars: t.cssVars, customCss: t.customCss, extensions: t.extensions };
    localStorage.setItem(KEY, JSON.stringify(data));
    applyTheme(data);
  } catch (err) {
    // ③ 网络故障 → 降级使用过期缓存
    console.warn('ThemeDist: fetch failed, using stale cache', err.message);
    const fallback = JSON.parse(localStorage.getItem(KEY) || 'null');
    if (fallback) applyTheme(fallback);
  }
})();

function applyTheme(d) {
  // 注入 34 个 CSS 变量到 :root
  Object.entries(d.cssVars).forEach(([k, v]) =>
    document.documentElement.style.setProperty(k, v)
  );

  // 注入主题专属 CSS（keyframes 动画、节日特效样式）
  if (d.customCss) {
    const s = document.createElement('style');
    s.setAttribute('data-themedist', '');
    s.textContent = d.customCss;
    document.head.appendChild(s);
  }

  // 渲染浮动装饰元素（emoji、节日粒子）
  if (d.extensions) {
    d.extensions.forEach(ext => {
      if (ext.type !== 'floating') return;
      const el = document.createElement('div');
      el.style.cssText = [
        'position:fixed', 'pointer-events:none',
        ext.top && 'top:' + ext.top, ext.left && 'left:' + ext.left,
        ext.right && 'right:' + ext.right, ext.bottom && 'bottom:' + ext.bottom,
        ext.fontSize && 'font-size:' + ext.fontSize,
        ext.animation && 'animation:' + ext.animation,
        ext.zIndex != null && 'z-index:' + ext.zIndex,
        ext.opacity != null && 'opacity:' + ext.opacity,
      ].filter(Boolean).join(';');
      el.textContent = ext.char;
      document.body.appendChild(el);
    });
  }
}`;

const cssCode = `/* ==========================================
   ThemeDist CSS 变量速查（5 大类 34 个变量）
   变量由 JS 注入到 :root，直接 var() 引用即可
   ========================================== */

/* ① 色板 Colors ————————————————————— */
body {
  background: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-body), system-ui, sans-serif;
}
h1, h2, h3 { color: var(--color-primary); }
a          { color: var(--color-secondary); }
code       { font-family: var(--font-mono), monospace; }

/* ② 字号 Typography ————————————————— */
h1   { font-size: var(--text-2xl); }
h2   { font-size: var(--text-xl); }
.lead    { font-size: var(--text-lg); }
.muted   { color: var(--color-text-muted); font-size: var(--text-sm); }

/* ③ 间距 & 圆角 Spacing ———————————— */
.card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radii);
  padding: var(--space-6);
  margin-bottom: var(--space-8);
  max-width: var(--content-max);
}
.btn {
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radii);
}

/* ④ 阴影 & 毛玻璃 Effects —————————— */
.card-sm { box-shadow: var(--shadow-sm); }
.card-md { box-shadow: var(--shadow-md); }
.card-lg { box-shadow: var(--shadow-lg); }
.glass {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur));
}

/* ⑤ 氛围光球 Ambient —————————————— */
.hero-glow::before {
  content: '';
  position: absolute;
  background: radial-gradient(circle, var(--ambient-1), transparent);
}`;

const linkCode = `<!-- 零 FOUC 方案：阻塞引入 CSS，确保首帧变量就绪 -->
<link rel="stylesheet" href="${siteUrl}/api/today.css">

<!-- 异步获取 JSON，用于 customCss 和浮动装饰 -->
<script>
fetch('${siteUrl}/api/today.json')
  .then(r => r.json())
  .then(t => {
    // 注入主题专属 CSS
    if (t.customCss) {
      const s = document.createElement('style');
      s.textContent = t.customCss;
      document.head.appendChild(s);
    }
    // 渲染浮动装饰
    if (t.extensions) {
      t.extensions.forEach(ext => {
        if (ext.type !== 'floating') return;
        const el = document.createElement('div');
        el.style.cssText = [
          'position:fixed','pointer-events:none',
          ext.top && 'top:'+ext.top,
          ext.left && 'left:'+ext.left,
          ext.animation && 'animation:'+ext.animation,
        ].filter(Boolean).join(';');
        el.textContent = ext.char;
        document.body.appendChild(el);
      });
    }
  });
<\/script>`;

.hp-card:hover .hp-card-bar__seg:nth-child(3) { flex: 1.2 !important; }

.hp-card-body {
  padding: 38px 44px;
  display: flex; align-items: center; gap: 36px; flex-wrap: wrap; justify-content: center;
}
.hp-card-swatches {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; flex-shrink: 0;
}
.hp-swatch {

    } catch { toast('复制失败，请手动选择'); }
  });

  // ── Submit to community ──
  document.getElementById('tp-submit').addEventListener('click', async () => {
    if (!currentTheme) return;
    const author = document.getElementById('tp-author').value.trim();
    if (!author) { toast('请填写你的昵称'); return; }

    const btn = document.getElementById('tp-submit');
    btn.disabled = true; btn.style.opacity = '0.6';

    const tagsRaw = document.getElementById('tp-tags').value.trim();
    const tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim()).filter(Boolean).slice(0, 5) : undefined;

    try {
      const res = await fetch('/api/v1/diy/submit.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: currentTheme.presetName || '未命名主题',
          author,
          cssVars: currentTheme.cssVars,
          customCss: currentTheme.customCss || undefined,
          extensions: currentTheme.extensions || undefined,
          clickEffect: currentTheme.clickEffect || undefined,
          tags,
        }),
      });

      const data = await res.json();
      const result = document.getElementById('tp-submit-result');

      if (res.ok && data.theme) {
        const shareUrl = `${location.origin}/share?id=${data.theme.id}`;
        result.className = 'tp-submit-result success';
        result.innerHTML = `
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#22c55e" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="#22c55e" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <strong style="color:#22c55e">提交成功！即将跳转到分享页…</strong>
          </div>
          ${data.warnings && data.warnings.length ? `<div style="margin-top:6px;color:var(--color-text-muted);font-size:12px">${data.warnings.map(w => '⚠ ' + w).join('<br>')}</div>` : ''}
        `;
        result.style.display = 'block';
        setTimeout(() => { location.href = shareUrl; }, 1800);
      } else {
        result.className = 'tp-submit-result error';
        result.innerHTML = `<strong>提交失败：</strong>${data.error || '未知错误'}`;
        result.style.display = 'block';
      }
    } catch (err) {
      const result = document.getElementById('tp-submit-result');
      result.className = 'tp-submit-result error';
      result.innerHTML = `<strong>网络错误：</strong>${err.message}`;
      result.style.display = 'block';
    } finally {
      btn.disabled = false; btn.style.opacity = '1';
    }
  });

  // ── Toast ──
  function toast(msg) {
    const el = document.getElementById('toast') || (() => {
      const d = document.createElement('div'); d.id = 'toast';
      d.style.cssText = 'position:fixed;bottom:32px;left:50%;transform:translateX(-50%);z-index:300;padding:10px 22px;border-radius:10px;font-size:13px;font-weight:600;background:var(--color-surface);border:1px solid var(--color-primary);color:var(--color-text);box-shadow:0 8px 30px rgba(0,0,0,0.2);opacity:0;pointer-events:none;transition:opacity 0.3s;';
      document.body.appendChild(d); return d;
    })();
    el.textContent = msg; el.style.opacity = '1';
    clearTimeout(el._timer);
    el._timer = setTimeout(() => { el.style.opacity = '0'; }, 1800);
  }

  // ── Drag & drop JSON file ──
  const editorCard = document.querySelector('.tp-editor-card');
  let dragCounter = 0;

  function highlightDropZone(on) {
    if (on) {
      editorCard.classList.add('drag-over');
    } else {
      editorCard.classList.remove('drag-over');
    }
  }

  editorCard.addEventListener('dragenter', (e) => {
    e.preventDefault(); dragCounter++;
    if (dragCounter === 1) highlightDropZone(true);
  });
  editorCard.addEventListener('dragleave', () => {
    dragCounter--;
    if (dragCounter === 0) highlightDropZone(false);
  });
  editorCard.addEventListener('dragover', (e) => { e.preventDefault(); });
  editorCard.addEventListener('drop', (e) => {
    e.preventDefault();
    dragCounter = 0;
    highlightDropZone(false);
    const file = e.dataTransfer.files[0];
    if (!file) return;
    if (!file.name.endsWith('.json') && file.type !== 'application/json') {
      toast('请拖入 .json 文件');
      return;
    }
    const reader = new FileReader();
    reader.onload = () => {
      input.value = reader.result;
      input.dispatchEvent(new Event('input'));
      toast('文件已加载');
    };
    reader.onerror = () => toast('文件读取失败');
    reader.readAsText(file);
  });

  // ── Improved JSON error with position ──
  const origShowErrors = showErrors;
  showErrors = function(errs) {
    let html = errs.map(e => `• ${e}`).join('<br>');
    // If there's raw JSON and parse failed, try to show position
    const raw = input.value.trim();
    if (raw && errs.length === 1 && errs[0].startsWith('JSON 解析失败')) {
      try {
        JSON.parse(raw);
      } catch (e) {
        if (e.message) {
          const m = e.message.match(/position\s+(\d+)/i);
          if (m) {
            const pos = parseInt(m[1]);
            const before = raw.substring(Math.max(0, pos - 40), pos);
            const at = raw.substring(pos, pos + 30);
            html += `<br><br><span style="opacity:0.7">…${before}<mark style="background:rgba(239,68,68,0.3);color:inherit">${at}</mark>…</span>`;
          }
        }
      }
    }
    errors.innerHTML = html;
    errors.style.display = 'block';
  };

  // ── Keyboard shortcuts ──
  document.addEventListener('keydown', (e) => {
    if (document.activeElement !== input) return;
    // Ctrl+Enter → apply
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter' && currentTheme) {
      e.preventDefault();
      document.getElementById('tp-apply').click();
    }
    // Ctrl+Shift+F → format
    if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'F') {
      e.preventDefault();
      document.getElementById('tp-format').click();
    }
  });
</script>

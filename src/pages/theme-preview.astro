  // ── Screenshot: theme style tile → direct PNG download ──
  function parseHex(hex) {
    var c = String(hex || '#888').replace('#','');
    if (c.length < 6) return [128,128,128];
    return [parseInt(c.slice(0,2),16), parseInt(c.slice(2,4),16), parseInt(c.slice(4,6),16)];
  }
  function rgbA(hex, a) { var r = parseHex(hex); return 'rgba(' + r[0] + ',' + r[1] + ',' + r[2] + ',' + a + ')'; }
  function lighten(hex, amt) { var r = parseHex(hex); return 'rgba(' + Math.min(255,r[0]+amt) + ',' + Math.min(255,r[1]+amt) + ',' + Math.min(255,r[2]+amt) + ',1)'; }
  function darken(hex, amt) { var r = parseHex(hex); return 'rgba(' + Math.max(0,r[0]-amt) + ',' + Math.max(0,r[1]-amt) + ',' + Math.max(0,r[2]-amt) + ',1)'; }

  function hexToHsl(hex) {
    var r = parseHex(hex);
    var rf = r[0] / 255, gf = r[1] / 255, bf = r[2] / 255;
    var max = Math.max(rf, gf, bf), min = Math.min(rf, gf, bf);
    var h = 0, s = 0, l = (max + min) / 2;
    if (max !== min) {
      var d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch (max) {
        case rf: h = ((gf - bf) / d + (gf < bf ? 6 : 0)) / 6; break;
        case gf: h = ((bf - rf) / d + 2) / 6; break;
        case bf: h = ((rf - gf) / d + 4) / 6; break;
      }
    }
    return { h: h * 360, s: s, l: l };
  }

  function crt(ctx, x, y, w, h, r) {
    r = Math.min(r, w/2, h/2);
    ctx.beginPath();
    ctx.moveTo(x + r, y); ctx.lineTo(x + w - r, y);
    ctx.quadraticCurveTo(x + w, y, x + w, y + r);
    ctx.lineTo(x + w, y + h - r); ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    ctx.lineTo(x + r, y + h); ctx.quadraticCurveTo(x, y + h, x, y + h - r);
    ctx.lineTo(x, y + r); ctx.quadraticCurveTo(x, y, x + r, y);
    ctx.closePath();
  }

  function generateScreenshot(theme) {
    var canvas = document.getElementById('tp-screenshot-canvas');
    var W = canvas.width = 800;
    var H = canvas.height = 500;
    var ctx = canvas.getContext('2d');
    if (!ctx) throw new Error('Canvas 2D context unavailable');
    var V = theme.cssVars || {};

    var pri    = V['--color-primary']    || '#6366f1';
    var sec    = V['--color-secondary']  || '#818cf8';
    var accent = V['--color-accent']     || sec;
    var bg     = V['--color-bg']         || '#0f0f23';
    var surf   = V['--color-surface']    || '#1a1a2e';
    var txt    = V['--color-text']       || '#f4f4f5';
    var muted  = V['--color-text-muted'] || '#a1a1aa';
    var border = V['--color-border']     || rgbA(txt, 0.12);
    var name   = theme.presetName || 'Untitled Theme';
    var css    = theme.customCss || '';
    var isDark = (function() {
      var c = bg.replace('#',''); if (c.length < 6) return true;
      var r = parseInt(c.slice(0,2),16)/255, g = parseInt(c.slice(2,4),16)/255, b = parseInt(c.slice(4,6),16)/255;
      return (0.2126*r + 0.7152*g + 0.0722*b) < 0.5;
    })();

    // ── Background ──
    var bgG = ctx.createLinearGradient(0, 0, W, H);
    bgG.addColorStop(0, bg);
    bgG.addColorStop(1, surf);
    ctx.fillStyle = bgG;
    ctx.fillRect(0, 0, W, H);

    // ── Ambient orbs ──
    ctx.save();
    var o1 = ctx.createRadialGradient(W*0.7, 60, 30, W*0.7, 60, 300);
    o1.addColorStop(0, rgbA(pri, 0.12)); o1.addColorStop(1, 'transparent');
    ctx.fillStyle = o1; ctx.fillRect(0, 0, W, H);
    ctx.restore();
    ctx.save();
    var o2 = ctx.createRadialGradient(W*0.25, H*0.75, 20, W*0.25, H*0.75, 280);
    o2.addColorStop(0, rgbA(sec, 0.08)); o2.addColorStop(1, 'transparent');
    ctx.fillStyle = o2; ctx.fillRect(0, 0, W, H);
    ctx.restore();

    // ── Subtle grid pattern ──
    ctx.save();
    ctx.globalAlpha = 0.03;
    ctx.strokeStyle = txt;
    ctx.lineWidth = 0.5;
    for (var gx = 0; gx < W; gx += 40) { ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke(); }
    for (var gy = 0; gy < H; gy += 40) { ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke(); }
    ctx.restore();

    // ═══════════════════════════════════════
    // PARTICLES: parse extensions & customCss, render sakura petals, stardust, glow, vignette
    // ═══════════════════════════════════════

    // Helper: draw a sakura petal shape (teardrop pointing upper-right, matches border-radius:50% 0 50% 50%)
    function drawSakuraPetal(ctx, x, y, size, angle, petalPri, petalSec, opacity, blurPx, glowPx) {
      ctx.save();
      ctx.globalAlpha = Math.min(1, Math.max(0, opacity));
      ctx.translate(x, y);
      ctx.rotate(angle);
      var s = size;
      var r = s / 2;
      // Path matching CSS border-radius: 50% 0 50% 50%
      ctx.beginPath();
      ctx.moveTo(s, 0);                // sharp top-right
      ctx.lineTo(s, s - r);            // right edge down
      ctx.arcTo(s, s, s - r, s, r);    // bottom-right curve
      ctx.arcTo(0, s, 0, s - r, r);    // bottom-left curve
      ctx.arcTo(0, 0, r, 0, r);        // top-left curve
      ctx.closePath();
      // Gradient: white highlight → light pink → deeper pink
      var petalGrad = ctx.createLinearGradient(0, 0, s, s * 0.7);
      petalGrad.addColorStop(0, 'rgba(255,255,255,0.95)');
      petalGrad.addColorStop(0.25, petalSec);
      petalGrad.addColorStop(1, petalPri);
      ctx.fillStyle = petalGrad;
      if (blurPx > 0) { ctx.shadowBlur = blurPx; ctx.shadowColor = rgbA(petalPri, 0.35); }
      if (glowPx > 0) { ctx.shadowBlur = glowPx; ctx.shadowColor = rgbA(petalPri, 0.7); }
      ctx.fill();
      // Inner highlight speck
      ctx.shadowBlur = 0;
      ctx.fillStyle = 'rgba(255,255,255,0.35)';
      ctx.beginPath();
      ctx.arc(r * 0.5, r * 0.5, r * 0.25, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    // Parse decorative extension HTML to extract particle elements
    var petalDefs = [];   // {leftPct, size, opacity, layer: 'bg'|'mid'|'fg'}
    var dustDefs = [];    // {leftPct, topPct, opacity}
    var glowDefs = [];    // {topPct, leftPct, rightPct, color}

    try {
      var allHtml = '';
      exts.forEach(function(ext) {
        if (ext.type === 'decorative' && ext.html) allHtml += ext.html;
      });
      if (allHtml) {
        var parser = new DOMParser();
        var doc = parser.parseFromString('<div>' + allHtml + '</div>', 'text/html');
        var root = doc.body;

        // Extract petals
        var petalEls = root.querySelectorAll('.omni-petal');
        petalEls.forEach(function(el) {
          var style = el.getAttribute('style') || '';
          var leftMatch = style.match(/left:\s*([\d.]+)%/);
          var sMatch = style.match(/--s:\s*([\d.]+)/);
          var oMatch = style.match(/--o:\s*([\d.]+)/);
          var isBg = el.classList.contains('bg-blur');
          var isFg = el.classList.contains('fg-sharp');
          petalDefs.push({
            leftPct: leftMatch ? parseFloat(leftMatch[1]) : Math.random() * 90 + 5,
            size: sMatch ? parseFloat(sMatch[1]) : 1,
            opacity: oMatch ? parseFloat(oMatch[1]) : 0.8,
            layer: isBg ? 'bg' : (isFg ? 'fg' : 'mid')
          });
        });

        // Extract stardust
        var dustEls = root.querySelectorAll('.omni-stardust');
        dustEls.forEach(function(el) {
          var style = el.getAttribute('style') || '';
          var leftMatch = style.match(/left:\s*([\d.]+)%/);
          var topMatch = style.match(/top:\s*([\d.]+)%/);
          var oMatch = style.match(/--o:\s*([\d.]+)/);
          dustDefs.push({
            leftPct: leftMatch ? parseFloat(leftMatch[1]) : 50,
            topPct: topMatch ? parseFloat(topMatch[1]) : 50,
            opacity: oMatch ? parseFloat(oMatch[1]) : 0.6
          });
        });

        // Extract glow orbs
        var glowEls = root.querySelectorAll('.yozakura-glow');
        glowEls.forEach(function(el) {
          var style = el.getAttribute('style') || '';
          var topMatch = style.match(/top:\s*([\d.]+)vh/);
          var leftMatch = style.match(/left:\s*([-\d.]+)vw/);
          var rightMatch = style.match(/right:\s*([-\d.]+)vw/);
          var bgMatch = style.match(/background:\s*([^;]+)/);
          glowDefs.push({
            topVh: topMatch ? parseFloat(topMatch[1]) : -20,
            leftVw: leftMatch ? parseFloat(leftMatch[1]) : null,
            rightVw: rightMatch ? parseFloat(rightMatch[1]) : null,
            bg: bgMatch ? bgMatch[1] : null
          });
        });
      }
    } catch(e) { /* fall back to defaults if parsing fails */ }

    // If no elements found from parsing, create defaults based on CSS analysis
    if (petalDefs.length === 0 && /petal|sakura/.test(css)) {
      for (var pi = 0; pi < 12; pi++) {
        var layer = pi < 4 ? 'bg' : (pi < 9 ? 'mid' : 'fg');
        petalDefs.push({
          leftPct: Math.random() * 85 + 5,
          size: layer === 'bg' ? Math.random() * 0.3 + 0.3 : (layer === 'fg' ? Math.random() * 0.5 + 1.4 : Math.random() * 0.4 + 0.6),
          opacity: layer === 'bg' ? Math.random() * 0.2 + 0.2 : (layer === 'fg' ? Math.random() * 0.1 + 0.85 : Math.random() * 0.2 + 0.6),
          layer: layer
        });
      }
    }
    if (dustDefs.length === 0 && /stardust|star|twinkle/.test(css)) {
      for (var di = 0; di < 6; di++) {
        dustDefs.push({ leftPct: Math.random() * 80 + 10, topPct: Math.random() * 70 + 15, opacity: Math.random() * 0.4 + 0.4 });
      }
    }
    if (glowDefs.length === 0 && /glow|moonlight/.test(css)) {
      glowDefs.push({ topVh: -20, leftVw: null, rightVw: -10, bg: null });
      glowDefs.push({ topVh: 50, leftVw: -20, rightVw: null, bg: null });
    }

    // ── Layer 0: yozakura glow orbs (behind everything) ──
    glowDefs.forEach(function(gd) {
      var gCx, gCy;
      if (gd.rightVw != null) gCx = W + (gd.rightVw / 100 * W);
      else if (gd.leftVw != null) gCx = (gd.leftVw / 100 * W);
      else gCx = W * 0.7;
      gCy = (gd.topVh / 100 * H);
      var gR = Math.max(W, H) * 0.45;
      var glowGrad = ctx.createRadialGradient(gCx, gCy, gR * 0.1, gCx, gCy, gR);
      glowGrad.addColorStop(0, rgbA(pri, 0.08));
      glowGrad.addColorStop(0.5, rgbA(sec, 0.04));
      glowGrad.addColorStop(1, 'transparent');
      ctx.save();
      ctx.fillStyle = glowGrad;
      ctx.fillRect(0, 0, W, H);
      ctx.restore();
    });

    // ── Layer 1: background blur petals (small, dim, subtle) ──
    petalDefs.filter(function(p) { return p.layer === 'bg'; }).forEach(function(pd) {
      var px = pd.leftPct / 100 * W;
      var py = Math.random() * H * 0.5 + H * 0.05; // upper half
      var sz = pd.size * 14;
      var ang = Math.random() * Math.PI * 2;
      drawSakuraPetal(ctx, px, py, sz, ang, pri, sec, pd.opacity * 0.5, sz * 0.5, 0);
    });

    // ── Layer 2: standard petals (midground) ──
    petalDefs.filter(function(p) { return p.layer === 'mid'; }).forEach(function(pd) {
      var px = pd.leftPct / 100 * W;
      var py = Math.random() * H * 0.55 + H * 0.1;
      var sz = pd.size * 16;
      var ang = Math.random() * Math.PI * 2;
      drawSakuraPetal(ctx, px, py, sz, ang, pri, sec, pd.opacity, 0, sz * 0.25);
    });

    // ── Layer 3: stardust dots ──
    dustDefs.forEach(function(dd) {
      var dx = dd.leftPct / 100 * W;
      var dy = dd.topPct / 100 * H;
      var dr = 2;
      var dOp = dd.opacity;
      ctx.save();
      ctx.globalAlpha = dOp;
      ctx.fillStyle = '#fff';
      ctx.shadowColor = pri;
      ctx.shadowBlur = 8;
      ctx.beginPath(); ctx.arc(dx, dy, dr, 0, Math.PI * 2); ctx.fill();
      // outer glow ring
      ctx.globalAlpha = dOp * 0.25;
      ctx.shadowBlur = 0;
      var dustGlow = ctx.createRadialGradient(dx, dy, dr * 0.5, dx, dy, dr * 4);
      dustGlow.addColorStop(0, pri);
      dustGlow.addColorStop(1, 'transparent');
      ctx.fillStyle = dustGlow;
      ctx.beginPath(); ctx.arc(dx, dy, dr * 4, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
    });

    // ── Layer 4: foreground sharp petals (large, bright, strong neon glow) ──
    petalDefs.filter(function(p) { return p.layer === 'fg'; }).forEach(function(pd) {
      var px = pd.leftPct / 100 * W;
      var py = Math.random() * H * 0.5 + H * 0.2;
      var sz = pd.size * 18;
      var ang = Math.random() * Math.PI * 2;
      drawSakuraPetal(ctx, px, py, sz, ang, pri, sec, pd.opacity, 0, sz * 0.8);
    });

    // ── Layer 5: cinematic vignette (dark edges → center transparent) ──
    var vignette = ctx.createRadialGradient(W/2, H/2, Math.min(W,H) * 0.35, W/2, H/2, Math.max(W,H) * 0.75);
    vignette.addColorStop(0, 'transparent');
    vignette.addColorStop(1, rgbA(bg, 0.55));
    ctx.save();
    ctx.fillStyle = vignette;
    ctx.fillRect(0, 0, W, H);
    ctx.restore();

    // ═══════════════════════════════════════
    // HEADER: Theme name + decorative bar
    // ═══════════════════════════════════════
    var headerY = 44;
    ctx.save();
    // Decorative gradient bar
    var barG = ctx.createLinearGradient(40, 0, 300, 0);
    barG.addColorStop(0, pri); barG.addColorStop(0.5, sec); barG.addColorStop(1, accent);
    ctx.fillStyle = barG;
    crt(ctx, 40, headerY - 26, 60, 4, 2); ctx.fill();
    // Theme name
    ctx.fillStyle = txt;
    ctx.font = 'bold 36px Inter, system-ui, sans-serif';
    ctx.fillText(name.slice(0, 40), 40, headerY + 16);
    // Preset ID
    ctx.fillStyle = muted;
    ctx.font = '13px Inter, system-ui, sans-serif';
    ctx.fillText((theme.preset || 'custom') + '  ·  ThemeDist', 44, headerY + 38);
    ctx.restore();

    // ═══════════════════════════════════════
    // COLOR SWATCHES — left side
    // ═══════════════════════════════════════
    var swatchAreaX = 40, swatchAreaY = 108;
    var swatchDefs = [
      {key: '--color-primary',   color: pri,    label: 'Primary'},
      {key: '--color-secondary', color: sec,    label: 'Secondary'},
      {key: '--color-accent',    color: accent, label: 'Accent'},
      {key: '--color-bg',        color: bg,     label: 'Background'},
      {key: '--color-surface',   color: surf,   label: 'Surface'},
      {key: '--color-text',      color: txt,    label: 'Text'},
    ];
    var swCols = 3, swRows = 2;
    var swW = 110, swH = 90, swGapX = 14, swGapY = 14;

    ctx.save();
    // Section label
    ctx.fillStyle = muted;
    ctx.font = '600 10px Inter, system-ui, sans-serif';
    ctx.fillText('COLOR PALETTE', swatchAreaX, swatchAreaY - 8);

    swatchDefs.forEach(function(sw, i) {
      var col = i % swCols, row = Math.floor(i / swCols);
      var sx = swatchAreaX + col * (swW + swGapX);
      var sy = swatchAreaY + row * (swH + swGapY);

      // Card bg
      ctx.fillStyle = rgbA(surf, 0.4);
      ctx.strokeStyle = rgbA(txt, 0.06); ctx.lineWidth = 1;
      crt(ctx, sx, sy, swW, swH, 12); ctx.fill(); ctx.stroke();

      // Color circle
      var cx = sx + swW/2, cy = sy + 30, cr = 22;
      // Shadow
      ctx.fillStyle = 'rgba(0,0,0,0.2)';
      ctx.beginPath(); ctx.arc(cx + 1, cy + 1, cr, 0, Math.PI*2); ctx.fill();
      // Color
      var swG = ctx.createRadialGradient(cx - cr*0.3, cy - cr*0.3, cr*0.1, cx, cy, cr);
      swG.addColorStop(0, lighten(sw.color, 30)); swG.addColorStop(1, sw.color);
      ctx.fillStyle = swG;
      ctx.beginPath(); ctx.arc(cx, cy, cr, 0, Math.PI*2); ctx.fill();
      // Ring
      ctx.strokeStyle = rgbA(txt, 0.12); ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.arc(cx, cy, cr, 0, Math.PI*2); ctx.stroke();

      // Label
      ctx.fillStyle = txt;
      ctx.font = '600 11px Inter, system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(sw.label, cx, sy + 68);
      // CSS var name
      ctx.fillStyle = muted;
      ctx.font = '9px JetBrains Mono, monospace';
      ctx.fillText(sw.key, cx, sy + 82);
      ctx.textAlign = 'start';
    });
    ctx.restore();

    // ═══════════════════════════════════════
    // TYPOGRAPHY + PREVIEW — right side
    // ═══════════════════════════════════════
    var typX = swatchAreaX + swCols * (swW + swGapX) + 20, typY = 108, typW = W - typX - 40;

    ctx.save();
    ctx.fillStyle = muted;
    ctx.font = '600 10px Inter, system-ui, sans-serif';
    ctx.fillText('TYPOGRAPHY', typX, typY - 8);

    // Card
    ctx.fillStyle = rgbA(surf, 0.5);
    ctx.strokeStyle = rgbA(txt, 0.06); ctx.lineWidth = 1;
    var cardH = 194;
    crt(ctx, typX, typY, typW, cardH, 12); ctx.fill(); ctx.stroke();

    // Gradient top bar on card
    var cardBarG = ctx.createLinearGradient(typX, 0, typX + typW, 0);
    cardBarG.addColorStop(0, pri); cardBarG.addColorStop(1, sec);
    ctx.fillStyle = cardBarG;
    ctx.fillRect(typX, typY, typW, 3);

    var tx = typX + 18;
    // Heading
    ctx.fillStyle = pri;
    ctx.font = 'bold 18px Inter, system-ui, sans-serif';
    ctx.fillText('Heading text for this theme', tx, typY + 36);
    // Body
    ctx.fillStyle = txt;
    ctx.font = '13px/1.6 Inter, system-ui, sans-serif';
    ctx.fillText('Body text flows naturally. The quick brown fox', tx, typY + 66);
    ctx.fillText('jumps over the lazy dog. A well-designed color', tx, typY + 86);
    ctx.fillText('system creates visual hierarchy and guides.', tx, typY + 106);
    // Muted
    ctx.fillStyle = muted;
    ctx.font = '12px Inter, system-ui, sans-serif';
    ctx.fillText('Secondary caption text  ·  Muted information', tx, typY + 136);
    // Link
    ctx.fillStyle = pri;
    ctx.font = '600 12px Inter, system-ui, sans-serif';
    ctx.fillText('Link text example →', tx, typY + 160);
    // Button mock
    var btnG = ctx.createLinearGradient(0, typY + 148, 0, typY + 180);
    btnG.addColorStop(0, pri); btnG.addColorStop(1, sec);
    ctx.fillStyle = btnG;
    crt(ctx, tx, typY + 148, 80, 28, 8); ctx.fill();
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 11px Inter, system-ui, sans-serif';
    ctx.fillText('Primary', tx + 18, typY + 167);
    ctx.restore();

    // ═══════════════════════════════════════
    // STATS BAR
    // ═══════════════════════════════════════
    var statY = swatchAreaY + swRows * (swH + swGapY) + 8;
    var statH = 52;

    ctx.save();
    ctx.fillStyle = rgbA(surf, 0.5);
    ctx.strokeStyle = rgbA(txt, 0.06); ctx.lineWidth = 1;
    crt(ctx, 40, statY, W - 80, statH, 12); ctx.fill(); ctx.stroke();

    var extsCount = Array.isArray(theme.extensions) ? theme.extensions.length : 0;
    var stats = [
      {label: 'CSS Variables', val: '48'},
      {label: 'Extensions', val: String(extsCount)},
      {label: 'Preset', val: theme.preset || 'custom'},
      {label: 'Dark Theme', val: isDark ? 'Yes' : 'No'},
    ];
    var stW = (W - 80 - 40) / 4;
    stats.forEach(function(s, i) {
      var sx = 56 + i * stW;
      ctx.fillStyle = txt;
      ctx.font = 'bold 16px Inter, system-ui, sans-serif';
      ctx.fillText(s.val, sx, statY + 24);
      ctx.fillStyle = muted;
      ctx.font = '10px Inter, system-ui, sans-serif';
      ctx.fillText(s.label, sx, statY + 40);
    });
    ctx.restore();

    // ═══════════════════════════════════════
    // FOOTER BRANDING
    // ═══════════════════════════════════════
    var footY = H - 36;
    ctx.save();
    ctx.fillStyle = muted;
    ctx.font = '11px Inter, system-ui, sans-serif';
    ctx.fillText('ThemeDist  ·  每日主题分发', 40, footY);
    ctx.fillStyle = pri;
    ctx.font = 'bold 11px Inter, system-ui, sans-serif';
    var fw = ctx.measureText('themedist.app').width;
    ctx.fillText('themedist.app', W - 40 - fw, footY);
    ctx.restore();

    return canvas;
  }


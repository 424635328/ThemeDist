---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="tp-section">
    <div class="tp-container">
      <!-- Compact header bar -->
      <div class="tp-topbar">
        <div class="tp-topbar-left">
          <span class="tp-topbar-title">主题预览</span>
          <span class="tp-topbar-sep">·</span>
          <span class="tp-topbar-desc">粘贴 JSON，即刻变装</span>
        </div>
        <div class="tp-topbar-right">
          <button class="tp-ghost-btn" id="tp-load-example" type="button" title="加载完整樱花示例">载入示例</button>
          <button class="tp-ghost-btn" id="tp-format" type="button" title="格式化 JSON (Ctrl+Shift+F)">格式化</button>
          <button class="tp-ghost-btn" id="tp-clear" type="button" title="清空并还原今日主题">清空</button>
        </div>
      </div>

      <!-- Two-column grid -->
      <div class="tp-grid">
        <!-- LEFT: Editor + Status -->
        <div class="tp-left">
          <div class="tp-editor-card">
            <div class="tp-editor-header">
              <span class="tp-editor-label">JSON 配置</span>
              <span id="tp-char-count" class="tp-char-count"></span>
            </div>
            <div class="tp-editor-wrap">
              <div id="tp-line-numbers" class="tp-line-numbers" aria-hidden="true">
                <div class="tp-line-numbers-inner"></div>
              </div>
              <textarea
                id="tp-json-input"
                class="tp-textarea"
                placeholder='粘贴完整主题 JSON …'
                spellcheck="false"
              ></textarea>
            </div>
            <div id="tp-errors" class="tp-errors" style="display:none"></div>
          </div>
          <div class="tp-status-bar">
            <span id="tp-status-badge" class="tp-status-badge idle">等待输入</span>
            <span id="tp-status-detail" class="tp-status-detail"></span>
          </div>
        </div>

        <!-- RIGHT: Showcase + Actions + Submit -->
        <div class="tp-right">
          <div id="tp-showcase" class="tp-showcase">
            <!-- Placeholder when no theme -->
            <div id="tp-showcase-empty" class="tp-showcase-empty">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <span>粘贴 JSON 以预览主题</span>
              <p>你也可以拖放 .json 文件到左侧编辑器</p>
            </div>
            <!-- Theme preview content -->
            <div id="tp-showcase-content" style="display:none">
              <div class="tp-showcase-header">
                <span class="tp-showcase-label">主题预览</span>
                <span class="tp-showcase-name" id="tp-showcase-name"></span>
              </div>
              <div class="tp-showcase-body">
                <div class="tp-showcase-colors" id="tp-showcase-swatches"></div>
                <div class="tp-showcase-panels">
                  <div class="tp-showcase-card">
                    <div class="tp-showcase-card-bar"></div>
                    <div class="tp-showcase-card-content">
                      <h4 class="tp-showcase-heading">标题文本 Heading</h4>
                      <p class="tp-showcase-body-text">正文段落展示 <strong>--color-text</strong> 与 <span class="tp-showcase-muted">--color-text-muted</span> 的对比，以及 <a href="#" onclick="return false" class="tp-showcase-link">--color-primary 链接</a> 的颜色。</p>
                      <div class="tp-showcase-buttons">
                        <span class="tp-showcase-btn-primary">Primary</span>
                        <span class="tp-showcase-btn-ghost">Ghost</span>
                      </div>
                    </div>
                  </div>
                  <div class="tp-showcase-meta">
                    <div class="tp-showcase-stat" id="tp-stat-vars">48 CSS 变量</div>
                    <div class="tp-showcase-stat" id="tp-stat-name">—</div>
                    <div class="tp-showcase-stat" id="tp-stat-exts">0 扩展</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Actions: grouped by intent -->
          <div class="tp-actions" id="tp-actions">
            <div class="tp-action-group">
              <button class="tp-btn tp-btn-primary" id="tp-apply" type="button" disabled>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                持久化到本站
              </button>
              <button class="tp-btn tp-btn-accent" id="tp-screenshot" type="button" disabled>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="3.5" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/><circle cx="8" cy="8.5" r="2.5" stroke="currentColor" stroke-width="1.4"/></svg>
                导出预览图
              </button>
            </div>
            <div class="tp-action-sep"></div>
            <div class="tp-action-group">
              <button class="tp-btn tp-btn-outline" id="tp-copy-json" type="button" disabled>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M2 12V4a2 2 0 012-2h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                复制 JSON
              </button>
              <button class="tp-btn tp-btn-outline" id="tp-copy-ai" type="button">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v8M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                复制给 AI
              </button>
            </div>
            <div class="tp-action-sep"></div>
            <div class="tp-action-group">
              <button class="tp-btn tp-btn-destructive" id="tp-restore" type="button" disabled>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0111.3-3.7M14 8a6 6 0 01-11.3 3.7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 4v4h4M14 12v-4h-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                还原
              </button>
            </div>
          </div>

          <!-- Submit (hidden until theme applied) -->
          <div class="tp-submit-section" id="tp-submit-section" style="display:none">
            <div class="tp-submit-card">
              <div class="tp-submit-header">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M8 1l2 5h5l-4 3 2 5-5-3-5 3 2-5-4-3h5l2-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                <span>提交到社区商店</span>
              </div>
              <div class="tp-submit-row">
                <input id="tp-author" class="tp-input" type="text" placeholder="你的昵称（必填）" maxlength="30" autocomplete="off" disabled />
                <input id="tp-tags" class="tp-input" type="text" placeholder="标签，逗号分隔：dark,vibrant,cool" maxlength="100" autocomplete="off" disabled />
                <button class="tp-btn tp-btn-primary" id="tp-submit" type="button" disabled>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  提交
                </button>
              </div>
              <div class="tp-tag-suggestions" id="tp-tag-suggestions" style="display:none"></div>
              <div id="tp-submit-result" class="tp-submit-result" style="display:none"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Hidden canvas for screenshot generation -->
      <canvas id="tp-screenshot-canvas" width="800" height="500" style="position:fixed;top:-9999px;left:-9999px;visibility:hidden"></canvas>
    </div>
  </section>
</Layout>

<style>
  .tp-section { padding: 32px 32px 40px; }
  .tp-container { max-width: 1300px; margin: 0 auto; }

  /* ── Grid layout ── */
  .tp-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 24px;
    align-items: start;
  }

  /* ── Top bar ── */
  .tp-topbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px; gap: 12px; flex-wrap: wrap;
    padding: 0 0 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .tp-topbar-left { display: flex; align-items: baseline; gap: 10px; }
  .tp-topbar-title {
    font-size: 18px; font-weight: 800; letter-spacing: -0.03em;
    color: var(--color-text);
  }
  .tp-topbar-sep { color: var(--color-text-muted); opacity: 0.2; font-weight: 300; }
  .tp-topbar-desc {
    font-size: 13px; color: var(--color-text-muted);
    font-weight: 500; letter-spacing: -0.01em;
  }
  .tp-topbar-right { display: flex; gap: 4px; }

  /* ── Editor card ── */
  .tp-editor-card {
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 10px;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 1px 8px rgba(0,0,0,0.03);
    position: relative;
  }
  .tp-editor-card:focus-within {
    border-color: color-mix(in srgb, var(--color-primary) 50%, var(--color-border));
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 8%, transparent), 0 4px 20px rgba(0,0,0,0.06);
  }
  .tp-editor-card.drag-over {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent), 0 8px 32px color-mix(in srgb, var(--color-primary) 12%, transparent);
  }
  .tp-editor-header {
    display: flex; align-items: center;
    padding: 10px 18px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 50%, transparent);
  }
  .tp-editor-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--color-text-muted);
    display: flex; align-items: center; gap: 6px;
  }
  .tp-editor-label::before {
    content: ''; width: 8px; height: 8px; border-radius: 3px;
    background: var(--color-primary);
    opacity: 0.6;
  }

  .tp-textarea {
    display: block;
    width: 100%; min-height: 480px;
    background: var(--color-bg);
    color: var(--color-text);
    border: none;
    padding: 18px 20px 18px 48px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 12.5px; line-height: 1.75;
    resize: vertical; outline: none;
    box-sizing: border-box;
    tab-size: 2;
    white-space: pre;
    overflow-x: auto;
  }
  .tp-textarea::placeholder { color: var(--color-text-muted); opacity: 0.18; }

  .tp-editor-wrap { position: relative; }

  .tp-line-numbers {
    position: absolute; top: 0; left: 0; width: 48px; bottom: 0;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
    z-index: 1;
    border-right: 1px solid color-mix(in srgb, var(--color-border) 40%, transparent);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-border));
  }
  .tp-line-numbers-inner {
    padding: 18px 4px 18px 0;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 12.5px; line-height: 1.75;
    text-align: right;
    color: var(--color-text-muted); opacity: 0.45;
    white-space: pre;
  }

  .tp-errors {
    padding: 12px 22px; font-size: 12px; line-height: 1.9;
    color: #f87171;
    background: rgba(239,68,68,0.05);
    border-top: 1px solid rgba(239,68,68,0.15);
  }

  /* ── Status bar ── */
  .tp-status-bar {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 24px; min-height: 28px;
  }
  .tp-status-badge {
    font-size: 10px; font-weight: 700; padding: 5px 14px; border-radius: 99px;
    letter-spacing: 0.05em; flex-shrink: 0;
    text-transform: uppercase;
  }
  .tp-status-badge.idle    { background: color-mix(in srgb, var(--color-text-muted) 8%, transparent); color: var(--color-text-muted); }
  .tp-status-badge.applied { background: rgba(34,197,94,0.1); color: #22c55e; }
  .tp-status-badge.error   { background: rgba(239,68,68,0.1); color: #f87171; }
  .tp-status-detail {
    font-size: 12px; color: var(--color-text-muted);
    font-weight: 500; letter-spacing: -0.01em;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  /* ── Theme Showcase ── */
  .tp-showcase {
    display: flex; flex-direction: column;
    margin-bottom: 16px;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    min-height: 240px;
    box-shadow: 0 1px 8px rgba(0,0,0,0.03);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .tp-showcase:has(#tp-showcase-content[style*="display: flex"]) {
    border-color: color-mix(in srgb, var(--color-primary) 18%, var(--color-border));
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }
  .tp-showcase-empty {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 48px 24px; gap: 14px;
    color: var(--color-text-muted); opacity: 0.3;
    font-size: 13px; font-weight: 500;
    flex: 1;
    text-align: center;
  }
  .tp-showcase-empty svg { opacity: 0.6; }
  .tp-showcase-empty p { margin: 0; font-size: 12px; opacity: 0.6; max-width: 220px; line-height: 1.6; }
  #tp-showcase-content {
    display: flex; flex-direction: column;
  }
  #tp-showcase-content.tp-showcase-enter {
    animation: tpShowcaseIn 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  @keyframes tpShowcaseIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  .tp-showcase-header {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 18px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 50%, transparent);
  }
  .tp-showcase-label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .tp-showcase-name {
    font-size: 13px; font-weight: 700; letter-spacing: -0.02em;
    color: var(--color-primary);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  .tp-showcase-body {
    display: flex; gap: 16px; padding: 16px;
    align-items: stretch; flex-wrap: wrap;
  }
  .tp-showcase-colors {
    display: flex; gap: 8px; align-items: center;
    padding: 14px 16px;
    background: color-mix(in srgb, var(--color-bg) 60%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .tp-showcase-swatch {
    display: inline-block;
    width: 30px; height: 30px; border-radius: 9px;
    border: 2px solid var(--color-border);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s;
    cursor: default; flex-shrink: 0;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  }
  .tp-showcase-swatch:hover { transform: scale(1.4); z-index: 3; box-shadow: 0 6px 18px rgba(0,0,0,0.18); }

  .tp-showcase-panels { flex: 1; min-width: 240px; display: flex; flex-direction: column; gap: 10px; }

  .tp-showcase-card {
    flex: 1;
    background: color-mix(in srgb, var(--color-bg) 70%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .tp-showcase-card:hover {
    border-color: color-mix(in srgb, var(--color-primary) 25%, var(--color-border));
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  .tp-showcase-card-bar {
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-secondary), var(--color-accent));
  }
  .tp-showcase-card-content {
    padding: 14px 16px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .tp-showcase-heading {
    font-size: 15px; font-weight: 700; letter-spacing: -0.03em;
    color: var(--color-primary); margin: 0;
  }
  .tp-showcase-body-text {
    font-size: 12px; line-height: 1.65; margin: 0;
    color: var(--color-text);
  }
  .tp-showcase-muted { color: var(--color-text-muted); }
  .tp-showcase-link { color: var(--color-primary); text-decoration: underline; cursor: default; font-weight: 500; }
  .tp-showcase-buttons { display: flex; gap: 8px; margin-top: 2px; }
  .tp-showcase-btn-primary {
    display: inline-flex; align-items: center;
    height: 28px; padding: 0 14px; border-radius: 8px;
    font-size: 11px; font-weight: 600;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: #fff;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }
  .tp-showcase-btn-ghost {
    display: inline-flex; align-items: center;
    height: 28px; padding: 0 14px; border-radius: 8px;
    font-size: 11px; font-weight: 600;
    background: transparent; color: var(--color-text-muted);
    border: 1.5px solid var(--color-border);
  }

  .tp-showcase-meta {
    display: flex; gap: 8px; flex-wrap: wrap;
  }
  .tp-showcase-stat {
    padding: 6px 12px; border-radius: 8px;
    font-size: 11px; font-weight: 600;
    background: color-mix(in srgb, var(--color-primary) 6%, transparent);
    color: var(--color-primary);
    border: 1px solid color-mix(in srgb, var(--color-primary) 12%, transparent);
  }

  /* ── Character count ── */
  .tp-char-count {
    font-size: 10px; color: var(--color-text-muted);
    font-family: 'JetBrains Mono', monospace;
    margin-left: auto; opacity: 0.5;
  }

  /* ── Actions ── */
  .tp-actions {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
    margin-bottom: 16px;
    padding: 16px 18px;
    background: color-mix(in srgb, var(--color-surface) 40%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }
  .tp-action-group {
    display: flex; gap: 6px;
  }
  .tp-action-sep {
    width: 1px; height: 24px;
    background: var(--color-border);
    margin: 0 6px; flex-shrink: 0;
  }

  .tp-btn {
    display: inline-flex; align-items: center; gap: 7px;
    height: 38px; padding: 0 18px;
    border-radius: 11px;
    font-size: 12px; font-weight: 600; letter-spacing: -0.01em;
    cursor: pointer; border: none;
    font-family: inherit;
    transition: all 0.25s cubic-bezier(0.22, 0.61, 0.36, 1);
    position: relative; overflow: hidden;
    white-space: nowrap;
  }
  .tp-btn::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at center, rgba(255,255,255,0.12) 0%, transparent 70%);
    opacity: 0; transition: opacity 0.3s;
  }
  .tp-btn:hover::after { opacity: 1; }
  .tp-btn:active { transform: scale(0.96); }
  .tp-btn:disabled {
    opacity: 0.3; cursor: not-allowed; pointer-events: none;
    filter: grayscale(0.5);
  }
  .tp-btn:disabled::after { display: none; }
  .tp-btn-primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: #fff;
    box-shadow: 0 2px 12px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }
  .tp-btn-primary:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--color-primary) 40%, transparent);
  }
  .tp-btn-outline {
    background: transparent; color: var(--color-text);
    border: 1.5px solid var(--color-border);
  }
  .tp-btn-outline:hover:not(:disabled) {
    border-color: var(--color-primary); color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 5%, transparent);
    transform: translateY(-1px);
  }
  .tp-btn-accent {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    border: none;
    box-shadow: 0 2px 12px rgba(99,102,241,0.25);
  }
  .tp-btn-accent:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(99,102,241,0.4);
  }
  .tp-btn-destructive {
    background: transparent; color: var(--color-text-muted);
    border: 1.5px solid var(--color-border);
  }
  .tp-btn-destructive:hover:not(:disabled) {
    border-color: #f87171; color: #f87171;
    background: rgba(239,68,68,0.06);
    transform: translateY(-1px);
  }
  .tp-ghost-btn {
    background: transparent; color: var(--color-text-muted);
    border: 1px solid transparent; padding: 4px 12px; height: 28px; font-size: 11px;
    border-radius: 7px; cursor: pointer; font-family: inherit; font-weight: 600;
    transition: all 0.2s;
  }
  .tp-ghost-btn:hover {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  /* ── Submit section ── */
  .tp-submit-section { margin-bottom: 16px; animation: tpFadeIn 0.3s ease; }
  .tp-submit-card {
    background: var(--color-surface);
    border: 1.5px solid color-mix(in srgb, var(--color-primary) 20%, var(--color-border));
    border-radius: 16px;
    padding: 18px 22px;
    box-shadow: 0 1px 8px rgba(0,0,0,0.03);
  }
  .tp-submit-header {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 700; letter-spacing: -0.02em;
    margin-bottom: 12px; color: var(--color-primary);
  }
  .tp-submit-row {
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  }
  .tp-tag-suggestions {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-top: 10px; align-items: center;
    padding: 10px 14px;
    background: color-mix(in srgb, var(--color-bg) 50%, transparent);
    border-radius: 12px;
    border: 1px dashed color-mix(in srgb, var(--color-border) 45%, transparent);
  }
  .tp-tag-suggestions-label {
    font-size: 11px; color: var(--color-text-muted);
    font-weight: 600; margin-right: 4px;
    display: inline-flex; align-items: center; gap: 5px;
  }
  .tp-tag-suggestions-label::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-primary); opacity: 0.55;
  }
  .tp-tag-chip {
    display: inline-flex; align-items: center;
    height: 28px; padding: 0 13px;
    border-radius: 14px;
    font-size: 12px; font-weight: 600; letter-spacing: -0.01em;
    cursor: pointer; font-family: inherit;
    border: 1px solid var(--color-border);
    background: linear-gradient(180deg,
      color-mix(in srgb, var(--color-surface) 70%, transparent) 0%,
      color-mix(in srgb, var(--color-bg) 60%, transparent) 100%);
    color: var(--color-text);
    box-shadow: 0 1px 2px rgba(0,0,0,0.06);
    transition: all 0.25s cubic-bezier(0.22, 0.61, 0.36, 1);
    white-space: nowrap;
    user-select: none;
    animation: tpTagIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes tpTagIn {
    from { opacity: 0; transform: scale(0.75) translateY(6px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  /* confidence tiers */
  .tp-tag-chip[data-tier="high"] {
    border-color: color-mix(in srgb, var(--color-primary) 35%, var(--color-border));
    box-shadow: 0 1px 4px color-mix(in srgb, var(--color-primary) 10%, transparent);
  }
  .tp-tag-chip[data-tier="mid"] {
    border-color: color-mix(in srgb, var(--color-primary) 18%, var(--color-border));
  }
  .tp-tag-chip:hover {
    color: #fff;
    border-color: var(--color-primary);
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    transform: translateY(-2px);
    box-shadow: 0 4px 18px color-mix(in srgb, var(--color-primary) 35%, transparent);
  }
  .tp-tag-chip:active {
    transform: scale(0.93);
    transition: transform 0.1s ease;
  }
  .tp-input {
    height: 38px; padding: 0 14px;
    border-radius: 10px;
    border: 1.5px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 13px; font-family: inherit;
    outline: none; transition: border-color 0.25s, box-shadow 0.25s;
    min-width: 140px; flex: 1;
  }
  .tp-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 10%, transparent);
  }
  .tp-input:disabled { opacity: 0.3; cursor: not-allowed; }
  .tp-input::placeholder { color: var(--color-text-muted); opacity: 0.4; }

  .tp-submit-result {
    margin-top: 12px; padding: 12px 18px; border-radius: 10px;
    font-size: 13px; line-height: 1.6;
    animation: tpFadeIn 0.3s ease;
  }
  @keyframes tpFadeIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
  .tp-submit-result.success {
    background: rgba(34,197,94,0.08);
    border: 1.5px solid rgba(34,197,94,0.2);
  }
  .tp-submit-result.error {
    background: rgba(239,68,68,0.06);
    border: 1.5px solid rgba(239,68,68,0.2);
  }
  .tp-submit-result a { color: var(--color-primary); font-weight: 600; text-decoration: underline; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .tp-section { padding: 16px 14px 32px; }
    .tp-grid { grid-template-columns: 1fr; }
    .tp-topbar { flex-direction: column; align-items: flex-start; padding: 0 0 12px; }
    .tp-textarea { min-height: 360px; padding: 14px 14px 14px 36px; }
    .tp-line-numbers { width: 36px; }
    .tp-line-numbers-inner { padding: 14px 3px 14px 0; }
    .tp-actions { padding: 12px 14px; gap: 6px; }
    .tp-action-sep { display: none; }
    .tp-btn { height: 36px; padding: 0 14px; font-size: 12px; border-radius: 10px; }
    .tp-showcase-body { flex-direction: column; padding: 12px; }
    .tp-showcase-colors { justify-content: center; }
    .tp-submit-row { flex-direction: column; }
    .tp-input { width: 100%; box-sizing: border-box; min-width: 0; }
    #tp-submit { width: 100%; justify-content: center; }
  }
</style>

<script>
  // ── Safety sanitizers ──
  const DANGEROUS_CSS = [
    /\burl\s*\(\s*["']?\s*(?:https?|ftp|data):/gi,
    /@import\b/gi, /expression\s*\(/gi, /javascript\s*:/gi,
    /behavior\s*:/gi, /-moz-binding\b/gi,
  ];

  function sanitizeCssVal(v) {
    if (!v) return '';
    let s = String(v).slice(0, 128);
    for (const p of DANGEROUS_CSS) s = s.replace(p, '');
    return s.replace(/[;{}]/g, '').trim();
  }

  function sanitizeCustomCss(css) {
    if (!css) return null;
    let s = String(css)
      .replace(/<\/style[\s\S]*?>/gi, '').replace(/<[^>]*>/g, '')
      .replace(/javascript\s*:/gi, '').replace(/expression\s*\(/gi, '')
      .replace(/@import\b/gi, '').replace(/behavior\s*:/gi, '')
      .replace(/-moz-binding\b/gi, '')
      .replace(/\burl\s*\(\s*["']?\s*(?:https?|ftp|data):/gi, 'url(banned:')
      .trim();
    if (s.length > 16384) s = s.slice(0, 16384);
    return s || null;
  }

  function safeDim(v) {
    const s = sanitizeCssVal(v);
    return /^-?[\d.]+(?:%|px|em|rem|vh|vw|vmin|vmax|s|ms)?$/i.test(s) ? s : '';
  }

  // ── Apply theme to current page ──
  let activeStyle, activeExts;
  let currentTheme = null;
  // Snapshot of today's theme CSS vars (set by Layout server-side :root style)
  const todayVars = {};
  const todayStyle = document.querySelector('style#td-custom-css');

  function isDarkTheme(vars) {
    const bg = vars['--color-bg'] || '#000';
    const c = bg.replace('#', '');
    if (c.length < 6) return true;
    const r = parseInt(c.slice(0,2), 16) / 255;
    const g = parseInt(c.slice(2,4), 16) / 255;
    const b = parseInt(c.slice(4,6), 16) / 255;
    return (0.2126 * r + 0.7152 * g + 0.0722 * b) < 0.5;
  }

  function applyThemeToPage(theme) {
    const root = document.documentElement;

    // CSS vars
    for (const [k, v] of Object.entries(theme.cssVars)) {
      root.style.setProperty(k, sanitizeCssVal(v));
    }

    // Remove today's custom CSS
    const old = document.getElementById('td-custom-css');
    if (old) old.remove();

    // Inject custom CSS
    if (activeStyle) { activeStyle.remove(); activeStyle = null; }
    if (theme.customCss) {
      const safe = sanitizeCustomCss(theme.customCss);
      if (safe) {
        activeStyle = document.createElement('style');
        activeStyle.id = 'tp-injected-css';
        activeStyle.textContent = safe;
        document.head.appendChild(activeStyle);
      }
    }

    // Clear + render extensions
    if (activeExts) { activeExts.innerHTML = ''; }
    const tdExt = document.getElementById('td-extensions');
    if (tdExt) tdExt.innerHTML = '';

    if (theme.extensions && theme.extensions.length > 0) {
      if (!activeExts) {
        activeExts = document.createElement('div');
        activeExts.id = 'tp-injected-exts';
        const ref = document.getElementById('td-extensions');
        if (ref && ref.nextSibling) document.body.insertBefore(activeExts, ref.nextSibling);
        else document.body.appendChild(activeExts);
      }
      theme.extensions.slice(0, 20).forEach(ext => {
        if (ext.type === 'floating' && ext.char) {
          const el = document.createElement('div');
          const t = safeDim(ext.top), l = safeDim(ext.left);
          const r = safeDim(ext.right), b = safeDim(ext.bottom);
          const fs = safeDim(ext.fontSize), anim = sanitizeCssVal(ext.animation);
          const z = (typeof ext.zIndex === 'number' && ext.zIndex > -2 && ext.zIndex < 100000) ? ext.zIndex : null;
          const op = (typeof ext.opacity === 'number' && ext.opacity >= 0 && ext.opacity <= 1) ? ext.opacity : null;
          el.style.cssText = [
            'position:fixed', 'pointer-events:none',
            t && 'top:' + t, l && 'left:' + l, r && 'right:' + r, b && 'bottom:' + b,
            fs && 'font-size:' + fs, anim && 'animation:' + anim,
            z != null && 'z-index:' + z, op != null && 'opacity:' + op,
          ].filter(Boolean).join(';');
          el.textContent = String(ext.char).slice(0, 4);
          activeExts.appendChild(el);
        } else if (ext.type === 'decorative' && ext.html) {
          const tpl = document.createElement('template');
          tpl.innerHTML = ext.html;
          const frag = tpl.content.cloneNode(true);
          frag.querySelectorAll('*').forEach(el => {
            Array.from(el.attributes).forEach(attr => {
              if (/^on/i.test(attr.name)) el.removeAttribute(attr.name);
            });
          });
          activeExts.appendChild(frag);
        }
      });
    }
  }

  function restoreTodayTheme() {
    const root = document.documentElement;
    // Only remove CSS vars we previously set (surgical, preserves other inline styles)
    if (currentTheme) {
      for (const k of Object.keys(currentTheme.cssVars)) {
        root.style.removeProperty(k);
      }
    }
    // Remove injected custom CSS
    if (activeStyle) { activeStyle.remove(); activeStyle = null; }
    // Clear injected extensions
    if (activeExts) { activeExts.innerHTML = ''; }
    // Restore today's custom CSS if it was removed
    if (todayStyle) {
      const restored = document.getElementById('td-custom-css');
      if (!restored) {
        const clone = todayStyle.cloneNode(true);
        document.head.appendChild(clone);
      }
    }
  }

  // ── Validation ──
  function validateTheme(obj) {
    const errs = [];
    if (!obj || typeof obj !== 'object') { errs.push('JSON 必须是一个对象'); return errs; }
    if (!obj.cssVars || typeof obj.cssVars !== 'object') { errs.push('缺少 cssVars 字段'); return errs; }
    if (!obj.cssVars['--color-primary']) errs.push('cssVars 缺少 --color-primary');
    if (!obj.cssVars['--color-bg']) errs.push('cssVars 缺少 --color-bg');
    if (obj.extensions !== undefined && obj.extensions !== null && !Array.isArray(obj.extensions)) {
      errs.push('extensions 必须是数组');
    }
    return errs;
  }

  // ── DOM refs ──
  const input = document.getElementById('tp-json-input');
  const errors = document.getElementById('tp-errors');
  const statusBadge = document.getElementById('tp-status-badge');
  const statusDetail = document.getElementById('tp-status-detail');
  const actions = document.getElementById('tp-actions');
  const submitSection = document.getElementById('tp-submit-section');

  const showcase = document.getElementById('tp-showcase');
  const showcaseSwatches = document.getElementById('tp-showcase-swatches');
  const charCount = document.getElementById('tp-char-count');
  const lineNumbers = document.getElementById('tp-line-numbers');
  const tagSuggestionsEl = document.getElementById('tp-tag-suggestions');
  const tagsInput = document.getElementById('tp-tags');
  const COLOR_KEYS = ['--color-primary','--color-secondary','--color-accent','--color-bg','--color-surface','--color-text'];

  // ── Line numbers ──
  const lineNumbersInner = lineNumbers.querySelector('.tp-line-numbers-inner');

  function updateLineNumbers() {
    const count = input.value.split('\n').length;
    const nums = [];
    for (let i = 1; i <= count; i++) nums.push(i);
    lineNumbersInner.textContent = nums.join('\n');
    syncLineScroll();
  }

  function syncLineScroll() {
    lineNumbersInner.style.transform = `translateY(${-input.scrollTop}px)`;
  }

  input.addEventListener('input', updateLineNumbers);
  input.addEventListener('scroll', syncLineScroll);
  updateLineNumbers();

  // ── Tag suggestions ──
  let tagSuggestAbort = null;

  function hexToHueClient(hex) {
    const c = hex.replace('#', '');
    if (c.length < 6) return 0;
    const r = parseInt(c.slice(0,2), 16) / 255;
    const g = parseInt(c.slice(2,4), 16) / 255;
    const b = parseInt(c.slice(4,6), 16) / 255;
    const max = Math.max(r,g,b), min = Math.min(r,g,b);
    if (max === min) return 0;
    let h = 0;
    if (max === r) h = ((g - b) / (max - min)) % 6;
    else if (max === g) h = (b - r) / (max - min) + 2;
    else h = (r - g) / (max - min) + 4;
    return ((h * 60) % 360 + 360) % 360;
  }

  function clientSideTagFallback(theme) {
    const tags = [];
    const vars = theme.cssVars;
    const dark = isDarkTheme(vars);
    tags.push({ tag: dark ? 'dark' : 'light', confidence: 0.85, reason: dark ? '背景偏深色' : '背景偏浅色' });
    const pri = vars['--color-primary'] || '#6366f1';
    const hue = hexToHueClient(pri);
    if ((hue >= 0 && hue <= 60) || hue >= 300) {
      tags.push({ tag: 'warm', confidence: 0.65, reason: '主色位于暖色区间' });
    } else if (hue >= 180 && hue <= 270) {
      tags.push({ tag: 'cool', confidence: 0.65, reason: '主色位于冷色区间' });
    }
    const glassBlur = (vars['--glass-blur'] || '').trim();
    if (glassBlur && glassBlur !== 'blur(0px)' && !glassBlur.startsWith('0')) {
      tags.push({ tag: 'glass', confidence: 0.65, reason: '检测到毛玻璃效果' });
    }
    return tags.slice(0, 5);
  }

  async function fetchTagSuggestions(theme) {
    if (tagSuggestAbort) tagSuggestAbort.abort();
    tagSuggestAbort = new AbortController();
    try {
      const res = await fetch('/api/v1/diy/suggest-tags.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          cssVars: theme.cssVars,
          customCss: theme.customCss,
          extensions: theme.extensions,
          presetName: theme.presetName,
        }),
        signal: tagSuggestAbort.signal,
      });
      if (!res.ok) throw new Error('API error');
      const data = await res.json();
      renderTagSuggestions(data.tags || []);
    } catch (err) {
      if (err.name === 'AbortError') return;
      renderTagSuggestions(clientSideTagFallback(theme));
    }
  }

  function renderTagSuggestions(tags) {
    if (!tags || tags.length === 0) {
      tagSuggestionsEl.style.display = 'none';
      tagSuggestionsEl.innerHTML = '';
      return;
    }
    tagSuggestionsEl.style.display = 'flex';
    tagSuggestionsEl.innerHTML = '';
    const label = document.createElement('span');
    label.className = 'tp-tag-suggestions-label';
    label.textContent = '推荐标签';
    tagSuggestionsEl.appendChild(label);
    for (const [i, t] of tags.entries()) {
      const chip = document.createElement('span');
      chip.className = 'tp-tag-chip';
      chip.dataset.tier = t.confidence >= 0.80 ? 'high' : t.confidence >= 0.55 ? 'mid' : 'low';
      chip.textContent = '#' + t.tag;
      chip.title = `${t.reason || ''} (置信度: ${Math.round(t.confidence * 100)}%)`;
      chip.style.animationDelay = `${i * 0.07}s`;
      chip.addEventListener('click', () => appendTagToInput(t.tag));
      tagSuggestionsEl.appendChild(chip);
    }
  }

  function appendTagToInput(tag) {
    const current = tagsInput.value.trim();
    const existing = current ? current.split(',').map(t => t.trim()).filter(Boolean) : [];
    if (existing.includes(tag)) return;
    existing.push(tag);
    tagsInput.value = existing.join(', ');
    tagsInput.dispatchEvent(new Event('input', { bubbles: true }));
  }

  function hideTagSuggestions() {
    tagSuggestionsEl.style.display = 'none';
    tagSuggestionsEl.innerHTML = '';
  }

  function updateShowcase(theme) {
    const empty = document.getElementById('tp-showcase-empty');
    const content = document.getElementById('tp-showcase-content');
    if (!theme) {
      empty.style.display = 'flex';
      content.style.display = 'none';
      content.classList.remove('tp-showcase-enter');
      return;
    }
    empty.style.display = 'none';
    content.style.display = 'flex';
    // Re-trigger entrance animation
    content.classList.remove('tp-showcase-enter');
    void content.offsetWidth;
    content.classList.add('tp-showcase-enter');
    const vars = theme.cssVars;

    // Update name
    const nameEl = document.getElementById('tp-showcase-name');
    if (nameEl) nameEl.textContent = theme.presetName || '未命名主题';

    // Color swatches
    showcaseSwatches.innerHTML = '';
    COLOR_KEYS.forEach(k => {
      const v = vars[k] || '#888';
      const el = document.createElement('span');
      el.className = 'tp-showcase-swatch';
      el.style.backgroundColor = v;
      el.title = `${k}: ${v}`;
      showcaseSwatches.appendChild(el);
    });

    // Stats
    const extsCount = theme.extensions ? theme.extensions.length : 0;
    document.getElementById('tp-stat-name').textContent = theme.presetName || '—';
    document.getElementById('tp-stat-exts').textContent = extsCount > 0 ? `${extsCount} 扩展` : '0 扩展';
  }

  function setButtonsEnabled(on) {
    document.getElementById('tp-apply').disabled = !on;
    document.getElementById('tp-copy-json').disabled = !on;
    document.getElementById('tp-screenshot').disabled = !on;
    document.getElementById('tp-restore').disabled = !on;
    document.getElementById('tp-submit').disabled = !on;
    document.getElementById('tp-author').disabled = !on;
    document.getElementById('tp-tags').disabled = !on;
  }

  // Smooth :root transition for theme changes
  document.documentElement.style.transition = 'all 0.35s ease';

  function setStatus(cls, text, detail) {
    statusBadge.className = 'tp-status-badge ' + cls;
    statusBadge.textContent = text;
    statusDetail.textContent = detail || '';
  }

  // ── Example theme ──
  const EXAMPLE = {"preset":"yozakura-reverie","presetName":"🌸 Yozakura","cssVars":{"--color-primary":"#ff8fa3","--color-secondary":"#ffc2d1","--color-accent":"#ff8fa3","--color-bg":"#030108","--color-surface":"#121017","--color-text":"#fdf0f5","--color-text-muted":"#9a8696","--color-border":"rgba(255,143,163,0.18)","--font-heading":"'Inter', system-ui, sans-serif","--font-body":"'Inter', system-ui, sans-serif","--font-mono":"'JetBrains Mono', monospace","--text-base":"clamp(1rem, 0.9rem + 0.5vw, 1.125rem)","--text-lg":"calc(var(--text-base) * 1.25)","--text-xl":"calc(var(--text-lg) * 1.25)","--text-2xl":"calc(var(--text-xl) * 1.25)","--text-sm":"calc(var(--text-base) / 1.25)","--space-unit":"0.25rem","--space-1":"calc(0.25rem * 1)","--space-2":"calc(0.25rem * 2)","--space-3":"calc(0.25rem * 3)","--space-4":"calc(0.25rem * 4)","--space-6":"calc(0.25rem * 6)","--space-8":"calc(0.25rem * 8)","--space-12":"calc(0.25rem * 12)","--radii":"0.75rem","--content-max":"72rem","--shadow-sm":"0 1px 2px rgba(0,0,0,0.08)","--shadow-md":"0 4px 12px rgba(0,0,0,0.12)","--shadow-lg":"0 12px 32px rgba(0,0,0,0.18)","--glass-bg":"color-mix(in srgb, var(--color-bg) 85%, transparent)","--glass-blur":"blur(16px)","--noise-opacity":"0","--ambient-1":"rgba(255, 143, 163, 0.18)","--ambient-2":"rgba(147, 112, 219, 0.08)"},"customCss":"\n            /* 1. 3D 翻滚与飘落复合动画（核心物理升级） */\n            @keyframes sakuraTumble {\n                0% { \n                    transform: translate3d(0, -10vh, 0) rotateZ(0deg) rotateX(0deg) rotateY(0deg) scale(var(--s, 1)); \n                    opacity: 0; \n                }\n                10% { \n                    opacity: var(--o, 0.85); \n                }\n                50% { \n                    /* 随风横向摇曳 + 3D翻滚 */\n                    transform: translate3d(var(--sway, 5vw), 45vh, 0) \n                               rotateZ(var(--r, 180deg)) \n                               rotateX(calc(var(--r) * 0.8)) \n                               rotateY(calc(var(--r) * 1.2)) \n                               scale(var(--s, 1)); \n                }\n                85% { \n                    opacity: var(--o, 0.85); \n                }\n                100% { \n                    /* 飘落至底 */\n                    transform: translate3d(calc(var(--sway, 5vw) * -0.5), 110vh, 0) \n                               rotateZ(calc(var(--r, 360deg) * 1.5)) \n                               rotateX(calc(var(--r) * 1.6)) \n                               rotateY(calc(var(--r) * 2.4)) \n                               scale(var(--s, 1)); \n                    opacity: 0; \n                }\n            }\n            \n            /* 2. 幻夜月光与云雾呼吸 */\n            @keyframes sakuraMoonlight {\n                0%   { opacity: 0.25; transform: scale(1) translate(0, 0); }\n                50%  { opacity: 0.45; transform: scale(1.08) translate(2%, 2%); filter: hue-rotate(5deg); }\n                100% { opacity: 0.25; transform: scale(1) translate(0, 0); }\n            }\n\n            /* 3. 星尘/流萤闪烁动画 */\n            @keyframes stardustTwinkle {\n                0%, 100% { opacity: 0; transform: scale(0.5); }\n                50% { opacity: var(--o, 0.6); transform: scale(1); box-shadow: 0 0 6px 1px rgba(255, 183, 197, 0.6); }\n            }\n\n            /* --- 元素样式 --- */\n\n            /* 基础花瓣：优化材质、增加通透感与高光 */\n            .omni-petal { \n                position: fixed; \n                top: -10vh; \n                width: 16px; \n                height: 16px; \n                background: linear-gradient(135deg, \n                    rgba(255,255,255,0.95) 0%, \n                    rgba(255,183,197,0.85) 30%, \n                    rgba(255,143,163,0.9) 100%); \n                border-radius: 50% 0 50% 50%; \n                /* 内发光与高光边缘 */\n                box-shadow: inset 2px 2px 4px rgba(255,255,255,0.6), \n                            inset -1px -1px 3px rgba(0,0,0,0.1),\n                            0 0 8px rgba(255, 143, 163, 0.3); \n                pointer-events: none; \n                z-index: 0; \n                transform-origin: 50% 50%;\n                will-change: transform, opacity; /* 性能优化 */\n                animation: sakuraTumble var(--dur, 12s) cubic-bezier(0.35, 0.05, 0.65, 0.95) infinite var(--d, 0s); \n            }\n\n            /* 远景花瓣：超强模糊、暗淡、小巧 */\n            .omni-petal.bg-blur {\n                filter: blur(5px) brightness(0.7);\n                z-index: -1;\n            }\n\n            /* 前景花瓣：巨大、清晰、强烈的赛博霓虹发光 */\n            .omni-petal.fg-sharp {\n                z-index: 10;\n                filter: drop-shadow(0 0 16px rgba(255,143,163,0.7)) brightness(1.1);\n            }\n\n            /* 唯美夜樱背景光晕 (双色交织) */\n            .yozakura-glow {\n                position: fixed;\n                top: -20vh;\n                right: -10vw;\n                width: 70vw;\n                height: 70vw;\n                background: radial-gradient(circle, \n                    rgba(255, 194, 209, 0.07) 0%, \n                    rgba(164, 118, 219, 0.05) 30%, \n                    transparent 65%);\n                border-radius: 50%;\n                pointer-events: none;\n                z-index: -2;\n                mix-blend-mode: screen;\n                animation: sakuraMoonlight 12s ease-in-out infinite alternate;\n            }\n\n            /* 电影级晕影 — 视线引导至中心 */\n            .cinematic-vignette {\n                position: fixed;\n                top: 0; left: 0; width: 100vw; height: 100vh;\n                background: radial-gradient(ellipse at center, transparent 55%, rgba(3, 1, 8, 0.55) 100%);\n                pointer-events: none;\n                z-index: 5;\n            }\n\n            /* 微光星尘点缀 */\n            .omni-stardust {\n                position: fixed;\n                width: 2px;\n                height: 2px;\n                background: #fff;\n                border-radius: 50%;\n                pointer-events: none;\n                z-index: -1;\n                animation: stardustTwinkle var(--dur, 4s) ease-in-out infinite var(--d, 0s);\n            }\n        ","extensions":[{"type":"decorative","html":"<!-- 电影级晕影层 -->\n            <div class=\"cinematic-vignette\"></div>\n            <!-- 意境层：夜樱光晕 -->\n            <div class=\"yozakura-glow\"></div>\n            <!-- 添加一个位于左下角的冷色辅光源，增加色彩层次 -->\n            <div class=\"yozakura-glow\" style=\"top: 50vh; right: auto; left: -20vw; background: radial-gradient(circle, rgba(164, 118, 219, 0.04) 0%, transparent 50%); animation-delay: -5s; transform: scale(0.8);\"></div>\n\n            <!-- 环境层：流萤 / 星尘 (随机散布) -->\n            <div class=\"omni-stardust\" style=\"top: 20%; left: 15%; --dur: 5s; --d: 1s; --o: 0.8;\"></div>\n            <div class=\"omni-stardust\" style=\"top: 45%; left: 80%; --dur: 7s; --d: 3s; --o: 0.6;\"></div>\n            <div class=\"omni-stardust\" style=\"top: 70%; left: 30%; --dur: 6s; --d: 2s; --o: 0.9;\"></div>\n            <div class=\"omni-stardust\" style=\"top: 85%; left: 65%; --dur: 8s; --d: 0s; --o: 0.5;\"></div>\n\n            <!-- 背景层：远景模糊花瓣 (空间景深感，轨迹平缓) -->\n            <div class=\"omni-petal bg-blur\" style=\"left: 8%;  --s: 0.5; --r: 280deg; --sway: 4vw;  --o: 0.4; --dur: 20s; --d: -2s;\"></div>\n            <div class=\"omni-petal bg-blur\" style=\"left: 35%; --s: 0.4; --r: -320deg; --sway: -3vw; --o: 0.3; --dur: 24s; --d: 4s;\"></div>\n            <div class=\"omni-petal bg-blur\" style=\"left: 75%; --s: 0.6; --r: 420deg; --sway: 6vw;  --o: 0.5; --dur: 18s; --d: 1s;\"></div>\n            <div class=\"omni-petal bg-blur\" style=\"left: 95%; --s: 0.4; --r: -200deg; --sway: -5vw; --o: 0.3; --dur: 22s; --d: 6s;\"></div>\n\n            <!-- 中景层：标准花瓣 (丰富画面，轨迹交错) -->\n            <div class=\"omni-petal\" style=\"left: 12%; --s: 0.8; --r: -450deg; --sway: -4vw; --o: 0.8; --dur: 14s; --d: 0s;\"></div>\n            <div class=\"omni-petal\" style=\"left: 28%; --s: 1.0; --r: 540deg;  --sway: 7vw;  --o: 0.9; --dur: 12s; --d: 3.5s;\"></div>\n            <div class=\"omni-petal\" style=\"left: 48%; --s: 0.7; --r: -360deg; --sway: -5vw; --o: 0.7; --dur: 16s; --d: 7s;\"></div>\n            <div class=\"omni-petal\" style=\"left: 62%; --s: 0.9; --r: 600deg;  --sway: 6vw;  --o: 0.8; --dur: 13s; --d: 1.5s;\"></div>\n            <div class=\"omni-petal\" style=\"left: 82%; --s: 1.0; --r: -540deg; --sway: -6vw; --o: 0.9; --dur: 15s; --d: 5s;\"></div>\n\n            <!-- 前景层：特大花瓣 (贴脸坠落，极速，带光学柔光) -->\n            <div class=\"omni-petal fg-sharp\" style=\"left: 18%; --s: 1.7; --r: 720deg;  --sway: 10vw; --o: 0.95; --dur: 9s;  --d: 2s;\"></div>\n            <div class=\"omni-petal fg-sharp\" style=\"left: 55%; --s: 1.5; --r: -600deg; --sway: -8vw; --o: 0.9;  --dur: 11s; --d: 6.5s;\"></div>\n            <div class=\"omni-petal fg-sharp\" style=\"left: 88%; --s: 1.9; --r: 800deg;  --sway: 7vw;  --o: 0.95; --dur: 8.5s;--d: 0.5s;\"></div>"}],"logoText":"YOZAKURA","logoColors":["#ffffff","#ffd1dc","#ff7b99","#b388ff"]};

  // ── Handle input ──
  let debounceTimer;
  input.addEventListener('input', () => {
    const len = input.value.length;
    charCount.textContent = len > 0 ? `${len} 字符` : '';

    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      const raw = input.value.trim();
      if (!raw) {
        restoreTodayTheme();
        updateShowcase(null);
        currentTheme = null;
        setStatus('idle', '等待输入');
        setButtonsEnabled(false);
        submitSection.style.display = 'none';
        hideTagSuggestions();
        errors.style.display = 'none';
        return;
      }
      try {
        const obj = JSON.parse(raw);
        const errs = validateTheme(obj);
        if (errs.length > 0) {
          showErrors(errs);
          if (obj.cssVars && typeof obj.cssVars === 'object') {
            applyThemeToPage(obj);
            currentTheme = obj;
            updateShowcase(obj);
            setStatus('applied', '已应用（有警告）', obj.presetName || '');
            setButtonsEnabled(true);
            fetchTagSuggestions(obj);
          } else {
            restoreTodayTheme();
            currentTheme = null;
            updateShowcase(null);
            setStatus('error', '数据不完整');
            setButtonsEnabled(false);
            submitSection.style.display = 'none';
              }
        } else {
          applyThemeToPage(obj);
          currentTheme = obj;
          updateShowcase(obj);
          setStatus('applied', '已应用', obj.presetName || '未命名主题');
          errors.style.display = 'none';
          setButtonsEnabled(true);
          fetchTagSuggestions(obj);
          submitSection.style.display = 'block';
          if (window.innerWidth < 769) {
            showcase.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      } catch (e) {
        showErrors([`JSON 解析失败: ${e.message}`]);
        restoreTodayTheme();
        currentTheme = null;
        updateShowcase(null);
        setStatus('error', 'JSON 无效');
        setButtonsEnabled(false);
        submitSection.style.display = 'none';
        hideTagSuggestions();
      }
    }, 250);
  });


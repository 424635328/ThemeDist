\"></div>\n            <div class=\"omni-petal\" style=\"left: 48%; --s: 0.7; --r: -360deg; --sway: -5vw; --o: 0.7; --dur: 16s; --d: 7s;\"></div>\n            <div class=\"omni-petal\" style=\"left: 62%; --s: 0.9; --r: 600deg;  --sway: 6vw;  --o: 0.8; --dur: 13s; --d: 1.5s;\"></div>\n            <div class=\"omni-petal\" style=\"left: 82%; --s: 1.0; --r: -540deg; --sway: -6vw; --o: 0.9; --dur: 15s; --d: 5s;\"></div>\n\n            <!-- 前景层：特大花瓣 (贴脸坠落，极速，带光学柔光) -->\n            <div class=\"omni-petal fg-sharp\" style=\"left: 18%; --s: 1.7; --r: 720deg;  --sway: 10vw; --o: 0.95; --dur: 9s;  --d: 2s;\"></div>\n            <div class=\"omni-petal fg-sharp\" style=\"left: 55%; --s: 1.5; --r: -600deg; --sway: -8vw; --o: 0.9;  --dur: 11s; --d: 6.5s;\"></div>\n            <div class=\"omni-petal fg-sharp\" style=\"left: 88%; --s: 1.9; --r: 800deg;  --sway: 7vw;  --o: 0.95; --dur: 8.5s;--d: 0.5s;\"></div>"}],"logoText":"YOZAKURA","logoColors":["#ffffff","#ffd1dc","#ff7b99","#b388ff"]};

  // ── Handle input ──
  let debounceTimer;
  input.addEventListener('input', () => {
    const len = input.value.length;
    charCount.textContent = len > 0 ? `${len} 字符` : '';

    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      const raw = input.value.trim();
      if (!raw) {
        restoreTodayTheme();
        updateShowcase(null);
        currentTheme = null;
        setStatus('idle', '等待输入');
        setButtonsEnabled(false);
        errors.style.display = 'none';
        return;
      }
      try {
        const obj = JSON.parse(raw);
        const errs = validateTheme(obj);
        if (errs.length > 0) {
          showErrors(errs);
          if (obj.cssVars && typeof obj.cssVars === 'object') {
            applyThemeToPage(obj);
            currentTheme = obj;
            updateShowcase(obj);
            setStatus('applied', '已应用（有警告）', obj.presetName || '');
            setButtonsEnabled(true);
          } else {
            restoreTodayTheme();
            currentTheme = null;
            updateShowcase(null);
            setStatus('error', '数据不完整');
            setButtonsEnabled(false);
              }
        } else {
          applyThemeToPage(obj);
          currentTheme = obj;
          updateShowcase(obj);
          setStatus('applied', '已应用', obj.presetName || '未命名主题');
          errors.style.display = 'none';
          setButtonsEnabled(true);
          submitSection.style.display = 'block';
        }
      } catch (e) {
        showErrors([`JSON 解析失败: ${e.message}`]);
        restoreTodayTheme();
        currentTheme = null;
        updateShowcase(null);
        setStatus('error', 'JSON 无效');
        setButtonsEnabled(false);
      }
    }, 250);
  });

  function showErrors(errs) {
    errors.innerHTML = errs.map(e => `• ${e}`).join('<br>');
    errors.style.display = 'block';
  }


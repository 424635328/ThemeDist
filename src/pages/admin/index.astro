</style>

<script>
  // ── CSRF helper ──
  function getCsrfToken() {
    const match = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]*)/);
    return match ? match[1] : '';
  }

  // ── Login ──
  const loginForm = document.getElementById('login-form');
  if (loginForm) {
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const accountEl = document.getElementById('login-account');
      const passwordEl = document.getElementById('login-password');
      const account = accountEl ? accountEl.value.trim() : '';
      const password = passwordEl ? passwordEl.value.trim() : '';
      const errorEl = document.getElementById('login-error');

      if (!account || !password) {
        window.__toast?.('请完整填写管理员账号和密码', 'warning');
        return;
      }

      try {
        const res = await fetch('/api/v1/admin/login.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ account, password }),
        });
        const data = await res.json();
        if (res.ok && data.success) {
          window.__toast?.('登录成功，正在跳转…');
          setTimeout(() => location.reload(), 600);
        } else {
          window.__toast?.(data.error || '登录失败，凭证不匹配', 'error');
        }
      } catch {
        window.__toast?.('网络层发生传输故障，请稍后检查重试', 'error');
      }
    });
  }

  // ─── Logout ───
  const btnLogout = document.getElementById('btn-logout');
  if (btnLogout) {
    btnLogout.addEventListener('click', async () => {
      await fetch('/api/v1/admin/login.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'logout' }),
      });
      window.__toast?.('已安全退出');
      setTimeout(() => location.reload(), 400);
    });
  }

  // ─── Admin Dashboard Logics ───
  if (!loginForm) {
    const loadingEl = document.getElementById('loading-state-admin');
    const emptyEl = document.getElementById('empty-state');
    const errorEl = document.getElementById('error-state-admin');
    const listEl = document.getElementById('theme-list-admin');
    const selectAll = document.getElementById('select-all');
    const selectedCount = document.getElementById('selected-count');
    const btnApprove = document.getElementById('btn-approve');
    const btnReject = document.getElementById('btn-reject');
    const btnRefresh = document.getElementById('btn-refresh');
    const btnRetry = document.getElementById('btn-retry');
    const countBadge = document.getElementById('pending-count-badge');
    const toolbar = document.getElementById('toolbar');
    const warningBox = document.getElementById('dangling-keys-warning');
    const warningBadgeCount = document.getElementById('dangling-badge-count');
    const recentlyApprovedSection = document.getElementById('recently-approved-section');
    const recentlyApprovedList = document.getElementById('recently-approved-list');
    const recentlyApprovedCount = document.getElementById('recently-approved-count');

    let themes = [];
    let selected = new Set();

    function updateSelection() {
      const cards = listEl?.querySelectorAll('.review-card') || [];
      cards.forEach(card => {
        const id = card.dataset.id || '';
        card.classList.toggle('selected', selected.has(id));
        const cb = card.querySelector('.review-checkbox');
        if (cb) cb.checked = selected.has(id);
      });
      if (selectedCount) {
        selectedCount.textContent = `已选 ${selected.size} 个主题`;
      }
      const hasSelection = selected.size > 0;
      if (btnApprove) btnApprove.disabled = !hasSelection;
      if (btnReject) btnReject.disabled = !hasSelection;
      if (selectAll) {
        selectAll.checked = themes.length > 0 && selected.size === themes.length;
        selectAll.indeterminate = selected.size > 0 && selected.size < themes.length;
      }
    }

    function toggleTheme(id) {
      if (selected.has(id)) selected.delete(id);
      else selected.add(id);
      updateSelection();
    }

    function renderCard(t) {
      const v = t.cssVars || {};
      const p = v['--color-primary'] || '#6366f1';
      const s = v['--color-secondary'] || '#8b5cf6';
      const a = v['--color-accent'] || '#06b6d4';
      const bg = v['--color-bg'] || '#0f0f23';
      const tx = v['--color-text'] || '#f4f4f5';
      const surface = v['--color-surface'] || bg;
      const muted = v['--color-text-muted'] || tx;
      const radii = v['--radii'] || '10px';
      const d = new Date(t.createdAt);
      const dateStr = d.getTime() ? d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';
      const authorInitial = (t.author || '?')[0].toUpperCase();

      // TTL countdown
      const ageMs = Date.now() - d.getTime();
      const ttlMs = 86400000 - ageMs;
      const ttlHours = Math.max(0, Math.floor(ttlMs / 3600000));
      const ttlMins = Math.max(0, Math.floor((ttlMs % 3600000) / 60000));
      const ttlUrgent = ttlMs < 3600000;
      const ttlWarn = ttlMs < 14400000;

      // CSS var count
      const varCount = Object.keys(v).length;

      // Has custom CSS?
      const hasCustomCSS = t.customCss && t.customCss.trim().length > 0;

      // Has extensions?
      const hasExts = t.extensions && t.extensions.length > 0;
      const floatingCount = hasExts ? t.extensions.filter(e => e.type === 'floating').length : 0;
      const decorativeCount = hasExts ? t.extensions.filter(e => e.type === 'decorative').length : 0;

      // Generate preview chip colors
      const chipBg = bg;
      const chipSurface = surface;
      const chipText = tx;
      const chipMuted = muted;

      return `
        <div class="card review-card" data-id="${escapeAttr(t.id)}" style="--rv-primary:${p};--rv-bg:${bg};--rv-text:${tx};--rv-surface:${surface};--rv-muted:${muted};--rv-radii:${radii}">
          <div class="review-card-top-bar" style="background:linear-gradient(90deg, ${p} 0%, ${s} 50%, ${a} 100%)"></div>
          <div class="review-card-body">
            <div class="review-left">
              <input type="checkbox" class="review-checkbox custom-checkbox" />
            </div>
            <div class="review-main">
              <div class="review-header">
                <h3 class="review-title">${escapeHtml(t.name)}</h3>
                <span class="review-badge-pending">
                  <span class="review-badge-dot"></span>
                  待审核
                </span>
                <button class="btn-moderate" data-id="${t.id}" title="内容审查" onclick="moderateTheme('${t.id}')">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                </button>
                <span class="review-ttl ${ttlUrgent ? 'ttl-urgent' : ttlWarn ? 'ttl-warn' : ''}" title="自动过期倒计时">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 4v5l3 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                  ${ttlMs <= 0 ? '已过期' : ttlHours > 0 ? ttlHours + 'h ' + ttlMins + 'm' : ttlMins + 'm'}
                </span>
              </div>
              <div class="review-meta">
                <span class="review-author-avatar" style="background:${p};color:${isLightReview(p) ? '#0f0f23' : '#fff'}">${authorInitial}</span>
                <span class="review-author-name">${escapeHtml(t.author)}</span>
                <span class="review-meta-sep">·</span>
                <span class="review-meta-date">${dateStr}</span>
                <span class="review-meta-sep">·</span>
                <span class="review-meta-extra">${varCount} 核心 CSS 变量</span>
                ${hasCustomCSS ? '<span class="review-meta-tag">含自定义 CSS</span>' : ''}
                ${hasExts ? `<span class="review-meta-tag">扩展: ${floatingCount > 0 ? floatingCount + '浮动' : ''}${floatingCount > 0 && decorativeCount > 0 ? ' + ' : ''}${decorativeCount > 0 ? decorativeCount + '装饰' : ''}</span>` : ''}
              </div>

              <div class="review-swatches">
                ${[
                  { l: 'P', c: p, key: '--color-primary', desc: '主色' },
                  { l: 'S', c: s, key: '--color-secondary', desc: '辅色' },
                  { l: 'A', c: a, key: '--color-accent', desc: '强调色' },
                  { l: 'Bg', c: bg, key: '--color-bg', desc: '画布背景' },
                  { l: 'Tx', c: tx, key: '--color-text', desc: '正文字体' },
                ].map(({ l, c, key, desc }) => `
                  <div class="review-swatch" title="点击可复制该 Hex 码\n${key}: ${c} (${desc})" data-swatch-hex="${c}">
                    <span class="review-swatch-color" style="background:${c};border:${key === '--color-bg' ? '1.5px solid var(--color-border)' : 'none'}">
                      <span class="review-swatch-letter" style="color:${key === '--color-text' ? bg : tx};text-shadow:0 0 2px ${bg}">${l}</span>
                    </span>
                    <span class="review-swatch-hex">${c}</span>
                  </div>
                `).join('')}
              </div>

              <div class="review-preview-chip" style="border-radius:${radii}">
                <div class="preview-chip-inner">
                  <div class="preview-chip-header">
                    <span class="preview-chip-muted" style="color:${chipMuted}">Preview SandBox</span>
                  </div>
                  <div class="preview-chip-buttons">
                    <span class="preview-chip-btn-primary" style="background:${p};color:${isLightReview(p) ? '#0f0f23' : '#fff'};border-radius:calc(${radii} / 2)">主要行为</span>
                    <span class="preview-chip-btn-ghost" style="border:1.5px solid ${hexToRgbaReview(p, 0.3)};color:${p};border-radius:calc(${radii} / 2)">次要操作</span>
                  </div>
                  <div class="preview-chip-card" style="background:${chipSurface};border-radius:calc(${radii} / 1.5)">
                    <span class="preview-chip-card-title" style="color:${chipText}">局部卡片组件</span>
                    <span class="preview-chip-card-desc" style="color:${chipMuted}">示例文本，展示当前主题色调配下的字色与面色融合对比度。</span>
                  </div>
                </div>
              </div>

              <div class="review-actions">
                <a href="/share?id=${escapeAttr(t.id)}" target="_blank" class="review-action-link" onclick="event.stopPropagation()">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  预览详情页
                </a>
                <button class="review-action-copy" data-copy-theme="${escapeAttr(JSON.stringify({ cssVars: v, customCss: t.customCss || null, extensions: t.extensions || null }))}" title="复制完整主题代码（CSS 变量 + 自定义 CSS + 扩展元素）">
                  <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 6v8a2 2 0 002 2h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  复制完整主题代码
                </button>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    async function loadThemes() {
      if (!loadingEl || !listEl) return;
      loadingEl.style.display = 'block';
      if (emptyEl) emptyEl.style.display = 'none';
      if (errorEl) errorEl.style.display = 'none';
      if (warningBox) warningBox.style.display = 'none';
      listEl.innerHTML = '';
      if (toolbar) toolbar.style.display = 'none';
      selected.clear();
      updateSelection();

      try {
        const res = await fetch('/api/v1/admin/review.json');
        if (!res.ok) throw new Error('Failed');
        const data = await res.json();

        console.log('[ThemeDist Admin Monitor] Raw response data:', data);

        themes = data.themes || data.list || data.data || [];
        const pendingCount = data.pending || 0;

        if (countBadge) {
          countBadge.textContent = `待审核任务数: ${pendingCount}`;
        }

        loadingEl.style.display = 'none';

        // Always render recently approved (24h rollback) regardless of pending state
        renderRecentlyApproved(data.recentlyApproved || []);

        if (pendingCount > 0 && themes.length === 0) {
          if (warningBox) {
            if (warningBadgeCount) warningBadgeCount.textContent = String(pendingCount);
            warningBox.style.display = 'block';
          }
          if (toolbar) toolbar.style.display = 'flex';
          return;
        }

        if (themes.length === 0) {
          if (emptyEl) emptyEl.style.display = 'block';
          return;
        }

        if (toolbar) toolbar.style.display = 'flex';
        listEl.innerHTML = themes.map(t => {
          try { return renderCard(t); } catch(e) { console.error('Render card error:', e); return ''; }
        }).join('');

        // Bind card events
        listEl.querySelectorAll('.review-card').forEach(card => {
          const el = card;
          el.addEventListener('click', (e) => {
            const target = e.target;
            if (target.tagName === 'A' || target.closest('a') || target.closest('button') || target.closest('.review-swatch')) return;
            const cb = el.querySelector('.review-checkbox');
            if (cb) {
              cb.checked = !cb.checked;
              toggleTheme(el.dataset.id || '');
            }
          });
        });

        listEl.querySelectorAll('.review-checkbox').forEach(cb => {
          cb.addEventListener('click', (e) => {
            e.stopPropagation();
            const card = (e.target as Element).closest('.review-card');
            if (card) {
              toggleTheme((card as HTMLElement).dataset.id || '');
            }
          });
        });

        updateSelection();
      } catch (err) {
        console.error('[ThemeDist Admin Error] Failed to fetch review list:', err);
        if (loadingEl) loadingEl.style.display = 'none';
        if (errorEl) errorEl.style.display = 'block';
      }
    }

    // ── Recently Approved Rendering ──
    let rollbackTimer = 0;
    function formatRemaining(approvedAt) {
      const remaining = approvedAt + 86400000 - Date.now(); // 24h window
      if (remaining <= 0) return { text: '已归档', expired: true };
      const h = Math.floor(remaining / 3600000);
      const m = Math.floor((remaining % 3600000) / 60000);
      if (h > 0) return { text: `剩余 ${h}h ${m}m 可撤回`, expired: false, urgent: h < 2 };
      return { text: `剩余 ${m}m 可撤回`, expired: false, urgent: true };
    }

    function renderRecentlyApproved(items) {
      if (!recentlyApprovedSection || !recentlyApprovedList) return;
      recentlyApprovedSection.style.display = 'block';

      if (!items || items.length === 0) {
        recentlyApprovedList.innerHTML = '<div class="card card-glass" style="padding:20px;text-align:center"><p class="text-muted" style="font-size:13px">暂无 24 小时内通过的主题</p></div>';
        if (recentlyApprovedCount) recentlyApprovedCount.textContent = '0';
        clearInterval(rollbackTimer);
        return;
      }
      if (recentlyApprovedCount) recentlyApprovedCount.textContent = String(items.length);

      recentlyApprovedList.innerHTML = items.map(t => {
        const remaining = formatRemaining(t.approvedAt || 0);
        const dateStr = new Date(t.createdAt).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
        return `
          <div class="rollback-card" id="rollback-${t.id}">
            <div class="rollback-info">
              <div class="rollback-name">${escapeHtml(t.name)}</div>
              <div class="rollback-meta">
                <span>${escapeHtml(t.author)}</span>
                <span>·</span>
                <span>提交于 ${dateStr}</span>
                ${t.reviewedBy ? `<span>·</span><span style="color:var(--color-primary)">审核: ${escapeHtml(t.reviewedBy)}</span>` : ''}
              </div>
            </div>
            <span class="rollback-time ${remaining.expired ? 'rollback-time-expired' : remaining.urgent ? 'rollback-time-urgent' : ''}" data-rollback-time="${t.id}" data-approved-at="${t.approvedAt || 0}">${remaining.text}</span>
            <button class="btn-rollback" data-rollback-id="${t.id}" ${remaining.expired ? 'disabled' : ''}>${remaining.expired ? '已归档' : '撤回至待审'}</button>
          </div>
        `;
      }).join('');

      // Bind rollback buttons
      recentlyApprovedList.querySelectorAll('.btn-rollback:not([disabled])').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.rollbackId || '';
          if (!await confirmDialog('确认撤回至待审？\n\n撤回后，该主题将从公共社区下架，并回到待审列表中。主题的原始提交时间将保持不变。', true)) return;
          try {
            const res = await fetch('/api/v1/admin/review.json', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
              body: JSON.stringify({ action: 'rollback', id }),
            });
            const data = await res.json();
            if (data.success) {
              window.__toast?.('已撤回至待审列表');
              loadThemes();
            } else {
              window.__toast?.(data.error || '撤回失败', 'error');
            }
          } catch {
            window.__toast?.('撤回请求失败', 'error');
          }
        });
      });

      // Live countdown timer (update every 30s)
      clearInterval(rollbackTimer);
      rollbackTimer = setInterval(() => {
        recentlyApprovedList.querySelectorAll('[data-rollback-time]').forEach(el => {
          const approvedAt = parseInt(el.dataset.approvedAt || '0');
          const remaining = formatRemaining(approvedAt);
          el.textContent = remaining.text;
          el.className = 'rollback-time ' + (remaining.expired ? 'rollback-time-expired' : remaining.urgent ? 'rollback-time-urgent' : '');
          const btn = recentlyApprovedList.querySelector(`[data-rollback-id="${el.dataset.rollbackId}"]`);
          if (btn) {
            if (remaining.expired) {
              btn.disabled = true;
              btn.textContent = '已归档';
            }
          }
        });
      }, 30000);
    }

    // Select all
    selectAll?.addEventListener('change', () => {
      if (selectAll.checked) {
        themes.forEach(t => selected.add(t.id));
      } else {
        selected.clear();
      }
      updateSelection();
    });

    // Approve
    btnApprove?.addEventListener('click', async () => {
      if (selected.size === 0) return;
      if (!await confirmDialog(`确认通过选中的 ${selected.size} 个主题？\n\n通过后该主题将发布至社区商店，并有机会进入每日主题轮换池。你在 24 小时内仍可将其撤回。`)) return;
      btnApprove.disabled = true;
      btnReject.disabled = true;
      try {
        const res = await fetch('/api/v1/admin/review.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          body: JSON.stringify({ action: 'approve', ids: Array.from(selected) }),
        });
        const data = await res.json();
        if (data.success) {
          window.__toast?.(`成功批准 ${data.done} 个社区主题`);
          loadThemes();
        } else {
          window.__toast?.(data.error || '操作失败');
        }
      } catch {
        window.__toast?.('服务端发生错误，批准失败');
      }
      btnApprove.disabled = true;
      btnReject.disabled = true;
    });

    // Reject
    btnReject?.addEventListener('click', async () => {
      if (selected.size === 0) return;
      if (!await confirmDialog(`确定要彻底驳回并抹除这 ${selected.size} 个主题设计吗？本操作无法后撤。`, true)) return;
      btnApprove.disabled = true;
      btnReject.disabled = true;
      try {
        const res = await fetch('/api/v1/admin/review.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          body: JSON.stringify({ action: 'reject', ids: Array.from(selected) }),
        });
        const data = await res.json();
        if (data.success) {
          window.__toast?.(`已抹除并回退 ${data.done} 个不合规主题`);
          loadThemes();
        } else {
          window.__toast?.(data.error || '驳回操作失败');
        }
      } catch {
        window.__toast?.('服务端响应异常');
      }
      btnApprove.disabled = true;
      btnReject.disabled = true;
    });

    btnRefresh?.addEventListener('click', loadThemes);
    btnRetry?.addEventListener('click', loadThemes);

    // Dynamic Swatch click copies hex value directly
    listEl?.addEventListener('click', (e) => {
      const swatch = e.target.closest('[data-swatch-hex]');
      if (swatch) {
        e.stopPropagation();
        const hex = swatch.getAttribute('data-swatch-hex');
        if (hex) {
          navigator.clipboard.writeText(hex).then(() => {
            window.__toast?.(`颜色值 ${hex} 已单独复制`);
          });
        }
        return;
      }

      // Copy complete theme code delegation
      const btn = e.target.closest('[data-copy-theme]');
      if (btn) {
        e.stopPropagation();
        const code = btn.getAttribute('data-copy-theme');
        if (code) {
          try {
            const parsed = JSON.parse(code);
            navigator.clipboard.writeText(JSON.stringify(parsed, null, 2)).then(() => {
              window.__toast?.('完整主题代码已复制，可粘贴至构建器导入');
            }).catch(() => {
              window.__toast?.('复制失败');
            });
          } catch {
            window.__toast?.('数据解析异常');
          }
        }
      }
    });

    // ─── Status Override Controls ───
    const statusIndicator = document.getElementById('status-indicator');
    const btnDeactivateOverride = document.getElementById('btn-deactivate-override');
    const activateBtns = document.querySelectorAll<HTMLElement>('.status-btn[data-action="activate"]');
    let currentOverrideStatus = '';

    const STATUS_LABELS: Record<string, string> = {
      maintenance: '维护模式',
      mourning: '哀悼模式',
      incident: '事件模式',
    };

    function updateOverrideUI(active: boolean, status?: string) {
      if (!statusIndicator) return;
      if (active && status) {
        currentOverrideStatus = status;
        statusIndicator.textContent = STATUS_LABELS[status] || status;
        statusIndicator.className = `status-badge status-badge-${status}`;
        if (btnDeactivateOverride) (btnDeactivateOverride as HTMLButtonElement).disabled = false;
        activateBtns.forEach(btn => {
          if (btn.dataset.status === status) {
            (btn as HTMLButtonElement).disabled = true;
          } else {
            (btn as HTMLButtonElement).disabled = false;
          }
        });
      } else {
        currentOverrideStatus = '';
        statusIndicator.textContent = '正常运行';
        statusIndicator.className = 'status-badge status-badge-normal';
        if (btnDeactivateOverride) (btnDeactivateOverride as HTMLButtonElement).disabled = true;
        activateBtns.forEach(btn => { (btn as HTMLButtonElement).disabled = false; });
      }
    }

    async function loadOverrideStatus() {
      try {
        const res = await fetch('/api/v1/admin/status-override.json');
        if (!res.ok) return;
        const data = await res.json();
        updateOverrideUI(data.active, data.status);
      } catch (e) {
        console.error('[ThemeDist Admin] Failed to load override status:', e);
      }
    }

    async function setOverride(action: string, status?: string) {
      try {
        const body: Record<string, string> = { action };
        if (status) body.status = status;
        const res = await fetch('/api/v1/admin/status-override.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (data.success) {
          if (action === 'activate') {
            window.__toast?.(`已激活 ${STATUS_LABELS[status || '']} 覆盖`);
            updateOverrideUI(true, status);
          } else {
            window.__toast?.('已恢复正常主题');
            updateOverrideUI(false);
          }
        } else {
          window.__toast?.(data.error || '操作失败');
        }
      } catch {
        window.__toast?.('服务端响应异常');
      }
    }

    activateBtns.forEach(btn => {
      btn.addEventListener('click', async () => {
        const status = btn.dataset.status || '';
        const label = STATUS_LABELS[status] || status;
        if (!await confirmDialog(`确定要启用「${label}」吗？全站主题将被立即覆盖，所有访问者将看到紧急状态主题。`, true)) return;
        setOverride('activate', status);
      });
    });

    btnDeactivateOverride?.addEventListener('click', async () => {
      if (!await confirmDialog('确定要恢复正常主题吗？所有访问者将立即恢复看到每日主题。')) return;
      setOverride('deactivate');
    });

    loadOverrideStatus();

    loadThemes();
  }

  function isLightReview(hex) {
    const c = hex.replace('#', '');
    const r = parseInt(c.slice(0, 2), 16);
    const g = parseInt(c.slice(2, 4), 16);
    const b = parseInt(c.slice(4, 6), 16);
    return (0.299 * r + 0.587 * g + 0.114 * b) > 150;
  }

  function hexToRgbaReview(hex, alpha) {
    const c = hex.replace('#', '');
    const r = parseInt(c.slice(0, 2), 16);
    const g = parseInt(c.slice(2, 4), 16);
    const b = parseInt(c.slice(4, 6), 16);
    return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
  }

  // 安全转义函数
  function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function escapeAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // ── Moderation ──
  async function moderateTheme(id) {
    const card = document.querySelector(`[data-id="${id}"]`);
    if (!card) return;
    const existingBadge = card.querySelector('.moderation-result');
    if (existingBadge) { existingBadge.remove(); return; }

    try {
      const csrf = document.cookie.match(/csrf_token=([^;]+)/)?.[1] || '';
      const res = await fetch('/api/v1/admin/moderate.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
        body: JSON.stringify({ id }),
      });
      const data = await res.json();
      const badge = document.createElement('div');
      badge.className = 'moderation-result';
      if (data.safe) {
        badge.innerHTML = '<span class="mod-safe">✓ 安全</span>';
      } else {
        const issues = (data.issues || []).map(i => {
          const icon = i.severity === 'critical' ? '🔴' : '🟡';
          return `<div class="mod-issue">${icon} <strong>${i.category}</strong>: ${escapeHtml(i.description)}</div>`;
        }).join('');
        badge.innerHTML = `<div class="mod-unsafe">⚠ 发现问题</div>${issues}`;
      }
      card.querySelector('.review-header')?.appendChild(badge);
    } catch {
      window.__toast?.('审查请求失败');
    }
  }
  window.moderateTheme = moderateTheme;
</script>
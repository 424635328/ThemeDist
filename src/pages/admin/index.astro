---
import Layout from '../../layouts/Layout.astro';
import { isAdmin } from '../../lib/auth';

const authed = isAdmin(Astro.cookies);
const siteUrl = Astro.url.origin;
---

<Layout>
  <!-- Data Bridge Container (彻底弃用 define:vars 注入，采用标准 DOM data-* 传递，杜绝 inline script 崩溃) -->
  <div 
    id="admin-dashboard-container"
    data-authed={authed ? 'true' : 'false'}
    data-site-url={siteUrl}
  >
    {!authed ? (
      <section class="section text-center" style="max-width:420px;margin:0 auto">
        <p class="t-label">Admin</p>
        <h1 class="t-heading mt-2">管理员登录</h1>

        <div class="card card-glass" style="padding:32px;margin-top:32px;text-align:left">
          <form id="login-form">
            <div style="margin-bottom:18px">
              <label style="display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:var(--color-text)">账号</label>
              <input
                type="text"
                name="account"
                id="login-account"
                autocomplete="username"
                placeholder="输入管理员账号"
                style="width:100%;height:44px;padding:0 14px;border-radius:12px;border:1.5px solid var(--color-border);background:color-mix(in srgb, var(--color-surface) 40%, transparent);color:var(--color-text);font-size:14px;font-family:inherit;outline:none;transition:border-color 0.2s"
              />
            </div>
            <div style="margin-bottom:24px">
              <label style="display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:var(--color-text)">密码</label>
              <input
                type="password"
                name="password"
                id="login-password"
                autocomplete="current-password"
                placeholder="输入管理员密码"
                style="width:100%;height:44px;padding:0 14px;border-radius:12px;border:1.5px solid var(--color-border);background:color-mix(in srgb, var(--color-surface) 40%, transparent);color:var(--color-text);font-size:14px;font-family:inherit;outline:none;transition:border-color 0.2s"
              />
            </div>
            <p id="login-error" style="color:#ef4444;font-size:13px;font-weight:600;margin-bottom:12px;display:none"></p>
            <button type="submit" class="btn btn-primary" style="width:100%;height:46px;font-size:14px;font-family:inherit">
              登录
            </button>
          </form>
        </div>
      </section>
    ) : (
      <section class="section-sm">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:24px">
          <div>
            <p class="t-label">Admin Dashboard</p>
            <h1 class="t-heading mt-2" style="font-size:26px">审核社区主题</h1>
          </div>
          <div style="display:flex;align-items:center;gap:12px">
            <span id="pending-count-badge" style="font-size:13px;font-weight:600;padding:6px 14px;border-radius:8px;background:color-mix(in srgb, var(--color-primary) 12%, transparent);color:var(--color-primary)">加载中…</span>
            <button id="btn-logout" class="btn btn-outline" style="height:38px;padding:0 16px;font-size:12px;font-family:inherit">退出登录</button>
          </div>
        </div>

        <!-- System Dangling Keys Warn Box (脏数据异常诊断面板，自动感知数据不一致) -->
        <div id="dangling-keys-warning" class="card" style="display:none;padding:18px 24px;border:1.5px solid rgba(245, 158, 11, 0.4);background:color-mix(in srgb, #f59e0b 8%, transparent);margin-bottom:20px;border-radius:12px">
          <div style="display:flex;align-items:center;gap:10px;color:#f59e0b;font-weight:700;font-size:14px;margin-bottom:6px">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M8 2l6 11H2L8 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 6v3.5M8 11.5h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            ⚠️ 检测到系统脏数据不一致异常
          </div>
          <p style="font-size:13px;color:var(--color-text-muted);line-height:1.5;margin:0">
            当前数据库反馈待审核总数为 <strong id="dangling-badge-count" style="color:var(--color-primary)">0</strong> 个，但未获取到任何有效的主题详情内容。<br/>
            这通常是由于以前直接抹除或不规范重置 Redis 导致**索引残留（悬空键）**。您可以点击右侧“刷新”重试，或联系系统管理员清空 Redis 中 <code>themes:pending</code> 集合的多余 ID。
          </p>
        </div>

        <!-- Toolbar -->
        <div id="toolbar" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px">
          <label style="display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--color-text);cursor:pointer;user-select:none">
            <input type="checkbox" id="select-all" style="width:16px;height:16px;accent-color:var(--color-primary);cursor:pointer" />
            全选
          </label>
          <span id="selected-count" style="font-size:12px;color:var(--color-text-muted)">已选 0</span>
          <div style="flex:1"></div>
          <button id="btn-approve" class="btn btn-primary" style="height:38px;padding:0 18px;font-size:12px;font-family:inherit" disabled>
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            审核通过
          </button>
          <button id="btn-reject" class="btn btn-outline" style="height:38px;padding:0 18px;font-size:12px;font-family:inherit;color:#ef4444;border-color:#ef444455" disabled>
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            驳回删除
          </button>
          <button id="btn-refresh" class="btn btn-ghost" style="height:38px;padding:0 14px;font-size:12px;font-family:inherit">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0110.47-4M14 8a6 6 0 01-10.47 4M2 2v4h4M14 14v-4h-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            刷新
          </button>
        </div>

        <!-- Loading -->
        <div id="loading-state-admin" style="text-align:center;padding:60px 20px">
          <div class="spinner-lg" style="width:36px;height:36px;border:3px solid var(--color-border);border-top-color:var(--color-primary);border-radius:50%;animation:spin 0.7s linear infinite;margin:0 auto 16px"></div>
          <p class="text-muted" style="font-size:14px">加载待审核主题…</p>
        </div>

        <!-- Empty state -->
        <div id="empty-state" style="display:none;text-align:center;padding:60px 20px">
          <div style="font-size:48px;margin-bottom:12px">🎉</div>
          <h2 style="font-size:20px;margin-bottom:6px">没有待审核主题</h2>
          <p class="text-muted" style="font-size:14px">所有社区主题已处理完毕</p>
        </div>

        <!-- Theme list -->
        <div id="theme-list-admin" style="display:flex;flex-direction:column;gap:12px;max-width:960px;margin:0 auto"></div>

        <!-- Error -->
        <div id="error-state-admin" style="display:none;text-align:center;padding:60px 20px">
          <div style="font-size:48px;margin-bottom:12px">⚠️</div>
          <h2 style="font-size:20px;margin-bottom:6px">加载失败</h2>
          <p class="text-muted" style="font-size:14px;margin-bottom:16px">可能是数据库连接问题</p>
          <button id="btn-retry" class="btn btn-primary" style="height:38px;padding:0 18px;font-size:12px;font-family:inherit">重试</button>
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  #login-form input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 12%, transparent);
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  #btn-approve:disabled, #btn-reject:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  /* ─── Review Card ─── */
  .review-card {
    padding: 0;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
  }
  .review-card:hover {
    transform: translateY(-1px);
  }
  .review-card.selected {
    border-color: var(--rv-primary, var(--color-primary)) !important;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--rv-primary, var(--color-primary)) 30%, transparent),
                0 8px 32px -8px rgba(0,0,0,0.2);
  }

  .review-card-top-bar {
    height: 4px;
    transition: height 0.25s;
  }
  .review-card:hover .review-card-top-bar {
    height: 6px;
  }

  .review-card-body {
    display: flex;
    gap: 0;
    padding: 20px;
  }

  .review-left {
    padding-right: 14px;
    padding-top: 2px;
    flex-shrink: 0;
  }
  .review-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--rv-primary, var(--color-primary));
    cursor: pointer;
    border-radius: 5px;
  }

  .review-main {
    flex: 1;
    min-width: 0;
  }

  /* ─── Header ─── */
  .review-header {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .review-title {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .review-badge-pending {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 6px;
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.2);
  }
  .review-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #f59e0b;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  .review-ttl {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-left: auto;
    font-variant-numeric: tabular-nums;
  }
  .review-ttl.ttl-warn { color: #f59e0b; }
  .review-ttl.ttl-urgent { color: #ef4444; font-weight: 600; }

  /* ─── Meta ─── */
  .review-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 14px;
    font-size: 12px;
  }
  .review-author-avatar {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .review-author-name {
    font-weight: 600;
    color: var(--color-text);
  }
  .review-meta-sep {
    color: var(--color-text-muted);
    opacity: 0.35;
    font-weight: 700;
  }
  .review-meta-date {
    color: var(--color-text-muted);
  }
  .review-meta-extra {
    color: var(--color-text-muted);
  }
  .review-meta-tag {
    font-size: 10px;
    font-weight: 600;
    padding: 1px 7px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--rv-primary, var(--color-primary)) 12%, transparent);
    color: var(--rv-primary, var(--color-primary));
  }

  /* ─── Swatches ─── */
  .review-swatches {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .review-swatch {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px 5px 5px;
    border-radius: 9px;
    background: color-mix(in srgb, var(--rv-surface, var(--color-surface)) 40%, transparent);
    border: 1px solid var(--color-border);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .review-swatch:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  .review-swatch-color {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .review-swatch-letter {
    font-size: 9px;
    font-weight: 700;
    line-height: 1;
  }
  .review-swatch-hex {
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* ─── Preview Chip ─── */
  .review-preview-chip {
    padding: 14px;
    margin-bottom: 14px;
    position: relative;
    overflow: hidden;
  }
  .review-preview-chip::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 100% 0%, var(--rv-primary, var(--color-primary)) 0%, transparent 70%);
    opacity: 0.04;
    pointer-events: none;
  }
  .preview-chip-inner {
    position: relative;
    z-index: 1;
  }
  .preview-chip-header {
    margin-bottom: 10px;
  }
  .preview-chip-muted {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .preview-chip-buttons {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }
  .preview-chip-btn-primary {
    display: inline-block;
    padding: 5px 14px;
    font-size: 10px;
    font-weight: 600;
    color: #fff;
  }
  .preview-chip-btn-ghost {
    display: inline-block;
    padding: 5px 14px;
    font-size: 10px;
    font-weight: 600;
    background: transparent;
  }
  .preview-chip-card {
    padding: 10px 12px;
  }
  .preview-chip-card-title {
    display: block;
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 3px;
  }
  .preview-chip-card-desc {
    font-size: 10px;
    line-height: 1.4;
  }

  /* ─── Actions ─── */
  .review-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .review-action-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 600;
    color: var(--rv-primary, var(--color-primary));
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .review-action-link:hover {
    background: color-mix(in srgb, var(--rv-primary, var(--color-primary)) 8%, transparent);
  }
  .review-action-copy {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-muted);
    background: none;
    border: 1px solid var(--color-border);
    padding: 5px 10px;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
  }
  .review-action-copy:hover {
    border-color: var(--rv-primary, var(--color-primary));
    color: var(--rv-primary, var(--color-primary));
    background: color-mix(in srgb, var(--rv-primary, var(--color-primary)) 6%, transparent);
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .review-card-body {
      padding: 14px;
    }
    .review-header {
      gap: 6px;
    }
    .review-title {
      font-size: 14px;
      width: 100%;
    }
    .review-ttl {
      margin-left: 0;
    }
    .review-swatches {
      gap: 6px;
    }
    .review-swatch {
      padding: 4px 7px 4px 4px;
    }
    .review-swatch-hex {
      font-size: 10px;
    }
    .preview-chip-buttons {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>

<script>
  // ─── Login ───
  const loginForm = document.getElementById('login-form');
  if (loginForm) {
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const accountEl = document.getElementById('login-account');
      const passwordEl = document.getElementById('login-password');
      const account = accountEl ? accountEl.value.trim() : '';
      const password = passwordEl ? passwordEl.value.trim() : '';
      const errorEl = document.getElementById('login-error');

      if (!account || !password) {
        errorEl.textContent = '请填写账号和密码';
        errorEl.style.display = 'block';
        return;
      }

      try {
        const res = await fetch('/api/admin/login.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ account, password }),
        });
        const data = await res.json();
        if (res.ok && data.success) {
          location.reload();
        } else {
          errorEl.textContent = data.error || '登录失败';
          errorEl.style.display = 'block';
        }
      } catch {
        errorEl.textContent = '网络错误，请稍后重试';
        errorEl.style.display = 'block';
      }
    });
  }

  // ─── Logout ───
  const btnLogout = document.getElementById('btn-logout');
  if (btnLogout) {
    btnLogout.addEventListener('click', async () => {
      await fetch('/api/admin/login.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'logout' }),
      });
      location.reload();
    });
  }

  // ─── Admin dashboard ───
  if (!loginForm) {
    const loadingEl = document.getElementById('loading-state-admin');
    const emptyEl = document.getElementById('empty-state');
    const errorEl = document.getElementById('error-state-admin');
    const listEl = document.getElementById('theme-list-admin');
    const selectAll = document.getElementById('select-all');
    const selectedCount = document.getElementById('selected-count');
    const btnApprove = document.getElementById('btn-approve');
    const btnReject = document.getElementById('btn-reject');
    const btnRefresh = document.getElementById('btn-refresh');
    const btnRetry = document.getElementById('btn-retry');
    const countBadge = document.getElementById('pending-count-badge');
    const toolbar = document.getElementById('toolbar');
    const warningBox = document.getElementById('dangling-keys-warning');
    const warningBadgeCount = document.getElementById('dangling-badge-count');

    let themes = [];
    let selected = new Set();

    function updateSelection() {
      const cards = listEl?.querySelectorAll('.review-card') || [];
      cards.forEach(card => {
        const id = card.dataset.id || '';
        card.classList.toggle('selected', selected.has(id));
        const cb = card.querySelector('.review-checkbox');
        if (cb) cb.checked = selected.has(id);
      });
      if (selectedCount) {
        selectedCount.textContent = `已选 ${selected.size}`;
      }
      const hasSelection = selected.size > 0;
      if (btnApprove) btnApprove.disabled = !hasSelection;
      if (btnReject) btnReject.disabled = !hasSelection;
      if (selectAll) {
        selectAll.checked = themes.length > 0 && selected.size === themes.length;
        selectAll.indeterminate = selected.size > 0 && selected.size < themes.length;
      }
    }

    function toggleTheme(id) {
      if (selected.has(id)) selected.delete(id);
      else selected.add(id);
      updateSelection();
    }

    function renderCard(t) {
      const v = t.cssVars || {};
      const p = v['--color-primary'] || '#6366f1';
      const s = v['--color-secondary'] || '#8b5cf6';
      const a = v['--color-accent'] || '#06b6d4';
      const bg = v['--color-bg'] || '#0f0f23';
      const tx = v['--color-text'] || '#f4f4f5';
      const surface = v['--color-surface'] || bg;
      const muted = v['--color-text-muted'] || tx;
      const radii = v['--radii'] || '10px';
      const d = new Date(t.createdAt);
      const dateStr = d.getTime() ? d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';
      const authorInitial = (t.author || '?')[0].toUpperCase();

      // TTL countdown
      const ageMs = Date.now() - d.getTime();
      const ttlMs = 86400000 - ageMs;
      const ttlHours = Math.max(0, Math.floor(ttlMs / 3600000));
      const ttlMins = Math.max(0, Math.floor((ttlMs % 3600000) / 60000));
      const ttlUrgent = ttlMs < 3600000;
      const ttlWarn = ttlMs < 14400000;

      // CSS var count
      const varCount = Object.keys(v).length;

      // Has custom CSS?
      const hasCustomCSS = t.customCss && t.customCss.trim().length > 0;

      // Generate preview chip colors
      const chipBg = bg;
      const chipSurface = surface;
      const chipText = tx;
      const chipMuted = muted;

      return `
        <div class="card card-interact review-card" data-id="${escapeAttr(t.id)}" style="--rv-primary:${p};--rv-bg:${bg};--rv-text:${tx};--rv-surface:${surface};--rv-muted:${muted};--rv-radii:${radii}">
          <div class="review-card-top-bar" style="background:linear-gradient(90deg, ${p} 0%, ${s} 50%, ${a} 100%)"></div>
          <div class="review-card-body">
            <div class="review-left">
              <input type="checkbox" class="review-checkbox" />
            </div>
            <div class="review-main">
              <div class="review-header">
                <h3 class="review-title">${escapeHtml(t.name)}</h3>
                <span class="review-badge-pending">
                  <span class="review-badge-dot"></span>
                  待审核
                </span>
                <span class="review-ttl ${ttlUrgent ? 'ttl-urgent' : ttlWarn ? 'ttl-warn' : ''}" title="自动过期倒计时">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 4v5l3 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                  ${ttlMs <= 0 ? '已过期' : ttlHours > 0 ? ttlHours + 'h ' + ttlMins + 'm' : ttlMins + 'm'}
                </span>
              </div>
              <div class="review-meta">
                <span class="review-author-avatar" style="background:${p};color:${isLightReview(p) ? '#0f0f23' : '#fff'}">${authorInitial}</span>
                <span class="review-author-name">${escapeHtml(t.author)}</span>
                <span class="review-meta-sep">·</span>
                <span class="review-meta-date">${dateStr}</span>
                <span class="review-meta-sep">·</span>
                <span class="review-meta-extra">${varCount} CSS 变量</span>
                ${hasCustomCSS ? '<span class="review-meta-sep">·</span><span class="review-meta-tag">含自定义 CSS</span>' : ''}
              </div>

              <div class="review-swatches">
                ${[
                  { l: 'P', c: p, key: '--color-primary', desc: '主色' },
                  { l: 'S', c: s, key: '--color-secondary', desc: '辅色' },
                  { l: 'A', c: a, key: '--color-accent', desc: '强调' },
                  { l: 'Bg', c: bg, key: '--color-bg', desc: '背景' },
                  { l: 'Tx', c: tx, key: '--color-text', desc: '文字' },
                ].map(({ l, c, key, desc }) => `
                  <div class="review-swatch" title="${key}: ${c} (${desc})">
                    <span class="review-swatch-color" style="background:${c};border:${key === '--color-bg' ? '1.5px solid var(--color-border)' : 'none'}">
                      <span class="review-swatch-letter" style="color:${key === '--color-text' ? bg : tx};text-shadow:0 0 2px ${bg}">${l}</span>
                    </span>
                    <span class="review-swatch-hex">${c}</span>
                  </div>
                `).join('')}
              </div>

              <div class="review-preview-chip" style="background:${chipBg};border-radius:${radii};border:1px solid ${hexToRgbaReview(p, 0.15)}">
                <div class="preview-chip-inner">
                  <div class="preview-chip-header">
                    <span class="preview-chip-muted" style="color:${chipMuted}">Preview</span>
                  </div>
                  <div class="preview-chip-buttons">
                    <span class="preview-chip-btn-primary" style="background:${p};border-radius:calc(${radii} / 2)">主要按钮</span>
                    <span class="preview-chip-btn-ghost" style="border:1.5px solid ${hexToRgbaReview(p, 0.3)};color:${p};border-radius:calc(${radii} / 2)">次要按钮</span>
                  </div>
                  <div class="preview-chip-card" style="background:${chipSurface};border-radius:calc(${radii} / 1.5);border:1.5px solid ${hexToRgbaReview(p, 0.12)}">
                    <span class="preview-chip-card-title" style="color:${chipText}">卡片标题</span>
                    <span class="preview-chip-card-desc" style="color:${chipMuted}">正文示例文本，展示字色对比度</span>
                  </div>
                </div>
              </div>

              <div class="review-actions">
                <a href="/share?id=${escapeAttr(t.id)}" target="_blank" class="review-action-link" onclick="event.stopPropagation()">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/><circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
                  在新标签页预览
                </a>
                <button class="review-action-copy" data-copy-vars="${escapeAttr(JSON.stringify(v))}" title="复制 CSS 变量 JSON">
                  <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><rect x="4" y="4" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 6v8a2 2 0 002 2h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  复制 CSS 变量
                </button>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    async function loadThemes() {
      if (!loadingEl || !listEl) return;
      loadingEl.style.display = 'block';
      if (emptyEl) emptyEl.style.display = 'none';
      if (errorEl) errorEl.style.display = 'none';
      if (warningBox) warningBox.style.display = 'none';
      listEl.innerHTML = '';
      if (toolbar) toolbar.style.display = 'none';
      selected.clear();
      updateSelection();

      try {
        const res = await fetch('/api/admin/review.json');
        if (!res.ok) throw new Error('Failed');
        const data = await res.json();
        
        // 🛡️ 调试哨兵：如果遇到 Bug，在 F12 控制台一秒即可发现数据结构长什么样
        console.log('[ThemeDist Admin Monitor] Raw response data:', data);

        // 防御性映射：兼容后端 API 返回 themes、list 或 data 等不同命名可能
        themes = data.themes || data.list || data.data || [];
        const pendingCount = data.pending || 0;

        if (countBadge) {
          countBadge.textContent = `待审核: ${pendingCount}`;
        }

        loadingEl.style.display = 'none';

        // ⚠️ 核心脏数据捕获：待审核数量 > 0，但实际拉取到的具体内容却为空（表明 Redis themes:pending 有悬空索引）
        if (pendingCount > 0 && themes.length === 0) {
          if (warningBox) {
            if (warningBadgeCount) warningBadgeCount.textContent = String(pendingCount);
            warningBox.style.display = 'block';
          }
          // Keep toolbar visible so the refresh button is accessible
          if (toolbar) toolbar.style.display = 'flex';
          return;
        }

        if (themes.length === 0) {
          if (emptyEl) emptyEl.style.display = 'block';
          return;
        }

        if (toolbar) toolbar.style.display = 'flex';
        listEl.innerHTML = themes.map(t => {
          try { return renderCard(t); } catch(e) { console.error('Render card error:', e); return ''; }
        }).join('');

        // Bind events
        listEl.querySelectorAll('.review-card').forEach(card => {
          const el = card;
          el.addEventListener('click', (e) => {
            const target = e.target;
            if (target.tagName === 'A' || target.closest('a') || target.closest('button')) return;
            const cb = el.querySelector('.review-checkbox');
            if (cb) {
              cb.checked = !cb.checked;
              toggleTheme(el.dataset.id || '');
            }
          });
        });

        listEl.querySelectorAll('.review-checkbox').forEach(cb => {
          cb.addEventListener('click', (e) => {
            e.stopPropagation();
            const card = e.target.closest('.review-card');
            if (card) {
              toggleTheme(card.dataset.id || '');
            }
          });
        });

        updateSelection();
      } catch (err) {
        console.error('[ThemeDist Admin Error] Failed to fetch review list:', err);
        loadingEl.style.display = 'none';
        if (errorEl) errorEl.style.display = 'block';
      }
    }

    // Select all
    selectAll?.addEventListener('change', () => {
      if (selectAll.checked) {
        themes.forEach(t => selected.add(t.id));
      } else {
        selected.clear();
      }
      updateSelection();
    });

    // Approve
    btnApprove?.addEventListener('click', async () => {
      if (selected.size === 0) return;
      btnApprove.disabled = true;
      btnReject.disabled = true;
      try {
        const res = await fetch('/api/admin/review.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'approve', ids: Array.from(selected) }),
        });
        const data = await res.json();
        if (data.success) {
          window.__toast?.(`已通过 ${data.done} 个主题`);
          loadThemes();
        } else {
          window.__toast?.(data.error || '操作失败');
        }
      } catch {
        window.__toast?.('操作失败，请稍后重试');
      }
      btnApprove.disabled = true;
      btnReject.disabled = true;
    });

    // Reject
    btnReject?.addEventListener('click', async () => {
      if (selected.size === 0) return;
      if (!confirm(`确定驳回并删除选中的 ${selected.size} 个主题吗？此操作不可撤销。`)) return;
      btnApprove.disabled = true;
      btnReject.disabled = true;
      try {
        const res = await fetch('/api/admin/review.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'reject', ids: Array.from(selected) }),
        });
        const data = await res.json();
        if (data.success) {
          window.__toast?.(`已驳回删除 ${data.done} 个主题`);
          loadThemes();
        } else {
          window.__toast?.(data.error || '操作失败');
        }
      } catch {
        window.__toast?.('操作失败，请稍后重试');
      }
      btnApprove.disabled = true;
      btnReject.disabled = true;
    });

    btnRefresh?.addEventListener('click', loadThemes);
    btnRetry?.addEventListener('click', loadThemes);

    // Copy CSS variables delegation
    listEl?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-copy-vars]');
      if (!btn) return;
      e.stopPropagation();
      const vars = btn.getAttribute('data-copy-vars');
      if (vars) {
        navigator.clipboard.writeText(vars).then(() => {
          window.__toast?.('CSS 变量已复制到剪贴板');
        }).catch(() => {
          window.__toast?.('复制失败');
        });
      }
    });

    loadThemes();
  }

  function isLightReview(hex) {
    const c = hex.replace('#', '');
    const r = parseInt(c.slice(0, 2), 16);
    const g = parseInt(c.slice(2, 4), 16);
    const b = parseInt(c.slice(4, 6), 16);
    return (0.299 * r + 0.587 * g + 0.114 * b) > 150;
  }

  function hexToRgbaReview(hex, alpha) {
    const c = hex.replace('#', '');
    const r = parseInt(c.slice(0, 2), 16);
    const g = parseInt(c.slice(2, 4), 16);
    const b = parseInt(c.slice(4, 6), 16);
    return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
  }

  function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function escapeAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
---
import Layout from '../../layouts/Layout.astro';
import { isAdmin } from '../../lib/auth';

const authed = isAdmin(Astro.cookies);
const siteUrl = Astro.url.origin;
---

<Layout>
  <!-- Data Bridge Container (采用标准 DOM 传递 data) -->
  <div 
    id="admin-dashboard-container"
    data-authed={authed ? 'true' : 'false'}
    data-site-url={siteUrl}
  >
    {!authed ? (
      <section class="section text-center login-section">
        <div class="login-container">
          <div class="login-brand">
            <div class="login-logo-shield">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <p class="t-label">Security Gate</p>
            <h1 class="t-heading mt-2">管理员鉴权</h1>
          </div>

          <div class="card card-glass login-card">
            <form id="login-form">
              <div class="form-group">
                <label class="form-label">账号</label>
                <div class="input-wrapper">
                  <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  </span>
                  <input
                    type="text"
                    name="account"
                    id="login-account"
                    autocomplete="username"
                    placeholder="请输入管理员账号"
                    class="dashboard-input"
                  />
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">密码</label>
                <div class="input-wrapper">
                  <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  </span>
                  <input
                    type="password"
                    name="password"
                    id="login-password"
                    autocomplete="current-password"
                    placeholder="请输入密码"
                    class="dashboard-input"
                  />
                </div>
              </div>
              <p id="login-error" class="login-error-text"></p>
              <button type="submit" class="btn btn-primary login-btn">
                <span>验证登录</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
            </form>
          </div>
        </div>
      </section>
    ) : (
      <section class="section-sm admin-section">
        <div class="admin-header-row">
          <div>
            <p class="t-label admin-label">
              <span class="pulse-icon-green"></span>
              Admin Control Center
            </p>
            <h1 class="t-heading mt-1" style="font-size:28px">审核社区主题</h1>
          </div>
          <div class="admin-meta-controls">
            <span id="pending-count-badge" class="badge-pending-pill">加载中…</span>
            <button id="btn-logout" class="btn btn-outline logout-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              退出登录
            </button>
          </div>
        </div>

        <!-- Status Override Section -->
        <div id="status-override-section" class="status-override-card card card-glass">
          <div class="status-override-header">
            <p class="t-label" style="display:flex;align-items:center;gap:6px">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              Emergency Control
            </p>
            <h2 style="font-size:20px;font-weight:800;margin-top:4px">系统状态覆盖</h2>
          </div>
          <div class="status-override-body">
            <div class="status-indicator-row">
              <span class="status-indicator-label">当前状态:</span>
              <span id="status-indicator" class="status-badge status-badge-normal">正常运行</span>
            </div>
            <div class="status-override-btns">
              <button class="btn status-btn status-btn-maintenance" data-action="activate" data-status="maintenance">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                维护模式
              </button>
              <button class="btn status-btn status-btn-mourning" data-action="activate" data-status="mourning">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 18a5 5 0 0 0-10 0"/><line x1="12" y1="2" x2="12" y2="9"/><line x1="4.22" y1="10.22" x2="5.64" y2="11.64"/><line x1="1" y1="18" x2="3" y2="18"/><line x1="21" y1="18" x2="23" y2="18"/><line x1="18.36" y1="11.64" x2="19.78" y2="10.22"/><line x1="23" y1="22" x2="1" y2="22"/><line x1="16" y1="5" x2="19" y2="2"/><line x1="2" y1="2" x2="5" y2="5"/></svg>
                哀悼模式
              </button>
              <button class="btn status-btn status-btn-incident" data-action="activate" data-status="incident">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                事件模式
              </button>
              <button class="btn status-btn status-btn-deactivate" id="btn-deactivate-override" disabled>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                恢复正常
              </button>
            </div>
          </div>
        </div>

        <!-- System Dangling Keys Warn Box -->
        <div id="dangling-keys-warning" class="card dangling-warning-box">
          <div class="warning-title-row">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M8 2l6 11H2L8 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 6v3.5M8 11.5h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            待审索引可能失效 (Dangling Residual)
          </div>
          <p class="warning-text">
            Redis 待审核总数显示为 <strong id="dangling-badge-count">0</strong>，但并没有获取到对应数据详情。
            这往往是因为直接清理数据库造成的<strong>空悬索引残留</strong>。请点击「刷新」或让系统管理员在 Redis 中移去多余的 <code>themes:pending</code> 集合元素。
          </p>
        </div>

        <!-- Toolbar (Sticky floating control bar) -->
        <div id="toolbar" class="admin-toolbar">
          <div class="toolbar-left">
            <label class="select-all-label">
              <input type="checkbox" id="select-all" class="custom-checkbox" />
              <span>全选本页</span>
            </label>
            <span id="selected-count" class="selected-counter">已选 0 个主题</span>
          </div>
          <div class="toolbar-actions">
            <button id="btn-approve" class="btn btn-primary action-btn-green" disabled>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>通过选中</span>
            </button>
            <button id="btn-reject" class="btn btn-outline action-btn-red" disabled>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <span>批量驳回</span>
            </button>
            <button id="btn-refresh" class="btn btn-ghost action-btn-refresh">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0110.47-4M14 8a6 6 0 01-10.47 4M2 2v4h4M14 14v-4h-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>刷新</span>
            </button>
          </div>
        </div>

        <!-- Loading state -->
        <div id="loading-state-admin" class="loading-state-container">
          <div class="spinner-lg"></div>
          <p class="text-muted">正在获取主题快照，请稍后…</p>
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="empty-state-container">
          <div class="empty-icon">🎉</div>
          <h2>没有积压待审的主题</h2>
          <p class="text-muted">当前社区公共主题商店运行秩序井然，无残留任务。</p>
        </div>

        <!-- Theme list container -->
        <div id="theme-list-admin" class="theme-grid-admin"></div>

        <!-- Recently Approved (24h rollback window) -->
        <div id="recently-approved-section" style="display:none;margin-top:48px">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
            <h2 style="font-size:18px;font-weight:700;letter-spacing:-0.03em">近期通过 <span style="font-size:12px;font-weight:500;color:var(--color-text-muted)">（24 小时内可撤回）</span></h2>
            <span id="recently-approved-count" style="font-size:11px;font-weight:600;padding:3px 10px;border-radius:99px;background:color-mix(in srgb, var(--color-primary) 14%, transparent);color:var(--color-primary)">0</span>
          </div>
          <div id="recently-approved-list" class="theme-grid-admin"></div>
        </div>

        <!-- Error state -->
        <div id="error-state-admin" class="error-state-container">
          <div class="error-icon">⚠️</div>
          <h2>状态拉取失败</h2>
          <p class="text-muted">可能是网络会话过期或 Redis 服务断开连接。</p>
          <button id="btn-retry" class="btn btn-primary" style="margin-top:12px">重新连接</button>
        </div>
      </section>
    )}
  </div>
</Layout>

<!-- 💡 BINGO! 增加 is:global 关键字，彻底解除 Astro 样式对动态生成 DOM 树的局部隔离 -->
<style is:global>
  /* ─── Variables & Global Reset for Dashboard ─── */
  :root {
    --dash-transition: cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ─── Login Screen Design ─── */
  .login-section {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 200px);
    padding: 20px;
  }
  .login-container {
    width: 100%;
    max-width: 420px;
    animation: zoomInDash 0.4s var(--dash-transition);
  }
  @keyframes zoomInDash {
    from { opacity: 0; transform: scale(0.97) translateY(10px); }
  }
  .login-brand {
    text-align: center;
    margin-bottom: 24px;
  }
  .login-logo-shield {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
  }
  .login-card {
    padding: 32px;
    border-radius: 20px;
    border: 1px solid var(--color-border);
  }
  .form-group {
    margin-bottom: 18px;
    text-align: left;
  }
  .form-label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-icon {
    position: absolute;
    left: 14px;
    color: var(--color-text-muted);
    opacity: 0.6;
    display: flex;
    align-items: center;
  }
  .dashboard-input {
    width: 100%;
    height: 46px;
    padding: 0 14px 0 40px;
    border-radius: 12px;
    border: 1.5px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 35%, transparent);
    color: var(--color-text);
    font-size: 14px;
    outline: none;
    transition: all 0.25s var(--dash-transition);
  }
  .dashboard-input:focus {
    border-color: var(--color-primary);
    background: var(--color-surface);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-primary) 12%, transparent);
  }
  .login-error-text {
    color: #ef4444;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 14px;
    text-align: left;
    display: none;
    padding: 8px 12px;
    border-radius: 8px;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
  .login-btn {
    width: 100%;
    height: 48px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  /* ─── Admin Dashboard Layout ─── */
  .admin-section {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 16px 80px;
  }
  .admin-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
  }
  .admin-label {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pulse-icon-green {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.3);
    animation: livePulse 2s infinite;
  }
  @keyframes livePulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0px rgba(16, 185, 129, 0.4); }
    50% { transform: scale(1.1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
  }
  .admin-meta-controls {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .badge-pending-pill {
    font-size: 12px;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 50px;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
  }
  .logout-btn {
    height: 38px;
    padding: 0 14px;
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-radius: 10px;
  }

  /* ─── Dangling Warning Box ─── */
  .dangling-warning-box {
    display: none;
    padding: 16px 20px;
    border: 1px solid rgba(245, 158, 11, 0.3);
    background: color-mix(in srgb, #f59e0b 6%, transparent);
    margin-bottom: 24px;
    border-radius: 12px;
    animation: slideDownWarn 0.3s var(--dash-transition);
  }
  @keyframes slideDownWarn {
    from { opacity: 0; transform: translateY(-8px); }
  }
  .warning-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #f59e0b;
    font-weight: 800;
    font-size: 14px;
    margin-bottom: 6px;
  }
  .warning-text {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
  .warning-text strong {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    padding: 1px 6px;
    border-radius: 4px;
  }

  /* ─── Sticky Toolbar Center ─── */
  .admin-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 20px;
    padding: 12px 18px;
    border-radius: 14px;
    border: 1px solid var(--color-border);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur, 12px));
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 75px;
    z-index: 100;
    transition: all 0.3s;
  }
  .toolbar-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .select-all-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text);
    cursor: pointer;
    user-select: none;
  }
  
  /* 自定义复选框美化 */
  .custom-checkbox {
    appearance: none;
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border: 2px solid var(--color-border);
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-surface) 60%, transparent);
    cursor: pointer;
    position: relative;
    outline: none;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .custom-checkbox:hover {
    border-color: var(--color-primary);
  }
  .custom-checkbox:checked {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .custom-checkbox:checked::before {
    content: "✓";
    color: #fff;
    font-size: 11px;
    font-weight: 900;
  }
  .custom-checkbox:indeterminate {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .custom-checkbox:indeterminate::before {
    content: "-";
    color: #fff;
    font-size: 14px;
    font-weight: 900;
  }

  .selected-counter {
    font-size: 12px;
    font-weight: 700;
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-text) 6%, transparent);
    padding: 3px 10px;
    border-radius: 6px;
  }
  .toolbar-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .action-btn-green {
    height: 36px;
    padding: 0 16px;
    font-size: 12px;
    gap: 6px;
    border-radius: 10px;
  }
  .action-btn-green:disabled, .action-btn-red:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .action-btn-red {
    height: 36px;
    padding: 0 16px;
    font-size: 12px;
    gap: 6px;
    border-radius: 10px;
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.3);
  }
  .action-btn-red:hover:not(:disabled) {
    background: rgba(239, 68, 68, 0.08);
    border-color: #ef4444;
  }
  .action-btn-refresh {
    height: 36px;
    padding: 0 12px;
    font-size: 12px;
    border-radius: 10px;
    gap: 4px;
  }

  /* ─── System States ─── */
  .loading-state-container, .empty-state-container, .error-state-container {
    text-align: center;
    padding: 80px 20px;
    animation: fadeInDash 0.3s ease-out;
  }
  .spinner-lg {
    width: 32px;
    height: 32px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.65s linear infinite;
    margin: 0 auto 16px;
  }
  .empty-icon, .error-icon {
    font-size: 40px;
    margin-bottom: 12px;
  }
  .empty-state-container h2, .error-state-container h2 {
    font-size: 18px;
    font-weight: 800;
    margin-bottom: 6px;
    color: var(--color-text);
  }
  .text-muted {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  /* ─── Grid Theme container ─── */
  .theme-grid-admin {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ─── Dynamic Card Styles (Now successfully rendering in Client-side DOM!) ─── */
  #admin-dashboard-container .review-card {
    border-radius: 16px !important;
    border: 1.5px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.25s var(--dash-transition) !important;
    animation: slideInCard 0.3s var(--dash-transition);
  }
  @keyframes slideInCard {
    from { opacity: 0; transform: translateY(12px); }
  }
  #admin-dashboard-container .review-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--rv-primary) 40%, var(--color-border));

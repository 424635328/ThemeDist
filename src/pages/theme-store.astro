</style>

<script>
  // ─── State ───
  const BATCH_SIZE = 40;
  let activeFilter = 'all';
  let activeSort = 'default';
  let visibleCount = 0;
  let loadedCount = 0;

  const search = document.getElementById('search');
  const clearBtn = document.getElementById('search-clear');
  const sortDropdown = document.getElementById('sort-dropdown');
  const sortTrigger = document.getElementById('sort-trigger');
  const sortLabel = document.getElementById('sort-label');
  const sortMenu = document.getElementById('sort-menu');
  const sortOptions = sortMenu.querySelectorAll('.sort-option');
  const grid = document.getElementById('theme-grid');
  const noResults = document.getElementById('no-results');
  const resultCount = document.getElementById('result-count');
  const sentinel = document.getElementById('load-sentinel');
  const chips = document.querySelectorAll('.chip');
  const totalCount = grid.children.length;

  // ─── Helpers ───
  function getAllCards() {
    return Array.from(grid.children);
  }

  function isPending(card) {
    return card.dataset.pending === '1';
  }

  function getClientId() {
    const key = 'td-client-id';
    let id = localStorage.getItem(key);
    if (!id) {
      id = crypto.randomUUID?.() || Array.from({ length: 12 }, () => Math.random().toString(36)[2]).join('');
      localStorage.setItem(key, id);
    }
    return id;
  }

  function getLoadedCards() {
    return getAllCards().filter(c => !isPending(c));
  }

  // ─── Match a card against current filters ───
  function cardMatches(card, q, filter) {
    const name = card.dataset.name || '';
    const preset = card.dataset.preset || '';
    const color = card.dataset.color || '';
    const cat = card.dataset.cat || '';
    const family = card.dataset.family || '';

    if (q && !name.includes(q) && !preset.includes(q) && !color.includes(q)) {
      return false;
    }

    if (filter === 'holiday') return cat === 'holiday';
    if (filter === 'daily') return cat === 'daily';
    if (filter === 'warm') return family === 'warm';
    if (filter === 'cool') return family === 'cool';

    return true;
  }

  // ─── Sort cards in the DOM ───
  function sortCards(cards, sort) {
    const sorted = [...cards];
    if (sort === 'name-asc') {
      sorted.sort((a, b) => (a.dataset.name || '').localeCompare(b.dataset.name || ''));
    } else if (sort === 'name-desc') {
      sorted.sort((a, b) => (b.dataset.name || '').localeCompare(a.dataset.name || ''));
    } else {
      sorted.sort((a, b) => {
        return parseInt(a.dataset.index || '0') - parseInt(b.dataset.index || '0');
      });
    }
    return sorted;
  }

  // ─── Apply filters + sort to loaded cards ───
  function refresh() {
    const q = search.value.toLowerCase().trim();
    const filter = activeFilter;
    const sort = activeSort;

    const allCards = getAllCards();
    const sorted = sortCards(allCards, sort);
    sorted.forEach(c => grid.appendChild(c));

    visibleCount = 0;
    allCards.forEach(card => {
      if (isPending(card)) {
        card.style.display = 'none';
        return;
      }
      const match = cardMatches(card, q, filter);
      card.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });

    updateSentinel();

    clearBtn.hidden = !q;
    noResults.hidden = visibleCount > 0;
    resultCount.textContent = q || filter !== 'all'
      ? `显示 ${visibleCount} / ${loadedCount} 个主题`
      : '';

    const url = new URL(location.href);
    if (q) url.searchParams.set('q', q); else url.searchParams.delete('q');
    if (filter !== 'all') url.searchParams.set('cat', filter); else url.searchParams.delete('cat');
    if (sort !== 'default') url.searchParams.set('sort', sort); else url.searchParams.delete('sort');
    history.replaceState(null, '', url.toString());
  }

  // ─── Progressive loading ───
  function loadBatch() {
    const pending = getAllCards().filter(c => isPending(c));
    if (pending.length === 0) {
      sentinel.style.display = 'none';
      return;
    }

    const batch = pending.slice(0, BATCH_SIZE);
    batch.forEach(card => {
      delete card.dataset.pending;
    });
    loadedCount = getLoadedCards().length;
    refresh();
  }

  function updateSentinel() {
    const hasMore = getAllCards().some(c => isPending(c));
    sentinel.style.display = hasMore ? '' : 'none';
  }

  // ─── Events ───
  let debounceTimer;
  search.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(refresh, 150);
  });

  clearBtn.addEventListener('click', () => {
    search.value = '';
    refresh();
    search.focus();
  });

  // ─── Sort dropdown ───
  function openSortMenu() {
    sortDropdown.classList.add('open');
    sortMenu.hidden = false;
    sortTrigger.setAttribute('aria-expanded', 'true');
    document.addEventListener('click', onClickOutsideSort, { once: true });
  }

  // Close Sort menu
  function closeSortMenu() {
    sortDropdown.classList.remove('open');
    sortMenu.hidden = true;
    sortTrigger.setAttribute('aria-expanded', 'false');
  }

  function onClickOutsideSort(e) {
    if (!sortDropdown.contains(e.target)) {
      closeSortMenu();
    } else {
      document.addEventListener('click', onClickOutsideSort, { once: true });
    }
  }

  sortTrigger.addEventListener('click', () => {
    if (sortMenu.hidden) openSortMenu(); else closeSortMenu();
  });

  sortOptions.forEach(opt => {
    opt.addEventListener('click', () => {
      const value = opt.dataset.value || 'default';
      activeSort = value;

      sortOptions.forEach(o => {
        o.classList.toggle('sort-option-active', o.dataset.value === value);
        o.setAttribute('aria-selected', String(o.dataset.value === value));
      });
      sortLabel.textContent = opt.textContent || '';

      closeSortMenu();
      refresh();
    });
  });

  // Keyboard: close menu on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !sortMenu.hidden) {
      closeSortMenu();
      sortTrigger.focus();
    }
  });

  // ─── Consolidated Chips logic ───
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter || 'all';
      if (filter === activeFilter) return;

      const prevFilter = activeFilter;
      activeFilter = filter;

      chips.forEach(c => {
        c.classList.toggle('chip-active', c.dataset.filter === filter);
        c.setAttribute('aria-pressed', String(c.dataset.filter === filter));
      });

      if (filter === 'community') {
        switchToCommunity();
      } else {
        if (prevFilter === 'community') {
          switchToRegular();
        } else {
          refresh();
        }
      }
    });
  });

  document.addEventListener('keydown', (e) => {
    const isInput = !!(document.activeElement)?.closest('input, textarea, select, [contenteditable]');
    if (e.key === '/' && !isInput) {
      e.preventDefault();
      search.focus();
      search.select();
    }
    if (e.key === 'Escape' && document.activeElement === search && search.value) {
      search.value = '';
      refresh();
    }
  });

  // Copy color from swatch
  grid.addEventListener('click', (e) => {
    const dot = e.target.closest('.color-dot');
    if (!dot) return;
    e.preventDefault();
    e.stopPropagation();
    navigator.clipboard.writeText(dot.dataset.color || '').then(() => {
      window.__toast?.(`${dot.dataset.color} 已复制`);
    }).catch(() => {});
  });

  // Apply saves to localStorage
  grid.addEventListener('click', (e) => {
    const btn = e.target.closest('.js-apply-btn');
    if (!btn) return;
    const preset = btn.dataset.preset;
    const name = btn.dataset.name;
    if (preset) {
      localStorage.setItem('themeDistApplied', JSON.stringify({ preset, name }));
    }
  });

  // ══════════════════════════════════════
  // Community themes 
  // ══════════════════════════════════════
  const communityGrid = document.getElementById('community-grid');
  const communityEmpty = document.getElementById('community-empty');
  const communitySort = document.getElementById('community-sort');
  const communityHeader = document.getElementById('community-header');
  const communityHeaderCount = document.getElementById('community-header-count');
  const communityChipCount = document.getElementById('community-chip-count');
  let commSort = 'new';
  let commTag = '';
  let commPage = 1;
  let commTotal = 0;
  let commLoaded = [];

  // ─── Community cache (sessionStorage, 5 min TTL) ───
  const COMM_CACHE_KEY = 'td_comm_cache';
  const COMM_CACHE_TTL = 5 * 60 * 1000;

  function getCommCache(sort, tag) {
    try {
      const raw = sessionStorage.getItem(COMM_CACHE_KEY);
      if (!raw) return null;
      const c = JSON.parse(raw);
      if (c.sort !== sort || c.tag !== tag) return null;
      if (Date.now() - c.ts > COMM_CACHE_TTL) return null;
      return c;
    } catch { return null; }
  }

  function setCommCache(sort, tag, themes, total) {
    try {
      sessionStorage.setItem(COMM_CACHE_KEY, JSON.stringify({ sort, tag, themes, total, ts: Date.now() }));
    } catch {}
  }

  function updateCacheAgeHint() {
    const el = document.getElementById('comm-cache-hint');
    if (!el) return;
    try {
      const raw = sessionStorage.getItem(COMM_CACHE_KEY);
      if (!raw) { el.textContent = ''; return; }
      const c = JSON.parse(raw);
      const age = Math.round((Date.now() - c.ts) / 1000);
      if (age < 60) el.textContent = `缓存 ${age}s 前`;
      else el.textContent = `缓存 ${Math.round(age / 60)}m 前`;
    } catch { el.textContent = ''; }
  }

  // ─── Init ───
  let cards = getAllCards();
  loadedCount = cards.filter(c => !isPending(c)).length;

  // Read URL params
  const params = new URLSearchParams(location.search);
  const qParam = params.get('q');
  if (qParam) search.value = qParam;

  const catParam = params.get('cat');
  if (catParam) {
    activeFilter = catParam;
    chips.forEach(c => {
      c.classList.toggle('chip-active', c.dataset.filter === catParam);
      c.setAttribute('aria-pressed', String(c.dataset.filter === catParam));
    });
  }

  const sortParam = params.get('sort');
  if (sortParam) {
    activeSort = sortParam;
    sortOptions.forEach(o => {
      const isActive = o.dataset.value === sortParam;
      o.classList.toggle('sort-option-active', isActive);
      o.setAttribute('aria-selected', String(o.dataset.value === sortParam));
      if (isActive) sortLabel.textContent = o.textContent || '';
    });
  }

  if (activeFilter === 'community') {
    switchToCommunity();
  } else {
    refresh();
  }

  // Hide today badges when previewing another theme
  const previewTheme = params.get('theme');
  const todayPreset = grid.dataset.todayPreset;
  if (previewTheme && previewTheme !== todayPreset) {
    document.querySelectorAll('.badge-today').forEach(b => {
      b.style.display = 'none';
    });
  }

  function isCommunityMode() {
    return activeFilter === 'community';
  }

  function renderCommunityCard(t) {
    const v = t.cssVars;
    const p = v['--color-primary'] || '#6366f1';
    const s = v['--color-secondary'] || '#8b5cf6';
    const a = v['--color-accent'] || '#06b6d4';
    const bg = v['--color-bg'] || '#0f0f23';
    const tx = v['--color-text'] || '#f4f4f5';
    const d = new Date(t.createdAt);
    const dateStr = d.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
    const likeKey = `td-like-${t.id}`;
    const liked = localStorage.getItem(likeKey) === '1';
    const authorInitial = (t.author || '?')[0].toUpperCase();
    const presetName = t.name || 'Untitled';

    return `
      <div class="card card-interact theme-card comm-card" data-comm-id="${escapeAttr(t.id)}" style="--comm-primary:${p};--comm-bg:${bg};--comm-text:${tx}">
        <div class="card-color-bar" aria-hidden="true">
          <div class="color-bar-seg" style="flex:3;background:${p}"></div>
          <div class="color-bar-seg" style="flex:1.5;background:${s}"></div>
          <div class="color-bar-seg" style="flex:0.8;background:${a}"></div>
          <div class="color-bar-seg" style="flex:2;background:${bg}"></div>
          <div class="color-bar-seg" style="flex:1.2;background:${tx}"></div>
        </div>
        <div class="card-body">
          <div class="card-header">
            <h3 class="card-title" title="${escapeHtml(presetName)}">${escapeHtml(presetName)}</h3>
            <span class="badge badge-comm">社区</span>
          </div>

          <div class="comm-palette-strip" aria-label="主题色盘">
            ${[
              { c: p, key: '--color-primary', label: '主色' },
              { c: s, key: '--color-secondary', label: '辅色' },
              { c: a, key: '--color-accent', label: '强调' },
              { c: bg, key: '--color-bg', label: '背景' },
              { c: tx, key: '--color-text', label: '文字' },
            ].map(({ c, key, label }) => `
              <button class="comm-palette-chip" data-color="${c}" title="${key}: ${c} — ${label}，点击复制" aria-label="复制 ${label} ${c}">
                <span class="comm-chip-swatch" style="background:${c};${key === '--color-bg' ? 'box-shadow:inset 0 0 0 1.5px var(--color-border)' : ''}"></span>
                <span class="comm-chip-hex">${c}</span>
              </button>
            `).join('')}
          </div>

          ${t.tags?.length ? `<div class="comm-tags">${t.tags.filter(onlyValidTags).map(tag => `<span class="comm-tag">${tag}</span>`).join('')}</div>` : ''}

          <div class="comm-meta-row">
            <div class="comm-meta-left">
              <span class="comm-author-avatar" style="background:${p};color:${isLight(p) ? '#0f0f23' : '#fff'}">${authorInitial}</span>
              <span class="comm-author-name">${escapeHtml(t.author)}</span>
              <span class="comm-meta-sep">·</span>
              <span class="comm-meta-date">${dateStr}</span>
            </div>
            <div class="comm-meta-right">
              <span class="comm-like-num">${t.likes}</span>
              <button class="comm-like-btn ${liked ? 'liked' : ''}" data-comm-like="${escapeAttr(t.id)}" title="${liked ? '已点赞' : '点赞'}">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 14s-6-3.5-6-7.5a3.5 3.5 0 016-2.2 3.5 3.5 0 016 2.2C14 10.5 8 14 8 14z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>

          <div class="card-actions">
            <a href="/share?id=${escapeAttr(t.id)}" class="btn-card btn-card-primary">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/><circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
              预览
            </a>
            <a href="/?theme=community-${escapeAttr(t.id)}" class="btn-card comm-apply-btn js-apply-btn" data-preset="community-${escapeAttr(t.id)}" data-name="${escapeHtml(presetName)}">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              应用
            </a>
          </div>
        </div>
      </div>
    `;
  }

  function renderCommunityList(themes, total, append) {
    if (!append) {
      commLoaded = themes;
      communityGrid.innerHTML = '';
    } else {
      commLoaded = commLoaded.concat(themes);
    }
    commTotal = total;

    const html = themes.map(renderCommunityCard).join('');
    communityGrid.insertAdjacentHTML('beforeend', html);
    communityGrid.style.display = '';
    communityEmpty.hidden = commTotal > 0;
    sentinel.style.display = commLoaded.length < commTotal ? '' : 'none';

    if (communityHeaderCount) communityHeaderCount.textContent = commTotal + ' 个主题';
    resultCount.textContent = commTotal > 0 ? '已加载 ' + commLoaded.length + ' / ' + commTotal + ' 个主题' : '';
    updateCacheAgeHint();
  }

  async function fetchCommunityThemes(page) {
    const tagParam = commTag ? `&tag=${commTag}` : '';
    const res = await fetch(`/api/v1/diy/themes.json?sort=${commSort}&page=${page}&size=20${tagParam}`);
    if (!res.ok) throw new Error('Fetch failed');
    return await res.json();
  }

  async function loadCommunityThemes(page) {
    if (!isCommunityMode()) return;
    try {
      // Page 1: check cache first
      if (page === 1 && !commTag) {
        const cached = getCommCache(commSort, commTag);
        if (cached) {
          renderCommunityList(cached.themes, cached.total, false);
          // Background refresh
          try {
            const data = await fetchCommunityThemes(1);
            if (data.themes) {
              renderCommunityList(data.themes, data.total, false);
              setCommCache(commSort, commTag, data.themes, data.total);
            }
          } catch { /* keep cached data */ }
          return;
        }
      }

      const data = await fetchCommunityThemes(page);
      if (data.themes) {
        renderCommunityList(data.themes, data.total, page > 1);
        if (page === 1 && !commTag) {
          setCommCache(commSort, commTag, data.themes, data.total);
        }
      }
    } catch {
      communityEmpty.hidden = commLoaded.length > 0;
    }
  }

  function switchToCommunity() {
    // Hide regular grid
    const allCards = getAllCards();
    allCards.forEach(c => c.style.display = 'none');
    noResults.hidden = true;

    if (communityHeader) communityHeader.style.display = '';
    communityGrid.style.display = '';
    commPage = 1;
    loadCommunityThemes(1);

    // Disable regular sort dropdown and search bar when switching to community
    sortDropdown.style.display = 'none';
    search.value = '';
    clearBtn.hidden = true;
    resultCount.textContent = '加载中…';

    // Synchronize URL query
    const url = new URL(location.href);
    url.searchParams.set('cat', 'community');
    url.searchParams.delete('q');
    url.searchParams.delete('sort');
    history.replaceState(null, '', url.toString());
  }

  function switchToRegular() {
    if (communityHeader) communityHeader.style.display = 'none';
    communityGrid.style.display = 'none';
    communityEmpty.hidden = true;
    sortDropdown.style.display = '';
    refresh();
  }

  // Community sort buttons
  communitySort.querySelectorAll('.comm-sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const sort = btn.getAttribute('data-comm-sort');
      if (!sort || sort === commSort) return;
      commSort = sort;
      communitySort.querySelectorAll('.comm-sort-btn').forEach(b => {
        b.classList.toggle('comm-sort-active', b.getAttribute('data-comm-sort') === sort);
      });
      commPage = 1;
      loadCommunityThemes(1);
    });
  });

  // Community tag filter chips
  const tagFilters = document.getElementById('comm-tag-filters');
  if (tagFilters) {
    tagFilters.addEventListener('click', (e) => {
      const chip = e.target.closest('.comm-tag-chip');
      if (!chip) return;
      const tag = chip.getAttribute('data-comm-tag') || '';
      if (tag === commTag) return;
      commTag = tag;
      tagFilters.querySelectorAll('.comm-tag-chip').forEach(c => {
        c.classList.toggle('comm-tag-active', c.getAttribute('data-comm-tag') === tag);
      });
      commPage = 1;
      loadCommunityThemes(1);
    });
  }

  // Community like button delegation
  communityGrid.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-comm-like]');
    if (!btn) return;
    e.preventDefault();
    const id = btn.getAttribute('data-comm-like') || '';
    const likeKey = `td-like-${id}`;
    if (localStorage.getItem(likeKey) === '1') {
      window.__toast?.('您已经为该主题点过赞了');
      return;
    }
    try {
      const res = await fetch('/api/v1/diy/like.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-client-id': getClientId() },
        body: JSON.stringify({ id }),
      });
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      // Update count in card
      const card = btn.closest('.theme-card');
      const numEl = card.querySelector('.comm-like-num');
      if (numEl) numEl.textContent = data.likes;
      btn.classList.add('liked');
      btn.innerHTML = `<svg width="11" height="11" viewBox="0 0 16 16" fill="none"><path d="M8 14s-6-3.5-6-7.5a3.5 3.5 0 016-2.2 3.5 3.5 0 016 2.2C14 10.5 8 14 8 14z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> 已赞`;
      localStorage.setItem(likeKey, '1');
      // Update in commLoaded too
      const idx = commLoaded.findIndex((t) => t.id === id);
      if (idx >= 0) commLoaded[idx].likes = data.likes;
    } catch {
      window.__toast?.('点赞暂时不可用，请稍后重试');
    }
  });

  // Community apply saves to localStorage
  communityGrid.addEventListener('click', (e) => {
    const btn = e.target.closest('.js-apply-btn');
    if (!btn) return;
    const preset = btn.dataset.preset;
    const name = btn.dataset.name;
    if (preset) {
      localStorage.setItem('themeDistApplied', JSON.stringify({ preset, name }));
    }
  });

  // Community card color dot copy
  communityGrid.addEventListener('click', (e) => {
    const dot = e.target.closest('.color-dot');
    if (!dot) return;
    e.preventDefault();
    e.stopPropagation();
    navigator.clipboard.writeText(dot.dataset.color || '').then(() => {
      window.__toast?.(`${dot.dataset.color} 已复制`);
    }).catch(() => {});
  });

  // Unified Sentinel Observer
  const ioSingle = new IntersectionObserver((entries) => {
    if (!entries[0].isIntersecting) return;
    if (isCommunityMode()) {
      if (commLoaded.length < commTotal) {
        commPage++;
        loadCommunityThemes(commPage);
      }
    } else {
      loadBatch();
    }
  }, { rootMargin: '400px' });
  ioSingle.observe(sentinel);

  // Fetch community count on load
  fetch('/api/v1/diy/themes.json?size=1')
    .then(r => r.json())
    .then(data => {
      if (data.dbAvailable) {
        communityChipCount.textContent = String(data.total);
      } else {
        communityChipCount.textContent = '离线';
      }
    })
    .catch(() => { communityChipCount.textContent = '离线'; });

  const VALID_TAGS = new Set(['dark','light','holiday','minimal','vibrant','nature','tech','retro','warm','cool','community','space','ocean','animated','elegant','glass','seasonal','fantasy','industrial']);
  function onlyValidTags(t) { return VALID_TAGS.has(t); }

  function isLight(hex) {
    const c = hex.replace('#', '');
    const r = parseInt(c.slice(0, 2), 16);
    const g = parseInt(c.slice(2, 4), 16);
    const b = parseInt(c.slice(4, 6), 16);
    return (0.299 * r + 0.587 * g + 0.114 * b) > 150;
  }

  function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function escapeAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
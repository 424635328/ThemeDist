<!-- ConsolePanel: Right — execution console (dark theme) -->
<div class="pg-run-toolbar">
  <div class="pg-run-tabs">
    <button class="pg-run-tab active" data-tab="request">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      Console
    </button>
    <button class="pg-run-tab" data-tab="history" id="pg-history-tab">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      History
      <span class="pg-history-badge" id="pg-history-badge" style="display:none">0</span>
    </button>
  </div>
</div>

<!-- Console Panel: Request -->
<div class="pg-run-panel" id="pg-panel-request">
  <!-- Language tabs -->
  <div class="pg-lang-tabs-wrapper">
    <div class="pg-lang-tabs" id="pg-code-lang-tabs">
      <button class="pg-lang-tab active" data-lang="curl">cURL</button>
      <button class="pg-lang-tab" data-lang="js">Fetch</button>
      <button class="pg-lang-tab" data-lang="py">Python</button>
    </div>
  </div>

  <!-- Custom Headers Editor -->
  <div class="pg-headers-editor" id="pg-headers-editor">
    <div class="pg-headers-editor-header" id="pg-headers-toggle">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      <span>Custom Headers</span>
      <span class="pg-headers-count" id="pg-headers-count">0</span>
    </div>
    <div class="pg-headers-list" id="pg-headers-list" style="display:none">
      <div id="pg-headers-rows"></div>
      <button class="pg-headers-add-btn" id="pg-headers-add">+ Add Header</button>
    </div>
  </div>

  <!-- Code Preview -->
  <div class="pg-run-block">
    <div class="pg-run-label">
      <div class="pg-label-left">
        <span class="pg-run-dot req"></span> CODE PREVIEW
        <span class="pg-run-method-badge" id="pg-req-method-badge">GET</span>
      </div>
      <button class="pg-copy-btn" id="pg-copy-btn" title="复制请求代码">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span id="pg-copy-text">复制代码</span>
      </button>
    </div>
    <div class="pg-code-container">
      <pre class="pg-code" id="pg-req-curl"></pre>
    </div>
  </div>

  <!-- Send Button -->
  <button class="pg-send-btn" id="pg-send-btn">
    <svg class="pg-send-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
    <span class="pg-send-label">发送请求</span>
    <span class="pg-send-hint">Ctrl + Enter</span>
  </button>

  <!-- Response -->
  <div class="pg-run-block pg-run-resp">
    <div class="pg-run-label">
      <div class="pg-label-left">
        <span class="pg-run-dot resp"></span> RESPONSE
        <span class="pg-run-status" id="pg-status"></span>
        <span class="pg-resp-meta" id="pg-resp-meta"></span>
      </div>
      <button class="pg-copy-btn pg-copy-resp-btn" id="pg-copy-resp-btn" title="复制响应">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        复制响应
      </button>
    </div>
    <div class="pg-code-container pg-resp-container">
      <pre class="pg-code pg-resp-code" id="pg-resp">从左侧选择接口，点击发送按钮发起请求</pre>
    </div>
    <div class="pg-resp-headers" id="pg-resp-headers" style="display:none">
      <div class="pg-resp-headers-title">Response Headers</div>
      <div id="pg-resp-headers-inner"></div>
    </div>
  </div>
</div>

<!-- History Panel -->
<div class="pg-run-panel" id="pg-panel-history" style="display:none">
  <div class="pg-history-toolbar">
    <span class="pg-history-title">调试历史 (本地存储)</span>
    <button class="pg-clear-history-btn" id="pg-clear-history">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
      清除历史
    </button>
  </div>
  <div class="pg-history-list" id="pg-history-list">
    <div class="pg-history-empty">暂无请求记录</div>
  </div>
</div>
